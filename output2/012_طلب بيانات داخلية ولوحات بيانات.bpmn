<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_012" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_012">
    <bpmn:participant id="Participant_012" name="طلب بيانات داخلية ولوحات بيانات" processRef="Process_012" />
  </bpmn:collaboration>
  <bpmn:process id="Process_012" isExecutable="false">
    <bpmn:laneSet id="LaneSet_012">
      <bpmn:lane id="Lane_Inputs" name="المدخلات"><bpmn:flowNodeRef>DataIn_Request</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="Lane_Requester" name="الوحدة التنظيمية الطالبة">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DataRequest</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Owner" name="الوحدة التنظيمية المالكة للبيانات">
        <bpmn:flowNodeRef>Gateway_OwnerApprove</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OwnerProvide</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Analyst" name="محلل بيانات / قسم السياسات الإسكانية">
        <bpmn:flowNodeRef>Task_CheckPermissions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PermAvailable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendForApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckDashboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DashboardExists</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RequestOwnerApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CreateDashboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GrantPermissions</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Admin" name="إداري سياسات إسكانية">
        <bpmn:flowNodeRef>Task_EmailNotification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DeptHead" name="رئيس قسم السياسات الإسكانية">
        <bpmn:flowNodeRef>Task_ReviewApprove</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ApproveData</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Outputs" name="المخرجات"><bpmn:flowNodeRef>DataOut_Dashboard</bpmn:flowNodeRef></bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="البداية"><bpmn:outgoing>Flow_1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:task id="Task_DataRequest" name="طلب البيانات"><bpmn:incoming>Flow_1</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_CheckPermissions" name="التحقق من صلاحيات الاطلاع على البيانات للوحدة التنظيمية الطالبة والتحقق من تصنيف البيانات سرية أو عامة"><bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_PermAvailable" name="الصلاحيات متوفرة والبيانات عامة"><bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_PermYes</bpmn:outgoing><bpmn:outgoing>Flow_PermNo</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_SendForApproval" name="إرسال الطلب للاعتماد من رئيس القسم"><bpmn:incoming>Flow_PermYes</bpmn:incoming><bpmn:outgoing>Flow_4</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_ReviewApprove" name="مراجعة الطلب واعتماده"><bpmn:incoming>Flow_4</bpmn:incoming><bpmn:outgoing>Flow_5</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_CheckDashboard" name="التأكد من عدم توفر البيانات المطلوبة في داش بورد تم إنشاؤه سابقاً"><bpmn:incoming>Flow_5</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_DashboardExists" name="يوجد داش بورد؟"><bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_DashYes</bpmn:outgoing><bpmn:outgoing>Flow_DashNo</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_ApproveData" name="اعتماد البيانات"><bpmn:incoming>Flow_DashYes</bpmn:incoming><bpmn:outgoing>Flow_7</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_EmailNotification" name="التواصل من خلال البريد الإلكتروني لاعتماد الجهة المالكة للبيانات"><bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_8</bpmn:outgoing></bpmn:task>
    <bpmn:endEvent id="EndEvent_2" name="النهاية"><bpmn:incoming>Flow_8</bpmn:incoming></bpmn:endEvent>
    <bpmn:task id="Task_RequestOwnerApproval" name="طلب اعتماد من الجهة المالكة لمنحه للجهة الطالبة"><bpmn:incoming>Flow_DashNo</bpmn:incoming><bpmn:incoming>Flow_PermNo</bpmn:incoming><bpmn:outgoing>Flow_9</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_OwnerApprove" name="موافقة المالك"><bpmn:incoming>Flow_9</bpmn:incoming><bpmn:outgoing>Flow_OwnerYes</bpmn:outgoing><bpmn:outgoing>Flow_OwnerNo</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_OwnerProvide" name="منح الموافقة على البيانات"><bpmn:incoming>Flow_OwnerYes</bpmn:incoming><bpmn:outgoing>Flow_10</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Merge" name="داشبورد"><bpmn:incoming>Flow_10</bpmn:incoming><bpmn:outgoing>Flow_11</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_CreateDashboard" name="إنشاء داشبورد للجهة الطالبة"><bpmn:incoming>Flow_11</bpmn:incoming><bpmn:outgoing>Flow_12</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_GrantPermissions" name="منح الصلاحيات اللازمة للوحدة التنظيمية الطالبة"><bpmn:incoming>Flow_12</bpmn:incoming><bpmn:outgoing>Flow_13</bpmn:outgoing></bpmn:task>
    <bpmn:endEvent id="EndEvent_1" name="النهاية"><bpmn:incoming>Flow_13</bpmn:incoming><bpmn:incoming>Flow_OwnerNo</bpmn:incoming></bpmn:endEvent>
    <bpmn:dataObjectReference id="DataIn_Request" name="نموذج الطلب" />
    <bpmn:dataObjectReference id="DataOut_Dashboard" name="داشبورد / بيانات" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_DataRequest" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_DataRequest" targetRef="Task_CheckPermissions" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_CheckPermissions" targetRef="Gateway_PermAvailable" />
    <bpmn:sequenceFlow id="Flow_PermYes" name="نعم" sourceRef="Gateway_PermAvailable" targetRef="Task_SendForApproval" />
    <bpmn:sequenceFlow id="Flow_PermNo" name="لا" sourceRef="Gateway_PermAvailable" targetRef="Task_RequestOwnerApproval" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_SendForApproval" targetRef="Task_ReviewApprove" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_ReviewApprove" targetRef="Task_CheckDashboard" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_CheckDashboard" targetRef="Gateway_DashboardExists" />
    <bpmn:sequenceFlow id="Flow_DashYes" name="نعم" sourceRef="Gateway_DashboardExists" targetRef="Task_ApproveData" />
    <bpmn:sequenceFlow id="Flow_DashNo" name="لا" sourceRef="Gateway_DashboardExists" targetRef="Task_RequestOwnerApproval" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_ApproveData" targetRef="Task_EmailNotification" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_EmailNotification" targetRef="EndEvent_2" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_RequestOwnerApproval" targetRef="Gateway_OwnerApprove" />
    <bpmn:sequenceFlow id="Flow_OwnerYes" name="نعم" sourceRef="Gateway_OwnerApprove" targetRef="Task_OwnerProvide" />
    <bpmn:sequenceFlow id="Flow_OwnerNo" name="لا" sourceRef="Gateway_OwnerApprove" targetRef="EndEvent_1" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_OwnerProvide" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Gateway_Merge" targetRef="Task_CreateDashboard" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_CreateDashboard" targetRef="Task_GrantPermissions" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_GrantPermissions" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_012">
      <bpmndi:BPMNShape id="Participant_012_di" bpmnElement="Participant_012" isHorizontal="false">
