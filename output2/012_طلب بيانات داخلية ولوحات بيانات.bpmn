      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_2_di" bpmnElement="EndEvent_2" color:background-color="#FFCDD2" color:border-color="#B71C1C">
        <dc:Bounds x="992" y="950" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="992" y="990" width="36" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RequestOwnerApproval_di" bpmnElement="Task_RequestOwnerApproval" color:background-color="#BBDEFB" color:border-color="#0D47A1">
        <dc:Bounds x="730" y="820" width="120" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_OwnerApprove_di" bpmnElement="Gateway_OwnerApprove" isMarkerVisible="true" color:background-color="#FFE082" color:border-color="#E65100">
        <dc:Bounds x="545" y="850" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="525" y="905" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_OwnerProvide_di" bpmnElement="Task_OwnerProvide" color:background-color="#BBDEFB" color:border-color="#0D47A1">
        <dc:Bounds x="510" y="950" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Merge_di" bpmnElement="Gateway_Merge" isMarkerVisible="true" color:background-color="#FFE082" color:border-color="#E65100">
        <dc:Bounds x="765" y="1050" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="745" y="1105" width="90" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreateDashboard_di" bpmnElement="Task_CreateDashboard" color:background-color="#BBDEFB" color:border-color="#0D47A1">
        <dc:Bounds x="730" y="1150" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GrantPermissions_di" bpmnElement="Task_GrantPermissions" color:background-color="#BBDEFB" color:border-color="#0D47A1">
        <dc:Bounds x="730" y="1270" width="120" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1" color:background-color="#FFCDD2" color:border-color="#B71C1C">
        <dc:Bounds x="772" y="1410" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="772" y="1450" width="36" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataIn_Request_di" bpmnElement="DataIn_Request">
