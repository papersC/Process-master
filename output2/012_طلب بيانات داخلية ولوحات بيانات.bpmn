      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1"><di:waypoint x="385" y="166" /><di:waypoint x="385" y="210" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2"><di:waypoint x="445" y="250" /><di:waypoint x="730" y="250" /></bpmndi:BPMNEdge>
