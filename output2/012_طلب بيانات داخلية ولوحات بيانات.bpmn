        <dc:Bounds x="730" y="570" width="120" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DashboardExists_di" bpmnElement="Gateway_DashboardExists" isMarkerVisible="true" color:background-color="#FFE082" color:border-color="#E65100">
        <dc:Bounds x="765" y="700" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="730" y="755" width="120" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
