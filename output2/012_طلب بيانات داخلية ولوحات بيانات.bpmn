      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewApprove_di" bpmnElement="Task_ReviewApprove" color:background-color="#BBDEFB" color:border-color="#0D47A1">
        <dc:Bounds x="1170" y="450" width="120" height="80" />
      </bpmndi:BPMNShape>
