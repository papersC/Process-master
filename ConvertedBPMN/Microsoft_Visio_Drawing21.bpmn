    <bpmn:task id="Shape_84" name="اعداد دليل تنظيمي بالتعاون مع الوحدات التنظيمية بناء على المقترحات مع الموارد المطلوبة خلال 3 سنوات"/>
    <bpmn:endEvent id="Shape_90" name="النهاية"/>
    <bpmn:task id="Shape_161" name="الوحدات التنظيمية"/>
    <bpmn:task id="Shape_170" name="دراسة الوضع الحالي واعداد مقترح بالهيكل مع المهام"/>
    <bpmn:task id="Shape_171" name="- ازدواجية المهام
- غياب بعض الأنشطة أو المهام أو التخصص
- عدم توافق الهيكل الحالي مع استراتيجية المؤسسة
- زيادة قيمة الرأس المالي
- توجيهات المدير التنفيذي"/>
    <bpmn:task id="Shape_179" name="دراسة الوضع الحالي وتعبئة نموذج طلب تحديث"/>
    <bpmn:task id="Shape_180" name="- الغاء أو استحداث وحدة تنظيمية / قسم على مستوى الإدارة
 - ترفيع أو تقليل مستوى القسم
- نقل قسم أو مهمة من وحدة تنظيمية الى أخرى
- تغيير مسمى وحدة تنظيمية
-تحديث المهام تعديل أو حذف"/>
    <bpmn:task id="Shape_182" name="المراجعة"/>
    <bpmn:task id="Shape_183" name="نموذج طلب تحديث الهيكل
MBRHE/QP/505/QF/01"/>
    <bpmn:task id="Shape_186" name="استبيان التقييم الذاتي لقياس كفاءة وفعالية الهيكل التنظيمي"/>
