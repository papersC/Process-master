    <bpmn:task id="Shape_27" name="استلام الفواتيرعن طريق البريد الإلكتروني&quot; لجنة الطوارئ ودفعات الاستشاريين والمصروفات التشغيلية والنماذج الموحدة &quot; أو نظام الرقابة الهندسية &quot;دفعات المقاولين والمستفيدين  &quot; أو نظام التراسل الإلكتروني&quot;دفعات المشاريع&quot;"/>
    <bpmn:task id="Shape_29" name="إدخال الفواتير في نظام الGRP  والتدقيق عليها وربطها بأوامر الشراء والتأكد من الاعتمادات اللازمة"/>
    <bpmn:task id="Shape_31" name="يوجد ملاحظات ؟"/>
    <bpmn:task id="Shape_34" name="إعادة الفواتير للجهة المرسلة للتعديل بناء على الملاحظات"/>
    <bpmn:task id="Shape_35" name="إغلاق الملاحظات وتسليم الفواتير المعدلة"/>
    <bpmn:task id="Shape_37" name="اعتماد الفاتورة وإنشاء القيود المحاسبية تلقائيا على نظام
Oracle"/>
    <bpmn:dataObject id="Shape_40" name="التدقيق على مستندات المعاملة والتأكد من صحة المعاملة والبيانات المدخلة وإعداد سندات الصرف وتحميلها على نظام مصرف دبي الإسلامي"/>
    <bpmn:task id="Shape_42" name="الدخول على نظام دبي الإسلامي والاطلاع على سندات الصرف بالإضافة إلى التغذية بين الحسابات البنكية للتأكد من السيولة النقدية المتاحة في كل حسابات المؤسسة لصرف الدفعات  وتحويلها للمخولين بالتوقيع للاعتماد"/>
    <bpmn:task id="Shape_48" name="استلام الاعتماد من قبل المخولين بالتوقيع (رسالة المخولين بالتوقيع ) واعتماد التغذية بين الحسابات لتحويل الدفعات ثم تحويل الدفعات لحسابات المستفيدين"/>
