    <bpmn:task id="Shape_28" name="إرسال رابط النموذج لكافة الوحدات التنظيمية لتحديد الاحتياجات التطويرية عن طريق نظام ويتم إرساله قبل الميزانية بشكل سنوي"/>
    <bpmn:task id="Shape_31" name="تحديد نوع الطلب هل هو تعديل على النظام أو إنشاء نظام جديد مع شرح مبسط للمتطلبات مع ذكر اسم النظام أو المشروع وتحديد أولوية الطلب  (بناء على وجود توجه أو متطلب حكومي أو قرار أو توجيه من الإدارة العليا ويجب إرفاقه وهل يتطلب ربط مع أي جهة خارجية  وما هي الخدمات المتأثرة بالتعديل وتحديدها  وهل طلب التغيير يتطلب إشعارات للمتعاملين داخليا أو خارجيا  وما هي القنوات اللازمة لإرسال الإشعار ومرتبط بزمن معين للتسليم أو هل هو موضوع داخلي مع تحديدد نص الإشعار وإرسال العملية قبل وما هي العملية المقترحة"/>
    <bpmn:task id="Shape_32" name="مراجعة الطلب"/>
    <bpmn:task id="Shape_34" name="المتطلبات متوفرة في النموذج"/>
    <bpmn:task id="Shape_36" name="تحديد الميزانية والموارد البشرية وإدراجها في الخطة التشغيلية للقسم وجدول زمني"/>
    <bpmn:task id="Shape_38" name="إرسال الطلب مرة أخرى مع الملاحظات أو تحديد النواقص اللازمة"/>
    <bpmn:task id="Shape_40" name="توفير النواقص؟"/>
    <bpmn:task id="Shape_42" name="رفض الطلب لحاجته لميزانية كبيرة  أو المتطلبات المذكورة في النموذج عن طريق النظام"/>
    <bpmn:task id="Shape_45" name="استلام بريد إلكتروني برفض الطلب"/>
