MRHE/QP/151/QF/01"/>
    <bpmn:endEvent id="Shape_62" name="النهاية"/>
    <bpmn:task id="Shape_64" name="- اذا كان عمر المسكن أكثر من 30 سنة يتم زيارة المسكن وقد يتم الاحلال  او الصيانة بناء على التقرير الفني.
- اذا كان بين 10 الى 30 سنة تتم اعداد التقرير الفني دون زيارة المسكن
- اذا كان اقل من 10 سنوات لايقبل طلب الصيانة من خدمة المتعاملين."/>
    <bpmn:task id="Shape_67" name="تحويل الطلب الى قسم معالجة الطلبات لاصدار الموافقة للمتعامل من خلال رسالة نصية"/>
