    <bpmn:task id="Shape_6" name="قياس رضا المتعاملين (مكالمات callback)"/>
    <bpmn:task id="Shape_3" name="المخرجات"/>
    <bpmn:task id="Shape_25" name="رئيس قسم العناية بالمتعاملين/أخصائي عناية بالمتعاملين"/>
