    <bpmn:task id="Shape_39" name="الاتصالات مع المتعاملين"/>
    <bpmn:task id="Shape_41" name="استبيان رضا المتعاملين"/>
    <bpmn:task id="Shape_42" name="التواصل مع المتعامل عبر الهاتف وتطبيق أسئلة استبيان رأي المتعاملين عبر كافة قنوات تقديم الخدمة الخاص بالمجلس التنفيذي وتسجيل النتائج"/>
    <bpmn:startEvent id="Shape_43" name="البداية"/>
    <bpmn:task id="Shape_47" name="تسجيل نتائج المكالمات بقوائم بيانات التواصل مع المتعاملين وإرسالها لإدارة الاستراتيجية"/>
    <bpmn:task id="Shape_49" name="عدد الموظفين المنفذين
 للاستبيان عبر مكالمات 
الCall back  خمس موظفين"/>
    <bpmn:task id="Shape_52" name="الرد على المكالمة وإبداء الرأي من خلال الإجابة على أسئلة الاستبيان"/>
    <bpmn:task id="Shape_55" name="تجميع بيانات التواصل مع المتعاملين لكافة قنوات تقديم الخدمة (الموقع الإلكتروني والتطبيق ومركز تقديم الخدمة من نظام Q-system  ومركز الاتصال من إدارة الخدمات الذكية"/>
    <bpmn:task id="Shape_57" name="فلترة القوائم وتوزيعها على موظفي مركز الاتصال"/>
    <bpmn:task id="Shape_104" name="فلترة أسماء المتعاملين غير الراضين ومن لديهم ملاحظات وإرسال القائمة كاملة (اقترااحات وملاحظات واستفسارات وشكر ) لقسم العناية بالمتعاملين"/>
    <bpmn:task id="Shape_111" name="استلام الملاحظات وحالات عدم الرضا والعمل على حلها وإغلاقها"/>
    <bpmn:task id="Shape_115" name="إرسال الحالات وملاحظات عدم الرضا  للوحدات التنظيمية المعنية عن طريق البريد الإلكتروني"/>
    <bpmn:task id="Shape_118" name="تسجيل ملاحظات حل الشكوى في قائمة إكسل (تفاصيل الحل وتاريخ الإغلاق غير متوفر"/>
    <bpmn:task id="Shape_119" name="الرد لقسم العناية بالمتعاملين عن طريق البريد الإلكتروني (تم اتخاذ الإجراء اللازم)"/>
    <bpmn:task id="Shape_122" name="إعداد تقرير (عدد الشكاوى والملاحظات التي تم حلها ) وإرسالها للاستراتيجية عن طريق البريد الإلكتروني"/>
    <bpmn:task id="Shape_124" name="استلام التقرير"/>
    <bpmn:endEvent id="Shape_125" name="النهاية"/>
    <bpmn:task id="Shape_128" name="نتائج استبيان رضا المتعاملين &quot;مكالمات التغذية الراجعة&quot;"/>
