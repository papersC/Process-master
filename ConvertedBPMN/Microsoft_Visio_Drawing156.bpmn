    <bpmn:startEvent id="Shape_30" name="البداية"/>
    <bpmn:task id="Shape_68" name="وضع خطة تفصيلية لعملية حصر الأصول الإسكانية والتجارية وتحديد الموارد والأدوات المطلوبة لإتمام هذه العملية بشكل فعال"/>
    <bpmn:task id="Shape_71" name="مسكن أم أرض؟"/>
    <bpmn:task id="Shape_73" name="التواصل  مع بلدية دبي للحصول على الجرد الأخير للأراضي التابعة للمؤسسة وحالتها"/>
    <bpmn:task id="Shape_74" name="جمع جميع المعلومات المتعلقة بالأصول الإسكانية والتجارية ، مثل العناوين والمساحات ومواصفات المباني، وكذلك الوثائق والعقود الخاصة بها."/>
    <bpmn:task id="Shape_77" name="تصنيف الأصول بناءً على معايير محددة، مثل نوع السكن (شقق، فلل، أراضي) والموقع الجغرافي وحالة الملكية (ممنوحة، مؤجرة، خالية)"/>
    <bpmn:task id="Shape_90" name="تحديد القيمة السوقية لكل من الأصول الإسكانية، باستخدام تقييمات موثوقة من خبراء العقارات أو البيانات المتوفرة في السوق."/>
    <bpmn:task id="Shape_92" name="اعداد قائمة شاملة لجميع الأصول بناءً على المعلومات والتصنيفات والقيم المحددة."/>
    <bpmn:task id="Shape_94" name="تحديث نظام إدارة الأصول بنتائج الحصر الأخيرة لتعزيز عملية  اتخاذ القرار في المؤسسة"/>
    <bpmn:task id="Shape_95" name="اعتماد القائمة ووضع التوصيات"/>
    <bpmn:task id="Shape_98" name="هل تم الاعتماد؟"/>
