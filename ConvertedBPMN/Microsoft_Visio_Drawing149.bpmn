    <bpmn:task id="Shape_507" name="زيارة المقاول لمراكز الخدمة لإنشاء حساب ورقم سري للنظام"/>
    <bpmn:task id="Shape_509" name="العقد"/>
    <bpmn:task id="Shape_510" name="بنود الأعمال"/>
