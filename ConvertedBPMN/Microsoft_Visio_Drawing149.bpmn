    <bpmn:startEvent id="Shape_367" name="البداية"/>
    <bpmn:task id="Shape_381" name="طلب المتعامل أن تقوم المؤسسة باختيار المقاول"/>
    <bpmn:task id="Shape_384" name="نوع الطلب"/>
    <bpmn:task id="Shape_434" name="اصدار مذكرة من مهندس المشروع الى رئيس قسم العقود والمشتريات ببيانات المتعامل لاختيار مقاول المشروع"/>
    <bpmn:task id="Shape_439" name="بعد اختيار المقاول يتم مخاطبته مباشرة من قسم العقود وإصدار امر تكليف للمهندس والمقاول المعني بالمشروع لإجراء اللازم"/>
    <bpmn:task id="Shape_440" name="تسليم المشروع للمقاول بحضور المالك والمقاول والمهندس مع وضع جدول زمني يوضح تاريخ بدء وانتهاء المشروع"/>
    <bpmn:task id="Shape_442" name="تحويل الطلب الى قسم الرقابة الهندسية لتوجيه الاستشاري لاعداد تصميم المسكن وجميع المخططات والتقديم على البلدية"/>
    <bpmn:dataObject id="Shape_447" name="تزويد المؤسسة بالمستندات اللازمة"/>
    <bpmn:dataObject id="Shape_450" name="مستند المناقصة"/>
