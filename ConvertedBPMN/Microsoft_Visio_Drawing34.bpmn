    <bpmn:task id="Shape_28" name="إعداد خطة متابعة اغلاق الفجوات المعرفية واعداد خطاب رسمي لكافة الوحدات التنظيمية للتأكد من اغلاق الفجوات المعرفية"/>
    <bpmn:task id="Shape_30" name="اغلاق الفجوات المعرفية باستخدام الأساليب المعتمدة في المؤسسة وفقاً لدليل إدارة المعرفة واعداد تقرير اغلاق الفجوات"/>
    <bpmn:task id="Shape_43" name="تحديد الفجوات المعرفية بناء على العمليات والمهام الحالية للوحدة التنظيمية والمشاريع والمبادرات المقترحة وتحديد الموارد المعرفية المطلوبة لها ومقارنتها مع تلك المتوفرة لديها تبعا لخطة تحليل الفجوات المعرفية."/>
    <bpmn:task id="Shape_57" name="توثيق الدروس المستفادة و العمل على تعميميها على المعنيين"/>
    <bpmn:task id="Shape_60" name="تحديث خطة متابعة الفجوات واعداد التقرير النهائي (مشتمل على التوصيات) ورفعه للمدير التنفيذي"/>
