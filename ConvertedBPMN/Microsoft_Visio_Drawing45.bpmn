    <bpmn:task id="Shape_43" name="هل تم اعتماد الخطة؟"/>
    <bpmn:task id="Shape_48" name="جدولة عمليات التدقيق الداخلي اعتمادا على آهمية وحالة النشاط المدقق علية مع مراعاة تسلسل العمليات وتتبع سير العمليات وقياس مدى فعاليتهتا ومصادر الخلل وفرص التطوير والتحسين"/>
    <bpmn:task id="Shape_53" name="اختيار فريق التدقيق الداخلي لإجراء التدقيق الداخلي"/>
    <bpmn:task id="Shape_56" name="رفع البيانات المطلوبة على الملف المشترك قبل اجراء التدقيق الداخلي لضمان اطلاع الفريق على المعلومات الكافية"/>
    <bpmn:startEvent id="Shape_62" name="دراسة المعلومات ذات العلاقة قبل بداية التدقيق حول نطاق العمل او المجال المُدقق عليه"/>
    <bpmn:task id="Shape_65" name="تحضير قائمة التفقد من قبل المُدقق لتدوين نتائج التدقيق طبقا للنموذج المعتمد"/>
    <bpmn:task id="Shape_71" name="التواصل مع الوحدة التنظيمية المدقق عليها بفترة كافية لتحديد المصادر المطلوبة لعملية التدقيق  (مثل الوقت المتوقع لتقييم كل جزء، نطاق عملية التدقيق، الفريق المطلوب الاجتماع معه، كيفية تسهيل مهمة التدقيق.)"/>
    <bpmn:task id="Shape_74" name="اجراء اجتماع افتتاحي مع الإدارة العليا او الممثل عنها في الوحدات التنظيمية لشرح نطاق عملية التدقيق وطريقة التقييم وأي معلومات ضرورية لضمان تنظيم ونجاح عملية التدقيق."/>
    <bpmn:task id="Shape_77" name="التحقق من السجلات والوثائق المطلوبة وذات العلاقة"/>
    <bpmn:task id="Shape_86" name="رفع نتائج التدقيق الي رئيس فريق التدقيق تبعا للنماذج المعتمدة خلال المدة الزمنية المتفق عليها"/>
    <bpmn:task id="Shape_89" name="الاجتماع مع المدققين لمراجعة ومناقشة التقارير والاتفاق عليها واعتماد النتائج بناء على فرص التطوير والملاحظات ونتائج التدقيق وتوضيح الية التعامل معها وفقا للأجراء الخاص بالإجراءات التصحيحية والمعتمدة"/>
    <bpmn:task id="Shape_95" name="هل تمت الموافقة على التقارير بعد المراجعة والاعتماد؟"/>
    <bpmn:task id="Shape_108" name="ارسال نسخ من التقارير الى مدراء الوحدات التنظيمية والمتابعة مع ملاك العمليات لاتخاذ الإجراءات التصحيحية وتحديث سجلات المخاطر"/>
    <bpmn:endEvent id="Shape_131" name="النهاية"/>
