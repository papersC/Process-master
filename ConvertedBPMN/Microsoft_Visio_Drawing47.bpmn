    <bpmn:task id="Shape_114" name="المخرجات"/>
    <bpmn:startEvent id="Shape_73" name="البداية"/>
    <bpmn:task id="Shape_74" name="تحديد العمليات\ الأدوات التنظيمية التي يراد توثيقها وتكليف موظف بإعداد نسخة أولية من الوثيقة"/>
    <bpmn:task id="Shape_83" name="يقوم الموظف المكلف بالتنسيق مع جميع المعنيين بالعملية\ الأداة التنظيمية، وإعداد النسخة الأولية للوثيقة باستخدام النموذج المخصص لوثائق إجراءات الجودة، بحيث يكون رقم الإصدار 0 (للدلالة على أن الوثيقة ما زالت تحت الإعداد ولم يتم إصدارها بعد) ومن ثم تسليم النسخة الأولية لمدير الإدارة"/>
    <bpmn:task id="Shape_87" name="هل تم الاعتماد؟"/>
    <bpmn:task id="Shape_89" name="هل تحتاج لاعتماد الإدارة العليا؟"/>
    <bpmn:task id="Shape_93" name="هل تم الاعتماد؟"/>
    <bpmn:task id="Shape_95" name="ارسال الوثيقة النهائية إلى ممثل الإدارة لترميز وترقيم ووضع وتاريخ إصدار"/>
    <bpmn:task id="Shape_101" name="ترميز وترقيم ووضع وتاريخ إصدار، بحيث يكون رقم الإصدار الأول للوثيقة المعتمدة هو 1، ورقم الإصدار الأول للنموذج هو أ. ويقوم بالتأكد من وجود التواقيع بمراجعة واعتماد الوثيقة، و يتم إدراج جميع الوثائق التي تم اعتمادها في قائمة التوثيق الرئيسية لنظام إدارة الجودة"/>
    <bpmn:endEvent id="Shape_104" name="النهاية"/>
    <bpmn:task id="Shape_115" name="المسودة الأولى من الوثيقة"/>
    <bpmn:task id="Shape_167" name="قائمة التوثيق الرئيسية لنظام إدارة الجودة"/>
    <bpmn:task id="Shape_169" name="قائمة الوثائق المراد توثيقها"/>
