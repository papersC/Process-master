    <bpmn:task id="Shape_55" name="تعديل الإكسل شيت (المشاريع والمسؤول عن كل مشروع والقيمة المالية (قيمة عرض السعر) لكل مشروع"/>
    <bpmn:task id="Shape_57" name="إرسال عرض السعر المعتمد عن طريق البريد الإلكتروني   للجنة لدراسة الحالة"/>
