    <bpmn:startEvent id="Shape_43" name="البداية"/>
    <bpmn:task id="Shape_47" name="تسجيل نتائج المكالمات بقوائم بيانات التواصل مع المتعاملين وإرسالها لإدارة الاستراتيجية"/>
    <bpmn:task id="Shape_49" name="عدد الموظفين المنفذين
 للاستبيان عبر مكالمات 
الCall back  خمس موظفين"/>
    <bpmn:task id="Shape_52" name="الرد على المكالمة وإبداء الرأي من خلال الإجابة على أسئلة الاستبيان"/>
    <bpmn:task id="Shape_55" name="تجميع بيانات التواصل مع المتعاملين لكافة قنوات تقديم الخدمة (الموقع الإلكتروني والتطبيق ومركز تقديم الخدمة من نظام Q-system  ومركز الاتصال من إدارة الخدمات الذكية"/>
    <bpmn:task id="Shape_57" name="فلترة القوائم وتوزيعها على موظفي مركز الاتصال"/>
    <bpmn:task id="Shape_104" name="فلترة أسماء المتعاملين غير الراضين ومن لديهم ملاحظات وإرسال القائمة لقسم العناية بالمتعاملين"/>
    <bpmn:task id="Shape_120" name="تحويل الشكاوى وحالات عدم الرضا و الملاحظات الخاصة بقسم خدمة المتعاملين والحالات الخاصة بالوحدات التنظيمية المعنية للمعنيين في الوحدات التنظيمية"/>
    <bpmn:task id="Shape_127" name="استلام الملاحظات وحالات عدم الرضا والشكاوى والاقتراحات والعمل على حلها وإغلاقها من يتتابع الغلااق مع الوحدات التنظيمية"/>
    <bpmn:task id="Shape_130" name="تقديم شكوى عبر إحدى قنوات تقديم الشكاوى المتاحة (مواقع التواصل الاجتماعي أو نظام CRM  أو نظام الشكاوى الحكومي أو مركز الاتصال"/>
    <bpmn:task id="Shape_131" name="شكاوى واقتراحات مواقع التواصل الاجتماعي والبث المباشر"/>
    <bpmn:task id="Shape_132" name="شكاوى واقتراحات نظام الشكاوى الحكومي"/>
    <bpmn:task id="Shape_133" name="شكاوى نظام CRM  في لمؤسسة"/>
    <bpmn:task id="Shape_137" name="V"/>
