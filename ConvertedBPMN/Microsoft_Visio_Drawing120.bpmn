    <bpmn:task id="Shape_142" name="استلام الحالات منفصلة عبر البريد الإلكتروني والمتابعة مع الإدارات المعنية بحل الشكوى وإغلاقها في نظام الشكاوى"/>
    <bpmn:task id="Shape_144" name="قائمة الشكاوى والملاحظات وحالات عدم الرضا والحلول الخاصة بها"/>
