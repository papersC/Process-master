    <bpmn:task id="Shape_28" name="إصدار موافقة خدمة إسكانية"/>
    <bpmn:task id="Shape_29" name="سحب قائمة الموافقات من نظام التقارير الذكية والتدقيق على الكشوفات (إذا كان هناك تغير على الحالة الاجتماعية  منها الحالة الاجتماعية أرملة أو مطلقة وعدد أفراد الأسرة والجنس )أو الاستفادة من خدمات إسكانية أخرى من المؤسسة او خارج المؤسسة ) وإعطاء الأولوية للطلبات الأقدم"/>
    <bpmn:dataObject id="Shape_31" name="التواصل مع المتعامل للتأكد من صحة البيانات والاشتراطات وطلب مجموعة من المستندات مثل إثبات الحالة الاجتماعية وخلاصة القيد وشهادة الراتب والتأكد من استفادته من برامج إسكانية أخرى"/>
    <bpmn:dataObject id="Shape_32" name="توفير المستندات المطلوبة عن طريق البريد الإلكتروني أو واتس أب المؤسسة"/>
    <bpmn:task id="Shape_35" name="مستحق؟"/>
    <bpmn:dataObject id="Shape_36" name="استلام المستندات والتأكد من صحتها وارشفتها على نظام الإسكان دون التحديث على بيانات المتعامل"/>
    <bpmn:task id="Shape_39" name="حصر قائمة المتعاملين غير المستحقين  مع أسباب عدم الاستحقاق وإرسالها لإدارة إسعاد المتعاملين للتعديل في النظام"/>
    <bpmn:task id="Shape_40" name="الاتصال هاتفيا+ إرسال رسالة نصية للمتعاملين المستحقين لزيارة موقع التخصيص &quot;حسب موقع المشروع&quot; لتحديد المساكن الخاصة فيهم"/>
    <bpmn:task id="Shape_43" name="منحة أم قرض؟"/>
    <bpmn:task id="Shape_45" name="إبلاغ المتعامل بضرورة زيارة موقع المشروع لتخصيص المسكن"/>
    <bpmn:task id="Shape_47" name="استلام القائمة والتعديل على حالة الطلب &quot;ملغي&quot; في نظام الإسكان"/>
    <bpmn:endEvent id="Shape_48" name="النهاية"/>
    <bpmn:task id="Shape_50" name="حجز مبدئي للمسكن عن طريق موقع المؤسسة  أ, موظف التخصيص في قسم الأصول وإيداع رسوم  مقدارها 10,000 درهم في حساب المؤسسة"/>
    <bpmn:task id="Shape_51" name="زيارة المتعامل موقع التخصيص لتنفيذ قرعة على مساكن المنح"/>
    <bpmn:task id="Shape_53" name="استلام وتسليم المساكن"/>
    <bpmn:endEvent id="Shape_54" name="النهاية"/>
