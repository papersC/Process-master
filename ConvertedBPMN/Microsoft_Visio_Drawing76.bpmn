    <bpmn:startEvent id="Shape_47" name="البداية"/>
    <bpmn:task id="Shape_49" name="تقديم طلب صيانة ،أو دعم لوجستي على موقع بيتنا الداخلي"/>
    <bpmn:task id="Shape_50" name="V"/>
    <bpmn:task id="Shape_53" name="إبلاغ موظف قسم الشؤون الإدارية بالتواصل مع شركة الصيانة"/>
    <bpmn:task id="Shape_55" name="التواصل مع الشركة عن طريق البريد الإلكتروني أو الهاتف لحل المشكلة وتنفيذ أعمال الصيانة"/>
