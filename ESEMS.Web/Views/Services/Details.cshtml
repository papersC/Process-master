@section Scripts {
    @* Antiforgery token hidden input — the controller's 12 AJAX POSTs
       require [ValidateAntiForgeryToken] and read the
       RequestVerificationToken header on every fetch below. *@
    @Html.AntiForgeryToken()
    <script nonce="@Context.CspNonce()">
        // ===== Tab switching =====
        // Replaces the previous anchor-scroll/pulse behaviour. Activates one
        // tab pane (#overview / #processes / #assets / #risks / #performance),
        // updates the active tab button and KPI chip styling, and writes the
        // hash so back/forward buttons + deep links continue to work — the
        // pane IDs match the legacy anchor IDs so external bookmarks still
        // land on the right section.
        function sd2ShowTab(name) {
            document.querySelectorAll('.sd2-tabpanel').forEach(p => p.classList.add('d-none'));
            document.querySelectorAll('.sd2-tab').forEach(t => t.classList.remove('active'));
            const pane = document.getElementById(name);
            const tab  = document.querySelector('.sd2-tab[data-sd2tab="' + name + '"]');
            if (pane) pane.classList.remove('d-none');
            if (tab)  tab.classList.add('active');
            try { history.replaceState(null, '', '#' + name); } catch (e) {}
            if (window.lucide) lucide.createIcons();
        }
        document.addEventListener('DOMContentLoaded', function () {
            const h = (location.hash || '').replace('#','');
            // Backwards-compat: legacy anchors #overview, #processes, #assets, #risks
            // map directly to tabs. Unknown hashes default to overview.
            const validTabs = ['overview', 'processes', 'assets', 'risks', 'performance'];
            sd2ShowTab(validTabs.includes(h) ? h : 'overview');
        });
        window.addEventListener('hashchange', function () {
            const h = (location.hash || '').replace('#','');
            const validTabs = ['overview', 'processes', 'assets', 'risks', 'performance'];
            if (validTabs.includes(h)) sd2ShowTab(h);
        });
    </script>
    <script nonce="@Context.CspNonce()">
        lucide.createIcons();
        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        const serviceId = '@Model.Id';

        // UX helpers — SweetAlert replaces raw browser alert/confirm so the
        // link/unlink flows match the rest of the app's modal style.
        function showErr(msg) {
            Swal.fire({ icon: 'error', title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Js_Error"].Value)), text: msg, confirmButtonColor: '#005B99' });
        }
        async function confirmDestructive(text) {
            const r = await Swal.fire({
                icon: 'warning', title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Confirm_AreYouSure"].Value)), text,
                showCancelButton: true,
                confirmButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Label_Yes"].Value)), cancelButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Button_Cancel"].Value)),
                confirmButtonColor: '#dc2626', cancelButtonColor: '#64748b'
            });
            return r.isConfirmed;
        }
        // ===== Custom modal show/hide (Tailwind floater pattern) =====
        // Replaces bootstrap.Modal — each modal has a backdrop (id+'Backdrop')
        // and a container (id+'Modal'). Show: remove `hidden` from both, set
        // display:flex on container (overrides the items-start utility's
        // inline-flex semantics when toggled this way). Hide: re-add `hidden`,
        // clear inline display. Lucide re-runs after show so the X icon
        // renders on first open. Same pattern as
        // Views/Improvements/Details.cshtml openAddMeasurementModal().
        function sd2OpenModal(name) {
            const backdrop = document.getElementById(name + 'Backdrop');
            const modal = document.getElementById(name + 'Modal');
            if (backdrop) backdrop.classList.remove('hidden');
            if (modal) {
                modal.classList.remove('hidden');
                modal.style.display = 'flex';
            }
            if (window.lucide) lucide.createIcons();
        }
        function sd2CloseModal(name) {
            const backdrop = document.getElementById(name + 'Backdrop');
            const modal = document.getElementById(name + 'Modal');
            if (backdrop) backdrop.classList.add('hidden');
            if (modal) {
                modal.classList.add('hidden');
                modal.style.display = 'none';
            }
        }
        // Esc closes whichever modal is open. One global listener so we don't
        // have to wire it per-modal.
        document.addEventListener('keydown', function (e) {
            if (e.key !== 'Escape') return;
            ['linkProcess','editServiceProcess','linkAsset','editServiceAsset','linkRisk','editServiceRisk'].forEach(function (name) {
                const modal = document.getElementById(name + 'Modal');
                if (modal && !modal.classList.contains('hidden')) sd2CloseModal(name);
            });
        });

        // ===== ASSET FUNCTIONS =====

        function openLinkAssetModal() {
            sd2OpenModal('linkAsset');
            loadAvailableAssets();
        }

        async function loadAvailableAssets() {
            try {
                const response = await fetch(`/Services/GetAvailableAssets?serviceId=${serviceId}`);
                const assets = await response.json();

                const container = document.getElementById('availableAssetsContainer');

                if (assets.length === 0) {
                    container.innerHTML = `
                        <div class="text-center py-4">
                            <i data-lucide="package-check" style="width: 48px; height: 48px;" class="text-muted"></i>
                            <p class="text-muted mt-2">@Shared["Text_AllAssetsLinkedToService"]</p>
                        </div>
                    `;
                    lucide.createIcons();
                    return;
                }

                container.innerHTML = '<div class="list-group">' + assets.map(asset => {
                    const statusClass = {
                        'Operational': 'success',
                        'UnderMaintenance': 'warning',
                        'Retired': 'secondary'
                    }[asset.status] || 'info';

                    const criticalityClass = {
                        1: 'danger',
                        2: 'warning',
                        3: 'info',
                        4: 'secondary'
                    }[asset.criticality] || 'secondary';

                    return `
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="fw-medium">${asset.assetTag}</span>
                                        <span class="badge badge-${statusClass}">${asset.status}</span>
                                        <span class="badge badge-${criticalityClass}">Criticality: ${asset.criticality}</span>
                                    </div>
                                    <p class="mb-1">${asset.nameEn}</p>
                                    ${asset.categoryName ? `<small class="text-muted">${asset.categoryName}</small>` : ''}
                                </div>
                                <button onclick="linkAsset('${asset.id}')" class="btn btn-sm btn-primary">Link</button>
                            </div>
                        </div>
                    `;
                }).join('') + '</div>';

                lucide.createIcons();
            } catch (error) {
                console.error('Error loading assets:', error);
                document.getElementById('availableAssetsContainer').innerHTML = `
                    <div class="alert alert-danger">Error loading assets. Please try again.</div>
                `;
            }
        }

        async function linkAsset(assetId) {
            try {
                const response = await fetch('/Services/LinkAsset', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                    body: new URLSearchParams({ serviceId, assetId, criticality: 3, isRequired: true })
                });

                const result = await response.json();

                if (result.success) {
                    sd2CloseModal('linkAsset');
                    location.reload();
                } else {
                    showErr(result.message || 'Error linking asset');
                }
            } catch (error) {
                console.error('Error linking asset:', error);
                showErr('Error linking asset. Please try again.');
            }
        }

        async function unlinkAsset(serviceId, assetId) {
            if (!(await confirmDestructive('Are you sure you want to unlink this asset from the service?'))) return;

            try {
                const response = await fetch('/Services/UnlinkAsset', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                    body: new URLSearchParams({ serviceId, assetId })
                });

                const result = await response.json();

                if (result.success) {
                    location.reload();
                } else {
                    showErr(result.message || 'Error unlinking asset');
                }
            } catch (error) {
                console.error('Error unlinking asset:', error);
                showErr('Error unlinking asset. Please try again.');
            }
        }

        function editServiceAsset(serviceId, assetId, criticality, isRequired, usageDescription) {
            document.getElementById('editServiceIdAsset').value = serviceId;
            document.getElementById('editAssetId').value = assetId;
            document.getElementById('editCriticality').value = criticality;
            document.getElementById('editIsRequired').checked = isRequired;
            document.getElementById('editUsageDescription').value = usageDescription || '';
            sd2OpenModal('editServiceAsset');
        }

        document.getElementById('editServiceAssetForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const serviceId = document.getElementById('editServiceIdAsset').value;
            const assetId = document.getElementById('editAssetId').value;
            const criticality = document.getElementById('editCriticality').value;
            const isRequired = document.getElementById('editIsRequired').checked;
            const usageDescription = document.getElementById('editUsageDescription').value;

            try {
                const response = await fetch('/Services/UpdateServiceAsset', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                    body: new URLSearchParams({ serviceId, assetId, criticality, isRequired, usageDescription })
                });

                const result = await response.json();

                if (result.success) {
                    sd2CloseModal('editServiceAsset');
                    location.reload();
                } else {
                    showErr(result.message || 'Error updating relationship');
                }
            } catch (error) {
                console.error('Error updating relationship:', error);
                showErr('Error updating relationship. Please try again.');
            }
        });

        // ===== RISK FUNCTIONS =====

        function openLinkRiskModal() {
            sd2OpenModal('linkRisk');
            loadAvailableRisks();
        }

        async function loadAvailableRisks() {
            try {
                const response = await fetch(`/Services/GetAvailableRisks?serviceId=${serviceId}`);
                const risks = await response.json();

                const container = document.getElementById('availableRisksContainer');

                if (risks.length === 0) {
                    container.innerHTML = `
                        <div class="text-center py-4">
                            <i data-lucide="shield-check" style="width: 48px; height: 48px;" class="text-muted"></i>
                            <p class="text-muted mt-2">@Shared["Text_AllRisksLinkedToService"]</p>
                        </div>
                    `;
                    lucide.createIcons();
                    return;
                }

                container.innerHTML = '<div class="list-group">' + risks.map(risk => {
                    const levelClass = {
                        'Critical': 'danger',
                        'High': 'warning',
                        'Medium': 'info',
                        'Low': 'success'
                    }[risk.riskLevel] || 'secondary';

                    return `
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="fw-medium">${risk.riskNumber}</span>
                                        <span class="badge badge-${levelClass}">${risk.riskLevel}</span>
                                        <span class="badge badge-secondary">Score: ${risk.inherentRiskScore}</span>
                                    </div>
                                    <p class="mb-1">${risk.nameEn}</p>
                                    ${risk.categoryName ? `<small class="text-muted">${risk.categoryName}</small>` : ''}
                                </div>
                                <button onclick="linkRisk('${risk.id}')" class="btn btn-sm btn-primary">Link</button>
                            </div>
                        </div>
                    `;
                }).join('') + '</div>';

                lucide.createIcons();
            } catch (error) {
                console.error('Error loading risks:', error);
                document.getElementById('availableRisksContainer').innerHTML = `
                    <div class="alert alert-danger">Error loading risks. Please try again.</div>
                `;
            }
        }

        async function linkRisk(riskId) {
            try {
                const response = await fetch('/Services/LinkRisk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                    body: new URLSearchParams({ serviceId, riskId, impactLevel: 3 })
                });

                const result = await response.json();

                if (result.success) {
                    sd2CloseModal('linkRisk');
                    location.reload();
                } else {
                    showErr(result.message || 'Error linking risk');
                }
            } catch (error) {
                console.error('Error linking risk:', error);
                showErr('Error linking risk. Please try again.');
            }
        }

        async function unlinkRisk(serviceId, riskId) {
            if (!(await confirmDestructive('Are you sure you want to unlink this risk from the service?'))) return;

            try {
                const response = await fetch('/Services/UnlinkRisk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                    body: new URLSearchParams({ serviceId, riskId })
                });

                const result = await response.json();

                if (result.success) {
                    location.reload();
                } else {
                    showErr(result.message || 'Error unlinking risk');
                }
            } catch (error) {
                console.error('Error unlinking risk:', error);
                showErr('Error unlinking risk. Please try again.');
            }
        }

        function editServiceRisk(serviceId, riskId, impactLevel, specificControls, notes) {
            document.getElementById('editServiceIdRisk').value = serviceId;
            document.getElementById('editRiskId').value = riskId;
            document.getElementById('editImpactLevel').value = impactLevel;
            document.getElementById('editSpecificControls').value = specificControls || '';
            document.getElementById('editNotes').value = notes || '';
            sd2OpenModal('editServiceRisk');
        }

        document.getElementById('editServiceRiskForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const serviceId = document.getElementById('editServiceIdRisk').value;
            const riskId = document.getElementById('editRiskId').value;
            const impactLevel = document.getElementById('editImpactLevel').value;
            const specificControls = document.getElementById('editSpecificControls').value;
            const notes = document.getElementById('editNotes').value;

            try {
                const response = await fetch('/Services/UpdateServiceRisk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                    body: new URLSearchParams({ serviceId, riskId, impactLevel, specificControls, notes })
                });

                const result = await response.json();

                if (result.success) {
                    sd2CloseModal('editServiceRisk');
                    location.reload();
                } else {
                    showErr(result.message || 'Error updating relationship');
                }
            } catch (error) {
                console.error('Error updating relationship:', error);
                showErr('Error updating relationship. Please try again.');
            }
        });

        // ===== PROCESS FUNCTIONS =====

        function openLinkProcessModal() {
            sd2OpenModal('linkProcess');
            loadAvailableProcesses();
        }

        async function loadAvailableProcesses() {
            try {
                const response = await fetch(`/Services/GetAvailableProcesses?serviceId=${serviceId}`);
                const processes = await response.json();
                const container = document.getElementById('availableProcessesContainer');

                if (processes.length === 0) {
                    container.innerHTML = `<div class="text-center py-4"><i data-lucide="git-branch" style="width: 48px; height: 48px;" class="text-muted"></i><p class="text-muted mt-2">All processes are already linked to this service.</p></div>`;
                    lucide.createIcons();
                    return;
                }

                container.innerHTML = '<div class="list-group">' + processes.map(p => `
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <span class="fw-medium">${p.name}</span>
                                <small class="text-muted d-block">${p.code} ${p.processGroupName ? '• ' + p.processGroupName : ''}</small>
                            </div>
                            <button onclick="linkProcess('${p.id}')" class="btn btn-sm btn-primary">Link</button>
                        </div>
                    </div>
                `).join('') + '</div>';
                lucide.createIcons();
            } catch (error) {
                console.error('Error loading processes:', error);
                document.getElementById('availableProcessesContainer').innerHTML = `<div class="alert alert-danger">Error loading processes. Please try again.</div>`;
            }
        }

        async function linkProcess(processId) {
            try {
                const response = await fetch('/Services/LinkProcess', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                    body: new URLSearchParams({ serviceId, processId, criticality: 3, isMandatory: true })
                });
                const result = await response.json();
                if (result.success) { sd2CloseModal('linkProcess'); location.reload(); }
                else { showErr(result.message || 'Error linking process'); }
            } catch (error) { console.error('Error linking process:', error); showErr('Error linking process.'); }
        }

        async function unlinkProcess(serviceId, processId) {
            if (!(await confirmDestructive('Are you sure you want to unlink this process from the service?'))) return;
            try {
                const response = await fetch('/Services/UnlinkProcess', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                    body: new URLSearchParams({ serviceId, processId })
                });
                const result = await response.json();
                if (result.success) { location.reload(); }
                else { showErr(result.message || 'Error unlinking process'); }
            } catch (error) { console.error('Error unlinking process:', error); showErr('Error unlinking process.'); }
        }

        function editServiceProcess(serviceId, processId, criticality, isMandatory, notes) {
            document.getElementById('editSPServiceId').value = serviceId;
            document.getElementById('editSPProcessId').value = processId;
            document.getElementById('editSPCriticality').value = criticality;
            document.getElementById('editSPIsMandatory').checked = isMandatory;
            document.getElementById('editSPNotes').value = notes || '';
            sd2OpenModal('editServiceProcess');
        }

        document.getElementById('editServiceProcessForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const sId = document.getElementById('editSPServiceId').value;
            const pId = document.getElementById('editSPProcessId').value;
            const criticality = document.getElementById('editSPCriticality').value;
            const isMandatory = document.getElementById('editSPIsMandatory').checked;
            const notes = document.getElementById('editSPNotes').value;

            try {
                const response = await fetch('/Services/UpdateServiceProcess', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': csrfToken },
                    body: new URLSearchParams({ serviceId: sId, processId: pId, criticality, isMandatory, notes })
                });
                const result = await response.json();
                if (result.success) { sd2CloseModal('editServiceProcess'); location.reload(); }
                else { showErr(result.message || 'Error updating relationship'); }
            } catch (error) {
                console.error('Error updating relationship:', error);
                showErr('Error updating relationship. Please try again.');
            }
        });
    </script>
}
