@section Scripts {
    <script nonce="@Context.CspNonce()">
        // ===== Tab switcher (deep-linkable via #hash) =====
        function pdShowTab(name) {
            document.querySelectorAll('.pd-tabpanel').forEach(p => p.classList.add('d-none'));
            document.querySelectorAll('.pd-tab').forEach(t => t.classList.remove('active'));
            const panel = document.getElementById('pd-tab-' + name);
            const tab = document.querySelector('.pd-tab[data-pdtab="' + name + '"]');
            if (panel) panel.classList.remove('d-none');
            if (tab) tab.classList.add('active');
            try { history.replaceState(null, '', '#' + name); } catch (e) {}
            if (window.lucide) lucide.createIcons();
            // Lazy-init / re-fit BPMN canvas when its tab becomes visible.
            // Initial load is deferred until here so the SVG canvas isn't
            // sized 0×0 (which would crash bpmn-js's fit-viewport with
            // "Failed to execute 'scale' on 'SVGMatrix'").
            if (name === 'bpmn' && typeof window.__pdLoadBpmn === 'function') {
                setTimeout(() => window.__pdLoadBpmn(), 60);
            }
        }
        // Restore tab from URL hash on load
        document.addEventListener('DOMContentLoaded', function () {
            const h = (location.hash || '').replace('#','');
            if (h && document.getElementById('pd-tab-' + h)) pdShowTab(h);
        });
    </script>
    <script nonce="@Context.CspNonce()">
        lucide.createIcons();

        // UX helpers
        function showErr(msg) { Swal.fire({ icon:'error', title:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Js_Error"].Value)), text:msg, confirmButtonColor:'#005B99' }); }
        async function confirmDestructive(text) {
            const r = await Swal.fire({ icon:'warning', title:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Confirm_AreYouSure"].Value)), text,
                showCancelButton:true, confirmButtonText:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Label_Yes"].Value)), cancelButtonText:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Button_Cancel"].Value)),
                confirmButtonColor:'#dc2626', cancelButtonColor:'#64748b' });
            return r.isConfirmed;
        }

        // ── Process Optimizer ────────────────────────────
        async function runProcessOptimizer(processId) {
            var container = document.getElementById('optimizerContent');
            var btn = document.getElementById('btnOptimize');
            container.style.display = 'block';
            container.innerHTML = '<div class="text-center py-4"><div class="spinner-border" style="color: #a855f7;"></div><p class="text-muted mt-2 small">@Html.Raw(Shared["ProcessOptimizer_Analyzing"].Value)</p></div>';
            btn.disabled = true;

            var token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
            try {
                var res = await fetch('/AI/OptimizeProcess', {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token ? token.value : '' },
                    body: JSON.stringify({ processId: processId })
                });
                var data = await res.json();
                if (data.success) {
                    renderOptimization(data.optimization, processId);
                } else {
                    container.innerHTML = '<div class="alert alert-warning mb-0">' + (data.error || 'Optimization failed') + '</div>';
                }
            } catch(e) {
                container.innerHTML = '<div class="alert alert-danger mb-0">@Html.Raw(Shared["Error_ProcessingRequest"].Value)</div>';
            }
            btn.disabled = false;
        }

        function renderOptimization(opt, processId) {
            var container = document.getElementById('optimizerContent');
            var isRtl = @(isRtl ? "true" : "false");

            // If string fallback (AI didn't return valid JSON)
            if (typeof opt === 'string') {
                if (typeof marked !== 'undefined') {
                    container.innerHTML = '<div class="prose">' + marked.parse(opt) + '</div>';
                } else {
                    container.innerHTML = '<div class="p-3 bg-light rounded"><pre class="mb-0" style="white-space: pre-wrap;">' + opt + '</pre></div>';
                }
                return;
            }

            var html = '';

            // ROI Summary banner
            var roi = opt.roiSummary || {};
            html += '<div class="alert mb-3 d-flex flex-wrap gap-3" style="background: linear-gradient(135deg, rgba(52,195,143,0.08), rgba(52,195,143,0.15)); border: 1px solid rgba(52,195,143,0.25); border-radius: 10px;">';
            html += '<div><i data-lucide="trending-up" style="width:14px;height:14px;color:#34C38F;"></i> <strong>' + (isRtl ? 'الوفورات المقدرة' : 'Est. Savings') + ':</strong> ' + (roi.totalEstimatedCostSavings || 0).toLocaleString() + ' AED</div>';
            html += '<div><i data-lucide="clock" style="width:14px;height:14px;color:#50A5F1;"></i> <strong>' + (isRtl ? 'توفير الوقت' : 'Time Savings') + ':</strong> ' + (roi.totalEstimatedTimeSavingsHours || 0) + (isRtl ? ' ساعة/سنة' : 'h/year') + '</div>';
            html += '<div><i data-lucide="calendar" style="width:14px;height:14px;color:#F1B44C;"></i> <strong>' + (isRtl ? 'فترة الاسترداد' : 'Payback') + ':</strong> ' + (roi.paybackPeriodMonths || '?') + (isRtl ? ' شهر' : ' months') + '</div>';
            html += '</div>';

            // 3 categories
            var categories = [
                { key: 'quickWins', icon: 'zap', color: '#34C38F', label: isRtl ? 'مكاسب سريعة (أقل من شهر)' : 'Quick Wins (< 1 month)' },
                { key: 'mediumTerm', icon: 'clock', color: '#F1B44C', label: isRtl ? 'متوسطة المدى (1-3 أشهر)' : 'Medium-Term (1-3 months)' },
                { key: 'longTerm', icon: 'target', color: '#50A5F1', label: isRtl ? 'طويلة المدى (3+ أشهر)' : 'Long-Term (3+ months)' }
            ];

            for (var c = 0; c < categories.length; c++) {
                var cat = categories[c];
                var items = opt[cat.key] || [];
                if (!items.length) continue;

                html += '<h6 class="d-flex align-items-center gap-2 mt-3 mb-2">';
                html += '<i data-lucide="' + cat.icon + '" style="width:16px;height:16px;color:' + cat.color + ';"></i>';
                html += '<span class="badge" style="background:' + cat.color + '; color: white;">' + items.length + '</span> ' + cat.label + '</h6>';

                for (var i = 0; i < items.length; i++) {
                    var item = items[i];
                    var createUrl = (window.SP_PATHBASE || '') + '/Improvements/Wizard?processId=' + processId +
                        '&title=' + encodeURIComponent(item.title || '') +
                        '&description=' + encodeURIComponent(item.description || '') +
                        '&estimatedCostSavings=' + (item.estimatedCostSavings || 0);

                    html += '<div class="card mb-2" style="border-' + (isRtl ? 'right' : 'left') + ': 3px solid ' + cat.color + '; border-radius: 8px;">';
                    html += '<div class="card-body py-2 px-3">';
                    html += '<div class="d-flex justify-content-between align-items-start gap-2">';
                    html += '<div class="flex-grow-1">';
                    html += '<strong class="d-block mb-1">' + (item.title || '') + '</strong>';
                    html += '<p class="text-muted small mb-1">' + (item.description || '') + '</p>';
                    html += '<div class="d-flex flex-wrap gap-2" style="font-size: var(--fs-xs);">';
                    html += '<span class="text-success"><i data-lucide="banknote" style="width:12px;height:12px;"></i> ' + (item.estimatedCostSavings || 0).toLocaleString() + ' AED</span>';
                    html += '<span class="text-info"><i data-lucide="clock" style="width:12px;height:12px;"></i> ' + (item.estimatedTimeSavingsHours || 0) + 'h</span>';
                    html += '<span class="badge bg-secondary">' + (item.effortLevel || '') + '</span>';
                    html += '</div></div>';
                    html += '<a href="' + createUrl + '" class="btn btn-sm btn-outline-primary flex-shrink-0" style="border-radius: 6px;" title="' + (isRtl ? 'إنشاء مبادرة' : 'Create Initiative') + '">';
                    html += '<i data-lucide="plus" style="width:14px;height:14px;"></i></a>';
                    html += '</div></div></div>';
                }
            }

            container.innerHTML = html;
            if (typeof lucide !== 'undefined') lucide.createIcons();
        }

        function confirmDeleteActivity(id, name) {
            Swal.fire({
                title: '@Shared["Confirm_Delete"]',
                text: '@Shared["Confirm_DeleteMessage"]',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#005B99',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '@Shared["Button_Delete"]',
                cancelButtonText: '@Shared["Button_Cancel"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteActivityId').value = id;
                    document.getElementById('deleteActivityForm').submit();
                }
            });
        }

        function confirmDeleteTask(id, name) {
            Swal.fire({
                title: '@Shared["Confirm_Delete"]',
                text: '@Shared["Confirm_DeleteMessage"]',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#005B99',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '@Shared["Button_Delete"]',
                cancelButtonText: '@Shared["Button_Cancel"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteTaskId').value = id;
                    document.getElementById('deleteTaskForm').submit();
                }
            });
        }

        // ===== PROCESS-SERVICE LINKING =====
        const processId = '@Model.Id';
        let linkServiceModalInstance, editProcessServiceModalInstance;

        document.addEventListener('DOMContentLoaded', function() {
            linkServiceModalInstance = new bootstrap.Modal(document.getElementById('linkServiceModal'));
            editProcessServiceModalInstance = new bootstrap.Modal(document.getElementById('editProcessServiceModal'));
        });

        function openLinkServiceModal() {
            linkServiceModalInstance.show();
            loadAvailableServices();
        }

        async function loadAvailableServices() {
            try {
                const response = await fetch(`/Processes/GetAvailableServices?processId=${processId}`);
                const services = await response.json();
                const container = document.getElementById('availableServicesContainer');

                if (services.length === 0) {
                    container.innerHTML = `<div class="text-center py-4"><i data-lucide="briefcase" style="width: 48px; height: 48px;" class="text-muted"></i><p class="text-muted mt-2">All services are already linked to this process.</p></div>`;
                    lucide.createIcons();
                    return;
                }

                container.innerHTML = '<div class="list-group">' + services.map(s => `
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <span class="fw-medium">${s.nameEn || s.nameAr}</span>
                                ${s.nameAr && s.nameAr !== s.nameEn ? `<small class="text-muted d-block">${s.nameAr}</small>` : ''}
                            </div>
                            <button onclick="linkService('${s.id}')" class="btn btn-sm btn-primary">Link</button>
                        </div>
                    </div>
                `).join('') + '</div>';
                lucide.createIcons();
            } catch (error) {
                console.error('Error loading services:', error);
                document.getElementById('availableServicesContainer').innerHTML = `<div class="alert alert-danger">Error loading services. Please try again.</div>`;
            }
        }

        async function linkService(serviceId) {
            try {
                const response = await fetch('/Processes/LinkService', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ processId, serviceId, criticality: 3, isMandatory: true })
                });
                const result = await response.json();
                if (result.success) { linkServiceModalInstance.hide(); location.reload(); }
                else { showErr(result.message || 'Error linking service'); }
            } catch (error) { console.error('Error linking service:', error); showErr('Error linking service.'); }
        }

        async function unlinkService(processId, serviceId) {
            if (!(await confirmDestructive('Are you sure you want to unlink this service from the process?'))) return;
            try {
                const response = await fetch('/Processes/UnlinkService', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ processId, serviceId })
                });
                const result = await response.json();
                if (result.success) { location.reload(); }
                else { showErr(result.message || 'Error unlinking service'); }
            } catch (error) { console.error('Error unlinking service:', error); showErr('Error unlinking service.'); }
        }

        function editProcessService(processId, serviceId, criticality, isMandatory, notes) {
            document.getElementById('editPSProcessId').value = processId;
            document.getElementById('editPSServiceId').value = serviceId;
            document.getElementById('editPSCriticality').value = criticality;
            document.getElementById('editPSIsMandatory').checked = isMandatory;
            document.getElementById('editPSNotes').value = notes || '';
            editProcessServiceModalInstance.show();
        }

        document.getElementById('editProcessServiceForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const pId = document.getElementById('editPSProcessId').value;
            const sId = document.getElementById('editPSServiceId').value;
            const criticality = document.getElementById('editPSCriticality').value;
            const isMandatory = document.getElementById('editPSIsMandatory').checked;
            const notes = document.getElementById('editPSNotes').value;

            try {
                const response = await fetch('/Processes/UpdateProcessService', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ processId: pId, serviceId: sId, criticality, isMandatory, notes })
                });
                const result = await response.json();
                if (result.success) { editProcessServiceModalInstance.hide(); location.reload(); }
                else { showErr(result.message || 'Error updating relationship'); }
            } catch (error) { console.error('Error updating relationship:', error); showErr('Error updating relationship.'); }
        });

        // Pure JS toggle — no Bootstrap Collapse involved
        function toggleActivity(headerEl) {
            var panel = headerEl.nextElementSibling;
            var chevron = headerEl.querySelector('.activity-chevron');
            if (!panel) return;

            if (panel.style.display === 'none' || panel.style.display === '') {
                panel.style.display = 'block';
                if (chevron) chevron.style.transform = 'rotate(90deg)';
                lucide.createIcons();
            } else {
                panel.style.display = 'none';
                if (chevron) chevron.style.transform = 'rotate(0deg)';
            }
        }
    </script>
    @if (!string.IsNullOrWhiteSpace(Model.BpmnDiagram))
    {
        <!-- bpmn-js viewer and modeler -->
        <link rel="stylesheet" href="~/lib/bpmn-js/diagram-js.css" asp-append-version="true">
        <link rel="stylesheet" href="~/lib/bpmn-js/bpmn-js.css" asp-append-version="true">
        <link rel="stylesheet" href="~/lib/bpmn-js/bpmn-embedded.css" asp-append-version="true">
        <style>
            /* Hide bpmn.io watermark */
            .bjs-powered-by { display: none !important; }
        </style>
        <script src="~/lib/bpmn-js/bpmn-navigated-viewer.production.min.js" asp-append-version="true"></script>
        <script src="~/lib/bpmn-js/bpmn-modeler.production.min.js" asp-append-version="true"></script>
        <script nonce="@Context.CspNonce()">
            (function() {
                const bpmnXml = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BpmnDiagram));
                const processId = '@Model.Id';

                let viewer = null;
                let modeler = null;
                let isEditMode = false;
                let currentBpmnInstance = null;

                // Initialize viewer
                viewer = new BpmnJS({
                    container: '#bpmnCanvas'
                });
                currentBpmnInstance = viewer;

                async function loadDiagram() {
                    try {
                        const result = await currentBpmnInstance.importXML(bpmnXml);
                        if (result && result.warnings && result.warnings.length) {
                            console.warn('BPMN import warnings:', result.warnings);
                        }
                        const canvas = currentBpmnInstance.get('canvas');
                        canvas.zoom('fit-viewport');
                    } catch (err) {
                        console.error('Error loading BPMN diagram:', err);
                        const detail = (err && (err.message || err.toString())) || 'unknown error';
                        const warnings = (err && err.warnings && err.warnings.length)
                            ? '<br><small class="text-muted">' + err.warnings.slice(0, 3).map(w => (w.message || w.error || String(w))).join('<br>') + '</small>'
                            : '';
                        document.getElementById('bpmnCanvas').innerHTML =
                            '<div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted p-3 text-center">' +
                            '<i data-lucide="alert-circle" class="mb-2"></i>' +
                            '<div>Error loading diagram</div>' +
                            '<small class="text-danger mt-1" style="max-width:80%;word-break:break-word;">' + detail + '</small>' +
                            warnings + '</div>';
                        lucide.createIcons();
                    }
                }

                async function enableEditMode() {
                    try {
                        isEditMode = true;

                        // Get current XML from viewer
                        const { xml } = await viewer.saveXML({ format: true });

                        // Destroy viewer
                        viewer.destroy();

                        // Create modeler
                        modeler = new BpmnJS({
                            container: '#bpmnCanvas',
                            keyboard: { bindTo: document }
                        });
                        currentBpmnInstance = modeler;

                        // Load diagram in modeler
                        await modeler.importXML(xml);
                        const canvas = modeler.get('canvas');
                        canvas.zoom('fit-viewport');

                        // Update UI
                        document.getElementById('btnEditDiagram').classList.add('d-none');
                        document.getElementById('btnSaveDiagram').classList.remove('d-none');
                        document.getElementById('btnCancelEdit').classList.remove('d-none');
                        document.getElementById('editModeIndicator').classList.remove('d-none');
                        document.getElementById('bpmnCard').style.border = '2px solid #ffc107';
                        lucide.createIcons();
                    } catch (err) {
                        console.error('Error enabling edit mode:', err);
                        Swal.fire({
                            icon: 'error',
                            title: '@(isRtl ? "خطأ!" : "Error!")',
                            text: '@(isRtl ? "خطأ في تفعيل وضع التعديل" : "Error enabling edit mode")' + ': ' + err.message,
                            confirmButtonText: '@(isRtl ? "حسناً" : "OK")'
                        });
                    }
                }

                async function disableEditMode() {
                    try {
                        isEditMode = false;

                        // Destroy modeler
                        if (modeler) {
                            modeler.destroy();
                            modeler = null;
                        }

                        // Recreate viewer
                        viewer = new BpmnJS({
                            container: '#bpmnCanvas'
                        });
                        currentBpmnInstance = viewer;

                        // Load original diagram
                        await viewer.importXML(bpmnXml);
                        const canvas = viewer.get('canvas');
                        canvas.zoom('fit-viewport');

                        // Update UI
                        document.getElementById('btnEditDiagram').classList.remove('d-none');
                        document.getElementById('btnSaveDiagram').classList.add('d-none');
                        document.getElementById('btnCancelEdit').classList.add('d-none');
                        document.getElementById('editModeIndicator').classList.add('d-none');
                        document.getElementById('bpmnCard').style.border = '';
                        lucide.createIcons();
                    } catch (err) {
                        console.error('Error disabling edit mode:', err);
                    }
                }

                async function saveDiagram() {
                    const saveBtn = document.getElementById('btnSaveDiagram');
                    const btnText = saveBtn.querySelector('.btn-text');
                    const spinner = saveBtn.querySelector('.spinner-border');

                    try {
                        // Show loading state
                        saveBtn.disabled = true;
                        btnText.classList.add('d-none');
                        spinner.classList.remove('d-none');

                        // Get updated XML from modeler
                        const { xml } = await modeler.saveXML({ format: true });

                        // Validate BPMN XML
                        if (!xml || !xml.includes('bpmn:definitions')) {
                            throw new Error('@(isRtl ? "مخطط BPMN غير صالح" : "Invalid BPMN diagram")');
                        }

                        // Send to server
                        const response = await fetch('/Processes/UpdateBpmnDiagram/' + processId, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                            },
                            body: JSON.stringify({ bpmnXml: xml })
                        });

                        const result = await response.json();

                        if (response.ok && result.success) {
                            // Show success message
                            Swal.fire({
                                icon: 'success',
                                title: '@(isRtl ? "نجح!" : "Success!")',
                                text: '@(isRtl ? "تم حفظ المخطط بنجاح" : "Diagram saved successfully")',
                                confirmButtonText: '@(isRtl ? "حسناً" : "OK")',
                                timer: 2000,
                                timerProgressBar: true
                            }).then(() => {
                                location.reload(); // Reload to show updated diagram
                            });
                        } else {
                            throw new Error(result.message || '@(isRtl ? "خطأ غير معروف" : "Unknown error")');
                        }
                    } catch (err) {
                        console.error('Error saving diagram:', err);

                        // Show error message
                        Swal.fire({
                            icon: 'error',
                            title: '@(isRtl ? "خطأ!" : "Error!")',
                            text: '@(isRtl ? "خطأ في حفظ المخطط" : "Error saving diagram")' + ': ' + err.message,
                            confirmButtonText: '@(isRtl ? "حسناً" : "OK")'
                        });

                        // Reset button state
                        saveBtn.disabled = false;
                        btnText.classList.remove('d-none');
                        spinner.classList.add('d-none');
                    }
                }

                // Defer the initial BPMN load until the BPMN tab is actually
                // visible. Calling fit-viewport on a 0×0 SVG (because the tab
                // panel starts with d-none) produces a non-finite SVGMatrix
                // scale and crashes with "Failed to execute 'scale' on
                // 'SVGMatrix'". The tab switcher invokes window.__pdLoadBpmn()
                // on first reveal.
                let bpmnInitialized = false;
                window.__pdLoadBpmn = async function () {
                    if (bpmnInitialized) {
                        // Already loaded — just re-fit in case container was resized.
                        try { currentBpmnInstance.get('canvas').zoom('fit-viewport'); } catch (e) {}
                        return;
                    }
                    bpmnInitialized = true;
                    await loadDiagram();
                };
                // If the page already loaded with #bpmn in the URL, the tab
                // was switched before this script ran; load now.
                if ((location.hash || '').replace('#','') === 'bpmn') {
                    window.__pdLoadBpmn();
                }

                // Edit mode controls
                document.getElementById('btnEditDiagram')?.addEventListener('click', enableEditMode);
                document.getElementById('btnSaveDiagram')?.addEventListener('click', saveDiagram);
                document.getElementById('btnCancelEdit')?.addEventListener('click', disableEditMode);

                // Zoom controls
                document.getElementById('btnZoomIn')?.addEventListener('click', () => {
                    const canvas = currentBpmnInstance.get('canvas');
                    canvas.zoom(canvas.zoom() * 1.2);
                });

                document.getElementById('btnZoomOut')?.addEventListener('click', () => {
                    const canvas = currentBpmnInstance.get('canvas');
                    canvas.zoom(canvas.zoom() / 1.2);
                });

                document.getElementById('btnFitView')?.addEventListener('click', () => {
                    const canvas = currentBpmnInstance.get('canvas');
                    canvas.zoom('fit-viewport');
                });

                document.getElementById('btnDownloadSvg')?.addEventListener('click', async () => {
                    try {
                        const { svg } = await currentBpmnInstance.saveSVG();
                        const blob = new Blob([svg], { type: 'image/svg+xml' });
                        const url = URL.createObjectURL(blob);
                        const a = document.createElement('a');
                        a.href = url;
                        a.download = '@(Model.Code)_diagram.svg';
                        a.click();
                        URL.revokeObjectURL(url);
                    } catch (err) {
                        console.error('Error exporting SVG:', err);
                        Swal.fire({
                            icon: 'error',
                            title: '@(isRtl ? "خطأ!" : "Error!")',
                            text: '@Shared["BPMN_ExportError"]',
                            confirmButtonText: '@(isRtl ? "حسناً" : "OK")'
                        });
                    }
                });

                // PNG Export functionality
                document.getElementById('btnDownloadPng')?.addEventListener('click', async () => {
                    try {
                        const { svg } = await currentBpmnInstance.saveSVG();

                        // Create canvas and convert SVG to PNG
                        const canvas = document.createElement('canvas');
                        const ctx = canvas.getContext('2d');
                        const img = new Image();

                        // Create blob URL for SVG
                        const svgBlob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' });
                        const svgUrl = URL.createObjectURL(svgBlob);

                        img.onload = function() {
                            // Scale for better quality
                            const scale = 2;
                            canvas.width = img.width * scale;
                            canvas.height = img.height * scale;

                            // Fill white background
                            ctx.fillStyle = '#ffffff';
                            ctx.fillRect(0, 0, canvas.width, canvas.height);

                            // Draw SVG
                            ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

                            // Convert to PNG and download
                            canvas.toBlob(function(blob) {
                                const url = URL.createObjectURL(blob);
                                const a = document.createElement('a');
                                a.href = url;
                                a.download = '@(Model.Code)_diagram.png';
                                a.click();
                                URL.revokeObjectURL(url);
                            }, 'image/png', 1.0);

                            URL.revokeObjectURL(svgUrl);
                        };

                        img.onerror = function() {
                            console.error('Error loading SVG for PNG conversion');
                            Swal.fire({
                                icon: 'error',
                                title: '@(isRtl ? "خطأ!" : "Error!")',
                                text: '@Shared["BPMN_ExportError"]',
                                confirmButtonText: '@(isRtl ? "حسناً" : "OK")'
                            });
                        };

                        img.src = svgUrl;
                    } catch (err) {
                        console.error('Error exporting PNG:', err);
                        Swal.fire({
                            icon: 'error',
                            title: '@(isRtl ? "خطأ!" : "Error!")',
                            text: '@Shared["BPMN_ExportError"]',
                            confirmButtonText: '@(isRtl ? "حسناً" : "OK")'
                        });
                    }
                });

                // Version History functionality
                let currentVersionId = null;
                let versionViewer = null;

                async function loadVersionHistory() {
                    const loading = document.getElementById('versionHistoryLoading');
                    const empty = document.getElementById('versionHistoryEmpty');
                    const table = document.getElementById('versionHistoryTable');
                    const tbody = document.getElementById('versionHistoryBody');

                    loading.classList.remove('d-none');
                    empty.classList.add('d-none');
                    table.classList.add('d-none');

                    try {
                        const response = await fetch('/Processes/GetBpmnVersions?processId=@Model.Id');
                        const data = await response.json();

                        loading.classList.add('d-none');

                        if (!data.success || !data.versions || data.versions.length === 0) {
                            empty.classList.remove('d-none');
                            return;
                        }

                        tbody.innerHTML = data.versions.map(v => `
                            <tr>
                                <td>
                                    <span class="badge ${v.isCurrent ? 'bg-success' : 'bg-secondary'}">
                                        v${v.versionNumber}
                                        ${v.isCurrent ? ' <i data-lucide="check" style="width:12px;height:12px;"></i>' : ''}
                                    </span>
                                </td>
                                <td>${new Date(v.createdAt).toLocaleString()}</td>
                                <td>${v.createdByName || '-'}</td>
                                <td>${v.changeDescription || '-'}</td>
                                <td>${v.formattedSize}</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" onclick="viewVersion('${v.id}')" title="@Shared["Action_ViewVersion"]">
                                        <i data-lucide="eye" style="width:14px;height:14px;"></i>
                                    </button>
                                    ${!v.isCurrent ? `<button class="btn btn-sm btn-outline-warning" onclick="restoreVersion('${v.id}')" title="@Shared["Action_RestoreVersion"]">
                                        <i data-lucide="rotate-ccw" style="width:14px;height:14px;"></i>
                                    </button>` : ''}
                                </td>
                            </tr>
                        `).join('');

                        table.classList.remove('d-none');
                        lucide.createIcons();
                    } catch (err) {
                        console.error('Error loading version history:', err);
                        loading.classList.add('d-none');
                        empty.classList.remove('d-none');
                    }
                }

                async function viewVersion(versionId) {
                    currentVersionId = versionId;
                    const modal = new bootstrap.Modal(document.getElementById('viewVersionModal'));

                    try {
                        const response = await fetch(`/Processes/GetBpmnVersion?versionId=${versionId}`);
                        const data = await response.json();

                        if (!data.success || !data.version) {
                            Swal.fire({ icon: 'error', title: '@(isRtl ? "خطأ!" : "Error!")', text: '@Shared["Error_NotFound"]' });
                            return;
                        }

                        document.getElementById('viewVersionTitle').textContent = `@Shared["Action_ViewVersion"] - v${data.version.versionNumber}`;
                        document.getElementById('btnRestoreFromModal').style.display = data.version.isCurrent ? 'none' : 'inline-flex';

                        modal.show();

                        // Initialize viewer after modal is shown
                        setTimeout(async () => {
                            const container = document.getElementById('viewVersionCanvas');
                            container.innerHTML = '';

                            if (versionViewer) {
                                versionViewer.destroy();
                            }

                            versionViewer = new BpmnJS({ container: container });
                            await versionViewer.importXML(data.version.bpmnXml);
                            versionViewer.get('canvas').zoom('fit-viewport');
                        }, 300);
                    } catch (err) {
                        console.error('Error viewing version:', err);
                        Swal.fire({ icon: 'error', title: '@(isRtl ? "خطأ!" : "Error!")', text: '@Shared["Error_ProcessingRequest"]' });
                    }
                }

                async function restoreVersion(versionId) {
                    const result = await Swal.fire({
                        title: '@Shared["Confirm_RestoreVersion"]',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#005B99',
                        confirmButtonText: '@Shared["Action_RestoreVersion"]',
                        cancelButtonText: '@Shared["Button_Cancel"]'
                    });

                    if (!result.isConfirmed) return;

                    try {
                        const response = await fetch(`/Processes/RestoreBpmnVersion?versionId=${versionId}`, { method: 'POST' });
                        const data = await response.json();

                        if (data.success) {
                            Swal.fire({ icon: 'success', title: '@Shared["Success_VersionRestored"]', timer: 1500, showConfirmButton: false });
                            bootstrap.Modal.getInstance(document.getElementById('viewVersionModal'))?.hide();
                            location.reload();
                        } else {
                            Swal.fire({ icon: 'error', title: '@(isRtl ? "خطأ!" : "Error!")', text: data.error || '@Shared["Error_ProcessingRequest"]' });
                        }
                    } catch (err) {
                        console.error('Error restoring version:', err);
                        Swal.fire({ icon: 'error', title: '@(isRtl ? "خطأ!" : "Error!")', text: '@Shared["Error_ProcessingRequest"]' });
                    }
                }

                // Event listeners for version history
                document.getElementById('btnRefreshVersions')?.addEventListener('click', loadVersionHistory);
                document.getElementById('btnRestoreFromModal')?.addEventListener('click', () => {
                    if (currentVersionId) restoreVersion(currentVersionId);
                });

                // Load version history on page load
                loadVersionHistory();
            })();
        </script>
    }
}
