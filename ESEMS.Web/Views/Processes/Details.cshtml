@model Process
@inject ESEMS.Web.Services.Integrations.Contracts.IProcessPerformanceProvider PerfProvider
@{
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    ViewData["Title"] = Shared["Title_ProcessDetails"].Value;
    var isMainProcess = (bool)(ViewBag.IsMainProcess ?? false);
    var subProcesses = ViewBag.SubProcesses as List<Process> ?? new List<Process>();

    // Pre-compute collections used across tabs.
    var allRisks = Model.Risks.Where(r => r.IsActive)
        .Select(r => new {
            NameAr = r.NameAr, NameEn = r.NameEn,
            Likelihood = r.LikelihoodScore, Impact = r.ImpactScore,
            Owner = (ESEMS.Web.Models.User?)null
        })
        .Concat(Model.EnterpriseRisks.Where(r => r.IsActive)
            .Select(r => new {
                NameAr = r.NameAr, NameEn = r.NameEn,
                Likelihood = r.Likelihood, Impact = r.Impact,
                Owner = r.Owner
            }))
        .OrderByDescending(r => r.Likelihood * r.Impact)
        .ToList();

    var linkedAssets = (Model.Assets ?? Enumerable.Empty<ESEMS.Web.Models.AssetManagement.Asset>())
        .Where(a => !a.IsDeleted).ToList();

    var linkedDocuments = ViewBag.LinkedDocuments as IEnumerable<ESEMS.Web.Models.DocumentManagement.ProcessDocument>
        ?? Enumerable.Empty<ESEMS.Web.Models.DocumentManagement.ProcessDocument>();
    var linkedDocCount = linkedDocuments.Count();

    var activities = Model.Activities?.Where(a => !a.IsDeleted)
        .OrderBy(a => a.DisplayOrder).ThenBy(a => a.Code).ToList()
        ?? new List<Activity>();

    var totalServices = Model.ProcessServices?.Count(ps => ps.IsActive) ?? 0;
    var totalActivities = isMainProcess ? (int)(ViewBag.TotalActivities ?? 0) : activities.Count;
    var totalTasks = isMainProcess ? (int)(ViewBag.TotalTasks ?? 0) : Model.Activities.Sum(a => a.Tasks.Count);
    var totalRisks = isMainProcess ? (int)(ViewBag.TotalRisks ?? 0) : allRisks.Count;
    var hasBpmnDiagram = !string.IsNullOrWhiteSpace(Model.BpmnDiagram);
}

<div class="esems-container">

@* =====================================================================
   Executive-tabs redesign:
   - Sticky compact header (always-visible identity + KPIs + actions)
   - 5 tabs: Overview / Activities / Linked Items / Risks / BPMN
   - Each tab panel groups existing cards verbatim — DOM IDs preserved
     so all original JS (BPMN viewer, ProcessOptimizer, link-service
     modal, activity accordion, version history) keeps working.
   ===================================================================== *@
<style>
    .pd-stickyhead {
        position: sticky; top: 0; z-index: 30;
        background: #fff;
        border-bottom: 1px solid #e5e7eb;
        margin: 0 -.75rem .85rem;
        padding: .55rem .75rem .35rem;
        box-shadow: 0 1px 0 rgba(15,23,42,.04);
    }
    .pd-titlerow { display: flex; align-items: center; justify-content: space-between; gap: .75rem; flex-wrap: wrap; }
    .pd-titlemain { min-width: 0; flex: 1 1 360px; display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
    .pd-code-pill { display: inline-block; padding: .14rem .55rem; font-size: var(--fs-xs); font-weight: 700; border-radius: .25rem; background: #eff6ff; color: #1d4ed8; font-family: ui-monospace, monospace; letter-spacing: .04em; }
    .pd-title { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; line-height: 1.2; max-width: 480px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .pd-status-pill { display: inline-flex; align-items: center; gap: .25rem; padding: .15rem .55rem; font-size: var(--fs-xs); font-weight: 600; border-radius: .25rem; background: #f1f5f9; color: #475569; }
    .pd-breadcrumb { font-size: var(--fs-xs); color: #6b7280; }
    .pd-actions { display: inline-flex; gap: .35rem; flex-wrap: wrap; }
    .pd-btn { border-radius: .375rem; padding: .35rem .7rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .35rem; cursor: pointer; text-decoration: none; border: 1px solid transparent; line-height: 1.1; }
    .pd-btn-outline { background: #fff; color: #005B99; border-color: #cbd5e1; }
    .pd-btn-outline:hover { background: #f1f5f9; color: #005B99; }
    .pd-btn-ai { background: linear-gradient(135deg,#a855f7,#6366f1); color: #fff; box-shadow: 0 2px 8px rgba(99,102,241,.18); border: none; }
    .pd-btn-ai:hover { color: #fff; opacity: .92; }

    .pd-kpis { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: .45rem; }
    .pd-kpi { display: inline-flex; align-items: center; gap: .35rem; padding: .25rem .55rem; border: 1px solid #e5e7eb; border-radius: .375rem; background: #fafbfc; font-size: var(--fs-xs); color: #475569; }
    .pd-kpi i { color: #005B99; }
    .pd-kpi b { color: #0f172a; font-weight: 700; font-size: var(--fs-xs); }
    .pd-kpi.pd-kpi-on { background: #ecfdf5; border-color: #a7f3d0; color: #047857; }
    .pd-kpi.pd-kpi-on i { color: #059669; }
    .pd-kpi.pd-kpi-off { background: #f8fafc; color: #64748b; }
    .pd-kpi.pd-kpi-off i { color: #94a3b8; }

    .pd-tabnav { display: flex; gap: 0; border-bottom: 1px solid #e5e7eb; margin: 0 -.75rem .9rem; padding: 0 .25rem; overflow-x: auto; scrollbar-width: thin; }
    .pd-tab { display: inline-flex; align-items: center; gap: .4rem; padding: .55rem .85rem; font-size: var(--fs-xs); font-weight: 600; color: #6b7280; background: transparent; border: none; border-bottom: 2px solid transparent; cursor: pointer; white-space: nowrap; transition: color .15s, border-color .15s; }
    .pd-tab:hover { color: #1d4ed8; }
    .pd-tab.active { color: #005B99; border-bottom-color: #005B99; }
    .pd-tab i { width: 14px; height: 14px; }
    .pd-tab .pd-tab-badge { display: inline-block; min-width: 18px; padding: 0 .35rem; font-size: var(--fs-xs); font-weight: 700; line-height: 16px; text-align: center; background: #e2e8f0; color: #334155; border-radius: 8px; }
    .pd-tab.active .pd-tab-badge { background: #005B99; color: #fff; }

    .pd-tabpanel { animation: pdFade .18s ease-out; }
    @@keyframes pdFade { from { opacity: 0; transform: translateY(2px); } to { opacity: 1; transform: none; } }

    /* Compact card overrides for inside tabs */
    .pd-tabpanel .card { border: 1px solid #e5e7eb; }
    .pd-tabpanel .card-header { background: #fff; border-bottom: 1px solid #f1f5f9; padding: .55rem .85rem; }
    .pd-tabpanel .card-body { padding: .85rem; }
    .pd-tabpanel .esems-label { font-size: var(--fs-xs); color: #6b7280; margin-bottom: .15rem; }
    .pd-tabpanel .esems-body { font-size: var(--fs-sm); }

    @@media (max-width: 768px) {
        .pd-title { white-space: normal; max-width: none; }
        .pd-actions { width: 100%; }
        .pd-actions .pd-btn { flex: 1 1 auto; justify-content: center; }
    }
</style>

<!-- ===================== STICKY HEADER ===================== -->
<div class="pd-stickyhead">
    <div class="pd-titlerow">
        <div class="pd-titlemain">
            <span class="pd-code-pill">@Model.Code</span>
            <h1 class="pd-title" title="@Model.Name">@Model.Name</h1>
            <span class="pd-status-pill">
                <i data-lucide="circle" style="width:8px;height:8px;fill:currentColor;"></i>
                @Shared[$"ProcessStatus_{Model.Status}"].Value
            </span>
            <span class="pd-breadcrumb">
                @(isRtl ? "المجموعة" : "Group"): @(isRtl ? Model.ProcessGroup?.NameAr : Model.ProcessGroup?.NameEn)
                • @(isRtl ? "الفئة" : "Category"): @(isRtl ? Model.ProcessGroup?.Category?.NameAr : Model.ProcessGroup?.Category?.NameEn)
            </span>
        </div>
        <div class="pd-actions">
            <a asp-action="Index" class="pd-btn pd-btn-outline">
                <i data-lucide="@(isRtl ? "arrow-right" : "arrow-left")" style="width:14px;height:14px;" aria-hidden="true"></i>
                @(isRtl ? "رجوع" : "Back")
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="pd-btn pd-btn-outline">
                <i data-lucide="edit" style="width:14px;height:14px;" aria-hidden="true"></i>
                @(isRtl ? "تعديل" : "Edit")
            </a>
            @* Prominent header button — KPI badge is also a link, but the
               audit said users couldn't find the RACI editor unless they
               drilled into an activity. A button next to Edit/AI Analysis
               is the unambiguous entry point. *@
            <a asp-action="Raci" asp-route-id="@Model.Id" class="pd-btn pd-btn-outline">
                <i data-lucide="users" style="width:14px;height:14px;" aria-hidden="true"></i>
                @(isRtl ? "مصفوفة RACI" : "RACI Matrix")
            </a>
            <button type="button" class="pd-btn pd-btn-ai"
                    onclick="executeAiAnalysis('/AI/AnalyzeProcess', { processId: '@Model.Id' }, '@(isRtl ? "تحليل العملية" : "Process Analysis")')">
                <i data-lucide="sparkles" style="width:14px;height:14px;" aria-hidden="true"></i>
                @(isRtl ? "تحليل الذكاء الاصطناعي" : "AI Analysis")
            </button>
        </div>
    </div>

    <div class="pd-kpis">
        <span class="pd-kpi"><i data-lucide="layers" style="width:12px;height:12px;"></i> @(isRtl ? "الأنشطة" : "Activities") <b>@totalActivities</b></span>
        <span class="pd-kpi"><i data-lucide="check-square" style="width:12px;height:12px;"></i> @(isRtl ? "المهام" : "Tasks") <b>@totalTasks</b></span>
        @{
            // RACI badge now matches the editor's actual scope:
            // Process-level + every Activity + every Task on this Process.
            var raciCount = isMainProcess
                ? (int)(ViewBag.TotalRaci ?? 0)
                : Model.RaciMatrix.Count
                  + Model.Activities.Sum(a => a.RaciMatrix.Count + a.Tasks.Sum(t => t.RaciMatrix.Count));
        }
        <a asp-action="Raci" asp-route-id="@Model.Id" class="pd-kpi"
           style="text-decoration:none;color:inherit;cursor:pointer;"
           title="@(isRtl ? "إدارة مصفوفة RACI" : "Manage RACI matrix")">
            <i data-lucide="users" style="width:12px;height:12px;"></i> RACI <b>@raciCount</b>
        </a>
        <span class="pd-kpi"><i data-lucide="shield-alert" style="width:12px;height:12px;"></i> @(isRtl ? "المخاطر" : "Risks") <b>@totalRisks</b></span>
        <span class="pd-kpi"><i data-lucide="briefcase" style="width:12px;height:12px;"></i> @(isRtl ? "الخدمات" : "Services") <b>@totalServices</b></span>
        <span class="pd-kpi"><i data-lucide="package" style="width:12px;height:12px;"></i> @(isRtl ? "الأصول" : "Assets") <b>@linkedAssets.Count</b></span>
        <span class="pd-kpi"><i data-lucide="folder-open" style="width:12px;height:12px;"></i> @(isRtl ? "الوثائق" : "Documents") <b>@linkedDocCount</b></span>
        <span class="pd-kpi @(hasBpmnDiagram ? "pd-kpi-on" : "pd-kpi-off")">
            <i data-lucide="git-branch" style="width:12px;height:12px;"></i>
            BPMN <b>@(hasBpmnDiagram ? (isRtl ? "موجود" : "Present") : (isRtl ? "غير موجود" : "Missing"))</b>
        </span>
    </div>
</div>

@* JustCreated banner — preserved from original, sits between header & tabs *@
@if (TempData["ActivityRowsRejected"] is int rejectedRowsCount && rejectedRowsCount > 0)
{
    <div class="alert alert-warning d-flex align-items-start gap-3 mb-3" role="status"
         style="border-left:4px solid #f59e0b;background:#fffbeb;">
        <i data-lucide="alert-triangle" style="width:24px;height:24px;color:#f59e0b;flex-shrink:0;margin-top:2px;"></i>
        <div class="flex-grow-1">
            <div class="fw-semibold mb-1">
                @(isRtl
                    ? $"تم تخطي {rejectedRowsCount} من صفوف الأنشطة"
                    : $"{rejectedRowsCount} activity row(s) were skipped")
            </div>
            <div class="small text-muted">
                @(isRtl
                    ? "يجب أن يكون اسم النشاط (عربي وإنجليزي) 3 أحرف على الأقل. أعد إضافتها من خلال زر \"إضافة نشاط\" أدناه."
                    : "Activity names must be at least 3 characters in both languages. Re-add them via the \"Add Activity\" button below.")
            </div>
        </div>
    </div>
}
@if (TempData["JustCreated"] != null)
{
    <div class="alert alert-success d-flex align-items-start gap-3 mb-3" role="status"
         style="border-left:4px solid #16a34a;background:#f0fdf4;">
        <i data-lucide="check-circle-2" style="width:24px;height:24px;color:#16a34a;flex-shrink:0;margin-top:2px;"></i>
        <div class="flex-grow-1">
            <div class="fw-semibold mb-1">@(isRtl ? "تم إنشاء العملية بنجاح" : "Process created successfully")</div>
            <div class="small text-muted mb-2">@(isRtl ? "الخطوات التالية الموصى بها:" : "Recommended next steps:")</div>
            <div class="d-flex flex-wrap gap-2">
                <a href="~/AI/Diagrams?processId=@Model.Id" class="btn btn-sm btn-primary">
                    <i data-lucide="git-branch" style="width:14px;height:14px;"></i>
                    @(isRtl ? "ارسم مخطط BPMN" : "Draw BPMN Diagram")
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">
                    <i data-lucide="link-2" style="width:14px;height:14px;"></i>
                    @(isRtl ? "اربط الخدمات والمخاطر" : "Link Services & Risks")
                </a>
                <button type="button" onclick="executeAiAnalysis('/AI/AnalyzeProcess', { processId: '@Model.Id' }, '@(isRtl ? "تحليل العملية" : "Process Analysis")')" class="btn btn-sm text-white"
                        style="background:linear-gradient(135deg,#a855f7,#6366f1);border:none;">
                    <i data-lucide="sparkles" style="width:14px;height:14px;"></i>
                    @(isRtl ? "تحليل بالذكاء الاصطناعي" : "Run AI Analysis")
                </button>
            </div>
        </div>
    </div>
}

<!-- ===================== TAB NAVIGATION ===================== -->
<div class="pd-tabnav" role="tablist">
    <button type="button" class="pd-tab active" data-pdtab="overview" onclick="pdShowTab('overview')" role="tab">
        <i data-lucide="file-text"></i> @(isRtl ? "نظرة عامة" : "Overview")
    </button>
    <button type="button" class="pd-tab" data-pdtab="activities" onclick="pdShowTab('activities')" role="tab">
        <i data-lucide="layers"></i> @(isRtl ? "الأنشطة والمهام" : "Activities & Tasks")
        <span class="pd-tab-badge">@totalActivities</span>
    </button>
    <button type="button" class="pd-tab" data-pdtab="linked" onclick="pdShowTab('linked')" role="tab">
        <i data-lucide="link-2"></i> @(isRtl ? "العناصر المرتبطة" : "Linked Items")
        <span class="pd-tab-badge">@(totalServices + linkedAssets.Count + linkedDocCount)</span>
    </button>
    <button type="button" class="pd-tab" data-pdtab="risks" onclick="pdShowTab('risks')" role="tab">
        <i data-lucide="shield-alert"></i> @(isRtl ? "المخاطر" : "Risks")
        <span class="pd-tab-badge">@allRisks.Count</span>
    </button>
    @* Performance tab — only renders when an external performance system is configured.
       The provider's IsEnabled flag is the single source of truth; the tab + panel
       disappear together when the tenant doesn't have the integration. *@
    @if (PerfProvider.IsEnabled)
    {
        <button type="button" class="pd-tab" data-pdtab="performance" onclick="pdShowTab('performance')" role="tab">
            <i data-lucide="gauge"></i> @(isRtl ? "الأداء" : "Performance")
        </button>
    }
    <button type="button" class="pd-tab" data-pdtab="bpmn" onclick="pdShowTab('bpmn')" role="tab">
        <i data-lucide="git-branch"></i> BPMN
    </button>
</div>


<!-- ===================== TAB: OVERVIEW ===================== -->
<section id="pd-tab-overview" class="pd-tabpanel" role="tabpanel">
    <div class="row g-3">
        <!-- Summary Card -->
        <div class="col-xl-8 col-lg-7">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <i data-lucide="file-text" style="width: 18px; height: 18px; color: var(--esems-color-primary);"></i>
                    <span class="esems-card-title">@(isRtl ? "ملخص" : "Summary")</span>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="esems-label">@(isRtl ? "النوع" : "Type")</label>
                            <p class="esems-body fw-medium mb-0">@Model.ProcessType</p>
                        </div>
                        <div class="col-md-6">
                            <label class="esems-label">@(isRtl ? "الوحدة المالكة" : "Owning Unit")</label>
                            <p class="esems-body fw-medium mb-0">@(Model.OwningUnit?.Name ?? "-")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="esems-label">@(isRtl ? "الخدمات المرتبطة" : "Linked Services")</label>
                            <p class="esems-body fw-medium mb-0">@totalServices @(isRtl ? "خدمات" : "services")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="esems-label">@(isRtl ? "الأهداف الاستراتيجية" : "Strategic Objectives")</label>
                            @{
                                var linkedObjectives = (Model.ProcessStrategicObjectives ?? Enumerable.Empty<ESEMS.Web.Models.ServiceManagement.ProcessStrategicObjective>())
                                    .Where(pso => pso.IsActive && pso.StrategicObjective != null)
                                    .Select(pso => pso.StrategicObjective!.Name)
                                    .ToList();
                                if (!linkedObjectives.Any() && Model.StrategicObjective != null)
                                {
                                    linkedObjectives.Add(Model.StrategicObjective.Name);
                                }
                            }
                            @if (linkedObjectives.Any())
                            {
                                <p class="esems-body fw-medium mb-0">@string.Join("، ", linkedObjectives)</p>
                            }
                            else
                            {
                                <p class="esems-body fw-medium mb-0">-</p>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="esems-label">@(isRtl ? "النظام" : "System")</label>
                            <p class="esems-body fw-medium mb-0">@(Model.System?.Name ?? "-")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="esems-label">@(isRtl ? "الوسوم" : "Tags")</label>
                            <p class="esems-body mb-0">@(string.IsNullOrWhiteSpace(Model.Tags) ? "-" : Model.Tags)</p>
                        </div>
                        <div class="col-md-6">
                            <label class="esems-label">@(isRtl ? "المدة التقديرية" : "Estimated Duration")</label>
                            <p class="esems-body mb-0">@(Model.EstimatedDuration.HasValue ? $"{Model.EstimatedDuration} {Model.DurationUnit}" : "-")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="esems-label">@(isRtl ? "التكلفة التقديرية" : "Estimated Cost")</label>
                            <p class="esems-body mb-0">@(Model.EstimatedCost.HasValue ? Model.EstimatedCost.Value.ToString("N2") : "-")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="esems-label">@(isRtl ? "حالة الأتمتة" : "Automation Status")</label>
                            <p class="esems-body fw-medium mb-0">@Model.AutomationStatus</p>
                        </div>
                        <div class="col-md-6">
                            <label class="esems-label">@Shared["Label_HasDetailedBreakdown"]</label>
                            <p class="esems-body fw-medium mb-0">
                                @if (Model.HasDetailedBreakdown)
                                {
                                    <span class="badge badge-success"><i data-lucide="check" style="width:12px;height:12px;"></i> @(isRtl ? "نعم" : "Yes")</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">@(isRtl ? "لا" : "No")</span>
                                }
                            </p>
                        </div>
                    </div>
                    <hr class="my-3" />
                    <div>
                        <label class="esems-label">@(isRtl ? "الوصف" : "Description")</label>
                        <p class="esems-body mb-0">@(Model.Description ?? "-")</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right column: Stats + Top Risks -->
        <div class="col-xl-4 col-lg-5">
            <div class="card mb-3">
                <div class="card-header d-flex align-items-center gap-2">
                    <i data-lucide="bar-chart-2" style="width: 18px; height: 18px; color: var(--esems-color-primary);"></i>
                    <span class="esems-card-title">@(isRtl ? "إحصائيات" : "Stats")</span>
                    @if (isMainProcess)
                    {
                        <span class="badge bg-info text-white ms-auto" style="font-size: var(--fs-xs);">@(isRtl ? "مجمّع" : "Aggregated")</span>
                    }
                </div>
                <div class="card-body py-2">
                    <ul class="list-group list-group-flush">
                        @if (isMainProcess)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                                <span class="esems-body-secondary">@(isRtl ? "العمليات الفرعية" : "Sub-Processes")</span>
                                <span class="esems-body fw-semibold">@subProcesses.Count</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                                <span class="esems-body-secondary">@(isRtl ? "الأنشطة" : "Activities")</span>
                                <span class="esems-body fw-semibold">@(ViewBag.TotalActivities ?? 0)</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                                <span class="esems-body-secondary">@(isRtl ? "المهام" : "Tasks")</span>
                                <span class="esems-body fw-semibold">@(ViewBag.TotalTasks ?? 0)</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                                <a asp-action="Raci" asp-route-id="@Model.Id" class="esems-body-secondary text-decoration-none d-inline-flex align-items-center gap-1"
                                   title="@(isRtl ? "إدارة مصفوفة RACI" : "Manage RACI matrix")">
                                    RACI <i data-lucide="external-link" style="width:10px;height:10px;color:#94a3b8;"></i>
                                </a>
                                <a asp-action="Raci" asp-route-id="@Model.Id" class="esems-body fw-semibold text-decoration-none" style="color:inherit;">@(ViewBag.TotalRaci ?? 0)</a>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                                <span class="esems-body-secondary">@(isRtl ? "المخاطر" : "Risks")</span>
                                <span class="esems-body fw-semibold">@(ViewBag.TotalRisks ?? 0)</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2 border-bottom-0">
                                <span class="esems-body-secondary">@(isRtl ? "المؤشرات" : "Measurements")</span>
                                <span class="esems-body fw-semibold">@(ViewBag.TotalMeasurements ?? 0)</span>
                            </li>
                        }
                        else
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                                <span class="esems-body-secondary">@(isRtl ? "الأنشطة" : "Activities")</span>
                                <span class="esems-body fw-semibold">@Model.Activities.Count</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                                <span class="esems-body-secondary">@(isRtl ? "المهام" : "Tasks")</span>
                                <span class="esems-body fw-semibold">@Model.Activities.Sum(a => a.Tasks.Count)</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                                <a asp-action="Raci" asp-route-id="@Model.Id" class="esems-body-secondary text-decoration-none d-inline-flex align-items-center gap-1"
                                   title="@(isRtl ? "إدارة مصفوفة RACI" : "Manage RACI matrix")">
                                    RACI <i data-lucide="external-link" style="width:10px;height:10px;color:#94a3b8;"></i>
                                </a>
                                <a asp-action="Raci" asp-route-id="@Model.Id" class="esems-body fw-semibold text-decoration-none" style="color:inherit;">@(Model.RaciMatrix.Count + Model.Activities.Sum(a => a.RaciMatrix.Count + a.Tasks.Sum(t => t.RaciMatrix.Count)))</a>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                                <span class="esems-body-secondary">@(isRtl ? "المخاطر" : "Risks")</span>
                                <span class="esems-body fw-semibold">@(Model.Risks.Count + Model.EnterpriseRisks.Count)</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2 border-bottom-0">
                                <span class="esems-body-secondary">@(isRtl ? "المؤشرات" : "Measurements")</span>
                                <span class="esems-body fw-semibold">@Model.Measurements.Count</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Top 5 Risks -->
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <i data-lucide="shield-alert" style="width: 18px; height: 18px; color: var(--esems-color-danger);"></i>
                        <span class="esems-card-title">@(isRtl ? "أعلى المخاطر" : "Top Risks")</span>
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <span class="badge badge-secondary">@allRisks.Count</span>
                        @if (allRisks.Count > 5)
                        {
                            <button type="button" class="btn btn-sm btn-link p-0 text-decoration-none" onclick="pdShowTab('risks')" title="@(isRtl ? "عرض الكل" : "View all")">
                                <i data-lucide="external-link" style="width:14px;height:14px;"></i>
                            </button>
                        }
                    </div>
                </div>
                <div class="card-body py-2">
                    @if (allRisks.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var risk in allRisks.Take(5))
                            {
                                var riskScore = risk.Likelihood * risk.Impact;
                                var levelClass = riskScore switch { >= 15 => "danger", >= 10 => "warning", >= 5 => "info", _ => "success" };
                                var levelLabel = riskScore switch { >= 15 => (isRtl ? "حرج" : "Critical"), >= 10 => (isRtl ? "عالي" : "High"), >= 5 => (isRtl ? "متوسط" : "Medium"), _ => (isRtl ? "منخفض" : "Low") };
                                <div class="list-group-item px-0 py-2">
                                    <div class="d-flex justify-content-between align-items-start mb-1 gap-2">
                                        <span class="esems-body fw-medium" style="font-size: var(--fs-xs);">@(isRtl ? risk.NameAr : risk.NameEn)</span>
                                        <span class="badge badge-@levelClass">@levelLabel</span>
                                    </div>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <small class="esems-caption text-muted">L: @risk.Likelihood</small>
                                        <small class="esems-caption text-muted">I: @risk.Impact</small>
                                        <small class="esems-caption text-muted">@(isRtl ? "نقاط" : "Score"): @riskScore</small>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="esems-body-secondary text-center py-3 mb-0">@(isRtl ? "لا توجد مخاطر" : "No risks identified")</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Process Optimizer Panel -->
    <div class="row g-4 mt-2">
        <div class="col-lg-12">
            <div class="card border-0" style="background: linear-gradient(135deg, rgba(168,85,247,0.05), rgba(99,102,241,0.05)); border: 1px solid rgba(168,85,247,0.12) !important;">
                <div class="card-header d-flex align-items-center justify-content-between gap-2 bg-transparent border-0 pb-0">
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 32px; height: 32px; background: linear-gradient(135deg, #a855f7, #6366f1);">
                            <i data-lucide="cpu" style="width: 16px; height: 16px; color: white;"></i>
                        </div>
                        <span class="esems-card-title">@Shared["ProcessOptimizer_Title"]</span>
                    </div>
                    <button type="button" onclick="runProcessOptimizer('@Model.Id')" class="btn btn-sm text-white" style="background: linear-gradient(135deg, #a855f7, #6366f1); border: none; border-radius: 8px;" id="btnOptimize">
                        <i data-lucide="zap" style="width: 14px; height: 14px;"></i>
                        <span class="@(isRtl ? "me-1" : "ms-1")">@Shared["ProcessOptimizer_Optimize"]</span>
                    </button>
                </div>
                <div class="card-body pt-2" id="optimizerContent" style="display: none;"></div>
            </div>
        </div>
    </div>
</section>


<!-- ===================== TAB: ACTIVITIES & TASKS ===================== -->
<section id="pd-tab-activities" class="pd-tabpanel d-none" role="tabpanel">
    @if (isMainProcess && subProcesses.Any())
    {
        <div class="card mb-3">
            <div class="card-header d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-2">
                    <i data-lucide="git-merge" style="width: 18px; height: 18px; color: var(--esems-color-primary);"></i>
                    <span class="esems-card-title">@(isRtl ? "العمليات الفرعية" : "Sub-Processes")</span>
                    <span class="badge bg-primary">@subProcesses.Count</span>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead style="background: #f8f9fa;">
                            <tr>
                                <th style="width: 90px; color: #005B99 !important; font-weight: 600;">@(isRtl ? "الكود" : "Code")</th>
                                <th style="color: #005B99 !important; font-weight: 600;">@(isRtl ? "الاسم" : "Name")</th>
                                <th style="color: #005B99 !important; font-weight: 600;">@(isRtl ? "الوحدة المالكة" : "Owning Unit")</th>
                                <th class="text-center" style="width: 90px; color: #005B99 !important; font-weight: 600;">@(isRtl ? "الأنشطة" : "Activities")</th>
                                <th class="text-center" style="width: 80px; color: #005B99 !important; font-weight: 600;">@(isRtl ? "المهام" : "Tasks")</th>
                                <th class="text-center" style="width: 80px; color: #005B99 !important; font-weight: 600;">BPMN</th>
                                <th class="text-end" style="width: 90px; color: #005B99 !important; font-weight: 600;">@(isRtl ? "إجراءات" : "Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sp in subProcesses)
                            {
                                var spTaskCount = sp.Activities.Sum(a => a.Tasks.Count);
                                var hasBpmn = sp.Activities.Any(a => a.Tasks.Any(t => !string.IsNullOrWhiteSpace(t.BpmnDiagram)));
                                <tr>
                                    <td><span class="badge bg-secondary">@sp.Code</span></td>
                                    <td>
                                        <div class="fw-medium">@(isRtl ? sp.NameAr : sp.NameEn)</div>
                                        @if (!string.IsNullOrWhiteSpace(isRtl ? sp.NameEn : sp.NameAr))
                                        {
                                            <small class="text-muted">@(isRtl ? sp.NameEn : sp.NameAr)</small>
                                        }
                                    </td>
                                    <td class="text-muted">@(sp.OwningUnit != null ? (isRtl ? sp.OwningUnit.NameAr : sp.OwningUnit.NameEn) : "-")</td>
                                    <td class="text-center"><span class="badge bg-info text-white">@sp.Activities.Count</span></td>
                                    <td class="text-center"><span class="badge bg-warning text-dark">@spTaskCount</span></td>
                                    <td class="text-center">
                                        @if (hasBpmn)
                                        {
                                            <i data-lucide="check-circle" style="width: 16px; height: 16px; color: #22c55e;"></i>
                                        }
                                        else
                                        {
                                            <i data-lucide="minus-circle" style="width: 16px; height: 16px; color: #cbd5e1;"></i>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@sp.Id" class="btn btn-sm btn-outline-primary" title="@(isRtl ? "عرض" : "View")">
                                            <i data-lucide="eye" style="width: 14px; height: 14px;"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Activities & Tasks accordion -->
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <i data-lucide="layers" style="width: 18px; height: 18px; color: var(--esems-color-primary);"></i>
                <span class="esems-card-title">@Shared["Section_ActivitiesAndTasks"]</span>
                <span class="badge bg-primary">@activities.Count</span>
            </div>
            <a asp-controller="Activities" asp-action="Create" asp-route-processId="@Model.Id" class="btn btn-sm btn-primary" title="@Shared["Action_AddActivity"]">
                <i data-lucide="plus" style="width: 14px; height: 14px;"></i>
                @Shared["Action_AddActivity"]
            </a>
        </div>
        <div class="card-body p-0">
            @if (activities.Any())
            {
                @foreach (var activity in activities)
                {
                    var actTasks = activity.Tasks?.Where(t => !t.IsDeleted).OrderBy(t => t.DisplayOrder).ThenBy(t => t.Code).ToList() ?? new List<ProcessTask>();
                    var collapseId = $"collapse_{activity.Id.ToString().Replace("-", "")}";
                    <div class="border-bottom">
                        <div class="d-flex align-items-center justify-content-between p-3 bg-light" style="cursor: pointer;" onclick="toggleActivity(this)">
                            <div class="d-flex align-items-center gap-2 flex-grow-1">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="activity-chevron" style="transition: transform 0.2s;"><polyline points="9 18 15 12 9 6"></polyline></svg>
                                <span class="badge bg-secondary" style="font-size: var(--fs-xs);">@activity.Code</span>
                                <span class="fw-medium">@(isRtl ? activity.NameAr : activity.NameEn)</span>
                                <span class="badge bg-info text-white ms-1" style="font-size: var(--fs-xs);">@activity.ChannelType</span>
                                @if (activity.HasDetailedBreakdown)
                                {
                                    <span class="badge bg-success text-white ms-1" style="font-size: var(--fs-xs);" title="@(isRtl ? "تفصيل مفصّل" : "Has Detailed Breakdown")">
                                        <i data-lucide="check-circle" style="width: 10px; height: 10px;"></i>
                                    </span>
                                }
                                <span class="badge bg-warning text-dark ms-auto" style="font-size: var(--fs-xs);">
                                    @actTasks.Count @(isRtl ? "مهام" : "Tasks")
                                </span>
                            </div>
                        </div>
                        <div class="activity-panel" style="display: none;">
                            <div class="p-3">
                                    <!-- Activity Details Row -->
                                    <div class="d-flex flex-wrap gap-3 mb-3 pb-3 border-bottom">
                                        <div>
                                            <small class="text-muted d-block">@(isRtl ? "المدة" : "Duration")</small>
                                            <span class="esems-body">@(activity.EstimatedDuration.HasValue ? $"{activity.EstimatedDuration} {activity.DurationUnit}" : "-")</span>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block">@(isRtl ? "التكلفة" : "Cost")</small>
                                            <span class="esems-body">@(activity.EstimatedCost.HasValue ? activity.EstimatedCost.Value.ToString("N2") : "-")</span>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block">@(isRtl ? "الوحدة المالكة" : "Owning Unit")</small>
                                            <span class="esems-body">@(activity.OwningUnit != null ? (isRtl ? activity.OwningUnit.NameAr : activity.OwningUnit.NameEn) : "-")</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(activity.Tags))
                                        {
                                            <div>
                                                <small class="text-muted d-block">@(isRtl ? "الوسوم" : "Tags")</small>
                                                <span class="esems-body">@activity.Tags</span>
                                            </div>
                                        }
                                        <div class="ms-auto d-flex gap-1">
                                            <a asp-controller="Activities" asp-action="Edit" asp-route-id="@activity.Id" class="btn btn-sm btn-outline-primary" title="@Shared["Action_Edit"]">
                                                <i data-lucide="edit" style="width: 14px; height: 14px;"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" title="@Shared["Action_Delete"]" onclick="confirmDeleteActivity('@activity.Id', '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode((isRtl ? activity.NameAr : activity.NameEn) ?? ""))')">
                                                <i data-lucide="trash-2" style="width: 14px; height: 14px;"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Tasks Table -->
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <h6 class="mb-0" style="font-size: var(--fs-sm);">
                                            <i data-lucide="check-square" style="width: 14px; height: 14px; color: var(--esems-color-primary);"></i>
                                            @(isRtl ? "المهام" : "Tasks") (@actTasks.Count)
                                        </h6>
                                        <a asp-controller="Tasks" asp-action="Create" asp-route-activityId="@activity.Id" class="btn btn-sm btn-outline-primary" title="@Shared["Action_AddTask"]">
                                            <i data-lucide="plus" style="width: 12px; height: 12px;"></i>
                                            @Shared["Action_AddTask"]
                                        </a>
                                    </div>
                                    @if (actTasks.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-sm table-hover mb-0">
                                                <thead style="background: #f8f9fa;">
                                                    <tr>
                                                        <th style="width: 80px; font-size: var(--fs-xs); color: #005B99 !important; font-weight: 600;">@(isRtl ? "الكود" : "Code")</th>
                                                        <th style="font-size: var(--fs-xs); color: #005B99 !important; font-weight: 600;">@(isRtl ? "الاسم" : "Name")</th>
                                                        <th class="text-center" style="width: 80px; font-size: var(--fs-xs); color: #005B99 !important; font-weight: 600;">@(isRtl ? "القناة" : "Channel")</th>
                                                        <th class="text-center" style="width: 90px; font-size: var(--fs-xs); color: #005B99 !important; font-weight: 600;">@(isRtl ? "الحالة" : "Status")</th>
                                                        <th class="text-center" style="width: 90px; font-size: var(--fs-xs); color: #005B99 !important; font-weight: 600;">@(isRtl ? "الأتمتة" : "Automation")</th>
                                                        <th class="text-end" style="width: 80px; font-size: var(--fs-xs); color: #005B99 !important; font-weight: 600;">@(isRtl ? "إجراءات" : "Actions")</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var task in actTasks)
                                                    {
                                                        <tr>
                                                            <td><span class="badge bg-secondary" style="font-size: var(--fs-xs);">@task.Code</span></td>
                                                            <td>
                                                                <div class="fw-medium" style="font-size: var(--fs-sm);">@(isRtl ? task.NameAr : task.NameEn)</div>
                                                                @if (!string.IsNullOrWhiteSpace(isRtl ? task.NameEn : task.NameAr))
                                                                {
                                                                    <small class="text-muted" style="font-size: var(--fs-xs);">@(isRtl ? task.NameEn : task.NameAr)</small>
                                                                }
                                                            </td>
                                                            <td class="text-center"><span class="badge bg-info text-white" style="font-size: var(--fs-xs);">@task.ChannelType</span></td>
                                                            <td class="text-center"><span class="badge bg-secondary" style="font-size: var(--fs-xs);">@task.ProcedureStatus</span></td>
                                                            <td class="text-center"><span class="badge bg-secondary" style="font-size: var(--fs-xs);">@task.AutomationStatus</span></td>
                                                            <td class="text-end">
                                                                <a asp-controller="Tasks" asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-outline-primary p-1" title="@Shared["Action_Edit"]">
                                                                    <i data-lucide="edit" style="width: 12px; height: 12px;"></i>
                                                                </a>
                                                                <button type="button" class="btn btn-sm btn-outline-danger p-1" title="@Shared["Action_Delete"]" onclick="confirmDeleteTask('@task.Id', '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode((isRtl ? task.NameAr : task.NameEn) ?? ""))')">
                                                                    <i data-lucide="trash-2" style="width: 12px; height: 12px;"></i>
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted text-center py-2 mb-0" style="font-size: var(--fs-sm);">@Shared["Text_NoTasks"]</p>
                                    }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-4">
                    <i data-lucide="layers" style="width: 40px; height: 40px; color: #cbd5e1;"></i>
                    <p class="text-muted mt-2 mb-0">@Shared["Text_NoActivities"]</p>
                </div>
            }
        </div>
    </div>
</section>


<!-- ===================== TAB: LINKED ITEMS ===================== -->
<section id="pd-tab-linked" class="pd-tabpanel d-none" role="tabpanel">
    <!-- Linked Services -->
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2">
                <i data-lucide="briefcase" style="width: 18px; height: 18px; color: var(--esems-color-primary);"></i>
                <span class="esems-card-title">@(isRtl ? "الخدمات المرتبطة" : "Linked Services")</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge badge-secondary">@totalServices</span>
                @if (User.HasClaim("Permission", "CanEdit"))
                {
                    <button onclick="openLinkServiceModal()" class="btn btn-sm btn-primary" title="@(isRtl ? "ربط خدمة" : "Link Service")">
                        <i data-lucide="plus" style="width: 14px; height: 14px;"></i>
                    </button>
                }
            </div>
        </div>
        <div class="card-body">
            @if (Model.ProcessServices != null && Model.ProcessServices.Any(ps => ps.IsActive))
            {
                <div class="list-group list-group-flush">
                    @foreach (var ps in Model.ProcessServices.Where(ps => ps.IsActive).OrderBy(ps => ps.Criticality))
                    {
                        var svc = ps.Service;
                        if (svc != null)
                        {
                            var critClass = ps.Criticality switch { 1 => "danger", 2 => "warning", 3 => "info", _ => "secondary" };
                            var critLabel = ps.Criticality switch { 1 => (isRtl ? "حرج" : "Critical"), 2 => (isRtl ? "عالي" : "High"), 3 => (isRtl ? "متوسط" : "Medium"), _ => (isRtl ? "منخفض" : "Low") };
                            <div class="list-group-item px-0">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <a asp-controller="Services" asp-action="Details" asp-route-id="@svc.Id" class="flex-grow-1 text-decoration-none">
                                        <div class="d-flex justify-content-between align-items-start mb-1">
                                            <span class="esems-body fw-medium">@svc.Code</span>
                                            <div class="d-flex gap-1">
                                                <span class="badge badge-@critClass">@critLabel</span>
                                                @if (ps.IsMandatory)
                                                {
                                                    <span class="badge badge-danger">@(isRtl ? "إلزامي" : "Mandatory")</span>
                                                }
                                            </div>
                                        </div>
                                        <small class="esems-caption text-muted d-block">@svc.Name</small>
                                        @if (!string.IsNullOrEmpty(ps.Notes))
                                        {
                                            <small class="esems-caption text-muted d-block mt-1">
                                                <i data-lucide="file-text" style="width: 12px; height: 12px;"></i> @ps.Notes
                                            </small>
                                        }
                                    </a>
                                    @if (User.HasClaim("Permission", "CanEdit"))
                                    {
                                        <div class="d-flex gap-1">
                                            <button onclick="editProcessService('@Model.Id', '@svc.Id', @ps.Criticality, @ps.IsMandatory.ToString().ToLower(), '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(ps.Notes ?? ""))')" class="btn btn-sm btn-link text-primary p-0" title="Edit">
                                                <i data-lucide="edit-2" style="width: 14px; height: 14px;"></i>
                                            </button>
                                            <button onclick="unlinkService('@Model.Id', '@svc.Id')" class="btn btn-sm btn-link text-danger p-0" title="Unlink">
                                                <i data-lucide="trash-2" style="width: 14px; height: 14px;"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <p class="esems-body-secondary text-center py-3 mb-0">@(isRtl ? "لا توجد خدمات مرتبطة" : "No linked services")</p>
            }
        </div>
    </div>

    <!-- Linked Assets -->
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2">
                <i data-lucide="package" style="width: 18px; height: 18px; color: var(--esems-color-primary);"></i>
                <span class="esems-card-title">@(isRtl ? "الأصول المرتبطة" : "Linked Assets")</span>
            </div>
            <span class="badge badge-secondary">@linkedAssets.Count</span>
        </div>
        <div class="card-body">
            @if (linkedAssets.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:140px;">@(isRtl ? "رمز الأصل" : "Asset Tag")</th>
                                <th>@(isRtl ? "الاسم" : "Name")</th>
                                <th class="text-end" style="width:56px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var asset in linkedAssets.OrderBy(a => a.AssetTag))
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@asset.AssetTag</span></td>
                                    <td class="esems-body fw-medium">@(isRtl ? asset.NameAr : asset.NameEn)</td>
                                    <td class="text-end">
                                        <a asp-controller="Assets" asp-action="Details" asp-route-id="@asset.Id" class="btn btn-sm btn-link text-primary p-0" title="@(isRtl ? "عرض" : "View")">
                                            <i data-lucide="eye" style="width:16px;height:16px;"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="esems-body-secondary text-center py-3 mb-0">@(isRtl ? "لا توجد أصول مرتبطة" : "No linked assets")</p>
            }
        </div>
    </div>

    <!-- Linked Documents -->
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2">
                <i data-lucide="folder-open" style="width: 18px; height: 18px; color: var(--esems-color-primary);"></i>
                <span class="esems-card-title">@(isRtl ? "الوثائق المرتبطة" : "Linked Documents")</span>
            </div>
            <span class="badge badge-secondary">@linkedDocCount</span>
        </div>
        <div class="card-body">
            @if (linkedDocCount == 0)
            {
                <p class="esems-body-secondary text-center py-3 mb-0">@(isRtl ? "لا توجد وثائق مرتبطة" : "No linked documents")</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@(isRtl ? "الملف" : "File")</th>
                                <th>@(isRtl ? "فئة الوثيقة" : "Document Category")</th>
                                <th>@(isRtl ? "نوع الوثيقة" : "Document Type")</th>
                                <th>@(isRtl ? "اللغة" : "Language")</th>
                                <th class="text-end" style="width:56px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pd in linkedDocuments)
                            {
                                var doc = pd.UserDocument;
                                var fileName = doc?.OriginalName ?? "(file)";
                                var fileSize = doc?.FileSize ?? 0;
                                var downloadUrl = doc != null ? $"/api/MySpace/{doc.Id}/download" : "#";
                                var sizeText = fileSize >= 1024 * 1024
                                    ? $"{fileSize / 1024.0 / 1024.0:F1} MB"
                                    : $"{fileSize / 1024.0:F1} KB";
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <i data-lucide="file-text" style="width:16px;height:16px;color:var(--esems-color-primary);"></i>
                                            <div>
                                                <div class="esems-body fw-medium">@fileName</div>
                                                <small class="esems-caption text-muted">@sizeText</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (pd.DocumentCategory != null)
                                        {
                                            @(isRtl ? pd.DocumentCategory.NameAr : pd.DocumentCategory.NameEn)
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (pd.DocumentType != null)
                                        {
                                            @(isRtl ? pd.DocumentType.NameAr : pd.DocumentType.NameEn)
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(pd.DocumentLanguage))
                                        {
                                            @pd.DocumentLanguage
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a href="@downloadUrl" class="btn btn-sm btn-link text-primary p-0" title="@(isRtl ? "تنزيل" : "Download")">
                                            <i data-lucide="download" style="width:16px;height:16px;"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>


<!-- ===================== TAB: RISKS (full list) ===================== -->
<section id="pd-tab-risks" class="pd-tabpanel d-none" role="tabpanel">
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between gap-2">
            <div class="d-flex align-items-center gap-2">
                <i data-lucide="shield-alert" style="width: 18px; height: 18px; color: var(--esems-color-danger);"></i>
                <span class="esems-card-title">@(isRtl ? "جميع المخاطر" : "All Risks")</span>
            </div>
            <span class="badge badge-secondary">@allRisks.Count</span>
        </div>
        <div class="card-body">
            @if (allRisks.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@(isRtl ? "الاسم" : "Name")</th>
                                <th class="text-center" style="width:90px;">@(isRtl ? "الاحتمالية" : "Likelihood")</th>
                                <th class="text-center" style="width:90px;">@(isRtl ? "التأثير" : "Impact")</th>
                                <th class="text-center" style="width:80px;">@(isRtl ? "النقاط" : "Score")</th>
                                <th class="text-center" style="width:110px;">@(isRtl ? "المستوى" : "Level")</th>
                                <th>@(isRtl ? "المالك" : "Owner")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var risk in allRisks)
                            {
                                var riskScore = risk.Likelihood * risk.Impact;
                                var levelClass = riskScore switch { >= 15 => "danger", >= 10 => "warning", >= 5 => "info", _ => "success" };
                                var levelLabel = riskScore switch { >= 15 => (isRtl ? "حرج" : "Critical"), >= 10 => (isRtl ? "عالي" : "High"), >= 5 => (isRtl ? "متوسط" : "Medium"), _ => (isRtl ? "منخفض" : "Low") };
                                <tr>
                                    <td class="esems-body fw-medium">@(isRtl ? risk.NameAr : risk.NameEn)</td>
                                    <td class="text-center">@risk.Likelihood</td>
                                    <td class="text-center">@risk.Impact</td>
                                    <td class="text-center fw-semibold">@riskScore</td>
                                    <td class="text-center"><span class="badge badge-@levelClass">@levelLabel</span></td>
                                    <td>
                                        @if (risk.Owner != null)
                                        {
                                            <small class="text-muted">
                                                <i data-lucide="user" style="width:12px;height:12px;"></i>
                                                @risk.Owner.GetLocalizedFullName()
                                            </small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="esems-body-secondary text-center py-3 mb-0">@(isRtl ? "لا توجد مخاطر" : "No risks identified")</p>
            }
        </div>
    </div>
    @* External-system risks — appended below the local risks table. Renders nothing when
       no external risk system is configured for this tenant. *@
    <div class="mt-3">
        @await Html.PartialAsync("Integrations/_LinkedRisks", new LinkedPanelArgs {
            EntityType = LinkedEntityType.Process,
            EntityId   = Model.Id,
            AnchorId   = "linked-risks-process"
        })
    </div>
</section>


