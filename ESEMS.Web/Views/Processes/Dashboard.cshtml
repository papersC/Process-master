@model IEnumerable<ESEMS.Web.Models.APQC.Process>
@inject IStringLocalizer<SharedResource> Shared

@{
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    ViewData["Title"] = Shared["Title_ProcessOverview"].Value;

    int total = ViewBag.TotalProcesses ?? 0;
    int active = ViewBag.ActiveProcesses ?? 0;
    int draft = ViewBag.DraftProcesses ?? 0;
    int underImprovement = ViewBag.UnderImprovementProcesses ?? 0;
    int archived = Math.Max(0, total - active - draft - underImprovement);
    int categories = ViewBag.TotalCategories ?? 0;
    int groups = ViewBag.TotalProcessGroups ?? 0;
}

@*
    Single-screen executive dashboard for the Process module.
    Mirrors the archetype used by the main /Dashboard redesign:
      * sticky compact header with action buttons
      * single-row KPI strip (6 tiles)
      * status-distribution doughnut on the left, recent-processes
        scrollable table on the right
    Drop-in with the controller — same @model + same ViewBag bag.
*@

<style>
    .pd-shell { display: flex; flex-direction: column; gap: .6rem; height: calc(100vh - 140px); min-height: 580px; }
    .pd-header { display: flex; align-items: center; justify-content: space-between; padding: .25rem 0 .4rem; border-bottom: 1px solid #e5e7eb; flex: 0 0 auto; }
    .pd-header h1 { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .5rem; }
    .pd-header p { margin: 0; font-size: var(--fs-xs); color: #6b7280; }
    .pd-header-actions { display: flex; gap: .4rem; }
    .pd-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; transition: background .15s, color .15s; }
    .pd-btn-primary { background: #005B99; color: #fff; border: none; }
    .pd-btn-primary:hover { background: #003d6b; color: #fff; }
    .pd-btn-outline { background: #fff; color: #005B99; border: 1px solid #cbd5e1; }
    .pd-btn-outline:hover { background: #f1f5f9; border-color: #005B99; color: #005B99; }

    .pd-kpi-grid { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: .5rem; flex: 0 0 auto; }
    @@media (max-width: 1280px) { .pd-kpi-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .pd-kpi { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .65rem .85rem; display: flex; align-items: center; gap: .65rem; transition: box-shadow .15s; }
    .pd-kpi:hover { box-shadow: 0 4px 12px rgba(0, 91, 153, .08); }
    .pd-kpi-bar { width: 4px; align-self: stretch; border-radius: 2px; flex-shrink: 0; }
    .pd-kpi-meta { flex: 1; min-width: 0; }
    .pd-kpi-label { font-size: var(--fs-xs); color: #6b7280; line-height: 1.2; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .pd-kpi-value { font-size: var(--fs-lg); font-weight: 700; color: #111827; line-height: 1.2; margin: 0; }

    .pd-main { display: grid; grid-template-columns: 1.1fr 1.4fr; gap: .6rem; flex: 1 1 0; min-height: 0; }
    @@media (max-width: 1024px) { .pd-main { grid-template-columns: 1fr; } }
    .pd-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; display: flex; flex-direction: column; min-height: 0; overflow: hidden; }
    .pd-card-head { display: flex; align-items: center; justify-content: space-between; gap: .5rem; padding: .5rem .85rem; border-bottom: 1px solid #f1f5f9; flex: 0 0 auto; }
    .pd-card-head h6 { margin: 0; font-size: var(--fs-sm); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .4rem; }
    .pd-card-body { flex: 1 1 0; min-height: 0; padding: .65rem .85rem .85rem; position: relative; }
    /* Doughnut card gets a bigger inner box so the chart doesn't touch the
       card edges. The canvas also caps at a reasonable max so on tall
       viewports the doughnut doesn't balloon. */
    .pd-chart-wrap { position: relative; height: 100%; max-width: 460px; max-height: 420px; margin: 0 auto; padding: 1rem .5rem .25rem; box-sizing: border-box; }
    .pd-chart-center { position: absolute; inset: 1rem .5rem .25rem; display: flex; flex-direction: column; align-items: center; justify-content: center; pointer-events: none; padding-bottom: 2.5rem; }
    .pd-chart-center .pd-chart-total { font-size: var(--fs-2xl); font-weight: 700; color: #111827; line-height: 1; }
    .pd-chart-center .pd-chart-label { font-size: var(--fs-xs); color: #6b7280; margin-top: .2rem; text-transform: uppercase; letter-spacing: .04em; }

    .pd-table-wrap { flex: 1 1 0; min-height: 0; overflow: auto; }
    .pd-table-wrap table { width: 100%; font-size: var(--fs-xs); border-collapse: collapse; }
    .pd-table-wrap thead { position: sticky; top: 0; background: #f8fafc; z-index: 1; }
    .pd-table-wrap th { font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: .04em; color: #6b7280; font-weight: 600; padding: .55rem .8rem; text-align: start; border-bottom: 1px solid #e5e7eb; white-space: nowrap; }
    .pd-table-wrap td { padding: .5rem .8rem; border-bottom: 1px solid #f3f4f6; color: #374151; }
    .pd-table-wrap tbody tr:hover td { background: #f9fafb; }
    .pd-status { display: inline-block; padding: .15rem .5rem; font-size: var(--fs-xs); font-weight: 600; border-radius: .25rem; }
    .pd-status-active { background: #ecfdf5; color: #047857; }
    .pd-status-draft { background: #fef3c7; color: #92400e; }
    .pd-status-improving { background: #eff6ff; color: #1d4ed8; }
    .pd-status-archived { background: #f1f5f9; color: #475569; }
    .pd-empty { padding: 2rem; text-align: center; color: #94a3b8; font-size: var(--fs-sm); }
</style>

<div class="pd-shell">

    @* ─────────── Sticky compact header ─────────── *@
    <div class="pd-header">
        <div>
            <h1>
                <i data-lucide="layout-dashboard" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>
                @Shared["Title_ProcessOverview"]
            </h1>
            <p>@Shared["Text_AnalyticsInsights"]</p>
        </div>
        <div class="pd-header-actions">
            <a asp-action="Index" class="pd-btn pd-btn-outline">
                <i data-lucide="list" class="w-4 h-4" aria-hidden="true"></i>
                @Shared["Button_ViewAllProcesses"]
            </a>
            <a asp-action="Create" class="pd-btn pd-btn-primary">
                <i data-lucide="plus" class="w-4 h-4" aria-hidden="true"></i>
                @Shared["Action_AddProcess"]
            </a>
        </div>
    </div>

    @* ─────────── KPI strip — 6 tiles in one row ─────────── *@
    <div class="pd-kpi-grid">
        <div class="pd-kpi"><span class="pd-kpi-bar" style="background:#005B99;"></span>
            <div class="pd-kpi-meta"><p class="pd-kpi-label">@Shared["Label_TotalProcesses"]</p><p class="pd-kpi-value">@total</p></div>
        </div>
        <div class="pd-kpi"><span class="pd-kpi-bar" style="background:#34C38F;"></span>
            <div class="pd-kpi-meta"><p class="pd-kpi-label">@Shared["Label_ActiveProcesses"]</p><p class="pd-kpi-value">@active</p></div>
        </div>
        <div class="pd-kpi"><span class="pd-kpi-bar" style="background:#F1B44C;"></span>
            <div class="pd-kpi-meta"><p class="pd-kpi-label">@Shared["Label_DraftProcesses"]</p><p class="pd-kpi-value">@draft</p></div>
        </div>
        <div class="pd-kpi"><span class="pd-kpi-bar" style="background:#8b5cf6;"></span>
            <div class="pd-kpi-meta"><p class="pd-kpi-label">@Shared["Label_UnderImprovement"]</p><p class="pd-kpi-value">@underImprovement</p></div>
        </div>
        <div class="pd-kpi"><span class="pd-kpi-bar" style="background:#6366f1;"></span>
            <div class="pd-kpi-meta"><p class="pd-kpi-label">@Shared["Label_ProcessCategories"]</p><p class="pd-kpi-value">@categories</p></div>
        </div>
        <div class="pd-kpi"><span class="pd-kpi-bar" style="background:#06b6d4;"></span>
            <div class="pd-kpi-meta"><p class="pd-kpi-label">@Shared["Label_ProcessGroups"]</p><p class="pd-kpi-value">@groups</p></div>
        </div>
    </div>

    @* ─────────── Two-column main: chart + recent table ─────────── *@
    <div class="pd-main">

        @* Status distribution doughnut *@
        <div class="pd-card">
            <div class="pd-card-head">
                <h6><i data-lucide="pie-chart" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@Shared["Dashboard_ProcessesByStatus"]</h6>
            </div>
            <div class="pd-card-body">
                <div class="pd-chart-wrap">
                    <canvas id="pdStatusChart"></canvas>
                    <div class="pd-chart-center">
                        <span class="pd-chart-total">@total</span>
                        <span class="pd-chart-label">@Shared["Label_TotalProcesses"]</span>
                    </div>
                </div>
            </div>
        </div>

        @* Recent processes scrollable table *@
        <div class="pd-card">
            <div class="pd-card-head">
                <h6><i data-lucide="clock" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "العمليات الحديثة" : "Recent Processes")</h6>
                <a asp-action="Index" style="font-size: var(--fs-xs);color:#005B99;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.25rem;">
                    @Shared["Action_ViewAll"]
                    <i data-lucide="@(isRtl ? "arrow-left" : "arrow-right")" class="w-3 h-3" aria-hidden="true"></i>
                </a>
            </div>
            <div class="pd-card-body" style="padding:0;">
                <div class="pd-table-wrap">
                    @if (Model.Any())
                    {
                        <table>
                            <thead>
                                <tr>
                                    <th>@Shared["Column_Code"]</th>
                                    <th>@Shared["Column_Name"]</th>
                                    <th>@Shared["Column_ProcessGroup"]</th>
                                    <th>@Shared["Column_Status"]</th>
                                    <th>@Shared["Column_LastUpdated"]</th>
                                    <th style="text-align:end;width:60px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var process in Model)
                                {
                                    var statusClass = process.Status switch
                                    {
                                        ESEMS.Web.Models.Enums.ProcessStatus.Active           => "pd-status-active",
                                        ESEMS.Web.Models.Enums.ProcessStatus.Draft            => "pd-status-draft",
                                        ESEMS.Web.Models.Enums.ProcessStatus.UnderImprovement => "pd-status-improving",
                                        _                                                      => "pd-status-archived"
                                    };
                                    <tr>
                                        <td><code style="font-size: var(--fs-xs);color:#475569;">@process.Code</code></td>
                                        <td><span style="font-weight:500;color:#111827;">@(isRtl ? process.NameAr : process.NameEn)</span></td>
                                        <td>@(process.ProcessGroup != null ? (isRtl ? process.ProcessGroup.NameAr : process.ProcessGroup.NameEn) : "—")</td>
                                        <td><span class="pd-status @statusClass">@Shared[$"ProcessStatus_{process.Status}"]</span></td>
                                        <td><span style="color:#6b7280;">@process.UpdatedAt.ToDubaiString("MMM dd, yyyy")</span></td>
                                        <td style="text-align:end;">
                                            <a asp-action="Details" asp-route-id="@process.Id"
                                               aria-label="@Shared["Button_View"]"
                                               style="color:#005B99;text-decoration:none;display:inline-flex;align-items:center;gap:.2rem;font-weight:600;">
                                                <i data-lucide="eye" class="w-3.5 h-3.5" aria-hidden="true"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="pd-empty">
                            <i data-lucide="inbox" class="w-8 h-8" aria-hidden="true" style="margin:0 auto .5rem;display:block;color:#cbd5e1;"></i>
                            @(isRtl ? "لا توجد عمليات حديثة" : "No recent processes")
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();

        // Status distribution doughnut. Computed in Razor; rendered with the
        // shared brand palette so it visually matches the main Dashboard.
        const isRtl = @(isRtl ? "true" : "false");
        Chart.defaults.font.family = "'Segoe UI', 'Roboto', sans-serif";
        if (isRtl) {
            Chart.defaults.plugins.legend.rtl = true;
            Chart.defaults.plugins.legend.textDirection = 'rtl';
            Chart.defaults.plugins.tooltip.rtl = true;
            Chart.defaults.plugins.tooltip.textDirection = 'rtl';
        }

        new Chart(document.getElementById('pdStatusChart'), {
            type: 'doughnut',
            data: {
                labels: [
                    @Html.Raw("'" + Shared["ProcessStatus_Active"].Value + "'") + ' (' + @active + ')',
                    @Html.Raw("'" + Shared["ProcessStatus_Draft"].Value + "'") + ' (' + @draft + ')',
                    @Html.Raw("'" + Shared["ProcessStatus_UnderImprovement"].Value + "'") + ' (' + @underImprovement + ')',
                    @Html.Raw("'" + Shared["ProcessStatus_Archived"].Value + "'") + ' (' + @archived + ')'
                ],
                datasets: [{
                    data: [@active, @draft, @underImprovement, @archived],
                    backgroundColor: ['#34C38F', '#F1B44C', '#8b5cf6', '#94a3b8'],
                    hoverBackgroundColor: ['#5dd9a8', '#f4c56d', '#a78bfa', '#cbd5e1'],
                    borderWidth: 3,
                    borderColor: '#fff',
                    hoverBorderWidth: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '68%',
                plugins: {
                    legend: { position: 'bottom', labels: { padding: 14, usePointStyle: true, font: { size: 12, weight: '500' } } },
                    tooltip: {
                        backgroundColor: 'rgba(0,0,0,.85)',
                        padding: 10,
                        titleFont: { size: 13, weight: 'bold' },
                        bodyFont: { size: 12 },
                        callbacks: {
                            label: function (c) {
                                var t = c.dataset.data.reduce((a, b) => a + b, 0);
                                var pct = t > 0 ? ((c.parsed / t) * 100).toFixed(1) : '0';
                                return c.label.replace(/\s\(\d+\)$/, '') + ': ' + c.parsed + ' (' + pct + '%)';
                            }
                        }
                    }
                }
            }
        });
    </script>
}
