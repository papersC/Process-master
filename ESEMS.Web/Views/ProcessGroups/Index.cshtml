@model IEnumerable<ProcessGroup>
@{
    ViewData["Title"] = Shared["Title_ProcessGroups"].Value;
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    var selectedCategoryId = ViewBag.SelectedCategoryId as string;
}

@*  Report-style index — same shape as /Processes Index (and /Categories).
    Inline header (no _ModuleBanner), separate toolbar, table card fills
    remaining viewport. Same .lt-* class names so APQC tiers L1/L2/L3
    look identical. JS hooks preserved verbatim:
      #searchInput, #searchClearBtn, #filterCategory, #resultCount,
      clearFilters(), .btn-delete-processgroup, #deleteForm. *@

<style>
    .lt-shell { display: flex; flex-direction: column; gap: .6rem; height: calc(100vh - 140px); min-height: 580px; }
    .lt-header { display: flex; align-items: center; justify-content: space-between; padding: .25rem 0 .4rem; border-bottom: 1px solid #e5e7eb; flex: 0 0 auto; }
    .lt-header h1 { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .5rem; }
    .lt-header p { margin: 0; font-size: var(--fs-xs); color: #6b7280; }
    .lt-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; }
    .lt-btn-primary { background: #005B99; color: #fff; border: none; } .lt-btn-primary:hover { background: #003d6b; color: #fff; }
    .lt-btn-outline { background: #fff; color: #005B99; border: 1px solid #cbd5e1; } .lt-btn-outline:hover { background: #f1f5f9; }
    .lt-toolbar { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .5rem .75rem; display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; flex: 0 0 auto; }
    .lt-search { flex: 1 1 220px; max-width: 320px; position: relative; }
    .lt-search input { width: 100%; padding: .42rem .7rem; padding-inline-start: 2.1rem; padding-inline-end: 2.2rem; border: 1px solid #d1d5db; border-radius: .375rem; font-size: var(--fs-sm); }
    .lt-search input:focus { outline: none; border-color: #005B99; box-shadow: 0 0 0 3px rgba(0,91,153,.12); }
    .lt-search .lt-search-icon { position: absolute; top: 50%; transform: translateY(-50%); inset-inline-start: .65rem; color: #9ca3af; pointer-events: none; }
    .lt-search .lt-search-clear { position: absolute; top: 50%; transform: translateY(-50%); inset-inline-end: .55rem; width: 22px; height: 22px; border-radius: 50%; border: none; background: transparent; color: #9ca3af; display: flex; align-items: center; justify-content: center; cursor: pointer; }
    .lt-search .lt-search-clear:hover { background: #f1f5f9; color: #475569; }
    .lt-toolbar select { padding: .38rem .55rem; border: 1px solid #d1d5db; border-radius: .375rem; font-size: var(--fs-xs); background: #fff; min-width: 140px; }
    .lt-result-count { font-size: var(--fs-xs); color: #475569; background: #f1f5f9; padding: .25rem .55rem; border-radius: .25rem; font-weight: 600; white-space: nowrap; }
    .lt-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; flex: 1 1 0; min-height: 0; display: flex; flex-direction: column; overflow: hidden; }
    .lt-table-wrap { flex: 1 1 0; min-height: 0; overflow: auto; }
    .lt-table-wrap table { width: 100%; font-size: var(--fs-sm); border-collapse: collapse; }
    .lt-table-wrap thead { position: sticky; top: 0; background: #f8fafc; z-index: 1; }
    .lt-table-wrap th { font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: .04em; color: #6b7280; font-weight: 600; padding: .55rem .75rem; text-align: start; border-bottom: 1px solid #e5e7eb; white-space: nowrap; }
    .lt-table-wrap td { padding: .5rem .75rem; border-bottom: 1px solid #f3f4f6; color: #374151; }
    .lt-table-wrap tbody tr:hover td { background: #f9fafb; }
    .lt-pill { display: inline-block; padding: .15rem .5rem; font-size: var(--fs-xs); font-weight: 600; border-radius: .25rem; }
    .lt-pill-procs { background: #eff6ff; color: #1d4ed8; }
    .lt-actions { display: inline-flex; gap: .35rem; }
    .lt-actions a, .lt-actions button { color: #005B99; padding: .2rem; border-radius: .25rem; transition: background .15s; background: transparent; border: none; cursor: pointer; }
    .lt-actions a:hover, .lt-actions button:hover { background: #eff6ff; }
    .lt-actions .lt-action-danger { color: #dc2626; }
    .lt-actions .lt-action-danger:hover { background: #fef2f2; }
</style>

<div class="lt-shell">
    <div class="lt-header">
        <div>
            <h1><i data-lucide="layers" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>@Shared["Heading_ProcessGroups"]</h1>
            <p>@Shared["Text_ManageAPQCProcessGroups_Level2"]</p>
        </div>
        <div style="display:flex;gap:.4rem;">
            <a asp-controller="Categories" asp-action="Index" class="lt-btn lt-btn-outline"><i data-lucide="folder-tree" class="w-4 h-4" aria-hidden="true"></i>@(isRtl ? "التصنيفات" : "Categories")</a>
            <a asp-action="Create" class="lt-btn lt-btn-primary"><i data-lucide="plus" class="w-4 h-4" aria-hidden="true"></i>@Shared["Action_AddGroup"]</a>
        </div>
    </div>

    <div class="lt-toolbar">
        <div class="lt-search">
            <i data-lucide="search" class="lt-search-icon w-4 h-4" aria-hidden="true"></i>
            <input type="text" id="searchInput" placeholder="@Shared["Placeholder_SearchProcessGroups"]" autocomplete="off" aria-label="@Shared["Placeholder_SearchProcessGroups"]" />
            <button type="button" id="searchClearBtn" class="lt-search-clear hidden" aria-label="@Shared["Button_Clear"]">
                <i data-lucide="x" class="w-3.5 h-3.5" aria-hidden="true"></i>
            </button>
        </div>
        <select id="filterCategory" aria-label="@Shared["Filter_Category"]">
            <option value="">@Shared["Filter_Category"]: @Shared["Filter_All"]</option>
            @foreach (var c in categories.OrderBy(c => c.SortKey ?? c.Code))
            {
                <option value="@c.Id" selected="@(c.Id == selectedCategoryId)">@(isRtl ? c.NameAr : c.NameEn)</option>
            }
        </select>
        <select id="filterTag" aria-label="@(isRtl ? "وسم" : "Tag")"><option value="">@(isRtl ? "وسم" : "Tag"): @Shared["Filter_All"]</option></select>
        <span id="resultCount" class="lt-result-count"></span>
        <button onclick="clearFilters()" class="lt-btn lt-btn-outline"><i data-lucide="x" class="w-3.5 h-3.5" aria-hidden="true"></i>@Shared["Button_Clear"]</button>
        <span style="flex:1;"></span>
        <button type="button" onclick="window.print()" class="lt-btn lt-btn-outline" aria-label="@Shared["Button_Export"]">
            <i data-lucide="download" class="w-3.5 h-3.5" aria-hidden="true"></i>@Shared["Button_Export"]
        </button>
    </div>

    <div class="lt-card">
        <div class="lt-table-wrap">
            <table class="esems-datatable">
                <thead>
                    <tr>
                        <th>@Shared["Column_Code"]</th>
                        <th>@Shared["Column_ProcessGroupName"]</th>
                        <th>@Shared["Column_Category"]</th>
                        <th style="text-align:center;">@Shared["Column_Processes"]</th>
                        <th style="text-align:end;">@Shared["Column_Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr data-tags="@(item.Tags ?? "")">
                            <td><code style="font-size: var(--fs-xs);color:#475569;">@item.Code</code></td>
                            <td><span style="font-weight:500;color:#111827;">@(isRtl ? item.NameAr : item.NameEn)</span></td>
                            <td>@(isRtl ? item.Category?.NameAr : item.Category?.NameEn)</td>
                            <td style="text-align:center;"><span class="lt-pill lt-pill-procs">@item.Processes.Count</span></td>
                            <td style="text-align:end;">
                                <span class="lt-actions">
                                    <a asp-action="Details" asp-route-id="@item.Id" title="@Shared["Tooltip_ViewDetails"]" aria-label="@Shared["Tooltip_ViewDetails"]"><i data-lucide="eye" class="w-4 h-4" aria-hidden="true"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" title="@Shared["Tooltip_EditRecord"]" aria-label="@Shared["Tooltip_EditRecord"]"><i data-lucide="edit" class="w-4 h-4" aria-hidden="true"></i></a>
                                    <button type="button" class="btn-delete-processgroup lt-action-danger" data-id="@item.Id" data-name="@(isRtl ? item.NameAr : item.NameEn)" title="@Shared["Button_Delete"]" aria-label="@Shared["Button_Delete"]">
                                        <i data-lucide="trash-2" class="w-4 h-4" aria-hidden="true"></i>
                                    </button>
                                </span>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" style="padding:3rem 1rem;text-align:center;color:#94a3b8;">
                            <i data-lucide="inbox" class="w-10 h-10" aria-hidden="true" style="margin:0 auto .5rem;display:block;color:#cbd5e1;"></i>
                            <div style="font-weight:500;margin-bottom:.25rem;">@Shared["Empty_NoProcessGroups"]</div>
                            <a asp-action="Create" style="color:#005B99;text-decoration:none;font-size: var(--fs-sm);">@Shared["Empty_CreateFirstProcessGroup"]</a>
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();

        const tableRows = Array.from(document.querySelectorAll('table tbody tr'));
        const categorySelect = document.getElementById('filterCategory');
        const searchInput = document.getElementById('searchInput');
        const searchClearBtn = document.getElementById('searchClearBtn');
        const resultCount = document.getElementById('resultCount');
        const filterTag = document.getElementById('filterTag');
        const totalRows = tableRows.filter(r => !r.querySelector('td[colspan]')).length;

        const countTemplate = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            (CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? "إظهار {0} من {1}" : "Showing {0} of {1}")));

        function applyFilters() {
            const q = (searchInput?.value || '').trim().toLowerCase();
            const catText = categorySelect?.options[categorySelect.selectedIndex]?.text?.trim().toLowerCase() || '';
            const catId = categorySelect?.value || '';
            const tag = (filterTag?.value || '').toLowerCase();
            let visible = 0;
            tableRows.forEach(row => {
                if (row.querySelector('td[colspan]')) return;
                const rowTags = (row.getAttribute('data-tags') || '');
                const text = (row.textContent + ' ' + rowTags).toLowerCase();
                const categoryCell = row.cells[2]?.textContent.trim().toLowerCase() || '';
                const matchesSearch = !q || text.includes(q);
                const matchesCategory = !catId || categoryCell === catText;
                const matchesTag = !tag || rowTags.toLowerCase().split(',').map(s => s.trim()).includes(tag);
                const show = matchesSearch && matchesCategory && matchesTag;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            if (resultCount) resultCount.textContent = countTemplate.replace('{0}', visible).replace('{1}', totalRows);
            if (searchClearBtn) searchClearBtn.classList.toggle('hidden', !q);
        }

        function clearFilters() {
            if (searchInput) searchInput.value = '';
            if (categorySelect) categorySelect.value = '';
            if (filterTag) filterTag.value = '';
            applyFilters();
            searchInput?.focus();
        }

        searchInput?.addEventListener('input', applyFilters);
        categorySelect?.addEventListener('change', applyFilters);
        filterTag?.addEventListener('change', applyFilters);
        searchClearBtn?.addEventListener('click', () => { if (searchInput) searchInput.value = ''; applyFilters(); searchInput?.focus(); });

        // Populate the Tag filter with the distinct tags present in the rows.
        (function () {
            if (!filterTag) return;
            const set = new Set();
            tableRows.forEach(r => (r.getAttribute('data-tags') || '').split(',').forEach(t => { const v = t.trim(); if (v) set.add(v); }));
            Array.from(set).sort((a, b) => a.localeCompare(b)).forEach(t => {
                const o = document.createElement('option'); o.value = t; o.textContent = t; filterTag.appendChild(o);
            });
        })();

        applyFilters();

        document.addEventListener('click', function (e) {
            const btn = e.target.closest('.btn-delete-processgroup');
            if (!btn) return;
            const id = btn.dataset.id;
            const name = btn.dataset.name || '';
            Swal.fire({
                title: '@Shared["Confirm_AreYouSure"]',
                text: '@Shared["Confirm_DeleteTextPrefix"]' + name,
                icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#005B99', cancelButtonColor: '#6b7280',
                confirmButtonText: '@Shared["Confirm_YesDelete"]',
                cancelButtonText: '@Shared["Button_Cancel"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteId').value = id;
                    document.getElementById('deleteForm').submit();
                }
            });
        });
    </script>
}
