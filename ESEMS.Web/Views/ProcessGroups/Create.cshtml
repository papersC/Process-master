@model ProcessGroup
@{
    ViewData["Title"] = Shared["Title_AddProcessGroup"].Value;
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

@*  Two-column form: left = Identity card (Category + Names + Descriptions)
    and Operational card (Tags, HasAutomatedProcesses); right = sticky
    sidebar with parent-Category chip (live), live tag chips, automation
    badge, Save/Cancel action bar. Same .pc-* tokens as Processes/Create +
    Categories/Create. Code auto-assigned. Owning Unit
    removed: ownership belongs at L3 (Process), not L2 (Process Group). *@

<style>
    .pc-shell { display: grid; grid-template-columns: minmax(0,1fr) 320px; gap: .75rem; align-items: start; }
    @@media (max-width: 992px) { .pc-shell { grid-template-columns: 1fr; } }
    .pc-header { display: flex; align-items: center; justify-content: space-between; padding: .25rem 0 .4rem; border-bottom: 1px solid #e5e7eb; margin-bottom: .6rem; }
    .pc-header h1 { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .5rem; }
    .pc-header p { margin: 0; font-size: var(--fs-xs); color: #6b7280; }
    .pc-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; border: none; }
    .pc-btn-primary { background: #005B99; color: #fff; } .pc-btn-primary:hover { background: #003d6b; color: #fff; }
    .pc-btn-outline { background: #fff; color: #005B99; border: 1px solid #cbd5e1; } .pc-btn-outline:hover { background: #f1f5f9; }
    .pc-btn-ghost { background: transparent; color: #374151; border: 1px solid #d1d5db; } .pc-btn-ghost:hover { background: #f9fafb; }
    .pc-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .9rem 1rem; margin-bottom: .6rem; }
    .pc-card-h { display: flex; align-items: center; gap: .5rem; padding-bottom: .55rem; margin-bottom: .75rem; border-bottom: 1px solid #f1f5f9; }
    .pc-card-h h2 { margin: 0; font-size: var(--fs-sm); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .45rem; }
    .pc-card-h .pc-card-sub { font-size: var(--fs-xs); color: #6b7280; margin-inline-start: auto; }
    .pc-label { display: block; font-size: var(--fs-xs); font-weight: 600; color: #374151; margin-bottom: .25rem; }
    .pc-label .req { color: #dc2626; }
    .pc-input, .pc-select, .pc-textarea { width: 100%; padding: .42rem .65rem; border: 1px solid #d1d5db; border-radius: .375rem; font-size: var(--fs-sm); background: #fff; color: #111827; }
    .pc-input:focus, .pc-select:focus, .pc-textarea:focus { outline: none; border-color: #005B99; box-shadow: 0 0 0 3px rgba(0,91,153,.12); }
    .pc-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: .65rem; }
    .pc-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: .65rem; }
    @@media (max-width: 768px) { .pc-grid-2, .pc-grid-3 { grid-template-columns: 1fr; } }
    .pc-row { margin-bottom: .65rem; }
    .pc-help { font-size: var(--fs-xs); color: #6b7280; margin-top: .2rem; }
    .pc-err { font-size: var(--fs-xs); color: #dc2626; margin-top: .2rem; display: block; }
    .pc-side { position: sticky; top: 1rem; display: flex; flex-direction: column; gap: .55rem; }
    .pc-tip-row { display: flex; align-items: flex-start; gap: .45rem; padding: .35rem 0; font-size: var(--fs-xs); color: #374151; line-height: 1.4; }
    .pc-tip-row i { color: #005B99; flex-shrink: 0; margin-top: .12rem; }
    .pc-side-actions { display: flex; flex-direction: column; gap: .35rem; padding-top: .25rem; }
    .pc-side-actions .pc-btn { justify-content: center; padding: .55rem .85rem; }
    .pc-checkbox-row { display: inline-flex; align-items: center; gap: .45rem; cursor: pointer; }
    .pc-checkbox-row input { width: 1rem; height: 1rem; accent-color: #005B99; }
    .pc-summary-row { display: flex; align-items: center; justify-content: space-between; padding: .35rem 0; font-size: var(--fs-xs); color: #374151; border-bottom: 1px dashed #f1f5f9; }
    .pc-summary-row:last-child { border-bottom: none; }
    .pc-pill { display: inline-block; padding: .12rem .45rem; font-size: var(--fs-xs); font-weight: 700; border-radius: .25rem; background: #eff6ff; color: #1d4ed8; min-width: 1.5rem; text-align: center; }
    .pc-pill-on { background: #d1fae5; color: #065f46; }
    .pc-pill-off { background: #f1f5f9; color: #6b7280; }
    .pc-tag-chip { display: inline-block; padding: .1rem .4rem; margin: .1rem; font-size: var(--fs-xs); font-weight: 600; border-radius: .25rem; background: #dbeafe; color: #1e40af; }
</style>

<div class="pc-header">
    <div>
        <h1><i data-lucide="folder-plus" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>@ViewData["Title"]</h1>
        <p>@(isRtl ? "إضافة مجموعة عمليات جديدة تحت فئة APQC" : "Create a new process group under an APQC category")</p>
    </div>
    <a asp-action="Index" class="pc-btn pc-btn-outline">
        <i data-lucide="@(isRtl ? "arrow-right" : "arrow-left")" class="w-4 h-4" aria-hidden="true"></i>@(isRtl ? "رجوع" : "Back")
    </a>
</div>

<form asp-action="Create" method="post" id="createForm">
    <div asp-validation-summary="ModelOnly" style="margin-bottom:.6rem;padding:.6rem .8rem;background:#fef2f2;border:1px solid #fecaca;border-radius:.375rem;color:#b91c1c;font-size: var(--fs-xs);"></div>

    <div class="pc-shell">
        <!-- ============ MAIN COLUMN ============ -->
        <div>
            <!-- Identity -->
            <div class="pc-card">
                <div class="pc-card-h">
                    <h2><i data-lucide="layers" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "الهوية" : "Identity")</h2>
                    <span class="pc-card-sub">@(isRtl ? "الكود والفئة الأم والأسماء" : "Code, parent category, names")</span>
                </div>

                @* Code is auto-generated server-side. The hidden input keeps the
                   model binder happy; the AJAX in the Scripts section still posts to
                   /ProcessGroups/NextCode when CategoryId changes and stuffs the result into
                   #Code so submission carries the live-computed value. The visual preview
                   badge was removed because it was visual noise — users don't pick the code,
                   the system does. Per project rule: never an editable Code input. *@
                <input type="hidden" asp-for="Code" id="Code" />
                <div class="pc-row">
                    <label asp-for="CategoryId" class="pc-label">@(isRtl ? "الفئة" : "Category") <span class="req">*</span></label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="pc-select" id="CategoryId">
                        <option value="">@(isRtl ? "-- اختر --" : "-- Select --")</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="pc-err"></span>
                </div>

                <div class="pc-grid-2 pc-row">
                    <div>
                        <label asp-for="NameEn" class="pc-label">@(isRtl ? "الاسم (إنجليزي)" : "Name (English)") <span class="req">*</span></label>
                        <input asp-for="NameEn" class="pc-input" />
                        <span asp-validation-for="NameEn" class="pc-err"></span>
                    </div>
                    <div>
                        <label asp-for="NameAr" class="pc-label">@(isRtl ? "الاسم (عربي)" : "Name (Arabic)") <span class="req">*</span></label>
                        <input asp-for="NameAr" dir="rtl" class="pc-input" />
                        <span asp-validation-for="NameAr" class="pc-err"></span>
                    </div>
                </div>

                <div class="pc-grid-2">
                    <div>
                        <label asp-for="DescriptionEn" class="pc-label">@(isRtl ? "الوصف (إنجليزي)" : "Description (English)")</label>
                        <textarea asp-for="DescriptionEn" rows="3" class="pc-textarea"></textarea>
                    </div>
                    <div>
                        <label asp-for="DescriptionAr" class="pc-label">@(isRtl ? "الوصف (عربي)" : "Description (Arabic)")</label>
                        <textarea asp-for="DescriptionAr" dir="rtl" rows="3" class="pc-textarea"></textarea>
                    </div>
                </div>
            </div>

            <!-- Operational -->
            @* Owning Unit removed: per APQC + ISO 9001 §4.4 ownership belongs at L3 (Process),
               not L2 (Process Group) — process groups span multiple units. *@
            <div class="pc-card">
                <div class="pc-card-h">
                    <h2><i data-lucide="settings" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "تشغيلي" : "Operational")</h2>
                    <span class="pc-card-sub">@(isRtl ? "الوسوم وحالة الأتمتة" : "Tags and automation")</span>
                </div>

                <div class="pc-row">
                    <label asp-for="Tags" class="pc-label"><i data-lucide="tag" class="w-3.5 h-3.5 inline-block" style="color:#005B99;" aria-hidden="true"></i> @(isRtl ? "وسوم" : "Tags")</label>
                    <input asp-for="Tags" class="pc-input" id="TagsInput" placeholder="@(isRtl ? "مثال: رقمي، عميل" : "e.g., Digital, Customer")" />
                    <div class="pc-help">@(isRtl ? "افصل الوسوم بفاصلة" : "Separate tags with commas")</div>
                </div>

                <label class="pc-checkbox-row">
                    <input asp-for="HasAutomatedProcesses" id="HasAutomated" />
                    <span style="font-size: var(--fs-xs);color:#374151;">@(isRtl ? "يتضمن عمليات مؤتمتة" : "Contains automated processes")</span>
                </label>
            </div>
        </div>

        <!-- ============ STICKY SIDEBAR ============ -->
        <aside class="pc-side">
            <div class="pc-card" style="margin-bottom:0;">
                <div class="pc-card-h">
                    <h2><i data-lucide="folder-tree" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "الفئة الأم" : "Parent Category")</h2>
                </div>
                <div id="parentChip" style="font-size: var(--fs-xs);padding:.45rem .6rem;border:1px solid #bfdbfe;background:#eff6ff;border-radius:.375rem;color:#1e40af;">
                    <span id="parentChipText">@(isRtl ? "اختر الفئة الأم" : "Select a parent category")</span>
                </div>
                <div class="pc-help" style="margin-top:.4rem;">@(isRtl ? "مجموعات العمليات هي المستوى الثاني (L2) في تسلسل APQC." : "Process groups are APQC Level 2 (L2) — they live under a Category and contain Processes.")</div>
            </div>

            <div class="pc-card" style="margin-bottom:0;">
                <div class="pc-card-h">
                    <h2><i data-lucide="info" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "ملخص" : "Summary")</h2>
                </div>
                <div class="pc-summary-row">
                    <span><i data-lucide="hash" class="w-3.5 h-3.5 inline-block" style="color:#6b7280;" aria-hidden="true"></i> @(isRtl ? "الكود" : "Code")</span>
                    <span class="pc-pill" id="sumCode">—</span>
                </div>
                <div class="pc-summary-row">
                    <span><i data-lucide="zap" class="w-3.5 h-3.5 inline-block" style="color:#6b7280;" aria-hidden="true"></i> @(isRtl ? "الأتمتة" : "Automation")</span>
                    <span class="pc-pill pc-pill-off" id="sumAuto">@(isRtl ? "لا" : "No")</span>
                </div>
                <div style="padding:.4rem 0 .1rem;">
                    <div style="font-size: var(--fs-xs);color:#6b7280;margin-bottom:.25rem;display:flex;align-items:center;gap:.3rem;">
                        <i data-lucide="tag" class="w-3.5 h-3.5" style="color:#6b7280;" aria-hidden="true"></i>
                        @(isRtl ? "الوسوم" : "Tags")
                    </div>
                    <div id="sumTags" style="min-height:1.5rem;">
                        <span style="font-size: var(--fs-xs);color:#9ca3af;">@(isRtl ? "لم تُضف وسوم بعد" : "No tags yet")</span>
                    </div>
                </div>
            </div>

            <div class="pc-side-actions">
                <button type="submit" class="pc-btn pc-btn-primary">
                    <i data-lucide="save" class="w-4 h-4" aria-hidden="true"></i>
                    @(isRtl ? "حفظ" : "Save")
                </button>
                <a asp-action="Index" class="pc-btn pc-btn-ghost">
                    <i data-lucide="x" class="w-4 h-4" aria-hidden="true"></i>
                    @(isRtl ? "إلغاء" : "Cancel")
                </a>
            </div>
        </aside>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();
        const isRtl = @Html.Raw(isRtl ? "true" : "false");

        const categorySel = document.getElementById('CategoryId');
        const codeInput = document.getElementById('Code');               // hidden — model binder
        const codeBadgeText = document.getElementById('codeBadgeText');  // visible preview
        const tagsInput = document.getElementById('TagsInput');
        const autoChk = document.getElementById('HasAutomated');
        const parentChipText = document.getElementById('parentChipText');
        const sumCode = document.getElementById('sumCode');
        const sumAuto = document.getElementById('sumAuto');
        const sumTags = document.getElementById('sumTags');

        function refreshParentChip() {
            const opt = categorySel.options[categorySel.selectedIndex];
            if (categorySel.value && opt) {
                parentChipText.textContent = opt.textContent.trim();
            } else {
                parentChipText.textContent = isRtl ? "اختر الفئة الأم" : "Select a parent category";
            }
        }
        function setCodePreview(code) {
            // Empty = "—" placeholder; non-empty = monospace badge in the sidebar plus
            // the hidden input + main badge text. The hidden input lets the form post
            // a hint; the server re-allocates anyway via NextProcessGroupCodeAsync.
            const value = (code || '').trim();
            if (codeInput) codeInput.value = value;
            if (sumCode) sumCode.textContent = value || '—';
            if (codeBadgeText) {
                if (value) {
                    codeBadgeText.textContent = value;
                    codeBadgeText.style.color = '#005B99';
                    codeBadgeText.style.fontWeight = '700';
                } else {
                    codeBadgeText.textContent = isRtl ? "اختر فئة لعرض الكود" : "Select a category to preview";
                    codeBadgeText.style.color = '#94a3b8';
                    codeBadgeText.style.fontWeight = '400';
                }
            }
        }

        // Race-guard: if the user changes the category fast, only the latest fetch
        // wins. Earlier responses get dropped by comparing reqId to the one stored.
        let codeReqId = 0;
        async function refreshCodePreview() {
            const cid = categorySel?.value;
            if (!cid) { setCodePreview(''); return; }
            const myReq = ++codeReqId;
            // Brief loading state so a slow query doesn't leave a stale value.
            if (codeBadgeText) {
                codeBadgeText.textContent = isRtl ? "جاري التوليد…" : "Generating…";
                codeBadgeText.style.color = '#94a3b8';
                codeBadgeText.style.fontWeight = '400';
            }
            try {
                const r = await fetch('@Url.Action("NextCode", "ProcessGroups")?categoryId=' + encodeURIComponent(cid));
                if (!r.ok) throw new Error('HTTP ' + r.status);
                const d = await r.json();
                if (myReq !== codeReqId) return; // a newer request superseded
                setCodePreview(d.code || '');
            } catch (e) {
                if (myReq !== codeReqId) return;
                setCodePreview('');
                if (codeBadgeText) codeBadgeText.textContent = (isRtl ? "تعذر التوليد" : "Could not preview") + ' (' + e.message + ')';
            }
        }

        function refreshAuto() {
            const on = !!(autoChk?.checked);
            sumAuto.textContent = on ? (isRtl ? "نعم" : "Yes") : (isRtl ? "لا" : "No");
            sumAuto.classList.toggle('pc-pill-on', on);
            sumAuto.classList.toggle('pc-pill-off', !on);
        }
        function refreshTags() {
            const raw = (tagsInput?.value || '').trim();
            if (!raw) {
                sumTags.innerHTML = `<span style="font-size: var(--fs-xs);color:#9ca3af;">${isRtl ? "لم تُضف وسوم بعد" : "No tags yet"}</span>`;
                return;
            }
            const tags = raw.split(',').map(t => t.trim()).filter(Boolean);
            sumTags.innerHTML = tags.map(t => `<span class="pc-tag-chip">${t.replace(/[<>&"']/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;'}[c]))}</span>`).join('');
        }

        categorySel?.addEventListener('change', () => { refreshParentChip(); refreshCodePreview(); });
        tagsInput?.addEventListener('input', refreshTags);
        autoChk?.addEventListener('change', refreshAuto);

        refreshParentChip();
        refreshCodePreview();   // handles both initial empty + pre-selected category (e.g. ?categoryId=...)
        refreshAuto();
        refreshTags();
    </script>
}
