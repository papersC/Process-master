@section Scripts {
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();

        const tocItems = Array.from(document.querySelectorAll('#umTocList .um-toc-item'));
        const sections = Array.from(document.querySelectorAll('#umDetail .um-section'));
        const empty    = document.getElementById('umEmpty');
        const search   = document.getElementById('umSearch');

        function showSection(id) {
            let found = false;
            sections.forEach(s => {
                const match = s.dataset.section === id;
                s.classList.toggle('active', match);
                if (match) found = true;
            });
            tocItems.forEach(t => t.classList.toggle('active', t.dataset.section === id));
            if (empty) empty.style.display = found ? 'none' : '';
            // Scroll the detail pane back to top whenever we switch sections.
            const detail = document.getElementById('umDetail');
            if (detail) detail.scrollTop = 0;
        }

        // Initial section: hash if present + valid, otherwise the first item.
        function syncFromHash() {
            const raw = (window.location.hash || '').replace('#', '').trim();
            const target = sections.some(s => s.dataset.section === raw) ? raw : (sections[0]?.dataset.section || '');
            if (target) showSection(target);
        }
        syncFromHash();
        window.addEventListener('hashchange', syncFromHash);

        // Click handler — let the browser update the hash, then we re-render.
        tocItems.forEach(t => t.addEventListener('click', e => {
            // Don't preventDefault — letting the browser update the hash gives
            // us free deep-linking + back-button support. The hashchange
            // listener will then call showSection().
        }));

        // TOC search — filter list items only; no content search yet.
        search?.addEventListener('input', () => {
            const q = (search.value || '').toLowerCase().trim();
            tocItems.forEach(t => {
                const ok = !q || (t.dataset.search || '').includes(q);
                t.classList.toggle('hidden', !ok);
            });
        });
    </script>
}
