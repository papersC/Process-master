@model MaintenanceSchedule
@{
    ViewData["Title"] = Shared["Title_EditMaintenanceSchedule"].Value;
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isRtl = culture.StartsWith("ar");
    var step1 = isRtl ? "البيانات الأساسية" : "Basics";
    var step2 = isRtl ? "الجدولة والتكلفة" : "Schedule & Cost";
}

<partial name="_WizardStyles" />

<div class="wiz-pageheader">
    <h1 class="wiz-pagetitle"><i data-lucide="edit" style="width:20px;height:20px;color:#005B99;"></i>@ViewData["Title"]</h1>
    <div style="display:inline-flex;align-items:center;gap:.85rem;">
        <span class="wiz-stepcount">@(isRtl ? "الخطوة" : "Step") <b id="stepCounter">1</b> @(isRtl ? "من" : "of") 2</span>
        <a asp-action="Schedules" class="wiz-cancellink"><i data-lucide="x" style="width:14px;height:14px;"></i> @Shared["Button_Cancel"]</a>
    </div>
</div>

<form asp-action="EditSchedule" method="post" id="wizardForm" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="AssetId" />
    <input type="hidden" asp-for="CreatedAt" />
    <input type="hidden" asp-for="CreatedById" />
    <input type="hidden" asp-for="UpdatedAt" />
    <input type="hidden" asp-for="UpdatedById" />
    <input type="hidden" asp-for="Version" />
    <div asp-validation-summary="ModelOnly" style="margin-bottom:.6rem;padding:.6rem .8rem;background:#fef2f2;border:1px solid #fecaca;border-radius:.375rem;color:#b91c1c;font-size: var(--fs-xs);"></div>

    <div class="wiz-grid">
        <!-- Left rail -->
        <aside class="wiz-rail">
            <ul class="wiz-steps" id="wizardSteps">
                <li class="wiz-step active" data-step="1" onclick="wizGoTo(1)">
                    <span class="wiz-stepnum">1</span>
                    <span class="wiz-steptext">
                        <span class="wiz-steptitle">@step1</span>
                        <span class="wiz-stepsub">@(isRtl ? "الاسم والنوع والوصف" : "Name, type, description")</span>
                    </span>
                </li>
                <li class="wiz-step" data-step="2" onclick="wizGoTo(2)">
                    <span class="wiz-stepnum">2</span>
                    <span class="wiz-steptext">
                        <span class="wiz-steptitle">@step2</span>
                        <span class="wiz-stepsub">@(isRtl ? "التكرار، التاريخ، التكلفة" : "Frequency, date, cost")</span>
                    </span>
                </li>
            </ul>
        </aside>

        <!-- Middle -->
        <section class="wiz-main">
            <!-- Step 1 -->
            <div class="wiz-step-content active" data-step="1">
                <div class="wiz-stephdr"><i data-lucide="info" style="width:18px;height:18px;"></i><h2>@(isRtl ? "الخطوة" : "Step") 1: @step1</h2></div>

                <div class="pc-grid-2 pc-row">
                    <div>
                        <label class="pc-label">@Shared["Label_Asset"]</label>
                        <input value="@Model.Asset?.AssetTag - @(isRtl ? Model.Asset?.NameAr : Model.Asset?.NameEn)" class="pc-input" readonly />
                    </div>
                    <div>
                        <label asp-for="Type" class="pc-label">@Shared["Label_MaintenanceType"] <span class="req">*</span></label>
                        <select asp-for="Type" id="TypeSel" asp-items="@ViewBag.MaintenanceTypes" class="pc-select"></select>
                        <span asp-validation-for="Type" class="pc-err"></span>
                    </div>
                </div>

                <div class="pc-grid-2 pc-row">
                    <div>
                        <label asp-for="NameEn" class="pc-label">@Shared["Label_NameEnglish"] <span class="req">*</span></label>
                        <input asp-for="NameEn" class="pc-input" />
                        <span asp-validation-for="NameEn" class="pc-err"></span>
                    </div>
                    <div>
                        <label asp-for="NameAr" class="pc-label">@Shared["Label_NameArabic"] <span class="req">*</span></label>
                        <input asp-for="NameAr" dir="rtl" class="pc-input" />
                        <span asp-validation-for="NameAr" class="pc-err"></span>
                    </div>
                </div>

                <div class="pc-grid-2">
                    <div>
                        <label asp-for="DescriptionEn" class="pc-label">@Shared["Label_DescriptionEnglish"]</label>
                        <textarea asp-for="DescriptionEn" rows="3" class="pc-textarea"></textarea>
                    </div>
                    <div>
                        <label asp-for="DescriptionAr" class="pc-label">@Shared["Label_DescriptionArabic"]</label>
                        <textarea asp-for="DescriptionAr" dir="rtl" rows="3" class="pc-textarea"></textarea>
                    </div>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="wiz-step-content" data-step="2">
                <div class="wiz-stephdr"><i data-lucide="calendar-clock" style="width:18px;height:18px;"></i><h2>@(isRtl ? "الخطوة" : "Step") 2: @step2</h2></div>

                <div class="pc-grid-3 pc-row">
                    <div>
                        <label asp-for="FrequencyDays" class="pc-label">@Shared["Label_FrequencyDays"] <span class="req">*</span></label>
                        <input asp-for="FrequencyDays" type="number" min="1" id="FrequencyDaysInp" class="pc-input" />
                        <span asp-validation-for="FrequencyDays" class="pc-err"></span>
                    </div>
                    <div>
                        <label asp-for="NextScheduledDate" class="pc-label">@Shared["Label_NextScheduledDate"] <span class="req">*</span></label>
                        <input asp-for="NextScheduledDate" type="date" id="NextDateInp" class="pc-input" />
                        <span asp-validation-for="NextScheduledDate" class="pc-err"></span>
                    </div>
                    <div style="display:flex;align-items:end;">
                        <label class="pc-checkbox-row">
                            <input asp-for="IsActive" id="IsActiveInp" />
                            <span style="font-size: var(--fs-xs);color:#374151;">@Shared["Label_ActiveSchedule"]</span>
                        </label>
                    </div>
                </div>

                <div class="pc-grid-2 pc-row">
                    <div>
                        <label asp-for="EstimatedDurationHours" class="pc-label">@Shared["Label_EstimatedDurationHours"]</label>
                        <input asp-for="EstimatedDurationHours" type="number" step="0.5" min="0" id="DurationInp" class="pc-input" />
                    </div>
                    <div>
                        <label asp-for="EstimatedCost" class="pc-label">@Shared["Label_EstimatedCostAED"]</label>
                        <input asp-for="EstimatedCost" type="number" step="0.01" min="0" id="CostInp" class="pc-input" />
                    </div>
                </div>

                @if (Model.LastPerformedDate.HasValue)
                {
                    <div style="margin-top:.85rem;padding:.6rem .8rem;background:#eff6ff;border:1px solid #bfdbfe;border-radius:.375rem;font-size: var(--fs-xs);color:#1e40af;">
                        <strong>@Shared["Text_LastPerformed"]:</strong> @Model.LastPerformedDate.Value.ToDubaiString("MMMM dd, yyyy")
                    </div>
                }
            </div>

            <div class="wiz-footer">
                <button type="button" class="pc-btn pc-btn-ghost" id="prevBtn" disabled>
                    <i data-lucide="@(isRtl ? "chevron-right" : "chevron-left")" style="width:16px;height:16px;"></i>
                    @(isRtl ? "السابق" : "Previous")
                </button>
                <button type="button" class="pc-btn pc-btn-primary" id="nextBtn">
                    @(isRtl ? "التالي" : "Next")
                    <i data-lucide="@(isRtl ? "chevron-left" : "chevron-right")" style="width:16px;height:16px;"></i>
                </button>
            </div>
        </section>

        <!-- Right rail -->
        <aside class="wiz-summary">
            <div class="wiz-sum-card">
                <div class="wiz-sum-hdr"><i data-lucide="package"></i><h3>@Shared["Label_Asset"]</h3></div>
                <div style="font-size: var(--fs-sm);color:#0f172a;font-weight:600;">@Model.Asset?.AssetTag</div>
                <p class="wiz-sum-note">@(isRtl ? Model.Asset?.NameAr : Model.Asset?.NameEn)</p>
            </div>

            <div class="wiz-sum-card">
                <div class="wiz-sum-hdr"><i data-lucide="calendar-clock"></i><h3>@(isRtl ? "ملخص الجدولة" : "Schedule Preview")</h3></div>
                <div class="wiz-sum-row"><span class="wiz-sum-label"><i data-lucide="repeat"></i> @Shared["Label_FrequencyDays"]</span><span class="wiz-sum-pill" id="sumFreq">—</span></div>
                <div class="wiz-sum-row"><span class="wiz-sum-label"><i data-lucide="calendar"></i> @Shared["Label_NextScheduledDate"]</span><span class="wiz-sum-pill" id="sumDate">—</span></div>
                <div class="wiz-sum-row"><span class="wiz-sum-label"><i data-lucide="clock"></i> @Shared["Label_EstimatedDurationHours"]</span><span class="wiz-sum-pill" id="sumDur">—</span></div>
                <div class="wiz-sum-row"><span class="wiz-sum-label"><i data-lucide="banknote"></i> @Shared["Label_EstimatedCostAED"]</span><span class="wiz-sum-pill" id="sumCost">—</span></div>
                <div class="wiz-sum-row"><span class="wiz-sum-label"><i data-lucide="circle"></i> @(isRtl ? "الحالة" : "Status")</span><span class="wiz-sum-pill" id="sumActive">—</span></div>
            </div>

            <div class="wiz-sum-actions">
                <button type="submit" class="pc-btn pc-btn-primary pc-btn-block" id="submitBtn" disabled
                        title="@(isRtl ? "أكمل جميع الخطوات لتفعيل الزر" : "Complete all steps to enable")">
                    <i data-lucide="save" style="width:16px;height:16px;"></i>
                    @Shared["Button_SaveChanges"]
                </button>
                <a asp-action="Schedules" class="pc-btn pc-btn-ghost pc-btn-block">
                    <i data-lucide="x" style="width:16px;height:16px;"></i>
                    @Shared["Button_Cancel"]
                </a>
            </div>
        </aside>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();
        const isRtl = @Html.Raw(isRtl ? "true" : "false");
        const TOTAL_STEPS = 2;
        let currentStep = 1, highestVisited = 1;
        const prevBtn   = document.getElementById('prevBtn');
        const nextBtn   = document.getElementById('nextBtn');
        const submitBtn = document.getElementById('submitBtn');
        const stepCounterEl = document.getElementById('stepCounter');

        function validateStep(n) {
            if (n !== 1) return true;
            const errors = [];
            const mark = (id, label) => {
                const el = document.getElementById(id);
                if (!el) return;
                const v = (el.value || '').trim();
                if (!v) { el.classList.add('invalid'); errors.push(label); } else { el.classList.remove('invalid'); }
            };
            mark('NameEn', isRtl ? "الاسم بالإنجليزية مطلوب" : "English name is required");
            mark('NameAr', isRtl ? "الاسم بالعربية مطلوب"   : "Arabic name is required");
            mark('TypeSel', isRtl ? "النوع مطلوب" : "Maintenance type is required");
            if (errors.length) {
                Swal.fire({ icon:'warning', title: isRtl ? "حقول مطلوبة" : "Required Fields", html: errors.join('<br>'), confirmButtonColor:'#005B99' });
                return false;
            }
            return true;
        }

        function showStep(n) {
            currentStep = Math.max(1, Math.min(TOTAL_STEPS, n));
            highestVisited = Math.max(highestVisited, currentStep);
            document.querySelectorAll('.wiz-step').forEach(el => {
                const s = parseInt(el.dataset.step, 10);
                el.classList.toggle('active', s === currentStep);
                el.classList.toggle('completed', s < highestVisited && s !== currentStep);
            });
            document.querySelectorAll('.wiz-step-content').forEach(p => {
                p.classList.toggle('active', parseInt(p.dataset.step, 10) === currentStep);
            });
            prevBtn.disabled = (currentStep === 1);
            nextBtn.classList.toggle('d-none', currentStep === TOTAL_STEPS);
            if (submitBtn) submitBtn.disabled = (currentStep !== TOTAL_STEPS);
            if (stepCounterEl) stepCounterEl.textContent = currentStep;
            if (window.lucide) lucide.createIcons();
        }
        window.wizGoTo = function (n) {
            if (n <= currentStep) { showStep(n); return; }
            if (n === currentStep + 1) { if (validateStep(currentStep)) showStep(n); return; }
            if (validateStep(currentStep)) showStep(currentStep + 1);
        };
        prevBtn.addEventListener('click', () => showStep(currentStep - 1));
        nextBtn.addEventListener('click', () => { if (validateStep(currentStep)) showStep(currentStep + 1); });

        // Live summary
        function refreshSummary() {
            const set = (id, txt) => { const e = document.getElementById(id); if (e) e.textContent = txt; };
            const freq = document.getElementById('FrequencyDaysInp')?.value;
            const date = document.getElementById('NextDateInp')?.value;
            const dur  = document.getElementById('DurationInp')?.value;
            const cost = document.getElementById('CostInp')?.value;
            set('sumFreq', freq ? `${freq} ${isRtl ? "يوم" : "days"}` : '—');
            set('sumDate', date || '—');
            set('sumDur',  dur  ? `${dur} ${isRtl ? "س" : "h"}` : '—');
            set('sumCost', cost ? Number(cost).toLocaleString() + ' AED' : '—');
            const on = !!document.getElementById('IsActiveInp')?.checked;
            const sa = document.getElementById('sumActive');
            if (sa) {
                sa.textContent = on ? (isRtl ? 'نشط' : 'Active') : (isRtl ? 'غير نشط' : 'Inactive');
                sa.className = 'wiz-sum-pill ' + (on ? 'wiz-sum-pill-on' : 'wiz-sum-pill-off');
            }
        }
        ['FrequencyDaysInp','NextDateInp','DurationInp','CostInp','IsActiveInp'].forEach(id => {
            document.getElementById(id)?.addEventListener('change', refreshSummary);
            document.getElementById(id)?.addEventListener('input', refreshSummary);
        });

        // Final validation on submit
        document.getElementById('wizardForm').addEventListener('submit', function (e) {
            if (!validateStep(1)) { e.preventDefault(); showStep(1); }
        });

        showStep(1);
        refreshSummary();
    </script>
}
