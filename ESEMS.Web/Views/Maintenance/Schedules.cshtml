@model IEnumerable<MaintenanceSchedule>
@{
    ViewData["Title"] = Shared["Nav_MaintenanceSchedules"].Value;
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isRtl = culture.StartsWith("ar");

    var total = Model.Count();
    var active = Model.Count(s => s.IsActive);
    var overdue = Model.Count(s => s.IsActive && s.NextScheduledDate < DateTime.UtcNow);
    var dueWeek = Model.Count(s => s.IsActive && s.NextScheduledDate >= DateTime.UtcNow && s.NextScheduledDate <= DateTime.UtcNow.AddDays(7));
}

<style>
    .lt-shell { display: flex; flex-direction: column; gap: .6rem; }
    .lt-header { display: flex; align-items: center; justify-content: space-between; padding: .25rem 0 .4rem; border-bottom: 1px solid #e5e7eb; }
    .lt-header h1 { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .5rem; }
    .lt-header p { margin: 0; font-size: var(--fs-xs); color: #6b7280; }
    .lt-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; border: none; }
    .lt-btn-primary { background: #005B99; color: #fff; } .lt-btn-primary:hover { background: #003d6b; color: #fff; }
    .lt-kpi-strip { display: flex; align-items: stretch; gap: .5rem; padding: .55rem .65rem; background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; flex-wrap: wrap; }
    .lt-kpi { display: flex; align-items: center; gap: .55rem; padding: .25rem .65rem; flex: 1 1 180px; min-width: 180px; border-inline-end: 1px dashed #e5e7eb; }
    .lt-kpi:last-child { border-inline-end: none; }
    .lt-kpi-icon { width: 34px; height: 34px; border-radius: .375rem; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .lt-kpi-icon.kpi-blue   { background: #eff6ff; color: #005B99; }
    .lt-kpi-icon.kpi-green  { background: #ecfdf5; color: #047857; }
    .lt-kpi-icon.kpi-red    { background: #fef2f2; color: #dc2626; }
    .lt-kpi-icon.kpi-yellow { background: #fefce8; color: #a16207; }
    .lt-kpi-num { font-size: var(--fs-base); font-weight: 700; color: #111827; line-height: 1; }
    .lt-kpi-label { font-size: var(--fs-xs); color: #6b7280; margin-top: .15rem; text-transform: uppercase; letter-spacing: .03em; white-space: nowrap; }
    @@media (max-width: 768px) { .lt-kpi { flex: 1 1 45%; border-inline-end: none; } }

    .lt-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; display: flex; flex-direction: column; overflow: hidden; }
    .lt-table-wrap { overflow: auto; }
    .lt-table-wrap table { width: 100%; font-size: var(--fs-sm); border-collapse: collapse; }
    .lt-table-wrap thead { position: sticky; top: 0; background: #f8fafc; z-index: 1; }
    .lt-table-wrap th { font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: .04em; color: #6b7280; font-weight: 600; padding: .55rem .75rem; text-align: start; border-bottom: 1px solid #e5e7eb; white-space: nowrap; }
    .lt-table-wrap td { padding: .5rem .75rem; border-bottom: 1px solid #f3f4f6; color: #374151; vertical-align: middle; }
    .lt-table-wrap tbody tr:hover td { background: #f9fafb; }
    .lt-table-wrap tbody tr.lt-row-overdue td { background: #fef2f2; }
    .lt-table-wrap tbody tr.lt-row-overdue:hover td { background: #fee2e2; }
    .lt-pill { display: inline-block; padding: .15rem .5rem; font-size: var(--fs-xs); font-weight: 600; border-radius: .25rem; white-space: nowrap; }
    .lt-pill-st-overdue   { background: #fef2f2; color: #b91c1c; }
    .lt-pill-st-soon      { background: #fefce8; color: #a16207; }
    .lt-pill-st-scheduled { background: #ecfdf5; color: #047857; }
    .lt-pill-st-inactive  { background: #f1f5f9; color: #475569; }
    .lt-actions { display: inline-flex; gap: .35rem; }
    .lt-actions a { color: #005B99; padding: .2rem; border-radius: .25rem; transition: background .15s; }
    .lt-actions a:hover { background: #eff6ff; }
</style>

<div class="lt-shell">
    <div class="lt-header">
        <div>
            <h1><i data-lucide="calendar-clock" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>@Shared["Nav_MaintenanceSchedules"]</h1>
            <p>@Shared["Text_PreventiveMaintenancePlanning"]</p>
        </div>
        <a asp-action="CreateSchedule" class="lt-btn lt-btn-primary">
            <i data-lucide="plus" class="w-4 h-4" aria-hidden="true"></i>@Shared["Button_CreateSchedule"]
        </a>
    </div>

    <div class="lt-kpi-strip">
        <div class="lt-kpi">
            <div class="lt-kpi-icon kpi-blue"><i data-lucide="calendar" class="w-4 h-4" aria-hidden="true"></i></div>
            <div><div class="lt-kpi-num">@total</div><div class="lt-kpi-label">@Shared["Label_TotalSchedules"]</div></div>
        </div>
        <div class="lt-kpi">
            <div class="lt-kpi-icon kpi-green"><i data-lucide="check-circle" class="w-4 h-4" aria-hidden="true"></i></div>
            <div><div class="lt-kpi-num">@active</div><div class="lt-kpi-label">@Shared["Label_ActiveSchedules"]</div></div>
        </div>
        <div class="lt-kpi">
            <div class="lt-kpi-icon kpi-red"><i data-lucide="alert-circle" class="w-4 h-4" aria-hidden="true"></i></div>
            <div><div class="lt-kpi-num">@overdue</div><div class="lt-kpi-label">@Shared["Status_Overdue"]</div></div>
        </div>
        <div class="lt-kpi">
            <div class="lt-kpi-icon kpi-yellow"><i data-lucide="clock" class="w-4 h-4" aria-hidden="true"></i></div>
            <div><div class="lt-kpi-num">@dueWeek</div><div class="lt-kpi-label">@Shared["Label_DueThisWeek"]</div></div>
        </div>
    </div>

    <div class="lt-card">
        <div class="lt-table-wrap">
            <table class="esems-datatable" id="schedulesTable">
                <thead>
                    <tr>
                        <th>@Shared["Label_Asset"]</th>
                        <th>@Shared["Column_Type"]</th>
                        <th>@Shared["Column_Frequency"]</th>
                        <th>@Shared["Column_LastPerformed"]</th>
                        <th>@Shared["Column_NextScheduled"]</th>
                        <th>@Shared["Column_Status"]</th>
                        <th style="text-align:end;">@Shared["Column_Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var schedule in Model)
                    {
                        var isOverdue = schedule.IsActive && schedule.NextScheduledDate < DateTime.UtcNow;
                        var isDueSoon = schedule.IsActive && schedule.NextScheduledDate >= DateTime.UtcNow && schedule.NextScheduledDate <= DateTime.UtcNow.AddDays(7);
                        var statusCls = !schedule.IsActive ? "lt-pill-st-inactive" : isOverdue ? "lt-pill-st-overdue" : isDueSoon ? "lt-pill-st-soon" : "lt-pill-st-scheduled";
                        var statusText = !schedule.IsActive ? Shared["Status_Inactive"].Value : isOverdue ? Shared["Status_Overdue"].Value : isDueSoon ? Shared["Status_DueSoon"].Value : Shared["Status_Scheduled"].Value;
                        var rowCls = isOverdue ? "lt-row-overdue" : "";
                        <tr class="@rowCls">
                            <td>
                                <div style="font-weight:600;color:#111827;">@schedule.Asset?.AssetTag</div>
                                <div style="font-size: var(--fs-xs);color:#6b7280;">@(isRtl ? schedule.Asset?.NameAr : schedule.Asset?.NameEn)</div>
                            </td>
                            <td style="color:#374151;">@Shared[$"MaintenanceType_{schedule.Type}"]</td>
                            <td style="color:#374151;">@string.Format(Shared["Text_EveryXDays"].Value, schedule.FrequencyDays)</td>
                            <td style="color:#6b7280;">
                                @(schedule.LastPerformedDate.HasValue ? schedule.LastPerformedDate.Value.ToDubaiString("MMM dd, yyyy") : Shared["Status_Never"].Value)
                            </td>
                            <td style="color:#374151;white-space:nowrap;">@schedule.NextScheduledDate.ToDubaiString("MMM dd, yyyy")</td>
                            <td><span class="lt-pill @statusCls">@statusText</span></td>
                            <td style="text-align:end;">
                                <span class="lt-actions">
                                    <a asp-action="EditSchedule" asp-route-id="@schedule.Id" title="@Shared["Tooltip_EditRecord"]" aria-label="@Shared["Tooltip_EditRecord"]"><i data-lucide="edit" class="w-4 h-4" aria-hidden="true"></i></a>
                                </span>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" style="padding:3rem 1rem;text-align:center;color:#94a3b8;">
                            <i data-lucide="inbox" class="w-10 h-10" aria-hidden="true" style="margin:0 auto .5rem;display:block;color:#cbd5e1;"></i>
                            <div style="font-weight:500;">@(isRtl ? "لا توجد جداول صيانة بعد" : "No schedules yet")</div>
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.CspNonce()">if (window.lucide) lucide.createIcons();</script>
}
