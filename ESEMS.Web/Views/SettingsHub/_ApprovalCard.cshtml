@using ESEMS.Web.Models.Workflow
@inject IStringLocalizer<SharedResource> Shared
@model ((string Key, string LabelEn, string LabelAr, string Icon, string Color) entity, List<ApprovalConfiguration> rules)
@{
    var entity = Model.entity;
    var rules = Model.rules;
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar";
    var label = isRtl ? entity.LabelAr : entity.LabelEn;

    string FormatCondition(ApprovalConfiguration r)
    {
        var parts = new List<string>();
        if (r.MinCostSavings.HasValue || r.MaxCostSavings.HasValue)
        {
            var lo = r.MinCostSavings.HasValue ? $"{r.MinCostSavings.Value:N0}" : "0";
            var hi = r.MaxCostSavings.HasValue ? $"{r.MaxCostSavings.Value:N0}" : "∞";
            parts.Add($"💰 AED {lo}–{hi}");
        }
        if (r.MinImpactScore.HasValue || r.MaxImpactScore.HasValue)
        {
            var lo = r.MinImpactScore ?? 1;
            var hi = r.MaxImpactScore ?? 10;
            parts.Add($"⚡ Impact {lo}–{hi}");
        }
        if (r.MinDurationDays.HasValue || r.MaxDurationDays.HasValue)
        {
            var lo = r.MinDurationDays ?? 0;
            var hi = r.MaxDurationDays.HasValue ? r.MaxDurationDays.Value.ToString() : "∞";
            parts.Add($"⏱ {lo}–{hi}d");
        }
        if (!string.IsNullOrWhiteSpace(r.Horizon)) parts.Add($"🎯 {r.Horizon}");
        if (!string.IsNullOrWhiteSpace(r.InnovationType)) parts.Add($"🧩 {r.InnovationType}");
        return parts.Count == 0 ? (isRtl ? "قاعدة عامة (كل الطلبات)" : "Catch-all (any submission)") : string.Join(" · ", parts);
    }

    string L1Name(ApprovalConfiguration r) => r.Level1ApproverType == "DirectManager"
        ? Shared["Label_DirectManager"].Value
        : (r.Level1ApproverName ?? "—");
    string L2Name(ApprovalConfiguration r) => !r.Level2Required
        ? Shared["Text_Disabled"].Value
        : (r.Level2ApproverType == "DirectManager"
            ? Shared["Label_DirectManager"].Value
            : (r.Level2ApproverName ?? "—"));
}

<div id="card-@entity.Key" class="rounded-xl border border-gray-200 shadow-sm mb-5 overflow-hidden">
    <!-- Card header -->
    <div class="px-5 py-3 flex items-center gap-3" style="background: linear-gradient(135deg, @entity.Color 0%, @(entity.Color)cc 100%); color:#fff;">
        <span class="w-10 h-10 rounded-lg bg-white/20 flex items-center justify-center">
            <i data-lucide="@entity.Icon" class="w-5 h-5"></i>
        </span>
        <div class="flex-1">
            <h3 class="font-bold text-base">@label</h3>
            <div class="text-xs opacity-80 font-mono">@entity.Key · @rules.Count @Shared["Text_Rules"]</div>
        </div>
        <button type="button"
                onclick="ApprovalHub.openRuleEditor('@entity.Key', null)"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/20 hover:bg-white/30 rounded-lg text-xs font-semibold transition">
            <i data-lucide="plus" class="w-3.5 h-3.5"></i>
            @Shared["Button_AddRule"]
        </button>
    </div>

    <!-- Rules table -->
    <div class="bg-white">
        @if (rules.Count == 0)
        {
            <div class="py-10 text-center text-gray-500">
                <i data-lucide="inbox" class="w-8 h-8 mx-auto mb-2 opacity-50"></i>
                <p class="text-sm mb-3">@Shared["Text_NoRulesYet"]</p>
                <button type="button" onclick="ApprovalHub.openRuleEditor('@entity.Key', null)"
                        class="inline-flex items-center gap-2 px-4 py-2 text-white rounded-lg text-sm font-semibold"
                        style="background:@entity.Color;">
                    <i data-lucide="plus" class="w-4 h-4"></i>
                    @Shared["Button_CreateFirstRule"]
                </button>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-600 border-b border-gray-200">
                    <tr>
                        <th class="px-3 py-2 text-center font-semibold w-14">@Shared["Col_Priority"]</th>
                        <th class="px-3 py-2 text-start font-semibold">@Shared["Col_RuleName"]</th>
                        <th class="px-3 py-2 text-start font-semibold">@Shared["Col_Conditions"]</th>
                        <th class="px-3 py-2 text-start font-semibold">@Shared["Col_Level1"]</th>
                        <th class="px-3 py-2 text-start font-semibold">@Shared["Col_Level2"]</th>
                        <th class="px-3 py-2 text-center font-semibold w-24">@Shared["Col_Actions"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var r in rules)
                    {
                        <tr class="hover:bg-blue-50 transition">
                            <td class="px-3 py-3 text-center">
                                <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg font-mono font-bold text-white text-xs"
                                      style="background:@entity.Color;">@r.Priority</span>
                            </td>
                            <td class="px-3 py-3">
                                <div class="font-semibold text-gray-900">@(r.RuleName ?? Shared["Text_Untitled"].Value)</div>
                                <div class="text-[10px] text-gray-400 font-mono">@r.Id.Substring(0, 8)</div>
                            </td>
                            <td class="px-3 py-3">
                                <span class="text-xs text-gray-700">@FormatCondition(r)</span>
                            </td>
                            <td class="px-3 py-3">
                                <div class="flex items-center gap-2">
                                    <i data-lucide="user" class="w-3.5 h-3.5 text-gray-400"></i>
                                    <span class="text-gray-800 text-xs">@L1Name(r)</span>
                                </div>
                            </td>
                            <td class="px-3 py-3">
                                @if (r.Level2Required)
                                {
                                    <div class="flex items-center gap-2">
                                        <i data-lucide="user-plus" class="w-3.5 h-3.5 text-purple-500"></i>
                                        <span class="text-gray-800 text-xs">@L2Name(r)</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-gray-400 text-xs italic">@L2Name(r)</span>
                                }
                            </td>
                            <td class="px-3 py-3 text-center">
                                <div class="inline-flex gap-1">
                                    <button type="button"
                                            onclick="ApprovalHub.openRuleEditor('@entity.Key', '@r.Id')"
                                            class="p-1.5 rounded text-blue-600 hover:bg-blue-100 transition"
                                            title="@Shared["Button_Edit"]">
                                        <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                    </button>
                                    <button type="button"
                                            onclick="ApprovalHub.deleteRule('@r.Id')"
                                            class="p-1.5 rounded text-red-600 hover:bg-red-100 transition"
                                            title="@Shared["Button_Delete"]">
                                        <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
