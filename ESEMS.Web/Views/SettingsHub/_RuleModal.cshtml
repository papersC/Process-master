@inject IStringLocalizer<SharedResource> Shared
@{
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<!-- Rule editor modal — shared across all entity cards.
     Opened by ApprovalHub.openRuleEditor(entityKey, ruleId|null) which
     populates the fields from window.__hubRules. Saved by ApprovalHub.saveRule().
     Outer uses overflow-y-auto so the whole modal scrolls as one block if
     content is taller than the viewport — the header never gets clipped and
     there is always a visible gap at the top. -->
<div id="ruleModal" class="fixed inset-0 z-50 hidden overflow-y-auto bg-black/60">
    <div class="flex items-start justify-center min-h-full px-4 pt-36 pb-10">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-5xl flex flex-col">
        <!-- Header -->
        <div class="px-5 py-3 border-b border-gray-200 flex items-center justify-between flex-shrink-0">
            <div class="flex items-center gap-3">
                <span class="w-9 h-9 rounded-lg bg-blue-100 flex items-center justify-center">
                    <i data-lucide="shield-check" class="w-4 h-4 text-blue-700"></i>
                </span>
                <div>
                    <h3 id="ruleModalTitle" class="font-bold text-base text-gray-900">@Shared["Heading_EditRule"]</h3>
                    <p id="ruleModalEntity" class="text-xs text-gray-500 font-mono"></p>
                </div>
            </div>
            @* M-19 (Tier-3 a11y): icon-only close button needs an accessible name. *@
            <button type="button" onclick="ApprovalHub.closeRuleEditor()" class="p-2 hover:bg-gray-100 rounded-lg"
                    aria-label="@(System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? "إغلاق" : "Close")">
                <i data-lucide="x" class="w-5 h-5 text-gray-600" aria-hidden="true"></i>
            </button>
        </div>

        <!-- Scrollable body -->
        <div class="p-5 space-y-4 overflow-y-auto flex-1">
            <input type="hidden" id="ruleId" />
            <input type="hidden" id="ruleEntityType" />

            <!-- Rule identity -->
            <div class="grid grid-cols-12 gap-3">
                <div class="col-span-12 md:col-span-9">
                    <label class="block text-xs font-semibold text-gray-700 mb-1">@Shared["Label_RuleName"]</label>
                    <input type="text" id="ruleName" placeholder="@Shared["Placeholder_RuleName"]"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
                <div class="col-span-12 md:col-span-3">
                    @* M-19 (Tier-3 a11y): formally associate <label> with the input. *@
                    <label for="rulePriority" class="block text-xs font-semibold text-gray-700 mb-1">@Shared["Label_Priority"]</label>
                    <input type="number" id="rulePriority" value="100" min="1" max="999"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
            </div>

            <!-- Conditions: compact 2-column grid -->
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
                <div class="flex items-center gap-2 mb-3">
                    <i data-lucide="filter" class="w-4 h-4 text-gray-600"></i>
                    <h4 class="font-semibold text-sm text-gray-900">@Shared["Heading_WhenApplies"]</h4>
                    <span class="ms-auto text-[10px] text-gray-500 italic">@Shared["Help_WhenApplies_Short"]</span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <!-- Cost -->
                    <div>
                        <label class="block text-[11px] font-semibold text-gray-700 mb-1">@Shared["Label_CostSavings"] (AED)</label>
                        <div class="flex items-center gap-1">
                            <input type="number" id="ruleMinCost" placeholder="@Shared["Placeholder_From"]" min="0" step="1000"
                                   class="w-full px-2 py-1.5 border border-gray-300 rounded text-xs bg-white" />
                            <span class="text-gray-400 text-xs">–</span>
                            <input type="number" id="ruleMaxCost" placeholder="@Shared["Placeholder_To"]" min="0" step="1000"
                                   class="w-full px-2 py-1.5 border border-gray-300 rounded text-xs bg-white" />
                        </div>
                    </div>

                    <!-- Impact -->
                    <div>
                        <label class="block text-[11px] font-semibold text-gray-700 mb-1">@Shared["Label_ImpactScoreBand"] (1–10)</label>
                        <div class="flex items-center gap-1">
                            <input type="number" id="ruleMinImpact" placeholder="@Shared["Placeholder_From"]" min="1" max="10"
                                   class="w-full px-2 py-1.5 border border-gray-300 rounded text-xs bg-white" />
                            <span class="text-gray-400 text-xs">–</span>
                            <input type="number" id="ruleMaxImpact" placeholder="@Shared["Placeholder_To"]" min="1" max="10"
                                   class="w-full px-2 py-1.5 border border-gray-300 rounded text-xs bg-white" />
                        </div>
                    </div>

                    <!-- Duration -->
                    <div>
                        <label class="block text-[11px] font-semibold text-gray-700 mb-1">@Shared["Label_DurationBand"] (@Shared["Text_Days"])</label>
                        <div class="flex items-center gap-1">
                            <input type="number" id="ruleMinDuration" placeholder="@Shared["Placeholder_From"]" min="0"
                                   class="w-full px-2 py-1.5 border border-gray-300 rounded text-xs bg-white" />
                            <span class="text-gray-400 text-xs">–</span>
                            <input type="number" id="ruleMaxDuration" placeholder="@Shared["Placeholder_To"]" min="0"
                                   class="w-full px-2 py-1.5 border border-gray-300 rounded text-xs bg-white" />
                        </div>
                    </div>

                    <!-- Horizon -->
                    <div>
                        <label for="ruleHorizon" class="block text-[11px] font-semibold text-gray-700 mb-1">@Shared["Label_Horizon"]</label>
                        <select id="ruleHorizon" class="w-full px-2 py-1.5 border border-gray-300 rounded text-xs bg-white">
                            <option value="">@Shared["Option_Any"]</option>
                            <option value="Horizon1_Current">@Shared["Option_Horizon1_Current"]</option>
                            <option value="Horizon2_Expand">@Shared["Option_Horizon2_Expand"]</option>
                            <option value="Horizon3_Future">@Shared["Option_Horizon3_Future"]</option>
                        </select>
                    </div>

                    <!-- Innovation (spans full width on md+) -->
                    <div class="md:col-span-2">
                        <label for="ruleInnovation" class="block text-[11px] font-semibold text-gray-700 mb-1">@Shared["Label_InnovationType"]</label>
                        <select id="ruleInnovation" class="w-full px-2 py-1.5 border border-gray-300 rounded text-xs bg-white">
                            <option value="">@Shared["Option_Any"]</option>
                            <option value="Incremental">@Shared["Option_Incremental"]</option>
                            <option value="Breakthrough">@Shared["Option_Breakthrough"]</option>
                            <option value="Disruptive">@Shared["Option_Disruptive"]</option>
                            <option value="Transformative">@Shared["Option_Transformative"]</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Approver levels side-by-side -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <!-- Level 1 -->
                <div class="rounded-lg border border-gray-200 p-3">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="px-2 py-0.5 rounded text-[10px] font-bold text-white bg-blue-600">@Shared["Label_ApprovalLevel"] 1</span>
                        <span class="font-semibold text-xs text-gray-800 flex-1 truncate">@Shared["Label_FirstLevelApproval"]</span>
                        <span class="px-1.5 py-0.5 rounded-full bg-red-100 text-red-700 text-[10px] font-semibold">@Shared["Label_Required"]</span>
                    </div>
                    <!-- Approver type tiles (compact) -->
                    <div class="flex gap-1.5 mb-2">
                        <label class="flex-1 relative">
                            <input type="radio" name="ruleL1Type" value="DirectManager" class="sr-only peer" />
                            <div class="px-2 py-1.5 rounded-md border border-gray-300 bg-white peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:text-blue-700 cursor-pointer text-[10px] text-center font-semibold flex items-center justify-center gap-1">
                                <i data-lucide="user-check" class="w-3 h-3"></i>
                                <span>@Shared["Label_DirectManager"]</span>
                            </div>
                        </label>
                        <label class="flex-1 relative">
                            <input type="radio" name="ruleL1Type" value="SpecificUser" class="sr-only peer" checked />
                            <div class="px-2 py-1.5 rounded-md border border-gray-300 bg-white peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:text-blue-700 cursor-pointer text-[10px] text-center font-semibold flex items-center justify-center gap-1">
                                <i data-lucide="user" class="w-3 h-3"></i>
                                <span>@Shared["Label_SpecificUser"]</span>
                            </div>
                        </label>
                    </div>
                    <div id="ruleL1UserWrap">
                        <input type="hidden" id="ruleL1UserId" />
                        <input type="text" id="ruleL1Search" placeholder="@Shared["Placeholder_SearchUser"]" autocomplete="off"
                               class="w-full px-2 py-1.5 border border-gray-300 rounded-md text-xs" />
                        <div id="ruleL1Results" class="relative">
                            <div id="ruleL1Dropdown" class="absolute z-50 w-full bg-white border border-gray-200 rounded-lg shadow-lg mt-1 max-h-48 overflow-y-auto hidden"></div>
                        </div>
                        <div id="ruleL1Badge" class="mt-1.5 hidden"></div>
                    </div>
                </div>

                <!-- Level 2 -->
                <div class="rounded-lg border border-gray-200 p-3">
                    <label class="flex items-center gap-2 mb-2 cursor-pointer">
                        <input type="checkbox" id="ruleL2Enabled" class="w-4 h-4 text-purple-600 rounded border-gray-300 focus:ring-purple-500" />
                        <span class="px-2 py-0.5 rounded text-[10px] font-bold text-white bg-purple-600">@Shared["Label_ApprovalLevel"] 2</span>
                        <span class="font-semibold text-xs text-gray-800 flex-1 truncate">@Shared["Label_SecondLevelApproval"]</span>
                    </label>
                    <div id="ruleL2Body" class="hidden">
                        <div class="flex gap-1.5 mb-2">
                            <label class="flex-1 relative">
                                <input type="radio" name="ruleL2Type" value="DirectManager" class="sr-only peer" />
                                <div class="px-2 py-1.5 rounded-md border border-gray-300 bg-white peer-checked:border-purple-500 peer-checked:bg-purple-50 peer-checked:text-purple-700 cursor-pointer text-[10px] text-center font-semibold flex items-center justify-center gap-1">
                                    <i data-lucide="user-check" class="w-3 h-3"></i>
                                    <span>@Shared["Label_DirectManager"]</span>
                                </div>
                            </label>
                            <label class="flex-1 relative">
                                <input type="radio" name="ruleL2Type" value="SpecificUser" class="sr-only peer" checked />
                                <div class="px-2 py-1.5 rounded-md border border-gray-300 bg-white peer-checked:border-purple-500 peer-checked:bg-purple-50 peer-checked:text-purple-700 cursor-pointer text-[10px] text-center font-semibold flex items-center justify-center gap-1">
                                    <i data-lucide="user" class="w-3 h-3"></i>
                                    <span>@Shared["Label_SpecificUser"]</span>
                                </div>
                            </label>
                        </div>
                        <div id="ruleL2UserWrap">
                            <input type="hidden" id="ruleL2UserId" />
                            <input type="text" id="ruleL2Search" placeholder="@Shared["Placeholder_SearchUser"]" autocomplete="off"
                                   class="w-full px-2 py-1.5 border border-gray-300 rounded-md text-xs" />
                            <div id="ruleL2Results" class="relative">
                                <div id="ruleL2Dropdown" class="absolute z-50 w-full bg-white border border-gray-200 rounded-lg shadow-lg mt-1 max-h-48 overflow-y-auto hidden"></div>
                            </div>
                            <div id="ruleL2Badge" class="mt-1.5 hidden"></div>
                        </div>
                    </div>
                    <div id="ruleL2Placeholder" class="text-[10px] text-gray-400 italic py-2">@Shared["Help_Level2"]</div>
                </div>
            </div>

            <!-- SLA & Escalation -->
            <div class="rounded-lg border border-amber-200 bg-amber-50 p-4">
                <div class="flex items-center gap-2 mb-3">
                    <i data-lucide="alarm-clock" class="w-4 h-4 text-amber-600"></i>
                    <h4 class="font-semibold text-sm text-gray-900">@(isRtl ? "اتفاقية مستوى الخدمة والتصعيد التلقائي" : "SLA & auto-escalation")</h4>
                    <span class="ms-auto text-[10px] text-gray-500 italic">@(isRtl ? "تُحال الخطوات المتأخرة عن موعدها إلى مستخدم التصعيد تلقائياً (تعمل المهمة كل 15 دقيقة)" : "Steps past due are handed to the escalation user automatically (worker runs every 15 min)")</span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                    <div>
                        <label class="block text-[11px] font-semibold text-gray-700 mb-1">@(isRtl ? "اتفاقية مستوى الخدمة للمستوى 1 (ساعات)" : "Level 1 SLA (hours)")</label>
                        <input type="number" id="ruleL1Sla" min="1" max="720" placeholder="@(isRtl ? "مثال: 48" : "e.g. 48")"
                               class="w-full px-2 py-1.5 border border-gray-300 rounded text-xs bg-white" />
                    </div>
                    <div>
                        <label class="block text-[11px] font-semibold text-gray-700 mb-1">@(isRtl ? "اتفاقية مستوى الخدمة للمستوى 2 (ساعات)" : "Level 2 SLA (hours)")</label>
                        <input type="number" id="ruleL2Sla" min="1" max="720" placeholder="@(isRtl ? "مثال: 72" : "e.g. 72")"
                               class="w-full px-2 py-1.5 border border-gray-300 rounded text-xs bg-white" />
                    </div>
                    <div>
                        <label class="block text-[11px] font-semibold text-gray-700 mb-1">@(isRtl ? "التصعيد إلى" : "Escalate to")</label>
                        <input type="hidden" id="ruleEscUserId" />
                        <input type="text" id="ruleEscSearch" placeholder="@Shared["Placeholder_SearchUser"]" autocomplete="off"
                               class="w-full px-2 py-1.5 border border-gray-300 rounded text-xs bg-white" />
                        <div id="ruleEscResults" class="relative">
                            <div id="ruleEscDropdown" class="absolute z-50 w-full bg-white border border-gray-200 rounded-lg shadow-lg mt-1 max-h-48 overflow-y-auto hidden"></div>
                        </div>
                        <div id="ruleEscBadge" class="mt-1.5 hidden"></div>
                    </div>
                </div>
                <p class="text-[10px] text-gray-500 mt-2">
                    @(isRtl ? "اترك اتفاقية مستوى الخدمة فارغة لعدم تتبّع أي موعد نهائي. اترك حقل «التصعيد إلى» فارغاً لتسجيل تجاوز اتفاقية مستوى الخدمة دون إعادة الإسناد." : "Leave SLA blank to track no deadline. Leave \"Escalate to\" blank to log the SLA breach without reassigning.")
                </p>
            </div>
        </div>

        <!-- Footer -->
        <div class="px-5 py-3 border-t border-gray-200 flex items-center justify-end gap-2 bg-gray-50 flex-shrink-0">
            <button type="button" onclick="ApprovalHub.closeRuleEditor()"
                    class="px-4 py-2 bg-white border border-gray-300 hover:bg-gray-100 text-gray-700 rounded-lg text-sm font-semibold">
                @Shared["Button_Cancel"]
            </button>
            <button type="button" onclick="ApprovalHub.saveRule()"
                    class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-semibold inline-flex items-center gap-2 shadow-sm">
                <i data-lucide="save" class="w-4 h-4"></i>
                @Shared["Button_SaveChanges"]
            </button>
        </div>
        </div>
    </div>
</div>
