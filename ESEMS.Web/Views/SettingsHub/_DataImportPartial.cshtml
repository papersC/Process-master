@inject IStringLocalizer<SharedResource> Shared
@{
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<div class="mb-3">
    <h5 class="fw-bold mb-1">@Shared["Heading_DataImport"]</h5>
    <p class="text-muted small mb-0">@Shared["Help_DataImport"]</p>
</div>

<div class="alert alert-info small py-2 mb-3">
    <i data-lucide="info" style="width:14px;height:14px;margin-inline-end:4px;"></i>
    @Shared["Help_DataImportWorkflow"]
</div>

<!-- Import mode: Append (default) vs Replace (wipe the imported type first) -->
<div class="d-flex align-items-center gap-3 flex-wrap mb-3 p-2 px-3 rounded" style="background:#f8fafc;border:1px solid #e5e7eb;">
    <span class="fw-semibold small">@(isRtl ? "وضع الاستيراد:" : "Import mode:")</span>
    <div class="form-check form-check-inline mb-0">
        <input class="form-check-input" type="radio" name="importMode" id="importModeAppend" value="append" checked>
        <label class="form-check-label small" for="importModeAppend">@(isRtl ? "إلحاق — إضافة للموجود (تخطّي المكرر)" : "Append — add to existing (skip duplicates)")</label>
    </div>
    <div class="form-check form-check-inline mb-0">
        <input class="form-check-input" type="radio" name="importMode" id="importModeReplace" value="replace">
        <label class="form-check-label small text-danger fw-semibold" for="importModeReplace">@(isRtl ? "استبدال — حذف الموجود من نفس النوع أولاً" : "Replace — wipe existing of this type first")</label>
    </div>
</div>

<!-- Quick link to full import page -->
<div class="d-flex justify-content-end mb-3">
    <a asp-controller="Import" asp-action="Index" class="btn btn-sm btn-outline-primary">
        <i data-lucide="external-link" style="width:14px;height:14px;margin-inline-end:4px;"></i>
        @Shared["Button_OpenFullImportPage"]
    </a>
</div>

@* F-028: persistent import results log. The transient toast still fires for
   quick feedback, but the full list of row errors/warnings is rendered here so
   a large import with many issues leaves a durable record (was: toast showed
   max 3 then vanished). Populated by DataImport.upload(); dismiss with the ×. *@
<div id="importResultLog" class="mb-3" hidden></div>

<div class="row g-3">
    <!-- Processes -->
    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle" style="width:56px;height:56px;background:#f1f5f9;">
                    <i data-lucide="workflow" style="width:28px;height:28px;color:#475569;"></i>
                </div>
                <h6 class="fw-bold mb-1">@Shared["Label_Processes"]</h6>
                <p class="text-muted small mb-3">@Shared["Help_ImportProcesses"]</p>
                <a asp-controller="Import" asp-action="DownloadProcessesTemplate" class="btn btn-sm btn-outline-secondary w-100 mb-2">
                    <i data-lucide="download" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                    @Shared["Button_DownloadTemplate"]
                </a>
                <label class="btn btn-sm btn-primary w-100 mb-0">
                    <i data-lucide="upload" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                    @Shared["Button_Upload"]
                    <input type="file" accept=".xlsx,.xls" hidden onchange="DataImport.upload('processes', this.files[0])" />
                </label>
            </div>
        </div>
    </div>

    <!-- Services -->
    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle" style="width:56px;height:56px;background:#f1f5f9;">
                    <i data-lucide="package" style="width:28px;height:28px;color:#475569;"></i>
                </div>
                <h6 class="fw-bold mb-1">@Shared["Label_Services"]</h6>
                <p class="text-muted small mb-3">@Shared["Help_ImportServices"]</p>
                <a asp-controller="Import" asp-action="DownloadServicesTemplate" class="btn btn-sm btn-outline-secondary w-100 mb-2">
                    <i data-lucide="download" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                    @Shared["Button_DownloadTemplate"]
                </a>
                <label class="btn btn-sm btn-primary w-100 mb-0">
                    <i data-lucide="upload" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                    @Shared["Button_Upload"]
                    <input type="file" accept=".xlsx,.xls" hidden onchange="DataImport.upload('services', this.files[0])" />
                </label>
            </div>
        </div>
    </div>

    <!-- Assets -->
    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle" style="width:56px;height:56px;background:#f1f5f9;">
                    <i data-lucide="box" style="width:28px;height:28px;color:#475569;"></i>
                </div>
                <h6 class="fw-bold mb-1">@Shared["Label_Assets"]</h6>
                <p class="text-muted small mb-3">@Shared["Help_ImportAssets"]</p>
                <a asp-controller="Import" asp-action="DownloadAssetsTemplate" class="btn btn-sm btn-outline-secondary w-100 mb-2">
                    <i data-lucide="download" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                    @Shared["Button_DownloadTemplate"]
                </a>
                <label class="btn btn-sm btn-primary w-100 mb-0">
                    <i data-lucide="upload" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                    @Shared["Button_Upload"]
                    <input type="file" accept=".xlsx,.xls" hidden onchange="DataImport.upload('assets', this.files[0])" />
                </label>
            </div>
        </div>
    </div>

    <!-- Risks -->
    <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle" style="width:56px;height:56px;background:#f1f5f9;">
                    <i data-lucide="alert-triangle" style="width:28px;height:28px;color:#475569;"></i>
                </div>
                <h6 class="fw-bold mb-1">@Shared["Label_Risks"]</h6>
                <p class="text-muted small mb-3">@Shared["Help_ImportRisks"]</p>
                <a asp-controller="Import" asp-action="DownloadRisksTemplate" class="btn btn-sm btn-outline-secondary w-100 mb-2">
                    <i data-lucide="download" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                    @Shared["Button_DownloadTemplate"]
                </a>
                <label class="btn btn-sm btn-primary w-100 mb-0">
                    <i data-lucide="upload" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                    @Shared["Button_Upload"]
                    <input type="file" accept=".xlsx,.xls" hidden onchange="DataImport.upload('risks', this.files[0])" />
                </label>
            </div>
        </div>
    </div>
</div>

<!-- Legacy MBRHE Asset Register — 4-column client xlsx import -->
<div class="mt-4">
    <h6 class="fw-bold mb-2">
        <i data-lucide="archive" style="width:16px;height:16px;margin-inline-end:4px;"></i>
        @(isRtl ? "استيراد سجلات العميل (تنسيق قديم)" : "Legacy client imports")
    </h6>
    <div class="alert alert-info small py-2 mb-3">
        <i data-lucide="info" style="width:14px;height:14px;margin-inline-end:4px;"></i>
        @(isRtl
            ? "الترتيب الموصى به: استورد «الهيكل التنظيمي» أولاً ثم «الأصول» — يُربط كل أصل بإدارته المالكة بالاسم. كتالوج الخدمات وخريطة APQC مستقلان. استوردت بترتيب خاطئ؟ استخدم «حذف هذا الاستيراد» أدناه ثم أعد الاستيراد."
            : "Recommended order: import Org Structure first, then Assets — each asset links to its owning department by name. Services and APQC are self-contained. Imported in the wrong order? Use “Delete this import” below, then re-import.")
    </div>
    <div class="row g-3">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm h-100 border-secondary-subtle">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i data-lucide="building-2" style="width:22px;height:22px;color:#475569;"></i>
                        <h6 class="fw-bold mb-0">@(isRtl ? "سجل أصول المؤسسة (MBRHE)" : "MBRHE Asset Register")</h6>
                    </div>
                    <p class="text-muted small mb-3">
                        @(isRtl
                            ? "ملف العميل بأربعة أعمدة فقط (الاسم، الوصف، التصنيف، الوحدة المالكة). يُحوّل تلقائياً: التصنيف Digital → فئة أصل معلوماتي، Physical → مشروع إسكاني، مع توليد رقم الأصل واستنتاج عدد المساكن من الاسم."
                            : "The client's 4-column xlsx (Asset Name, Description, Classification, Owner). Mapped automatically: Digital → information-asset category, Physical → housing-project category, with auto-generated AssetTag and unit-count parsed from the name.")
                    </p>
                    <label class="btn btn-sm btn-primary w-100 mb-0">
                        <i data-lucide="upload" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                        @Shared["Button_Upload"]
                        <input type="file" accept=".xlsx,.xls" hidden onchange="DataImport.upload('mbrhe-assets', this.files[0])" />
                    </label>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm h-100 border-secondary-subtle">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i data-lucide="network" style="width:22px;height:22px;color:#475569;"></i>
                        <h6 class="fw-bold mb-0">@(isRtl ? "الهيكل التنظيمي والمهام (MBRHE)" : "MBRHE Org Structure + Functional Tasks")</h6>
                    </div>
                    <p class="text-muted small mb-3">
                        @(isRtl
                            ? "ملف العميل بورقتين: «الهيكل التنظيمي» (38 وحدة بهيكل شجري) و«المهام الوظيفية» (283+ مهمة موزعة على الوحدات). يُنشئ وحدات تنظيمية مع روابط الوحدة الأم والنوع، ومسؤوليات لكل وحدة."
                            : "The client's two-sheet xlsx: \"Org Structure\" (38 units with parent linkage + type) and \"Functional Tasks\" (283+ tasks grouped under each unit). Creates OrganizationUnit rows with ParentId resolved from the parent-name column, plus OrganizationUnitResponsibility rows for the tasks.")
                    </p>
                    <label class="btn btn-sm btn-primary w-100 mb-0">
                        <i data-lucide="upload" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                        @Shared["Button_Upload"]
                        <input type="file" accept=".xlsx,.xls" hidden onchange="DataImport.upload('mbrhe-org', this.files[0])" />
                    </label>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm h-100 border-secondary-subtle">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i data-lucide="book-open" style="width:22px;height:22px;color:#475569;"></i>
                        <h6 class="fw-bold mb-0">@(isRtl ? "كتالوج خدمات المؤسسة (MBRHE)" : "MBRHE Services Catalog")</h6>
                    </div>
                    <p class="text-muted small mb-3">
                        @(isRtl
                            ? "ملف العميل بـ 22 عموداً ثنائي اللغة (الورقة \"MBRHE Services\"). يُنشئ خدمة كاملة مع محتوى الكتالوج (الجمهور المستهدف، الشروط، السياسات، الإجراء، القنوات، الرسوم)، ويُنشئ فئات الخدمات المفقودة تلقائياً."
                            : "The client's 22-column bilingual xlsx (sheet \"MBRHE Services\"). Creates a full Service + ServiceCatalogInfo sidecar (target audience, pre-conditions, policies, procedure, channels, fees), and auto-creates missing service categories.")
                    </p>
                    <label class="btn btn-sm btn-primary w-100 mb-0">
                        <i data-lucide="upload" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                        @Shared["Button_Upload"]
                        <input type="file" accept=".xlsx,.xls" hidden onchange="DataImport.upload('mbrhe-services', this.files[0])" />
                    </label>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm h-100 border-secondary-subtle">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i data-lucide="git-branch" style="width:22px;height:22px;color:#475569;"></i>
                        <h6 class="fw-bold mb-0">@(isRtl ? "خريطة عمليات APQC" : "APQC Process Mapping")</h6>
                    </div>
                    <p class="text-muted small mb-3">
                        @(isRtl
                            ? "ملف العميل الكبير (225 صفاً × 25 عموداً) يغطي التسلسل الهرمي الثلاثي لـ APQC. يُنشئ الفئات (L1) ومجموعات العمليات (L2) والعمليات (L3) مع التصنيف ومستوى الأتمتة ووضع الحالي/المقترح. الروابط مع الوحدات والأنظمة والخدمات والشركاء تُترك للإكمال لاحقاً."
                            : "The client's 225-row × 25-col denormalized APQC hierarchy. Creates Categories (L1), ProcessGroups (L2), and Processes (L3) with classification, automation level, automability, and Current/Proposed status. Cross-entity links (Org Units, Digital Systems, Linked Services, Government Partners, Strategic Objectives) deferred to follow-up.")
                    </p>
                    <label class="btn btn-sm btn-primary w-100 mb-0">
                        <i data-lucide="upload" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                        @Shared["Button_Upload"]
                        <input type="file" accept=".xlsx,.xls" hidden onchange="DataImport.upload('mbrhe-apqc', this.files[0])" />
                    </label>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- BPMN drawings library — bulk import of .bpmn files from output2/ -->
<div class="mt-4">
    <h6 class="fw-bold mb-2">
        <i data-lucide="file-code-2" style="width:16px;height:16px;margin-inline-end:4px;"></i>
        @(isRtl ? "مكتبة رسومات BPMN" : "BPMN Drawings Library")
    </h6>
    <div class="alert alert-info small py-2 mb-3">
        <i data-lucide="info" style="width:14px;height:14px;margin-inline-end:4px;"></i>
        @(isRtl
            ? "يستورد ملفات BPMN من مجلد output2/ في جذر التطبيق ويربط كل ملف برشاقة بعملية المستوى الثالث المقابلة بالاسم العربي. الملفات التي لا يتم العثور على عملية مناسبة لها تُحفظ في النظام لربطها لاحقاً يدوياً أو لإنشاء عملية جديدة من رسمها."
            : "Imports the .bpmn files from the output2/ folder at the app root and fuzzy-matches each one to an L3 Process by Arabic/English name. Files that don't auto-match are kept in the system so you can later link them by hand or create a Process from the drawing.")
    </div>
    <div class="card shadow-sm border-secondary-subtle">
        <div class="card-body">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <i data-lucide="library-big" style="width:22px;height:22px;color:#475569;"></i>
                    <div>
                        <div class="fw-bold">@(isRtl ? "استيراد كل رسومات BPMN" : "Import All BPMN Drawings")</div>
                        <div class="text-muted small" id="bpmnLibSubtitle">
                            @(isRtl
                                ? "اضغط «معاينة» لمسح المجلد ورؤية اقتراحات الربط قبل تنفيذ الاستيراد."
                                : "Click Preview to scan the folder and review match suggestions before any DB write.")
                        </div>
                    </div>
                </div>
                <button type="button" id="bpmnLibPreviewBtn" class="btn btn-sm btn-primary">
                    <i data-lucide="search" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                    @(isRtl ? "معاينة الربط" : "Preview mappings")
                </button>
            </div>
        </div>
    </div>
</div>

<!-- BPMN library preview modal — populated on demand -->
<div class="modal fade" id="bpmnLibModal" tabindex="-1" aria-labelledby="bpmnLibModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="bpmnLibModalLabel">
                    <i data-lucide="library-big" style="width:18px;height:18px;margin-inline-end:6px;"></i>
                    @(isRtl ? "تأكيد ربط ملفات BPMN" : "Confirm BPMN file mappings")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="bpmnLibSummary" class="alert alert-light border small mb-3"></div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle small">
                        <thead class="table-light">
                            <tr>
                                <th style="width:50px;">@(isRtl ? "رقم" : "#")</th>
                                <th>@(isRtl ? "الملف" : "File")</th>
                                <th style="min-width:280px;">@(isRtl ? "ربط بعملية" : "Link to Process")</th>
                                <th>@(isRtl ? "نتيجة المطابقة" : "Match")</th>
                            </tr>
                        </thead>
                        <tbody id="bpmnLibTbody"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between align-items-center">
                <div class="small text-muted" id="bpmnLibFooterMeta"></div>
                <div>
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">
                        @(isRtl ? "إلغاء" : "Cancel")
                    </button>
                    <button type="button" class="btn btn-sm btn-primary" id="bpmnLibConfirmBtn">
                        <i data-lucide="check" style="width:14px;height:14px;margin-inline-end:4px;"></i>
                        @(isRtl ? "تنفيذ الاستيراد" : "Run import")
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent legacy imports — undo a run -->
<div class="mt-4">
    <h6 class="fw-bold mb-2">
        <i data-lucide="history" style="width:16px;height:16px;margin-inline-end:4px;"></i>
        @(isRtl ? "عمليات الاستيراد الأخيرة" : "Recent imports")
    </h6>
    <p class="text-muted small mb-3">
        @(isRtl
            ? "تراجَع عن أي عملية استيراد قديمة لحذف جميع الصفوف التي أنشأتها، حتى تتمكن من تصحيح الملف وإعادة الاستيراد. تبقى الصفوف المرتبطة ببيانات أخرى دون حذف."
            : "Undo a legacy import to delete every row it created — so you can fix the file and re-import. Rows that are now referenced by other data are kept.")
    </p>
    <div id="recentImportsList" class="d-flex flex-column gap-2">
        <div class="text-muted small">@(isRtl ? "جارٍ التحميل…" : "Loading…")</div>
    </div>
</div>

<!-- Export section -->
<div class="mt-4">
    <h6 class="fw-bold mb-2"><i data-lucide="download-cloud" style="width:16px;height:16px;margin-inline-end:4px;"></i>@Shared["Heading_Export"]</h6>
    <p class="text-muted small mb-3">@Shared["Help_Export"]</p>
    <div class="d-flex flex-wrap gap-2">
        <a asp-controller="Import" asp-action="ExportProcesses" class="btn btn-sm btn-outline-primary"><i data-lucide="workflow" style="width:14px;height:14px;margin-inline-end:4px;"></i>@Shared["Label_Processes"]</a>
        <a asp-controller="Import" asp-action="ExportServices" class="btn btn-sm btn-outline-primary"><i data-lucide="package" style="width:14px;height:14px;margin-inline-end:4px;"></i>@Shared["Label_Services"]</a>
        <a asp-controller="Import" asp-action="ExportAssets" class="btn btn-sm btn-outline-primary"><i data-lucide="box" style="width:14px;height:14px;margin-inline-end:4px;"></i>@Shared["Label_Assets"]</a>
        <a asp-controller="Import" asp-action="ExportRisks" class="btn btn-sm btn-outline-primary"><i data-lucide="alert-triangle" style="width:14px;height:14px;margin-inline-end:4px;"></i>@Shared["Label_Risks"]</a>
    </div>
</div>

<script nonce="@Context.CspNonce()">
window.DataImport = (function() {
    var IS_RTL = @(isRtl ? "true" : "false");
    var T = IS_RTL ? {
        deleteBtn: 'حذف هذا الاستيراد',
        confirm:   'سيتم حذف جميع الصفوف التي أنشأها هذا الاستيراد. هل أنت متأكد؟',
        none:      'لا توجد عمليات استيراد حديثة يمكن التراجع عنها.',
        loadFail:  'تعذّر تحميل عمليات الاستيراد الأخيرة.',
        rows:      'صف',
        skipped:   'تم تخطّي',
        deleting:  'جارٍ الحذف…',
        errorsLabel:   'أخطاء الصفوف',
        warningsLabel: 'تحذيرات',
        rowWord:       'صف',
        dismiss:       'إغلاق'
    } : {
        deleteBtn: 'Delete this import',
        confirm:   'This will delete every row this import created. Continue?',
        none:      'No recent imports to undo.',
        loadFail:  'Couldn’t load recent imports.',
        rows:      'rows',
        skipped:   'skipped',
        deleting:  'Deleting…',
        errorsLabel:   'Row errors',
        warningsLabel: 'Warnings',
        rowWord:       'row',
        dismiss:       'Dismiss'
    };

    // Human labels for the Replace-mode confirm. Only kinds listed here support
    // Replace; anything else (e.g. org) silently falls back to Append.
    var REPLACE_LABELS = IS_RTL ? {
        'processes':      'العمليات',
        'mbrhe-apqc':     'الفئات ومجموعات العمليات والعمليات (كتالوج APQC)',
        'services':       'الخدمات',
        'mbrhe-services': 'الخدمات',
        'assets':         'الأصول',
        'mbrhe-assets':   'الأصول',
        'risks':          'المخاطر'
    } : {
        'processes':      'Processes',
        'mbrhe-apqc':     'Categories, Process Groups & Processes (APQC catalog)',
        'services':       'Services',
        'mbrhe-services': 'Services',
        'assets':         'Assets',
        'mbrhe-assets':   'Assets',
        'risks':          'Risks'
    };

    function esc(s) {
        return (s == null ? '' : String(s)).replace(/[&<>"']/g, function(c) {
            return ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', '\'':'&#39;' })[c];
        });
    }

    async function upload(kind, file) {
        if (!file) return;

        // Append/Replace toggle. Replace wipes the imported type's existing data
        // first — confirm before the destructive action; unsupported kinds append.
        var modeEl = document.querySelector('input[name=importMode]:checked');
        var mode = modeEl ? modeEl.value : 'append';
        if (mode === 'replace') {
            var label = REPLACE_LABELS[kind];
            if (!label) {
                ShubToast('info', IS_RTL
                    ? 'الاستبدال غير مدعوم لهذا النوع — سيتم الإلحاق بدلاً من ذلك.'
                    : 'Replace isn’t supported for this type — appending instead.');
                mode = 'append';
            } else if (!window.confirm(
                (IS_RTL ? 'وضع الاستبدال: سيتم حذف كل سجلات «' : 'Replace mode: this permanently deletes all existing ')
                + label
                + (IS_RTL ? '» الحالية نهائياً قبل الاستيراد. هل تريد المتابعة؟' : ' before importing. Continue?'))) {
                return;
            }
        }

        ShubToast('info', '@Html.Raw(Shared["Toast_UploadStarted"].Value)');
        var fd = new FormData();
        fd.append('__RequestVerificationToken', ShubToken());
        fd.append('kind', kind);
        fd.append('mode', mode);
        fd.append('file', file);
        try {
            var r = await fetch('/SettingsHub/ImportUpload', { method: 'POST', body: fd });
            var d = await r.json();
            if (d.success) ShubToast((d.warnings && d.warnings.length) ? 'info' : 'success', d.message || '@Html.Raw(Shared["Toast_UploadQueued"].Value)');
            else ShubToast('error', d.error || '@Html.Raw(Shared["Js_UploadFailed"].Value)');
            renderResult(kind, d); // F-028: persist the full error/warning list
        } catch (e) {
            ShubToast('error', e.message);
            renderResult(kind, { success: false, error: e.message });
        }
        loadRecent();
    }

    // F-028: render the full, non-disappearing import outcome (summary + every
    // row error and warning) into #importResultLog. esc() guards all messages.
    function renderResult(kind, d) {
        var panel = document.getElementById('importResultLog');
        if (!panel) return;
        var ok = !!d.success;
        var hasWarn = d.warnings && d.warnings.length;
        var headClass = ok ? (hasWarn ? 'warning' : 'success') : 'danger';
        var summary = esc(d.message || d.error || '');
        var html = '<div class="d-flex justify-content-between align-items-start gap-2">'
            + '<div class="fw-semibold small">' + esc(kind) + ' — ' + summary + '</div>'
            + '<button type="button" class="btn-close" style="font-size:.6rem;" aria-label="' + esc(T.dismiss) + '" data-dismiss-log></button>'
            + '</div>';
        function list(items, label, color) {
            if (!items || !items.length) return '';
            return '<div class="mt-2 small fw-semibold" style="color:' + color + ';">' + esc(label) + ' (' + items.length + ')</div>'
                + '<ul class="small mb-0 ps-3" style="max-height:160px;overflow:auto;color:' + color + ';">'
                + items.map(function (e) { return '<li>' + esc(T.rowWord) + ' ' + esc(e.row) + ': ' + esc(e.message) + '</li>'; }).join('')
                + '</ul>';
        }
        html += list(d.errors, T.errorsLabel, '#b91c1c');
        html += list(d.warnings, T.warningsLabel, '#b45309');
        panel.className = 'mb-3 alert alert-' + headClass;
        panel.innerHTML = html;
        panel.hidden = false;
        if (window.lucide && window.lucide.createIcons) window.lucide.createIcons();
    }

    function render(items) {
        var list = document.getElementById('recentImportsList');
        if (!list) return;
        if (!items || !items.length) {
            list.innerHTML = '<div class="text-muted small">' + esc(T.none) + '</div>';
            return;
        }
        list.innerHTML = items.map(function(it) {
            var when = '';
            try { when = new Date(it.createdAt).toLocaleString(); } catch (e) {}
            var meta = esc(it.imported) + ' ' + esc(T.rows)
                + (it.skipped ? ' · ' + esc(it.skipped) + ' ' + esc(T.skipped) : '')
                + (it.fileName ? ' · ' + esc(it.fileName) : '')
                + (when ? ' · ' + esc(when) : '');
            return '<div class="d-flex align-items-center justify-content-between border rounded p-2">'
                +   '<div class="me-2">'
                +     '<div class="fw-semibold small">' + esc(it.kindLabel) + '</div>'
                +     '<div class="text-muted" style="font-size:.75rem;">' + meta + '</div>'
                +   '</div>'
                +   '<button type="button" class="btn btn-sm btn-outline-danger flex-shrink-0" data-revert-id="' + esc(it.id) + '">'
                +     '<i data-lucide="trash-2" style="width:14px;height:14px;margin-inline-end:4px;"></i>' + esc(T.deleteBtn)
                +   '</button>'
                + '</div>';
        }).join('');
        if (window.lucide && window.lucide.createIcons) window.lucide.createIcons();
    }

    async function loadRecent() {
        var list = document.getElementById('recentImportsList');
        if (!list) return;
        try {
            var r = await fetch('/SettingsHub/RecentImports', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            var d = await r.json();
            render(d.items || []);
        } catch (e) {
            list.innerHTML = '<div class="text-danger small">' + esc(T.loadFail) + '</div>';
        }
    }

    async function revert(id, btn) {
        if (!window.confirm(T.confirm)) return;
        if (btn) { btn.disabled = true; btn.textContent = T.deleting; }
        var fd = new FormData();
        fd.append('__RequestVerificationToken', ShubToken());
        fd.append('id', id);
        try {
            var r = await fetch('/SettingsHub/RevertImport', { method: 'POST', body: fd });
            var d = await r.json();
            if (d.success) ShubToast('success', d.message || 'Done.');
            else ShubToast('error', d.error || 'Undo failed.');
        } catch (e) { ShubToast('error', e.message); }
        loadRecent();
    }

    // Delegated click for the dynamically-rendered delete buttons (CSP-safe — no inline handlers).
    document.addEventListener('click', function(ev) {
        if (!ev.target || !ev.target.closest) return;
        // F-028: dismiss the persistent import results log.
        if (ev.target.closest('[data-dismiss-log]')) {
            var panel = document.getElementById('importResultLog');
            if (panel) { panel.hidden = true; panel.innerHTML = ''; }
            return;
        }
        var btn = ev.target.closest('[data-revert-id]');
        if (!btn) return;
        ev.preventDefault();
        revert(btn.getAttribute('data-revert-id'), btn);
    });

    if (document.readyState !== 'loading') loadRecent();
    else document.addEventListener('DOMContentLoaded', loadRecent);

    return { upload: upload, loadRecent: loadRecent, revert: revert };
})();

// BPMN library importer — preview-then-confirm flow against /SettingsHub/BpmnLibrary*
window.BpmnLibraryImport = (function () {
    var IS_RTL = @(isRtl ? "true" : "false");
    var T = IS_RTL ? {
        previewing:   'جارٍ مسح المجلد…',
        importing:    'جارٍ تنفيذ الاستيراد…',
        noFiles:      'لم يتم العثور على ملفات .bpmn في المجلد.',
        scanFailed:   'فشل مسح المجلد',
        importFailed: 'فشل تنفيذ الاستيراد',
        summary:      function (t, m, u, e) { return 'تم العثور على ' + t + ' ملف(ات): ' + m + ' مطابقة تلقائية، ' + u + ' بدون مطابقة، ' + e + ' خطأ قراءة.'; },
        leaveOrphan:  '— احفظ كرسم منفصل (بدون عملية) —',
        orphanBadge:  'سيتم حفظه للاستخدام لاحقاً',
        overwriteWarn: 'لدى هذه العملية رسم BPMN حالياً — الاستيراد سيستبدله (مع الاحتفاظ بنسخة قديمة).',
        scoreLabel:   'النقاط',
        readError:    'خطأ قراءة',
        existingDiagram: 'يوجد رسم',
        done:         'تم'
    } : {
        previewing:   'Scanning folder…',
        importing:    'Importing…',
        noFiles:      'No .bpmn files found in the folder.',
        scanFailed:   'Folder scan failed',
        importFailed: 'Import failed',
        summary:      function (t, m, u, e) { return t + ' file(s): ' + m + ' auto-matched, ' + u + ' unmatched, ' + e + ' read error(s).'; },
        leaveOrphan:  '— Store as orphan (no Process) —',
        orphanBadge:  'Will be stored for later',
        overwriteWarn:'This Process already has a BPMN diagram — importing will replace it (old kept as a version).',
        scoreLabel:   'score',
        readError:    'read error',
        existingDiagram: 'has diagram',
        done:         'Done'
    };

    var bsModal = null;
    var latest = null;

    function esc(s) {
        return (s == null ? '' : String(s)).replace(/[&<>"']/g, function (c) {
            return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', '\'': '&#39;' })[c];
        });
    }

    function getModal() {
        if (!bsModal) {
            var el = document.getElementById('bpmnLibModal');
            bsModal = bootstrap.Modal.getOrCreateInstance(el);
        }
        return bsModal;
    }

    function buildOptions(file) {
        // Suggested goes first when present; then alternatives; then explicit orphan choice.
        var seen = {};
        var optionsHtml = '';

        if (file.suggestedProcessId) {
            seen[file.suggestedProcessId] = true;
            var label = (file.suggestedProcessCode ? '[' + file.suggestedProcessCode + '] ' : '')
                + (IS_RTL ? (file.suggestedProcessNameAr || file.suggestedProcessNameEn || file.suggestedProcessId)
                          : (file.suggestedProcessNameEn || file.suggestedProcessNameAr || file.suggestedProcessId));
            optionsHtml += '<option value="' + esc(file.suggestedProcessId) + '" selected>'
                + esc(label) + ' (' + (file.score != null ? file.score.toFixed(2) : '—') + ')'
                + '</option>';
        }

        (file.alternatives || []).forEach(function (a) {
            if (seen[a.processId]) return;
            seen[a.processId] = true;
            var label = (a.code ? '[' + a.code + '] ' : '')
                + (IS_RTL ? (a.nameAr || a.nameEn || a.processId) : (a.nameEn || a.nameAr || a.processId));
            optionsHtml += '<option value="' + esc(a.processId) + '">'
                + esc(label) + ' (' + (a.score != null ? a.score.toFixed(2) : '—') + ')'
                + '</option>';
        });

        // Orphan option — present even when there's a suggestion so the user can opt out.
        var orphanSelected = file.suggestedProcessId ? '' : ' selected';
        optionsHtml = '<option value=""' + orphanSelected + '>' + esc(T.leaveOrphan) + '</option>' + optionsHtml;

        return optionsHtml;
    }

    function renderRow(file, idx) {
        var meta = [];
        if (file.processAlreadyHasDiagram) {
            meta.push('<span class="badge text-bg-warning" title="' + esc(T.overwriteWarn) + '">' + esc(T.existingDiagram) + '</span>');
        }
        if (file.readError) {
            meta.push('<span class="badge text-bg-danger">' + esc(T.readError) + '</span>');
            if (file.readErrorMessage) {
                meta.push('<span class="text-muted small">' + esc(file.readErrorMessage) + '</span>');
            }
        }
        if (!file.suggestedProcessId && !file.readError) {
            meta.push('<span class="badge text-bg-secondary">' + esc(T.orphanBadge) + '</span>');
        }
        if (file.matchHow && file.matchHow !== 'none') {
            meta.push('<code class="small text-muted">' + esc(file.matchHow) + '</code>');
        }

        var disabled = file.readError ? ' disabled' : '';
        var detected = file.detectedName || '';
        var sizeKb = (file.xmlSizeBytes / 1024).toFixed(1);

        return '<tr data-file="' + esc(file.fileName) + '">'
            + '<td class="text-muted">' + esc(file.filePrefix || (idx + 1)) + '</td>'
            + '<td>'
            +   '<div class="fw-semibold">' + esc(detected) + '</div>'
            +   '<div class="text-muted small">' + esc(file.fileName) + ' · ' + esc(sizeKb) + ' KB</div>'
            + '</td>'
            + '<td>'
            +   '<select class="form-select form-select-sm bpmn-lib-pick"' + disabled + '>'
            +     buildOptions(file)
            +   '</select>'
            + '</td>'
            + '<td class="small">' + meta.join(' ') + '</td>'
            + '</tr>';
    }

    function renderPreview(data) {
        latest = data;
        var modalLabel = document.getElementById('bpmnLibModalLabel');
        if (modalLabel && data.folder) {
            // Folder path on the title row helps the user spot misconfig.
        }
        var summary = document.getElementById('bpmnLibSummary');
        if (data.totalFiles === 0) {
            summary.innerHTML = '<div>' + esc(T.noFiles) + '</div>'
                + '<div class="text-muted small">' + esc(data.folder) + '</div>';
            document.getElementById('bpmnLibTbody').innerHTML = '';
            document.getElementById('bpmnLibFooterMeta').textContent = '';
            return;
        }
        summary.innerHTML = '<div class="fw-semibold">' + esc(T.summary(data.totalFiles, data.matchedCount, data.unmatchedCount, data.readErrorCount)) + '</div>'
            + '<div class="text-muted small mt-1">' + esc(data.folder) + '</div>';

        var rowsHtml = (data.files || []).map(renderRow).join('');
        document.getElementById('bpmnLibTbody').innerHTML = rowsHtml;
        document.getElementById('bpmnLibFooterMeta').textContent = data.folder;

        if (window.lucide && window.lucide.createIcons) window.lucide.createIcons();
    }

    async function preview() {
        var btn = document.getElementById('bpmnLibPreviewBtn');
        if (btn) { btn.disabled = true; }
        ShubToast('info', T.previewing);
        try {
            var r = await fetch('/SettingsHub/BpmnLibraryPreview', {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            var d = await r.json();
            if (!d.success) {
                ShubToast('error', d.error || T.scanFailed);
                return;
            }
            renderPreview(d);
            getModal().show();
        } catch (e) {
            ShubToast('error', e.message || T.scanFailed);
        } finally {
            if (btn) { btn.disabled = false; }
        }
    }

    async function runImport() {
        if (!latest || !latest.files) return;
        var mappings = {};
        document.querySelectorAll('#bpmnLibTbody tr').forEach(function (tr) {
            var fname = tr.getAttribute('data-file');
            var sel = tr.querySelector('select.bpmn-lib-pick');
            mappings[fname] = sel && !sel.disabled ? (sel.value || '') : '';
        });

        var confirmBtn = document.getElementById('bpmnLibConfirmBtn');
        if (confirmBtn) { confirmBtn.disabled = true; }
        ShubToast('info', T.importing);
        try {
            var r = await fetch('/SettingsHub/BpmnLibraryImport', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': ShubToken()
                },
                body: JSON.stringify({ mappings: mappings })
            });
            var d = await r.json();
            if (d.success) {
                ShubToast('success', d.message || T.done);
                getModal().hide();
            } else {
                ShubToast('error', d.error || (d.message || T.importFailed));
            }
        } catch (e) {
            ShubToast('error', e.message || T.importFailed);
        } finally {
            if (confirmBtn) { confirmBtn.disabled = false; }
        }
    }

    document.addEventListener('click', function (ev) {
        var trg = ev.target && ev.target.closest ? ev.target.closest('#bpmnLibPreviewBtn') : null;
        if (trg) { ev.preventDefault(); preview(); return; }
        var conf = ev.target && ev.target.closest ? ev.target.closest('#bpmnLibConfirmBtn') : null;
        if (conf) { ev.preventDefault(); runImport(); }
    });

    return { preview: preview, runImport: runImport };
})();
</script>
