@model IEnumerable<ImprovementInitiative>
@{
    ViewData["Title"] = Shared["Title_Improvements"].Value;
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<style>
    .lt-shell { display: flex; flex-direction: column; gap: .6rem; }
    .lt-header { display: flex; align-items: center; justify-content: space-between; padding: .25rem 0 .4rem; border-bottom: 1px solid #e5e7eb; }
    .lt-header h1 { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .5rem; }
    .lt-header p { margin: 0; font-size: var(--fs-xs); color: #6b7280; }
    .lt-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; border: none; }
    .lt-btn-primary { background: #005B99; color: #fff; } .lt-btn-primary:hover { background: #003d6b; color: #fff; }
    .lt-btn-outline { background: #fff; color: #005B99; border: 1px solid #cbd5e1; } .lt-btn-outline:hover { background: #f1f5f9; }
    .lt-btn-ghost { background: transparent; color: #6b7280; border: 1px solid transparent; } .lt-btn-ghost:hover { background: #f9fafb; color: #111827; }
    .lt-btn-icon-only { padding: .42rem; }

    .lt-quad-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: .5rem; }
    @@media (max-width: 992px) { .lt-quad-strip { grid-template-columns: 1fr 1fr; } }
    .lt-quad { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .65rem .75rem; text-decoration: none; transition: all .15s; display: flex; align-items: center; gap: .55rem; color: inherit; }
    .lt-quad:hover { box-shadow: 0 1px 3px rgba(0,0,0,.07); transform: translateY(-1px); }
    .lt-quad.active { border-width: 2px; }
    .lt-quad.q-quick.active { border-color: #16a34a; }
    .lt-quad.q-major.active { border-color: #005B99; }
    .lt-quad.q-fill.active  { border-color: #d97706; }
    .lt-quad.q-thnk.active  { border-color: #dc2626; }
    .lt-quad-icon { width: 36px; height: 36px; border-radius: .375rem; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .q-quick .lt-quad-icon { background: #ecfdf5; color: #047857; }
    .q-major .lt-quad-icon { background: #eff6ff; color: #005B99; }
    .q-fill  .lt-quad-icon { background: #fffbeb; color: #b45309; }
    .q-thnk  .lt-quad-icon { background: #fef2f2; color: #b91c1c; }
    .lt-quad-num { font-size: var(--fs-lg); font-weight: 800; line-height: 1; }
    .q-quick .lt-quad-num { color: #047857; }
    .q-major .lt-quad-num { color: #005B99; }
    .q-fill  .lt-quad-num { color: #b45309; }
    .q-thnk  .lt-quad-num { color: #b91c1c; }
    .lt-quad-name { font-size: var(--fs-sm); font-weight: 700; color: #111827; }
    .lt-quad-sub { font-size: var(--fs-xs); color: #6b7280; line-height: 1.25; margin-top: .12rem; }

    .lt-toolbar { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .5rem .75rem; display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
    .lt-search { flex: 1 1 220px; max-width: 320px; position: relative; }
    .lt-search input { width: 100%; padding: .42rem .7rem; padding-inline-start: 2.1rem; border: 1px solid #d1d5db; border-radius: .375rem; font-size: var(--fs-sm); }
    .lt-search input:focus { outline: none; border-color: #005B99; box-shadow: 0 0 0 3px rgba(0,91,153,.12); }
    .lt-search > i, .lt-search > svg { position: absolute; top: 50%; transform: translateY(-50%); inset-inline-start: .65rem; width: 16px; height: 16px; color: #9ca3af; pointer-events: none; }
    .lt-select { padding: .4rem .55rem; border: 1px solid #d1d5db; border-radius: .375rem; font-size: var(--fs-xs); background: #fff; color: #111827; min-width: 130px; }

    .lt-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; display: flex; flex-direction: column; overflow: hidden; }
    .lt-table-wrap { overflow: auto; }
    .lt-table-wrap table { width: 100%; font-size: var(--fs-sm); border-collapse: collapse; }
    .lt-table-wrap thead { position: sticky; top: 0; background: #f8fafc; z-index: 1; }
    .lt-table-wrap th { font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: .04em; color: #6b7280; font-weight: 600; padding: .55rem .75rem; text-align: start; border-bottom: 1px solid #e5e7eb; white-space: nowrap; }
    .lt-table-wrap td { padding: .5rem .75rem; border-bottom: 1px solid #f3f4f6; color: #374151; vertical-align: middle; }
    .lt-table-wrap tbody tr:hover td { background: #f9fafb; }

    .lt-pill { display: inline-block; padding: .15rem .5rem; font-size: var(--fs-xs); font-weight: 600; border-radius: .25rem; white-space: nowrap; }
    .lt-pill-quad-QuickWins      { background: #ecfdf5; color: #047857; }
    .lt-pill-quad-MajorProjects  { background: #eff6ff; color: #005B99; }
    .lt-pill-quad-FillIns        { background: #fffbeb; color: #b45309; }
    .lt-pill-quad-ThanklessTasks { background: #fef2f2; color: #b91c1c; }
    .lt-pill-pri { background: #f5f3ff; color: #6d28d9; }
    .lt-pill-st-Completed  { background: #ecfdf5; color: #047857; }
    .lt-pill-st-InProgress { background: #eff6ff; color: #1d4ed8; }
    .lt-pill-st-OnHold     { background: #fffbeb; color: #b45309; }
    .lt-pill-st-Planning   { background: #f1f5f9; color: #475569; }
    .lt-pill-st-default    { background: #f1f5f9; color: #475569; }

    .lt-progress { display: flex; align-items: center; gap: .35rem; min-width: 120px; }
    .lt-progress-bar { flex: 1; height: 6px; background: #e5e7eb; border-radius: 999px; overflow: hidden; }
    .lt-progress-fill { height: 100%; background: #005B99; border-radius: 999px; }
    .lt-progress-pct { font-size: var(--fs-xs); font-weight: 700; color: #374151; min-width: 2.4rem; text-align: end; }

    .lt-actions { display: inline-flex; gap: .35rem; }
    .lt-actions a { color: #005B99; padding: .2rem; border-radius: .25rem; transition: background .15s; }
    .lt-actions a:hover { background: #eff6ff; }
    .lt-export-wrap { position: relative; }
    .lt-export-menu { position: absolute; right: 0; top: calc(100% + .25rem); background: #fff; border: 1px solid #e5e7eb; border-radius: .375rem; box-shadow: 0 6px 16px rgba(0,0,0,.08); min-width: 180px; z-index: 20; padding: .25rem; }
    .lt-export-menu a { display: flex; align-items: center; gap: .5rem; padding: .45rem .65rem; font-size: var(--fs-xs); color: #374151; text-decoration: none; border-radius: .25rem; }
    .lt-export-menu a:hover { background: #f1f5f9; }
    .lt-export-menu.hidden { display: none; }
</style>

<div class="lt-shell">
    <div class="lt-header">
        <div>
            <h1><i data-lucide="rocket" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>@Shared["Title_Improvements"]</h1>
            <p>@Shared["Text_ManageImprovementInitiatives"]</p>
        </div>
        <div style="display:flex;gap:.4rem;">
            <a asp-action="Dashboard" class="lt-btn lt-btn-outline"><i data-lucide="layout-dashboard" class="w-4 h-4" aria-hidden="true"></i>@(isRtl ? "نظرة عامة" : "Overview")</a>
            <a asp-action="Kanban" class="lt-btn lt-btn-outline"><i data-lucide="kanban" class="w-4 h-4" aria-hidden="true"></i>@Shared["Button_KanbanBoard"]</a>
            <a asp-action="Roadmap" class="lt-btn lt-btn-outline"><i data-lucide="map" class="w-4 h-4" aria-hidden="true"></i>@(isRtl ? "خارطة الطريق" : "Roadmap")</a>
            <a asp-controller="Dashboard" asp-action="QuadrantAnalysis" class="lt-btn lt-btn-outline"><i data-lucide="scatter-chart" class="w-4 h-4" aria-hidden="true"></i>@Shared["Title_QuadrantAnalysis"]</a>
            <a asp-action="Wizard" class="lt-btn lt-btn-primary"><i data-lucide="sparkles" class="w-4 h-4" aria-hidden="true"></i>@Shared["Label_UseWizard"]</a>
        </div>
    </div>

    @* Drafts banner — populated via /Improvements/MyDrafts on page load.
       Hidden when the user has no in-progress wizard drafts. Kept inline
       (not partial) so the UI stays in lockstep with the wizard markup. *@
    <div id="draftsBanner" class="d-none mb-3" style="background:linear-gradient(90deg,#fef3c7 0%,#fef9e7 100%);border:1px solid #f59e0b;border-radius:8px;padding:.65rem .9rem;">
        <div class="d-flex align-items-center gap-2 mb-2">
            <i data-lucide="bookmark" class="w-4 h-4" style="color:#92400e;" aria-hidden="true"></i>
            <strong style="color:#78350f;font-size:var(--fs-sm);">@(isRtl ? "مسودات معلقة" : "Drafts in progress")</strong>
            <span id="draftsCount" class="badge" style="background:#92400e;color:#fff;font-size:var(--fs-xs);"></span>
            <button type="button" id="draftsClearAllBtn" class="btn btn-link btn-sm p-0 ms-auto" style="color:#991b1b;font-size:var(--fs-xs);text-decoration:none;">
                <i data-lucide="trash-2" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                @(isRtl ? "حذف الكل" : "Clear all")
            </button>
        </div>
        <div id="draftsList" class="d-flex flex-wrap gap-2"></div>
    </div>

    @* Active-filter chip — surfaces deep-linked filters (e.g. the "stalled
       initiatives" notification opens ?statusFilter=Stalled). Without this
       the list looks like the unfiltered view but isn't, which is confusing. *@
    @if (ViewBag.IsStalledFilter == true)
    {
        <div style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;background:#fffbeb;border:1px solid #fcd34d;border-radius:.5rem;font-size:var(--fs-xs);color:#92400e;">
            <i data-lucide="filter" class="w-4 h-4" aria-hidden="true"></i>
            <span style="font-weight:600;">@(isRtl ? "تم تطبيق التصفية:" : "Filter applied:")</span>
            <span style="background:#fef3c7;color:#78350f;padding:.15rem .55rem;border-radius:999px;font-weight:600;display:inline-flex;align-items:center;gap:.3rem;">
                <i data-lucide="alert-triangle" class="w-3 h-3" aria-hidden="true"></i>
                @(isRtl ? "متوقفة (٩٠+ يوم بدون تحديث)" : "Stalled (90+ days idle)")
            </span>
            <a href="@Url.Action("Index")" style="margin-inline-start:auto;color:#92400e;text-decoration:none;display:inline-flex;align-items:center;gap:.25rem;">
                <i data-lucide="x" class="w-3.5 h-3.5" aria-hidden="true"></i>
                @(isRtl ? "إزالة التصفية" : "Clear filter")
            </a>
        </div>
    }

    <div class="lt-quad-strip">
        <a href="@Url.Action("Index", new { quadrant = ImprovementQuadrant.QuickWins })" class="lt-quad q-quick @(ViewBag.SelectedQuadrant == ImprovementQuadrant.QuickWins ? "active" : "")">
            <div class="lt-quad-icon"><i data-lucide="zap" class="w-4 h-4" aria-hidden="true"></i></div>
            <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:.4rem;">
                    <span class="lt-quad-name">@Shared["ImprovementQuadrant_QuickWins"]</span>
                    <span class="lt-quad-num">@ViewBag.QuickWinsCount</span>
                </div>
                <div class="lt-quad-sub">@Shared["Text_QuickWins_Subtitle"]</div>
            </div>
        </a>
        <a href="@Url.Action("Index", new { quadrant = ImprovementQuadrant.MajorProjects })" class="lt-quad q-major @(ViewBag.SelectedQuadrant == ImprovementQuadrant.MajorProjects ? "active" : "")">
            <div class="lt-quad-icon"><i data-lucide="briefcase" class="w-4 h-4" aria-hidden="true"></i></div>
            <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:.4rem;">
                    <span class="lt-quad-name">@Shared["ImprovementQuadrant_MajorProjects"]</span>
                    <span class="lt-quad-num">@ViewBag.MajorProjectsCount</span>
                </div>
                <div class="lt-quad-sub">@Shared["Text_MajorProjects_Subtitle"]</div>
            </div>
        </a>
        <a href="@Url.Action("Index", new { quadrant = ImprovementQuadrant.FillIns })" class="lt-quad q-fill @(ViewBag.SelectedQuadrant == ImprovementQuadrant.FillIns ? "active" : "")">
            <div class="lt-quad-icon"><i data-lucide="list-checks" class="w-4 h-4" aria-hidden="true"></i></div>
            <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:.4rem;">
                    <span class="lt-quad-name">@Shared["ImprovementQuadrant_FillIns"]</span>
                    <span class="lt-quad-num">@ViewBag.FillInsCount</span>
                </div>
                <div class="lt-quad-sub">@Shared["Text_FillIns_Subtitle"]</div>
            </div>
        </a>
        <a href="@Url.Action("Index", new { quadrant = ImprovementQuadrant.ThanklessTasks })" class="lt-quad q-thnk @(ViewBag.SelectedQuadrant == ImprovementQuadrant.ThanklessTasks ? "active" : "")">
            <div class="lt-quad-icon"><i data-lucide="alert-triangle" class="w-4 h-4" aria-hidden="true"></i></div>
            <div style="flex:1;min-width:0;">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:.4rem;">
                    <span class="lt-quad-name">@Shared["ImprovementQuadrant_ThanklessTasks"]</span>
                    <span class="lt-quad-num">@ViewBag.ThanklessTasksCount</span>
                </div>
                <div class="lt-quad-sub">@Shared["Text_ThanklessTasks_Subtitle"]</div>
            </div>
        </a>
    </div>

    <div class="lt-toolbar">
        <div class="lt-search">
            <i data-lucide="search" class="w-4 h-4" aria-hidden="true"></i>
            <input type="text" id="searchInput" placeholder="@Shared["Filter_SearchImprovements"]" />
        </div>
        <select id="filterQuadrant" class="lt-select" aria-label="@Shared["Filter_Quadrant"]">
            <option value="">@Shared["Filter_Quadrant"]: @Shared["Filter_All"]</option>
            <option value="QuickWins">@Shared["ImprovementQuadrant_QuickWins"]</option>
            <option value="MajorProjects">@Shared["ImprovementQuadrant_MajorProjects"]</option>
            <option value="FillIns">@Shared["ImprovementQuadrant_FillIns"]</option>
            <option value="ThanklessTasks">@Shared["ImprovementQuadrant_ThanklessTasks"]</option>
        </select>
        <select id="filterStatus" class="lt-select" aria-label="@Shared["Filter_Status"]">
            <option value="">@Shared["Filter_Status"]: @Shared["Filter_All"]</option>
            <option value="Planning">@Shared["Status_Planning"]</option>
            <option value="InProgress">@Shared["Status_InProgress"]</option>
            <option value="Completed">@Shared["Status_Completed"]</option>
            <option value="OnHold">@Shared["Status_OnHold"]</option>
        </select>
        <select id="filterPriority" class="lt-select" aria-label="@Shared["Filter_Priority"]">
            <option value="">@Shared["Filter_Priority"]: @Shared["Filter_All"]</option>
            <option value="1">1 (@Shared["Priority_Highest"])</option>
            <option value="2">2</option><option value="3">3</option><option value="4">4</option>
            <option value="5">5 (@Shared["Priority_Lowest"])</option>
        </select>
        <button type="button" id="clearFiltersBtn" class="lt-btn lt-btn-ghost"><i data-lucide="x" class="w-3.5 h-3.5" aria-hidden="true"></i>@Shared["Filter_Clear"]</button>
        <span style="flex:1;"></span>
        <div class="lt-export-wrap">
            <button type="button" id="exportToggle" class="lt-btn lt-btn-outline"><i data-lucide="download" class="w-3.5 h-3.5" aria-hidden="true"></i>@Shared["Button_Export"]<i data-lucide="chevron-down" class="w-3 h-3" aria-hidden="true"></i></button>
            <div id="exportMenu" class="lt-export-menu hidden">
                <a href="~/api/export/improvements/excel"><i data-lucide="file-spreadsheet" class="w-4 h-4" style="color:#047857;" aria-hidden="true"></i>@Shared["Button_ExportExcel"]</a>
            </div>
        </div>
    </div>

    <div class="lt-card">
        <div class="lt-table-wrap">
            <table id="improvementsTable">
                <thead>
                    <tr>
                        <th>@Shared["Column_Title"]</th>
                        <th>@Shared["Column_ProcessService"]</th>
                        <th>@Shared["Column_Quadrant"]</th>
                        <th>@Shared["Column_Priority"]</th>
                        <th>@Shared["Column_Status"]</th>
                        <th>@Shared["Column_Progress"]</th>
                        <th style="text-align:end;">@Shared["Column_Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var processNames = (item.ImprovementProcesses ?? Enumerable.Empty<ImprovementProcess>())
                            .Select(x => x.Process?.Name)
                            .Where(n => !string.IsNullOrWhiteSpace(n))
                            .Distinct()
                            .ToList();
                        var serviceNames = (item.ImprovementServices ?? Enumerable.Empty<ImprovementService>())
                            .Select(x => x.Service?.Name)
                            .Where(n => !string.IsNullOrWhiteSpace(n))
                            .Distinct()
                            .ToList();
                        if (processNames.Count == 0 && !string.IsNullOrWhiteSpace(item.Process?.Name)) processNames.Add(item.Process!.Name);
                        if (serviceNames.Count == 0 && !string.IsNullOrWhiteSpace(item.Service?.Name)) serviceNames.Add(item.Service!.Name);
                        var workItemParts = new List<string>();
                        if (processNames.Count > 0) workItemParts.Add(string.Join(", ", processNames));
                        if (serviceNames.Count > 0) workItemParts.Add(string.Join(", ", serviceNames));
                        var workItem = workItemParts.Count > 0 ? string.Join(" • ", workItemParts) : "—";
                        var quadCls = $"lt-pill-quad-{item.Quadrant}";
                        var statusKey = item.Status.ToString();
                        var statusCls = (item.Status == ImprovementStatus.Completed || item.Status == ImprovementStatus.InProgress || item.Status == ImprovementStatus.OnHold) ? $"lt-pill-st-{statusKey}" : "lt-pill-st-default";
                        var priLabel = item.Priority switch
                        {
                            1 => Shared["Priority_Highest"].Value,
                            2 => Shared["Priority_High"].Value,
                            3 => Shared["Priority_Medium"].Value,
                            4 => Shared["Priority_Low"].Value,
                            _ => Shared["Priority_Lowest"].Value
                        };
                        <tr data-quadrant="@item.Quadrant" data-priority="@item.Priority" data-status="@statusKey">
                            <td style="font-weight:600;color:#111827;">@(isRtl ? item.TitleAr : item.TitleEn)</td>
                            <td style="color:#6b7280;">@workItem</td>
                            <td><span class="lt-pill @quadCls">@Shared[$"ImprovementQuadrant_{item.Quadrant}"]</span></td>
                            <td><span class="lt-pill lt-pill-pri">@priLabel</span></td>
                            <td><span class="lt-pill @statusCls">@Shared[$"ChangeRequestStatus_{item.Status}"].Value</span></td>
                            <td>
                                <div class="lt-progress">
                                    <div class="lt-progress-bar"><div class="lt-progress-fill" style="width:@(item.ProgressPercentage)%"></div></div>
                                    <div class="lt-progress-pct">@item.ProgressPercentage%</div>
                                </div>
                            </td>
                            <td style="text-align:end;">
                                <span class="lt-actions">
                                    @* Quick-record shortcut for InProgress / OnHold initiatives —
                                       sends the user straight to Details which now defaults to the
                                       Measurements tab when status is InProgress. Saves the
                                       Details → Measurements tab click. *@
                                    @if (item.Status == ImprovementStatus.InProgress || item.Status == ImprovementStatus.OnHold)
                                    {
                                        <a asp-action="Details" asp-route-id="@item.Id" title="@(isRtl ? "تسجيل قراءة" : "Record reading")" aria-label="@(isRtl ? "تسجيل قراءة" : "Record reading")" style="color:#15803D;"><i data-lucide="plus-circle" class="w-4 h-4" aria-hidden="true"></i></a>
                                    }
                                    <a asp-action="Details" asp-route-id="@item.Id" title="@Shared["Tooltip_ViewDetails"]" aria-label="@Shared["Tooltip_ViewDetails"]"><i data-lucide="eye" class="w-4 h-4" aria-hidden="true"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" title="@Shared["Tooltip_EditRecord"]" aria-label="@Shared["Tooltip_EditRecord"]"><i data-lucide="edit" class="w-4 h-4" aria-hidden="true"></i></a>
                                </span>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" style="padding:3rem 1rem;text-align:center;color:#94a3b8;">
                            <i data-lucide="inbox" class="w-10 h-10" aria-hidden="true" style="margin:0 auto .5rem;display:block;color:#cbd5e1;"></i>
                            <div style="font-weight:500;margin-bottom:.25rem;">@Shared["Text_NoImprovementsFound"]</div>
                            <a asp-action="Wizard" style="color:#005B99;text-decoration:none;font-size: var(--fs-sm);">@Shared["Text_CreateFirstInitiative"]</a>
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();
        const search = document.getElementById('searchInput');
        const fq = document.getElementById('filterQuadrant');
        const fst = document.getElementById('filterStatus');
        const fpri = document.getElementById('filterPriority');
        const rows = Array.from(document.querySelectorAll('tbody tr'));
        function apply() {
            const q = (search?.value || '').toLowerCase().trim();
            const quad = (fq?.value || '').trim();
            const st = (fst?.value || '').trim();
            const pri = (fpri?.value || '').trim();
            rows.forEach(r => {
                if (r.querySelector('td[colspan]')) return;
                const text = r.textContent.toLowerCase();
                const okQ = !q || text.includes(q);
                const okQuad = !quad || r.dataset.quadrant === quad;
                const okSt = !st || r.dataset.status === st;
                const okPri = !pri || r.dataset.priority === pri;
                r.style.display = (okQ && okQuad && okSt && okPri) ? '' : 'none';
            });
        }
        search?.addEventListener('input', apply);
        fq?.addEventListener('change', apply);
        fst?.addEventListener('change', apply);
        fpri?.addEventListener('change', apply);
        document.getElementById('clearFiltersBtn')?.addEventListener('click', function () {
            if (search) search.value = '';
            if (fq) fq.value = '';
            if (fst) fst.value = '';
            if (fpri) fpri.value = '';
            apply();
        });
        // Export dropdown
        const exportBtn = document.getElementById('exportToggle');
        const exportMenu = document.getElementById('exportMenu');
        exportBtn?.addEventListener('click', function (e) {
            e.stopPropagation();
            exportMenu.classList.toggle('hidden');
        });
        document.addEventListener('click', function (e) {
            if (!e.target.closest('.lt-export-wrap')) exportMenu?.classList.add('hidden');
        });

        // Drafts banner — pulls the user's in-progress wizard drafts and
        // renders one chip per draft (Resume + Delete). Stays hidden when
        // the list is empty.
        (async function loadDrafts() {
            try {
                const res = await fetch('@Url.Action("MyDrafts", "Improvements")');
                if (!res.ok) return;
                const drafts = await res.json();
                if (!drafts || drafts.length === 0) return;
                const banner = document.getElementById('draftsBanner');
                const list = document.getElementById('draftsList');
                document.getElementById('draftsCount').textContent = drafts.length;
                const isAr = @(isRtl ? "true" : "false");
                const fmtDate = (s) => { try { return new Date(s).toLocaleString(isAr ? 'ar-AE' : 'en-GB', { dateStyle: 'short', timeStyle: 'short' }); } catch { return s; } };
                list.innerHTML = drafts.map(d => {
                    const safeTitle = (d.title || (isAr ? 'مسودة' : 'Untitled draft')).replace(/[<>&"]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c]));
                    return '<div class="d-inline-flex align-items-center gap-1 px-2 py-1 rounded" style="background:#fff;border:1px solid #fcd34d;font-size:var(--fs-xs);">' +
                        '<span style="color:#78350f;max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + safeTitle + '">' + safeTitle + '</span>' +
                        '<span class="text-muted" style="font-size:var(--fs-xs);">· ' + fmtDate(d.updatedAt) + '</span>' +
                        '<a href="@Url.Action("Wizard", "Improvements")?draftId=' + encodeURIComponent(d.id) + '" class="btn btn-sm btn-primary py-0 px-2 ms-1" style="font-size:var(--fs-xs);">' +
                            (isAr ? 'استئناف' : 'Resume') + '</a>' +
                        '<button type="button" class="btn btn-sm btn-outline-danger py-0 px-2" style="font-size:var(--fs-xs);" data-draft-id="' + d.id + '">' +
                            (isAr ? 'حذف' : 'Delete') + '</button>' +
                    '</div>';
                }).join('');
                banner.classList.remove('d-none');
                if (window.lucide) lucide.createIcons();

                list.addEventListener('click', async function (e) {
                    const btn = e.target.closest('button[data-draft-id]');
                    if (!btn) return;
                    const ok = await Swal.fire({
                        title: isAr ? 'حذف المسودة؟' : 'Delete draft?',
                        text:  isAr ? 'لن تستطيع التراجع عن هذا الإجراء.' : "You won't be able to undo this.",
                        icon: 'warning', showCancelButton: true,
                        confirmButtonText: isAr ? 'حذف' : 'Delete',
                        cancelButtonText:  isAr ? 'إلغاء' : 'Cancel',
                        confirmButtonColor: '#dc2626', cancelButtonColor: '#64748b'
                    });
                    if (!ok.isConfirmed) return;
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const fd = new FormData();
                    fd.append('id', btn.dataset.draftId);
                    fd.append('__RequestVerificationToken', token);
                    const r = await fetch('@Url.Action("DeleteDraft", "Improvements")', { method: 'POST', body: fd });
                    if (r.ok) btn.closest('div').remove();
                    if (list.children.length === 0) document.getElementById('draftsBanner').classList.add('d-none');
                });

                document.getElementById('draftsClearAllBtn')?.addEventListener('click', async function () {
                    const ok = await Swal.fire({
                        title: isAr ? 'حذف جميع المسودات؟' : 'Delete all drafts?',
                        text:  isAr ? ('سيتم حذف ' + drafts.length + ' مسودة.') : ('This will delete ' + drafts.length + ' drafts.'),
                        icon: 'warning', showCancelButton: true,
                        confirmButtonText: isAr ? 'حذف الكل' : 'Delete all',
                        cancelButtonText:  isAr ? 'إلغاء' : 'Cancel',
                        confirmButtonColor: '#dc2626', cancelButtonColor: '#64748b'
                    });
                    if (!ok.isConfirmed) return;
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const fd = new FormData();
                    fd.append('__RequestVerificationToken', token);
                    const r = await fetch('@Url.Action("ClearMyDrafts", "Improvements")', { method: 'POST', body: fd });
                    if (r.ok) {
                        list.innerHTML = '';
                        document.getElementById('draftsBanner').classList.add('d-none');
                    }
                });
            } catch (e) { /* silent */ }
        })();
    </script>
    @Html.AntiForgeryToken()
}
