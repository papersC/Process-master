        transition: opacity 0.15s, background 0.15s;
        white-space: nowrap;
    }
    .imp-btn:hover { text-decoration: none; opacity: 0.92; }
    .imp-btn-ghost {
        background: transparent;
        border-color: #d1d5db;
        color: #4b5563;
    }
    .imp-btn-ghost:hover { background: #f3f5f8; color: #1f2937; }
    .imp-btn-primary {
        background: #005B99;
        color: #fff;
        border-color: #005B99;
    }
    .imp-btn-primary:hover { background: #004580; color: #fff; }
    .imp-btn-success {
        background: #15803D;
        color: #fff;
        border-color: #15803D;
    }
    .imp-btn-success:hover { background: #14532d; color: #fff; }
