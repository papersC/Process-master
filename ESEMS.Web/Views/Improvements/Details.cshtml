        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
    }

    /* Ready-to-close banner — surfaces the next action when status =
       Completed so the user doesn't hunt for the Close button in the
       right rail. */
    .imp-ready-close-banner {
        display: flex;
        align-items: center;
        gap: .85rem;
        background: linear-gradient(90deg, #f0fdf4 0%, #dcfce7 100%);
        border: 1px solid #86efac;
        border-radius: 8px;
        padding: .75rem 1rem;
        margin-bottom: .85rem;
    }
    .imp-ready-close-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: .15rem;
        line-height: 1.35;
    }
    .imp-ready-close-text strong { color: #166534; font-size: var(--fs-sm); }
    .imp-ready-close-text span { color: #15803D; font-size: var(--fs-sm); }

    /* ── Body grid (main + rail) ────────────────────────── */
    .imp-body {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 1rem;
        align-items: start;
    }
    @@media (max-width: 1199px) {
        .imp-body { grid-template-columns: 1fr; }
    }
    .imp-main { min-width: 0; }

    /* Sticky tab navigation row inside the tabs card */
    .imp-tabs .imp-tabnav {
        position: sticky;
        top: 70px;
        z-index: 10;
        background: #fff;
        border-radius: 8px 8px 0 0;
    }

    /* ── Right rail ──────────────────────────────────────── */
    .imp-rail {
