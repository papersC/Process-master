@model IEnumerable<ImprovementInitiative>
@using ESEMS.Web.Models.Enums
@{
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    ViewData["Title"] = Shared["Dashboard_ImprovementJourney"].Value;

    int total = ViewBag.TotalInitiatives ?? 0;
    int quickWins = ViewBag.QuickWinsCount ?? 0;
    int majorProjects = ViewBag.MajorProjectsCount ?? 0;
    int fillIns = ViewBag.FillInsCount ?? 0;
    int thankless = ViewBag.ThanklessTasksCount ?? 0;
    int h1 = ViewBag.H1Count ?? 0;
    int h2 = ViewBag.H2Count ?? 0;
    int h3 = ViewBag.H3Count ?? 0;
    // Horizon is optional — it's only stamped when an initiative is Approved.
    // Surface the unassigned residual so 55 = 21 (H1) + 16 (H2+H3) + 18 (none)
    // reconciles on screen rather than leaving an unexplained 18-item gap.
    int hNone = Math.Max(0, total - h1 - h2 - h3);
}

<style>
    .id-shell { display: flex; flex-direction: column; gap: .6rem; height: calc(100vh - 140px); min-height: 600px; }
    .id-header { display: flex; align-items: center; justify-content: space-between; padding: .25rem 0 .4rem; border-bottom: 1px solid #e5e7eb; flex: 0 0 auto; }
    .id-header h1 { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .5rem; }
    .id-header p { margin: 0; font-size: var(--fs-xs); color: #6b7280; }
    .id-header-actions { display: flex; gap: .4rem; }
    .id-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; transition: background .15s, color .15s; }
    .id-btn-primary { background: #005B99; color: #fff; border: none; }
    .id-btn-primary:hover { background: #003d6b; color: #fff; }
    .id-btn-outline { background: #fff; color: #005B99; border: 1px solid #cbd5e1; }
    .id-btn-outline:hover { background: #f1f5f9; border-color: #005B99; }

    .id-kpi-grid { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: .5rem; flex: 0 0 auto; }
    @@media (max-width: 1280px) { .id-kpi-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
    .id-kpi { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .65rem .85rem; display: flex; align-items: center; gap: .65rem; }
    .id-kpi:hover { box-shadow: 0 4px 12px rgba(0,91,153,.08); }
    .id-kpi-bar { width: 4px; align-self: stretch; border-radius: 2px; flex-shrink: 0; }
    .id-kpi-meta { flex: 1; min-width: 0; }
    .id-kpi-label { font-size: var(--fs-xs); color: #6b7280; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .id-kpi-value { font-size: var(--fs-lg); font-weight: 700; color: #111827; line-height: 1.2; margin: 0; }

    .id-main { display: grid; grid-template-columns: 1.1fr 1.4fr; gap: .6rem; flex: 1 1 0; min-height: 0; }
    @@media (max-width: 1024px) { .id-main { grid-template-columns: 1fr; } }
    .id-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; display: flex; flex-direction: column; min-height: 0; overflow: hidden; }
    .id-card-head { display: flex; align-items: center; justify-content: space-between; padding: .5rem .85rem; border-bottom: 1px solid #f1f5f9; flex: 0 0 auto; }
    .id-card-head h6 { margin: 0; font-size: var(--fs-sm); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .4rem; }
    .id-card-body { flex: 1 1 0; min-height: 0; padding: .65rem .85rem; position: relative; }
    .id-chart-wrap { position: relative; height: 100%; max-width: 460px; max-height: 420px; margin: 0 auto; padding: 1rem .5rem .25rem; box-sizing: border-box; }
    .id-chart-center { position: absolute; inset: 1rem .5rem .25rem; display: flex; flex-direction: column; align-items: center; justify-content: center; pointer-events: none; padding-bottom: 2.5rem; }
    .id-chart-center .id-chart-total { font-size: var(--fs-2xl); font-weight: 700; color: #111827; line-height: 1; }
    .id-chart-center .id-chart-label { font-size: var(--fs-xs); color: #6b7280; margin-top: .2rem; text-transform: uppercase; letter-spacing: .04em; }

    .id-pri-list { flex: 1 1 0; min-height: 0; overflow-y: auto; padding: 0 .25rem; }
    .id-pri-item { display: flex; align-items: center; gap: .8rem; padding: .65rem .65rem; border-bottom: 1px solid #f3f4f6; text-decoration: none; transition: background .15s; }
    .id-pri-item:hover { background: #f9fafb; }
    .id-pri-meta { flex: 1; min-width: 0; }
    .id-pri-name { font-size: var(--fs-sm); font-weight: 600; color: #111827; line-height: 1.3; margin: 0 0 .15rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .id-pri-context { font-size: var(--fs-xs); color: #6b7280; display: flex; gap: .65rem; align-items: center; flex-wrap: wrap; }
    .id-pri-context span { display: inline-flex; align-items: center; gap: .2rem; }
    .id-pri-quadrant { font-size: var(--fs-xs); padding: .12rem .45rem; border-radius: .25rem; font-weight: 600; flex-shrink: 0; }
    .id-pri-q-quickwins { background: #ecfdf5; color: #047857; }
    .id-pri-q-major { background: #eff6ff; color: #1d4ed8; }
    .id-pri-q-fillins { background: #fef3c7; color: #92400e; }
    .id-pri-q-thankless { background: #f1f5f9; color: #475569; }
    .id-pri-score { display: flex; flex-direction: column; align-items: flex-end; flex-shrink: 0; min-width: 56px; }
    .id-pri-score-value { font-size: var(--fs-base); font-weight: 700; color: #f59e0b; display: inline-flex; align-items: center; gap: .2rem; }
    .id-pri-score-sub { font-size: var(--fs-xs); color: #94a3b8; }

    .id-quick-nav { display: flex; gap: .4rem; flex: 0 0 auto; }
    .id-quick-nav a { flex: 1; background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .65rem .85rem; display: flex; align-items: center; gap: .55rem; text-decoration: none; color: #374151; transition: border-color .15s, color .15s; font-size: var(--fs-sm); font-weight: 600; }
    .id-quick-nav a:hover { border-color: #005B99; color: #005B99; }
</style>

<div class="id-shell">

    <div class="id-header">
        <div>
            <h1><i data-lucide="rocket" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>@Shared["Dashboard_ImprovementJourney"]</h1>
            <p>@Shared["Help_ImprovementJourney"]</p>
        </div>
        <div class="id-header-actions">
            <a asp-action="Wizard" class="id-btn id-btn-primary">
                <i data-lucide="sparkles" class="w-4 h-4" aria-hidden="true"></i>
                @Shared["Dashboard_StartNewInitiative"]
            </a>
        </div>
    </div>

    <div class="id-kpi-grid">
        <div class="id-kpi"><span class="id-kpi-bar" style="background:#005B99;"></span><div class="id-kpi-meta"><p class="id-kpi-label">@Shared["Label_TotalInitiatives"]</p><p class="id-kpi-value">@total</p></div></div>
        <div class="id-kpi"><span class="id-kpi-bar" style="background:#34C38F;"></span><div class="id-kpi-meta"><p class="id-kpi-label">@Shared["ImprovementQuadrant_QuickWins"]</p><p class="id-kpi-value">@quickWins</p></div></div>
        <div class="id-kpi"><span class="id-kpi-bar" style="background:#3b82f6;"></span><div class="id-kpi-meta"><p class="id-kpi-label">@Shared["ImprovementQuadrant_MajorProjects"]</p><p class="id-kpi-value">@majorProjects</p></div></div>
        <div class="id-kpi"><span class="id-kpi-bar" style="background:#F1B44C;"></span><div class="id-kpi-meta"><p class="id-kpi-label">@Shared["ImprovementQuadrant_FillIns"]</p><p class="id-kpi-value">@fillIns</p></div></div>
        <div class="id-kpi"><span class="id-kpi-bar" style="background:#94a3b8;"></span><div class="id-kpi-meta"><p class="id-kpi-label">@Shared["ImprovementQuadrant_ThanklessTasks"]</p><p class="id-kpi-value">@thankless</p></div></div>
        <div class="id-kpi"><span class="id-kpi-bar" style="background:#8b5cf6;"></span><div class="id-kpi-meta"><p class="id-kpi-label">H1</p><p class="id-kpi-value">@h1</p></div></div>
        <div class="id-kpi"><span class="id-kpi-bar" style="background:#06b6d4;"></span><div class="id-kpi-meta"><p class="id-kpi-label">H2 / H3</p><p class="id-kpi-value">@(h2 + h3)</p></div></div>
        @if (hNone > 0)
        {
            <div class="id-kpi" title="@(isRtl ? "المبادرات التي لم يتم تحديد أفقها بعد. يتم تعيين الأفق عند الموافقة." : "Initiatives without a horizon yet. Horizon is assigned at approval time.")">
                <span class="id-kpi-bar" style="background:#cbd5e1;"></span>
                <div class="id-kpi-meta">
                    <p class="id-kpi-label">@(isRtl ? "بدون أفق" : "No horizon")</p>
                    <p class="id-kpi-value" style="color:#64748b;">@hNone</p>
                </div>
            </div>
        }
    </div>

    <div class="id-main">
        <div class="id-card">
            <div class="id-card-head">
                <h6><i data-lucide="pie-chart" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@Shared["Dashboard_ImprovementQuadrants"]</h6>
            </div>
            <div class="id-card-body">
                <div class="id-chart-wrap">
                    <canvas id="idQuadrantChart"></canvas>
                    <div class="id-chart-center">
                        <span class="id-chart-total">@total</span>
                        <span class="id-chart-label">@Shared["Label_TotalInitiatives"]</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="id-card">
            <div class="id-card-head">
                <h6><i data-lucide="star" class="w-4 h-4" style="color:#f59e0b;" aria-hidden="true"></i>@Shared["Dashboard_TopPriorities"]</h6>
                <a asp-action="Index" style="font-size: var(--fs-xs);color:#005B99;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.25rem;">
                    @Shared["Dashboard_ViewAllInitiatives"]
                    <i data-lucide="@(isRtl ? "arrow-left" : "arrow-right")" class="w-3 h-3" aria-hidden="true"></i>
                </a>
            </div>
            <div class="id-card-body" style="padding:0;">
                <div class="id-pri-list">
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            var qClass = item.Quadrant switch
                            {
                                ImprovementQuadrant.QuickWins => "id-pri-q-quickwins",
                                ImprovementQuadrant.MajorProjects => "id-pri-q-major",
                                ImprovementQuadrant.FillIns => "id-pri-q-fillins",
                                _ => "id-pri-q-thankless"
                            };
                            <a class="id-pri-item" asp-action="Details" asp-route-id="@item.Id">
                                <div class="id-pri-meta">
                                    <p class="id-pri-name">@item.Name</p>
                                    <div class="id-pri-context">
                                        <span class="id-pri-quadrant @qClass">@Shared[$"ImprovementQuadrant_{item.Quadrant}"]</span>
                                        @if (item.Process != null) { <span><i data-lucide="git-branch" class="w-3 h-3" aria-hidden="true"></i>@item.Process.Name</span> }
                                        @if (item.OwningUnit != null) { <span><i data-lucide="building-2" class="w-3 h-3" aria-hidden="true"></i>@item.OwningUnit.Name</span> }
                                    </div>
                                </div>
                                <div class="id-pri-score">
                                    <span class="id-pri-score-value"><i data-lucide="star" class="w-3.5 h-3.5" aria-hidden="true" style="fill:currentColor;"></i>@((item.TotalPrioritizationScore ?? 0).ToString("F1"))</span>
                                    <span class="id-pri-score-sub">I:@item.ImpactScore · E:@item.EffortScore</span>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div style="padding:2rem;text-align:center;color:#94a3b8;font-size: var(--fs-sm);">
                            <i data-lucide="lightbulb" class="w-8 h-8" aria-hidden="true" style="margin:0 auto .5rem;display:block;color:#cbd5e1;"></i>
                            @(isRtl ? "لا توجد مبادرات حتى الآن" : "No initiatives yet")
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="id-quick-nav">
        <a asp-action="Index"><i data-lucide="list" class="w-4 h-4" aria-hidden="true"></i>@Shared["Nav_Improvements"]</a>
        <a asp-action="Kanban"><i data-lucide="kanban" class="w-4 h-4" aria-hidden="true"></i>@Shared["Nav_Kanban"]</a>
        <a asp-action="Roadmap"><i data-lucide="map" class="w-4 h-4" aria-hidden="true"></i>@Shared["Nav_Roadmap"]</a>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();
        const isRtl = @(isRtl ? "true" : "false");
        if (isRtl) {
            Chart.defaults.plugins.legend.rtl = true;
            Chart.defaults.plugins.legend.textDirection = 'rtl';
            Chart.defaults.plugins.tooltip.rtl = true;
            Chart.defaults.plugins.tooltip.textDirection = 'rtl';
        }
        new Chart(document.getElementById('idQuadrantChart'), {
            type: 'doughnut',
            data: {
                labels: [
                    @Html.Raw("'" + Shared["ImprovementQuadrant_QuickWins"].Value + "'"),
                    @Html.Raw("'" + Shared["ImprovementQuadrant_MajorProjects"].Value + "'"),
                    @Html.Raw("'" + Shared["ImprovementQuadrant_FillIns"].Value + "'"),
                    @Html.Raw("'" + Shared["ImprovementQuadrant_ThanklessTasks"].Value + "'")
                ],
                datasets: [{
                    data: [@quickWins, @majorProjects, @fillIns, @thankless],
                    backgroundColor: ['#34C38F', '#3b82f6', '#F1B44C', '#94a3b8'],
                    hoverBackgroundColor: ['#5dd9a8', '#60a5fa', '#f4c56d', '#cbd5e1'],
                    borderWidth: 3, borderColor: '#fff', hoverBorderWidth: 4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false, cutout: '68%',
                plugins: {
                    legend: { position: 'bottom', labels: { padding: 14, usePointStyle: true, font: { size: 12, weight: '500' } } },
                    tooltip: {
                        backgroundColor: 'rgba(0,0,0,.85)', padding: 10,
                        callbacks: { label: function(c){ var t=c.dataset.data.reduce((a,b)=>a+b,0); var p=t>0?((c.parsed/t)*100).toFixed(1):'0'; return c.label+': '+c.parsed+' ('+p+'%)'; } }
                    }
                }
            }
        });
    </script>
}
