@model IEnumerable<ImprovementInitiative>
@{
    ViewData["Title"] = Shared["Title_ImprovementKanban"].Value;
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");

    var byStatus = Model
        .GroupBy(i => i.Status)
        .ToDictionary(g => g.Key, g => g.ToList());

    // Canonical flow: Proposed → UnderReview → Approved → InProgress → Completed → Closed
    var statuses = new[]
    {
        ImprovementStatus.Proposed,
        ImprovementStatus.UnderReview,
        ImprovementStatus.Approved,
        ImprovementStatus.InProgress,
        ImprovementStatus.Completed,
        ImprovementStatus.Closed
    };

    string GetStatusLabel(ImprovementStatus status) => status switch {
        ImprovementStatus.Proposed => Shared["Status_Proposed"].Value,
        ImprovementStatus.UnderReview => Shared["Status_UnderReview"].Value,
        ImprovementStatus.Approved => Shared["Status_Approved"].Value,
        ImprovementStatus.InProgress => Shared["Status_InProgress"].Value,
        ImprovementStatus.Completed => Shared["Status_Completed"].Value,
        ImprovementStatus.Closed => Shared["Status_Closed"].Value,
        _ => status.ToString()
    };
}

<style>
    .sortable-ghost {
        opacity: 0.4;
        background: #f3f4f6;
    }
    .sortable-drag {
        opacity: 1;
        cursor: grabbing !important;
    }
    .kanban-card {
        cursor: grab;
        position: relative;
    }
    .kanban-card:active {
        cursor: grabbing;
    }
    /* Audit fix: the cards had a `cursor: grab` but no visual affordance —
       users had no way to know they could be dragged until they happened to
       try. A subtle 6-dot drag handle in the top-end corner fades in on
       hover. The card itself stays the drop target. */
    .kanban-drag-handle {
        position: absolute;
        top: .35rem;
        inset-inline-end: .35rem;
        width: 14px;
        height: 14px;
        opacity: 0;
        transition: opacity .15s ease;
        color: #94a3b8;
        pointer-events: none;
    }
    .kanban-card:hover .kanban-drag-handle,
    .kanban-card:focus-within .kanban-drag-handle {
        opacity: 1;
    }
    /* .lt-* toolbar shared across the modernized list pages. */
    .lt-toolbar { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .5rem .75rem; display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; margin-bottom: .85rem; }
    .lt-search { flex: 1 1 220px; max-width: 320px; position: relative; }
    .lt-search input { width: 100%; padding: .42rem .7rem; padding-inline-start: 2.1rem; border: 1px solid #d1d5db; border-radius: .375rem; font-size: var(--fs-sm); }
    .lt-search input:focus { outline: none; border-color: #005B99; box-shadow: 0 0 0 3px rgba(0,91,153,.12); }
    .lt-search > i, .lt-search > svg { position: absolute; top: 50%; transform: translateY(-50%); inset-inline-start: .65rem; width: 16px; height: 16px; color: #9ca3af; pointer-events: none; }
    .lt-select { padding: .4rem .55rem; border: 1px solid #d1d5db; border-radius: .375rem; font-size: var(--fs-xs); background: #fff; color: #111827; min-width: 130px; }
    .lt-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; border: none; }
    .lt-btn-outline { background: #fff; color: #005B99; border: 1px solid #cbd5e1; } .lt-btn-outline:hover { background: #f1f5f9; }
    .lt-btn-ghost { background: transparent; color: #6b7280; border: 1px solid transparent; } .lt-btn-ghost:hover { background: #f9fafb; color: #111827; }
</style>

<!-- Compact header (banner replaced) -->
<div class="d-flex align-items-center justify-content-between mb-3 pb-2" style="border-bottom: 1px solid #e5e7eb;">
    <div>
        <h1 style="margin:0;font-size: var(--fs-base);font-weight:600;color:#111827;display:flex;align-items:center;gap:.5rem;">
            <i data-lucide="kanban" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>
            @Shared["Heading_KanbanBoard"]
        </h1>
        <p style="margin:0;font-size: var(--fs-xs);color:#6b7280;">@Shared["Help_KanbanBoard"]</p>
    </div>
    <div style="display:flex;gap:.4rem;">
        <a asp-action="Index" style="background:#fff;color:#005B99;border:1px solid #cbd5e1;border-radius:.375rem;padding:.42rem .85rem;font-size: var(--fs-xs);font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.4rem;"><i data-lucide="list" class="w-4 h-4" aria-hidden="true"></i>@Shared["Button_ListView"]</a>
        <a asp-action="Wizard" style="background:#005B99;color:#fff;border:none;border-radius:.375rem;padding:.42rem .85rem;font-size: var(--fs-xs);font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.4rem;"><i data-lucide="sparkles" class="w-4 h-4" aria-hidden="true"></i>@Shared["Label_UseWizard"]</a>
    </div>
</div>

<!-- Search and Filters Bar -->
<div class="lt-toolbar">
    <div class="lt-search">
        <i data-lucide="search" class="w-4 h-4" aria-hidden="true"></i>
        <input type="text" id="searchInput" placeholder="@Shared["Placeholder_SearchInitiatives"]" />
    </div>
    <select id="filterQuadrant" class="lt-select" aria-label="@Shared["Filter_Quadrant"]">
        <option value="">@Shared["Filter_Quadrant"]: @Shared["Filter_All"]</option>
        <option value="QuickWins">@Shared["Label_QuickWins"]</option>
        <option value="MajorProjects">@Shared["Label_MajorProjects"]</option>
        <option value="FillIns">@Shared["Label_FillIns"]</option>
        <option value="ThanklessTasks">@Shared["ImprovementQuadrant_ThanklessTasks"]</option>
    </select>
    <select id="filterStatus" class="lt-select" aria-label="@Shared["Filter_Status"]">
        <option value="">@Shared["Filter_Status"]: @Shared["Filter_All"]</option>
        <option value="Proposed">@Shared["Status_Proposed"]</option>
        <option value="UnderReview">@Shared["Status_UnderReview"]</option>
        <option value="Approved">@Shared["Status_Approved"]</option>
        <option value="InProgress">@Shared["Status_InProgress"]</option>
        <option value="Completed">@Shared["Status_Completed"]</option>
        <option value="Closed">@Shared["Status_Closed"]</option>
    </select>
    <select id="filterPriority" class="lt-select" aria-label="@Shared["Filter_Priority"]">
        <option value="">@Shared["Filter_Priority"]: @Shared["Filter_All"]</option>
        <option value="1">1 (@Shared["Priority_Highest"])</option>
        <option value="2">2</option><option value="3">3</option><option value="4">4</option>
        <option value="5">5 (@Shared["Priority_Lowest"])</option>
    </select>
    <button type="button" onclick="clearFilters()" class="lt-btn lt-btn-ghost"><i data-lucide="x" class="w-3.5 h-3.5" aria-hidden="true"></i>@Shared["Button_Clear"]</button>
    <span style="flex:1;"></span>
    <button type="button" onclick="window.print()" class="lt-btn lt-btn-outline"><i data-lucide="download" class="w-3.5 h-3.5" aria-hidden="true"></i>@Shared["Button_Export"]</button>
</div>

<!-- Kanban Board -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-6 gap-4">
    @foreach (var status in statuses)
    {
        var items = byStatus.ContainsKey(status) ? byStatus[status] : new List<ImprovementInitiative>();
        // Neutral column styling with a single brand-blue accent for the count badge.
        // Icons differentiate the lifecycle stages without introducing rainbow colors.
        var statusConfig = status switch {
            ImprovementStatus.Proposed => new { Icon = "lightbulb" },
            ImprovementStatus.UnderReview => new { Icon = "eye" },
            ImprovementStatus.Approved => new { Icon = "check-circle" },
            ImprovementStatus.InProgress => new { Icon = "loader" },
            ImprovementStatus.Completed => new { Icon = "check-circle-2" },
            ImprovementStatus.Closed => new { Icon = "archive" },
            _             => new { Icon = "circle" }
        };

        <div class="bg-gray-50 rounded-lg p-3" data-status="@status">
            <!-- Column Header -->
            <div class="flex items-center justify-between mb-3 pb-2 border-b border-gray-200">
                <div class="flex items-center gap-2">
                    <i data-lucide="@statusConfig.Icon" class="w-4 h-4 text-gray-600"></i>
                    <h3 class="font-semibold text-gray-900 text-sm">@GetStatusLabel(status)</h3>
                </div>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-blue-100" style="color:#005B99;">@items.Count</span>
            </div>

            <!-- Cards Container -->
            <div class="kanban-cards space-y-2 min-h-[200px]">
                @foreach (var item in items.OrderBy(i => i.Priority))
                {
                    var quadrantConfig = item.Quadrant switch {
                        ImprovementQuadrant.QuickWins => new { BadgeClass = "bg-green-100", BadgeTextColor = "#34C38F" },
                        ImprovementQuadrant.MajorProjects => new { BadgeClass = "bg-blue-100", BadgeTextColor = "#005B99" },
                        ImprovementQuadrant.FillIns => new { BadgeClass = "bg-amber-100", BadgeTextColor = "#F1B44C" },
                        ImprovementQuadrant.ThanklessTasks => new { BadgeClass = "bg-red-100", BadgeTextColor = "#F46A6A" },
                        _ => new { BadgeClass = "bg-gray-100", BadgeTextColor = "#6b7280" }
                    };

                    <div class="kanban-card bg-white rounded-lg shadow-sm border border-gray-200 p-3 cursor-move hover:shadow-md transition-shadow group"
                         data-id="@item.Id"
                         data-quadrant="@item.Quadrant"
                         data-priority="@item.Priority">

                        <i data-lucide="grip-vertical" class="kanban-drag-handle" aria-hidden="true"></i>

                        <!-- Card Title -->
                        <div class="font-semibold text-gray-900 mb-2 text-sm line-clamp-2" style="padding-inline-end: 1.1rem;">
                            @(isRtl ? item.TitleAr : item.TitleEn)
                        </div>

                        <!-- Card Badges -->
                        <div class="flex flex-wrap items-center gap-1.5 mb-2">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold @quadrantConfig.BadgeClass" style="color: @quadrantConfig.BadgeTextColor;">
                                @Shared[$"ImprovementQuadrant_{item.Quadrant}"]
                            </span>
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-semibold bg-gray-100 text-gray-700" title="@Shared["Help_ImpactEffortScore"]">
                                <i data-lucide="target" class="w-3 h-3" aria-hidden="true"></i>
                                @(item.ImpactScore * item.EffortScore)
                            </span>
                        </div>

                        <!-- Card Metadata -->
                        <div class="flex items-center gap-3 text-xs text-gray-500 mb-2">
                            <span class="flex items-center gap-1" title="@Shared["Label_Impact"]">
                                <i data-lucide="trending-up" class="w-3 h-3" aria-hidden="true"></i>
                                <span>@item.ImpactScore</span>
                            </span>
                            <span class="flex items-center gap-1" title="@Shared["Label_Effort"]">
                                <i data-lucide="zap" class="w-3 h-3" aria-hidden="true"></i>
                                <span>@item.EffortScore</span>
                            </span>
                        </div>

                        <!-- Progress Bar -->
                        @if (item.ProgressPercentage > 0)
                        {
                            <div class="mt-2">
                                <div class="flex items-center justify-between mb-1">
                                    <span class="text-xs text-gray-600">@Shared["Label_Progress"]</span>
                                    <span class="text-xs font-semibold text-blue-600">@item.ProgressPercentage%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-1.5">
                                    <div class="bg-blue-600 h-1.5 rounded-full" style="width: @item.ProgressPercentage%"></div>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (!items.Any())
                {
                    <div class="text-center py-8 text-gray-400">
                        <i data-lucide="inbox" class="w-8 h-8 mx-auto mb-2"></i>
                        <p class="text-xs">@Shared["Text_NoImprovements"]</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Legend -->
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mt-6">
    <h3 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
        <i data-lucide="info" class="w-4 h-4" style="color: #005B99;"></i>
        @Shared["Heading_HowToUseKanban"]
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
            <h4 class="text-xs font-semibold text-gray-700 mb-3">@Shared["Heading_QuadrantColors"]</h4>
            <div class="space-y-2">
                <div class="flex items-center gap-2">
                    <span class="px-2 py-1 bg-green-100 rounded text-xs font-semibold" style="color: #34C38F;">@Shared["Label_QuickWins"]</span>
                    <span class="text-xs text-gray-600">@Shared["Text_HighImpactLowEffort"]</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="px-2 py-1 bg-blue-100 rounded text-xs font-semibold" style="color: #005B99;">@Shared["Label_MajorProjects"]</span>
                    <span class="text-xs text-gray-600">@Shared["Text_HighImpactHighEffort"]</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="px-2 py-1 bg-amber-100 rounded text-xs font-semibold" style="color: #F1B44C;">@Shared["Label_FillIns"]</span>
                    <span class="text-xs text-gray-600">@Shared["Text_LowImpactLowEffort"]</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="px-2 py-1 bg-red-100 rounded text-xs font-semibold" style="color: #F46A6A;">@Shared["ImprovementQuadrant_ThanklessTasks"]</span>
                    <span class="text-xs text-gray-600">@Shared["Text_LowImpactHighEffort"]</span>
                </div>
            </div>
        </div>
        <div>
            <h4 class="text-xs font-semibold text-gray-700 mb-3">@Shared["Heading_DragAndDrop"]</h4>
            <p class="text-xs text-gray-600 mb-3">@Shared["Text_DragDropDescription"]</p>
            <h4 class="text-xs font-semibold text-gray-700 mb-3 mt-4">@Shared["Heading_StatusColumns"]</h4>
            <div class="flex flex-wrap gap-2">
                <span class="px-2 py-1 bg-gray-50 border border-gray-200 rounded text-xs font-medium text-gray-700">@Shared["Status_Proposed"]</span>
                <span class="px-2 py-1 bg-gray-50 border border-gray-200 rounded text-xs font-medium text-gray-700">@Shared["Status_UnderReview"]</span>
                <span class="px-2 py-1 bg-gray-50 border border-gray-200 rounded text-xs font-medium text-gray-700">@Shared["Status_Approved"]</span>
                <span class="px-2 py-1 bg-gray-50 border border-gray-200 rounded text-xs font-medium text-gray-700">@Shared["Status_InProgress"]</span>
                <span class="px-2 py-1 bg-gray-50 border border-gray-200 rounded text-xs font-medium text-gray-700">@Shared["Status_Completed"]</span>
                <span class="px-2 py-1 bg-gray-50 border border-gray-200 rounded text-xs font-medium text-gray-700">@Shared["Status_Closed"]</span>
            </div>
        </div>
    </div>
</div>

<!-- Floating Help Button -->
<div class="fixed bottom-6 right-6 z-50">
    <button type="button" onclick="window.location.href='@Url.Action("UserManual", "Home")'" class="w-14 h-14 rounded-full shadow-lg text-white flex items-center justify-center transition-all hover:shadow-xl hover:scale-110" style="background: linear-gradient(135deg, #005B99 0%, #003d6b 100%);" title="@Shared["Help_ImprovementJourney"]">
        <i data-lucide="help-circle" class="w-6 h-6"></i>
    </button>
</div>

@section Scripts {
    <!-- SortableJS for drag and drop -->
    <script src="~/lib/sortablejs/Sortable.min.js" asp-append-version="true"></script>

    <script nonce="@Context.CspNonce()">
        lucide.createIcons();

        // Defensive Sortable init.
        //
        // Background: the script executes at end-of-body, the columns ARE in
        // the DOM, and SortableJS IS loaded — yet on first load the columns
        // ended up with zero Sortable instances bound. The most likely cause
        // is that a later script (Skote / Bootstrap dropdowns / a layout JS)
        // mutates DOM right after this block runs, invalidating any
        // references Sortable captured.
        //
        // Three guards:
        //   1. Defer to the next animation frame so any synchronous DOM
        //      mutation queued before us is drained first.
        //   2. Detect any column that came out without a Sortable instance
        //      (Sortable.get(col) === null) and retry it. Two retries with
        //      a 250 ms gap cover the slowest enhancement pass we've seen.
        //   3. Wrap each new Sortable(...) in try/catch + console.error so
        //      future breakage surfaces in DevTools instead of silently
        //      degrading drag/drop to a no-op.
        const sortableOptions = {
            group: 'kanban',
            animation: 150,
            ghostClass: 'sortable-ghost',
            dragClass: 'sortable-drag',
            onEnd: function(evt) {
                    // Reordering within the same column is not a status change —
                    // skip the API call so the state machine doesn't reject a
                    // self-transition (e.g. UnderReview → UnderReview).
                    if (evt.from === evt.to) return;

                    const itemId = evt.item.dataset.id;
                    const newStatus = evt.to.closest('[data-status]').dataset.status;

                    // Call API to update status
                    fetch('@Url.Action("UpdateStatus", "Improvements")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        },
                        body: JSON.stringify({ id: itemId, status: newStatus })
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (!data.success) {
                            // Rollback FIRST so the UI is correct even if Swal is slow.
                            evt.item.remove();
                            evt.from.insertBefore(evt.item, evt.from.children[evt.oldIndex]);
                            Swal.fire({
                                icon: 'warning',
                                title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Toast_TransitionBlocked"].Value)),
                                html: '<div class="text-sm text-start">' + (data.error || @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Toast_TransitionBlockedFallback"].Value))) + '</div>',
                                confirmButtonColor: '#005B99',
                                confirmButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Button_OK"].Value))
                            });
                        } else {
                            // Subtle non-blocking toast using Swal mixin
                            const Toast = Swal.mixin({
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true
                            });
                            Toast.fire({ icon: 'success', title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Toast_StatusUpdated"].Value)) });
                            // Update badge counts
                            updateColumnCounts();
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        Swal.fire({
                            icon: 'error',
                            title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Js_Error"].Value)),
                            text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Js_ConnectionError"].Value))
                        });
                        // Revert the move
                        evt.item.remove();
                        evt.from.insertBefore(evt.item, evt.from.children[evt.oldIndex]);
                    });
                }
        };

        function initKanbanSortable() {
            let installed = 0;
            document.querySelectorAll('.kanban-cards').forEach(column => {
                // Skip columns already bound — keeps the retry idempotent.
                if (Sortable.get && Sortable.get(column)) return;
                try {
                    new Sortable(column, sortableOptions);
                    installed++;
                } catch (err) {
                    console.error('Sortable init failed on column', column, err);
                }
            });
            return installed;
        }

        // Defer past any late DOM mutations from Skote / Bootstrap / Tailwind
        // play, then retry once at 250 ms and once at 750 ms to cover slower
        // enhancement passes.
        requestAnimationFrame(() => {
            initKanbanSortable();
            setTimeout(initKanbanSortable, 250);
            setTimeout(initKanbanSortable, 750);
        });

        // Update column counts
        function updateColumnCounts() {
            document.querySelectorAll('[data-status]').forEach(column => {
                const count = column.querySelectorAll('.kanban-card').length;
                const badge = column.querySelector('.badge');
                if (badge) badge.textContent = count;
            });
        }

        // Filter functionality
        document.getElementById('filterQuadrant').addEventListener('change', filterCards);
        document.getElementById('filterStatus').addEventListener('change', filterCards);
        document.getElementById('filterPriority').addEventListener('change', filterCards);
        document.getElementById('searchInput').addEventListener('input', filterCards);

        function filterCards() {
            const quadrant = document.getElementById('filterQuadrant').value;
            const status = document.getElementById('filterStatus').value;
            const priority = document.getElementById('filterPriority').value;
            const search = document.getElementById('searchInput').value.toLowerCase();

            // Filter cards
            document.querySelectorAll('.kanban-card').forEach(card => {
                let show = true;

                if (quadrant && card.dataset.quadrant !== quadrant) show = false;
                if (priority && card.dataset.priority !== priority) show = false;
                if (search && !card.textContent.toLowerCase().includes(search)) show = false;

                card.style.display = show ? '' : 'none';
            });

            // Filter columns by status
            document.querySelectorAll('[data-status]').forEach(column => {
                if (status && column.dataset.status !== status) {
                    column.style.display = 'none';
                } else {
                    column.style.display = '';
                }
            });

            lucide.createIcons();
        }

        function clearFilters() {
            document.getElementById('filterQuadrant').value = '';
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterPriority').value = '';
            document.getElementById('searchInput').value = '';
            filterCards();
        }

        // Click to view details
        document.querySelectorAll('.kanban-card').forEach(card => {
            card.addEventListener('click', function(e) {
                // Don't navigate if dragging
                if (e.target.closest('.sortable-drag')) return;
                window.location.href = '@Url.Action("Details", "Improvements")/' + this.dataset.id;
            });
        });
    </script>
}

