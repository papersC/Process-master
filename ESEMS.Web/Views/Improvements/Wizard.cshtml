            const setVal = (sel, v) => { const el = card.querySelector(sel); if (el) el.value = v || ''; };
            setVal('.m-name-en', ne);
            setVal('.m-name-ar', na);
            setVal('.m-unit', unit);

            // Direction toggle — flip to whatever the catalog says
            if (dir) {
                card.querySelectorAll('.dir-btn').forEach(b => {
                    const isMatch = (b.dataset.dir === dir);
                    b.classList.toggle('active', isMatch);
                    if (isMatch) {
                        const hidden = card.querySelector('.m-direction');
                        if (hidden) hidden.value = dir;
                    }
                });
            }

            // Type — KpiDefinition.DefaultType maps onto the measurement type select
            if (dtype) {
                const typeSel = card.querySelector('.m-type');
                if (typeSel) {
                    const opt = Array.from(typeSel.options).find(o => o.value === dtype);
                    if (opt) typeSel.value = dtype;
                }
            }

            if (window.lucide) lucide.createIcons();
        }

