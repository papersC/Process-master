@model ImprovementInitiative
@{
    ViewData["Title"] = Shared["Title_ImprovementWizard"].Value ?? "Improvement Wizard";
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<div class="wiz-shell">
    <!-- Compact full-width page header: title + step counter + cancel. -->
    <div class="wiz-pageheader">
        <div class="wiz-pageheader-title">
            <i data-lucide="wand-2" class="w-4 h-4" style="color:#005B99" aria-hidden="true"></i>
            <h1>@ViewData["Title"]</h1>
        </div>
        <div class="wiz-pageheader-meta">
            <span class="wiz-step-counter">
                <span id="currentStepLabel">@(isRtl ? "الخطوة" : "Step")</span>
                <span id="currentStep">1</span>
                <span>@(isRtl ? "من" : "of")</span>
                <span>3</span>
            </span>
            <a asp-action="Index" id="wizardCancelBtn" class="wiz-cancel">
                <i data-lucide="x" class="w-3.5 h-3.5" aria-hidden="true"></i>
                @Shared["Button_Cancel"]
            </a>
        </div>
    </div>

    @* KPI summary strip — live counts of what the user has built so far.
       Sits below the page header so the picture-of-progress is always
       visible without leaving whatever step you're on. JS updates every
       chip on input/change/MutationObserver. *@
    <div class="wiz-kpi-strip" id="wizKpiStrip" aria-label="@(isRtl ? "ملخص مباشر" : "Live summary")">
        <span class="wiz-kpi" data-kpi="processes" title="@(isRtl ? "العمليات المختارة" : "Selected processes")">
            <i data-lucide="git-branch" class="w-3.5 h-3.5" aria-hidden="true"></i>
            <span class="wiz-kpi-num" data-kpi-num="processes">0</span>
            <span class="wiz-kpi-lbl">@(isRtl ? "عمليات" : "processes")</span>
        </span>
        <span class="wiz-kpi" data-kpi="services" title="@(isRtl ? "الخدمات المختارة" : "Selected services")">
            <i data-lucide="package" class="w-3.5 h-3.5" aria-hidden="true"></i>
            <span class="wiz-kpi-num" data-kpi-num="services">0</span>
            <span class="wiz-kpi-lbl">@(isRtl ? "خدمات" : "services")</span>
        </span>
        <span class="wiz-kpi" data-kpi="measurements" title="@(isRtl ? "المقاييس المضافة" : "Added measurements")">
            <i data-lucide="bar-chart-3" class="w-3.5 h-3.5" aria-hidden="true"></i>
            <span class="wiz-kpi-num" data-kpi-num="measurements">0</span>
            <span class="wiz-kpi-lbl">@(isRtl ? "مقاييس" : "measurements")</span>
        </span>
        <span class="wiz-kpi" data-kpi="team" title="@(isRtl ? "أعضاء الفريق" : "Team members")">
            <i data-lucide="users" class="w-3.5 h-3.5" aria-hidden="true"></i>
            <span class="wiz-kpi-num" data-kpi-num="team">0</span>
            <span class="wiz-kpi-lbl">@(isRtl ? "أعضاء" : "team")</span>
        </span>
        <span class="wiz-kpi" data-kpi="actions" title="@(isRtl ? "الإجراءات" : "Action items")">
            <i data-lucide="list-todo" class="w-3.5 h-3.5" aria-hidden="true"></i>
            <span class="wiz-kpi-num" data-kpi-num="actions">0</span>
            <span class="wiz-kpi-lbl">@(isRtl ? "إجراءات" : "actions")</span>
        </span>
    </div>

    <!-- Body: vertical-stepper rail (left) + main content (right). -->
    <div class="wiz-body">
        <aside class="wiz-rail @(isRtl ? "wiz-rail-rtl" : "")" aria-label="@(isRtl ? "خطوات المعالج" : "Wizard steps")">
            @* Consolidated 3-step rail (was 7). Each macro step contains the
               original sub-section panes — those still exist below as
               wizard-content divs sharing the same data-step value.            *@
            <ol class="wiz-stepper">
                <li class="wizard-step active cursor-pointer" data-step="1" title="@(isRtl ? "تعريف" : "Define")">
                    <div class="step-circle">1</div>
                    <div class="step-meta">
                        <div class="step-label">@(isRtl ? "تعريف" : "Define")</div>
                        <div class="step-subtitle">@(isRtl ? "النطاق والتصنيف" : "Scope & classification")</div>
                    </div>
                </li>
                <li class="wizard-step cursor-pointer" data-step="2" title="@(isRtl ? "القياس والهدف" : "Measure & Target")">
                    <div class="step-circle">2</div>
                    <div class="step-meta">
                        <div class="step-label">@(isRtl ? "القياس والهدف" : "Measure & Target")</div>
                        <div class="step-subtitle">@(isRtl ? "المقاييس والقيم" : "Metrics + values")</div>
                    </div>
                </li>
                <li class="wizard-step cursor-pointer" data-step="3" title="@(isRtl ? "التقييم والخطة" : "Score & Plan")">
                    <div class="step-circle">3</div>
                    <div class="step-meta">
                        <div class="step-label">@(isRtl ? "التقييم والخطة" : "Score & Plan")</div>
                        <div class="step-subtitle">@(isRtl ? "الأولوية والفريق والإجراءات" : "Priority + team + actions")</div>
                    </div>
                </li>
            </ol>
        </aside>

        <main class="wiz-main">
    <!-- Wizard Form -->
    <form asp-action="CreateFromWizard" method="post" id="wizardForm" data-once-submit>
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
	        <div id="clientError" class="alert alert-danger mb-4 hidden"></div>

		        <!-- Keep legacy single FK fields for backward compatibility (set via JS from multi-select) -->
		        <input asp-for="ProcessId" type="hidden" id="hdnSingleProcessId" />
		        <input asp-for="ServiceId" type="hidden" id="hdnSingleServiceId" />

        <!-- Status is hidden — brand-new initiatives default to Proposed. -->
        <input type="hidden" asp-for="Status" value="Proposed" />

        <!-- Step 1 (Scope): just pick what you're improving + the title.
             4 fields fit comfortably in ~200px. -->
        <div class="wizard-content bg-white rounded-lg shadow-sm p-4 mb-3" data-step="1">
            <div class="flex items-center gap-2 mb-3">
                <i data-lucide="target" class="w-4 h-4" style="color:#005B99"></i>
                <h3 class="text-base font-semibold text-gray-900">@(isRtl ? "النطاق" : "Scope")</h3>
            </div>
            @* Live completion checklist for this macro step. JS sets the
               .wiz-checklist data state to "ok" / "missing" and rewrites
               the inner text. Rendered once per step at the top pane. *@
            <div class="wiz-checklist" data-step-checklist="1" data-state="missing">
                <i data-lucide="circle-dashed" class="w-3.5 h-3.5" aria-hidden="true"></i>
                <span class="wiz-checklist-text"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                <div>
                    <label class="form-label text-sm mb-1">@(isRtl ? "العمليات" : "Processes")</label>
                    <div class="cs-wrap relative" id="csWrap_processes">
                        <div class="cs-trigger flex flex-wrap items-center gap-1 px-2 py-1 border border-gray-300 rounded-md min-h-[32px] bg-white cursor-pointer" onclick="csToggle('processes')">
                            <span id="csChips_processes" class="flex flex-wrap gap-1"></span>
                            <span id="csPh_processes" class="text-xs text-gray-400 truncate">@(isRtl ? "اختر عمليات..." : "Select processes...")</span>
                            <svg class="w-3.5 h-3.5 text-gray-400 ml-auto shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </div>
                        <div id="csDrop_processes" class="absolute z-50 mt-1 w-full bg-white border border-gray-200 rounded-md shadow-lg hidden">
                            <div class="p-2 border-b border-gray-100">
                                <input type="text" placeholder="@(isRtl ? "بحث..." : "Search...")" class="w-full px-2 py-1 text-xs border border-gray-200 rounded focus:outline-none" oninput="csFilter('processes',this.value)">
                            </div>
                            <div class="max-h-60 overflow-y-auto">
                                @{
                                    var processItems = ViewBag.Processes as IEnumerable<SelectListItem> ?? Array.Empty<SelectListItem>();
                                }
                                @foreach (var item in processItems)
                                {
                                    <label class="cs-opt flex items-center gap-2 px-3 py-1.5 hover:bg-blue-50 cursor-pointer text-xs">
                                        <input type="checkbox" value="@item.Value" class="rounded text-blue-600 cs-chk" data-csid="processes" data-label="@item.Text" onchange="csUpdate('processes')">
                                        <span class="truncate">@item.Text</span>
                                    </label>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div>
                    <label class="form-label text-sm mb-1">@(isRtl ? "الخدمات" : "Services")</label>
                    <div class="cs-wrap relative" id="csWrap_services">
                        <div class="cs-trigger flex flex-wrap items-center gap-1 px-2 py-1 border border-gray-300 rounded-md min-h-[32px] bg-white cursor-pointer" onclick="csToggle('services')">
                            <span id="csChips_services" class="flex flex-wrap gap-1"></span>
                            <span id="csPh_services" class="text-xs text-gray-400 truncate">@(isRtl ? "اختر خدمات..." : "Select services...")</span>
                            <svg class="w-3.5 h-3.5 text-gray-400 ml-auto shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </div>
                        <div id="csDrop_services" class="absolute z-50 mt-1 w-full bg-white border border-gray-200 rounded-md shadow-lg hidden">
                            <div class="p-2 border-b border-gray-100">
                                <input type="text" placeholder="@(isRtl ? "بحث..." : "Search...")" class="w-full px-2 py-1 text-xs border border-gray-200 rounded focus:outline-none" oninput="csFilter('services',this.value)">
                            </div>
                            <div class="max-h-60 overflow-y-auto">
                                @{
                                    var serviceItems = ViewBag.Services as IEnumerable<SelectListItem> ?? Array.Empty<SelectListItem>();
                                }
                                @foreach (var item in serviceItems)
                                {
                                    <label class="cs-opt flex items-center gap-2 px-3 py-1.5 hover:bg-blue-50 cursor-pointer text-xs">
                                        <input type="checkbox" value="@item.Value" class="rounded text-blue-600 cs-chk" data-csid="services" data-label="@item.Text" onchange="csUpdate('services')">
                                        <span class="truncate">@item.Text</span>
                                    </label>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label asp-for="TitleEn" class="form-label text-sm mb-1">@(isRtl ? "العنوان (إنجليزي)" : "Title (English)") <span class="text-danger">*</span></label>
                    <input asp-for="TitleEn" class="form-control form-control-sm" placeholder="@(isRtl ? "مثال: Reduce Processing Time" : "e.g., Reduce Processing Time")" />
                </div>
                <div>
                    <label asp-for="TitleAr" class="form-label text-sm mb-1">@(isRtl ? "العنوان (عربي)" : "Title (Arabic)") <span class="text-danger">*</span></label>
                    <input asp-for="TitleAr" class="form-control form-control-sm" placeholder="@(isRtl ? "مثال: تقليل وقت المعالجة" : "e.g., تقليل وقت المعالجة")" dir="rtl" />
                </div>
            </div>
            <p class="text-[11px] text-gray-400 mt-2">@(isRtl ? "يمكنك اختيار أكثر من عملية و/أو خدمة." : "You can pick more than one process and/or service.")</p>
        </div>

        <!-- Step 2 (Details): descriptions + classification (Source / Owner /
             Innovation Type / Horizon). Kept flat — ~6 small fields. -->
        @* Was Step 2 — now folded into Step 1 (Define). *@
        <div class="wizard-content bg-white rounded-lg shadow-sm p-4 mb-3 hidden" data-step="1">
            <div class="flex items-center gap-2 mb-3">
                <i data-lucide="file-text" class="w-4 h-4" style="color:#005B99"></i>
                <h3 class="text-base font-semibold text-gray-900">@(isRtl ? "التفاصيل والتصنيف (اختياري)" : "Details & Classification (optional)")</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                <div>
                    <label asp-for="DescriptionEn" class="form-label text-sm mb-1">@(isRtl ? "الوصف (إنجليزي)" : "Description (English)")</label>
                    <textarea asp-for="DescriptionEn" class="form-control form-control-sm" rows="2" placeholder="@(isRtl ? "صف مبادرة التحسين..." : "Describe the improvement initiative...")"></textarea>
                </div>
                <div>
                    <label asp-for="DescriptionAr" class="form-label text-sm mb-1">@(isRtl ? "الوصف (عربي)" : "Description (Arabic)")</label>
                    <textarea asp-for="DescriptionAr" class="form-control form-control-sm" rows="2" placeholder="@(isRtl ? "وصف مبادرة التحسين..." : "Describe the improvement initiative (Arabic)...")" dir="rtl"></textarea>
                </div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                <div>
                    <label asp-for="Source" class="form-label text-sm mb-1">@Shared["Label_Source"]</label>
                    <select asp-for="Source" asp-items="@(new SelectList(Enum.GetValues<ChangeRequestSource>().Select(v => new { Value = v.ToString(), Display = Shared[$"ChangeRequestSource_{v}"].Value }), "Value", "Display"))" class="form-select form-select-sm"></select>
                </div>
                <div>
                    <label asp-for="OwnerId" class="form-label text-sm mb-1">@Shared["Label_Owner"]</label>
                    <select asp-for="OwnerId" asp-items="ViewBag.Users" class="form-select form-select-sm">
                        <option value="">@(isRtl ? "-- اختر --" : "-- Select --")</option>
                    </select>
                </div>
                <div>
                    <label asp-for="InnovationType" class="form-label text-sm mb-1">@Shared["Label_InnovationType"]</label>
                    <select asp-for="InnovationType" asp-items="@(new SelectList(Enum.GetValues<InnovationType>().Select(v => new { Value = v.ToString(), Display = Shared[$"InnovationType_{v}"].Value }), "Value", "Display"))" class="form-select form-select-sm">
                        <option value="">@(isRtl ? "-- اختر --" : "-- Select --")</option>
                    </select>
                </div>
                <div>
                    <label asp-for="Horizon" class="form-label text-sm mb-1">@Shared["Label_Horizon"]</label>
                    <select asp-for="Horizon" asp-items="@(new SelectList(Enum.GetValues<ImprovementHorizon>().Select(v => new { Value = v.ToString(), Display = Shared[$"ImprovementHorizon_{v}"].Value }), "Value", "Display"))" class="form-select form-select-sm">
                        <option value="">@(isRtl ? "-- اختر --" : "-- Select --")</option>
                    </select>
                </div>
                @* TargetDate moved here from old Step 4 — initiative-level deadline
                   that defines a planning attribute, so it lives with the other
                   classification fields. *@
                <div>
                    <label asp-for="TargetDate" class="form-label text-sm mb-1">@(isRtl ? "تاريخ الإنجاز المستهدف" : "Target Completion Date")</label>
                    <input asp-for="TargetDate" type="date" class="form-control form-control-sm" />
                </div>
            </div>
        </div>

        <!-- Hidden fields for measurement data (populated by JS on submit) -->
        <input type="hidden" name="MeasurementTypes" id="hdnMeasurementTypes" />
        <input type="hidden" name="MeasurementNames" id="hdnMeasurementNames" />
        <input type="hidden" name="MeasurementNamesAr" id="hdnMeasurementNamesAr" />
        <input type="hidden" name="MeasurementUnits" id="hdnMeasurementUnits" />
        <input type="hidden" name="MeasurementTargets" id="hdnMeasurementTargets" />
        <input type="hidden" name="MeasurementAsIs" id="hdnMeasurementAsIs" />
        <input type="hidden" name="MeasurementWeights" id="hdnMeasurementWeights" />
        <input type="hidden" name="MeasurementAppliesTo" id="hdnMeasurementAppliesTo" />
        <input type="hidden" name="MeasurementPeriods" id="hdnMeasurementPeriods" />
        <input type="hidden" name="MeasurementMethods" id="hdnMeasurementMethods" />
        <input type="hidden" name="MeasurementToBe" id="hdnMeasurementToBe" />
        <input type="hidden" name="MeasurementBpmn" id="hdnMeasurementBpmn" />
        <input type="hidden" name="MeasurementPriorities" id="hdnMeasurementPriorities" />
        <input type="hidden" name="MeasurementDirections" id="hdnMeasurementDirections" />
        @* New: persists the per-row catalog link so the saved ImprovementMeasurement
           rows carry KpiDefinitionId. Per-card values are stored in .m-kpi-definition-id
           hidden inputs and joined with '|' on form submit. *@
        <input type="hidden" name="MeasurementKpiDefinitionIds" id="hdnMeasurementKpiDefinitionIds" />

        <!-- Was Step 3 (Define Metrics) — now Step 2 (Measure & Target).
             Per-card Now/Target inputs were inlined inside addMeasurementRow,
             so the standalone Step-4 pane below has been removed. -->
        <div class="wizard-content bg-white rounded-lg shadow-sm p-4 mb-3 hidden" data-step="2">
            <h3 class="text-xl font-semibold text-gray-900 mb-4">
                <i data-lucide="bar-chart-3" class="w-5 h-5 inline-block text-blue-600"></i>
                @Shared["Title_Step2"]
            </h3>
            <p class="text-gray-600 mb-6">@Shared["Text_Step2Desc"]</p>

            <div class="wiz-checklist" data-step-checklist="2" data-state="missing">
                <i data-lucide="circle-dashed" class="w-3.5 h-3.5" aria-hidden="true"></i>
                <span class="wiz-checklist-text"></span>
            </div>

            <!-- Scope Summary Banner -->
            <div class="scope-banner-container"></div>

            <div id="measurementRows" class="d-flex flex-column gap-3">
                <!-- Measurement cards will be added here by JS -->
            </div>

            @* Compact empty-hint — visible only when there are zero cards.
               Points down to the Quick Add strip below as the primary path. *@
            <div id="measurementEmpty" class="text-center py-3 px-4 mt-2 border border-dashed border-gray-300 rounded text-sm text-gray-500">
                <i data-lucide="info" class="w-3.5 h-3.5 inline-block" style="color:#94a3b8;margin-inline-end:.25rem;"></i>
                @(isRtl ? "اختر قالبًا أدناه أو أضف مقياسًا فارغًا:" : "Pick a template below, or add a blank measurement:")
                <button type="button" class="btn btn-link btn-sm p-0 ms-1" style="font-size:var(--fs-sm);" onclick="addMeasurementRow()">
                    @(isRtl ? "+ إضافة فارغ" : "+ Add blank")
                </button>
            </div>

            @* Quick-add row — common KPI shapes pre-fill Type / Direction /
               Unit. Always visible on step 2, sits below the cards so the
               user adds new measurements at the end of the existing list. *@
            <div id="qaTemplates" class="mt-3" style="position:relative;">
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <span class="text-xs text-gray-500" style="font-weight:600;">@(isRtl ? "إضافة سريعة:" : "Quick add:")</span>
                    <button type="button" class="btn btn-sm btn-outline-secondary qa-tpl" data-tpl="time">
                        <i data-lucide="clock" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                        @(isRtl ? "وقت" : "Time")
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary qa-tpl" data-tpl="cost">
                        <i data-lucide="banknote" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                        @(isRtl ? "تكلفة" : "Cost")
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary qa-tpl" data-tpl="satisfaction">
                        <i data-lucide="smile" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                        @(isRtl ? "الرضا" : "Satisfaction")
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary qa-tpl" data-tpl="productivity">
                        <i data-lucide="trending-up" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                        @(isRtl ? "إنتاجية" : "Productivity")
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary qa-tpl" data-tpl="errors">
                        <i data-lucide="alert-triangle" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                        @(isRtl ? "نسبة الأخطاء" : "Error rate")
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary qa-tpl" data-tpl="visits">
                        <i data-lucide="users-2" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                        @(isRtl ? "عدد الزيارات" : "Visits")
                    </button>
                </div>
                @* Target picker — shown after the user clicks a template and
                   2+ scope items are selected. Lets the user choose exactly
                   which processes / services this measurement should apply
                   to (default: all selected). *@
                <div id="qaTargetPicker" class="qa-picker hidden">
                    <div class="qa-picker-header">
                        <strong id="qaPickerTitle"></strong>
                        <button type="button" class="btn btn-sm btn-link p-0 ms-auto" id="qaPickerClose" aria-label="@(isRtl?"إغلاق":"Close")">
                            <i data-lucide="x" class="w-3.5 h-3.5" aria-hidden="true"></i>
                        </button>
                    </div>
                    <div class="qa-picker-body">
                        <p class="text-xs text-gray-600 mb-2">@(isRtl ? "اختر العناصر التي ينطبق عليها هذا المقياس:" : "Pick which scope items this measurement applies to:")</p>
                        <div id="qaPickerList" class="d-flex flex-column gap-1"></div>
                    </div>
                    <div class="qa-picker-footer">
                        <button type="button" class="btn btn-sm btn-link" id="qaPickerSelectAll">@(isRtl ? "تحديد الكل" : "Select all")</button>
                        <button type="button" class="btn btn-sm btn-link" id="qaPickerSelectNone">@(isRtl ? "إلغاء التحديد" : "Clear")</button>
                        <span style="flex:1"></span>
                        <button type="button" class="btn btn-sm btn-primary" id="qaPickerApply">@(isRtl ? "تطبيق" : "Apply")</button>
                    </div>
                </div>
            </div>

            <button type="button" id="btnAddMeasurement" class="btn btn-outline-primary btn-sm mt-3 hidden" onclick="addMeasurementRow()">
                <i data-lucide="plus" class="w-4 h-4 inline-block"></i>
                @Shared["Button_AddMeasurement"]
            </button>
        </div>

        <!-- BPMN Editor Modal -->
        <div class="modal fade" id="bpmnModal" tabindex="-1" aria-labelledby="bpmnModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-centered" style="max-width:92vw;">
                <div class="modal-content">
                    <div class="modal-header py-2" style="background:linear-gradient(135deg,#005B99 0%,#003d6b 100%);color:#fff;">
                        <h5 class="modal-title" id="bpmnModalLabel">
                            <i data-lucide="git-branch" class="w-5 h-5 inline-block"></i>
                            @(isRtl ? "محرر مخطط BPMN" : "BPMN Diagram Editor")
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <!-- Tabs -->
                    <ul class="nav nav-tabs px-3 pt-2 mb-0" id="bpmnModalTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="bpmnBrowseTab" data-bs-toggle="tab" data-bs-target="#bpmnBrowsePane" type="button" role="tab">
                                <i data-lucide="folder-search" class="w-4 h-4 inline-block"></i>
                                @(isRtl ? "تصفح الموجود" : "Browse Existing")
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="bpmnDrawTab" data-bs-toggle="tab" data-bs-target="#bpmnDrawPane" type="button" role="tab">
                                <i data-lucide="pen-tool" class="w-4 h-4 inline-block"></i>
                                @(isRtl ? "رسم جديد" : "Draw New")
                            </button>
                        </li>
                    </ul>
                    <div class="modal-body p-0">
                        <div class="tab-content">
                            <!-- Tab 1: Browse Existing -->
                            <div class="tab-pane fade show active" id="bpmnBrowsePane" role="tabpanel">
                                <div class="p-3 border-bottom bg-light">
                                    <div class="d-flex align-items-center gap-3 flex-wrap">
                                        <label class="text-sm fw-semibold text-nowrap">@(isRtl ? "اختر عملية:" : "Select Process:")</label>
                                        <select id="bpmnProcessSelect" class="form-select form-select-sm" style="max-width:350px">
                                            <option value="">@(isRtl ? "-- اختر عملية --" : "-- Select a Process --")</option>
                                        </select>
                                    </div>
                                </div>
                                <div id="bpmnBrowseCanvas" style="height:420px;background:#fafafa;background-image:linear-gradient(rgba(0,0,0,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,.04) 1px,transparent 1px);background-size:20px 20px;position:relative;">
                                    <div id="bpmnModalEmpty" class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                                        <i data-lucide="file-code-2" class="w-12 h-12 mb-3" style="opacity:.4"></i>
                                        <p class="text-sm">@(isRtl ? "اختر عملية لعرض مخططها" : "Select a process to view its diagram")</p>
                                    </div>
                                </div>
                            </div>
                            <!-- Tab 2: Draw New -->
                            <div class="tab-pane fade" id="bpmnDrawPane" role="tabpanel">
                                <div class="p-2 border-bottom bg-light d-flex align-items-center gap-2 flex-wrap">
                                    <button type="button" class="btn btn-outline-secondary btn-sm" id="bpmnNewBtn" title="@(isRtl?"جديد":"New")" aria-label="@(isRtl?"جديد":"New")"><i data-lucide="file-plus" class="w-4 h-4 inline-block" aria-hidden="true"></i></button>
                                    <div class="vr"></div>
                                    <button type="button" class="btn btn-outline-primary btn-sm" id="bpmnAiGenBtn"><i data-lucide="sparkles" class="w-4 h-4 inline-block" aria-hidden="true"></i> @(isRtl?"توليد AI":"AI Generate")</button>
                                    <button type="button" class="btn btn-outline-info btn-sm" id="bpmnAiRefineBtn"><i data-lucide="wand-2" class="w-4 h-4 inline-block" aria-hidden="true"></i> @(isRtl?"تحسين AI":"AI Refine")</button>
                                    <div class="vr"></div>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" id="bpmnZoomInBtn" title="@Shared["Button_ZoomIn"]" aria-label="@Shared["Button_ZoomIn"]"><i data-lucide="zoom-in" class="w-4 h-4 inline-block" aria-hidden="true"></i></button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" id="bpmnZoomOutBtn" title="@Shared["Button_ZoomOut"]" aria-label="@Shared["Button_ZoomOut"]"><i data-lucide="zoom-out" class="w-4 h-4 inline-block" aria-hidden="true"></i></button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" id="bpmnFitBtn" title="@Shared["Button_Fit"]" aria-label="@Shared["Button_Fit"]"><i data-lucide="maximize-2" class="w-4 h-4 inline-block" aria-hidden="true"></i></button>
                                    <div class="vr"></div>
                                    <button type="button" class="btn btn-success btn-sm ms-auto" id="bpmnSaveToProcessBtn"><i data-lucide="save" class="w-4 h-4 inline-block"></i> @(isRtl?"حفظ للعملية":"Save to Process")</button>
                                </div>
                                <!-- AI panel -->
                                <div id="bpmnAiPanel" class="p-3 border-bottom bg-white d-none">
                                    <div class="row g-2">
                                        <div class="col-md-4"><input type="text" id="bpmnAiTitle" class="form-control form-control-sm" placeholder="@(isRtl?"اسم العملية":"Process name")"></div>
                                        <div class="col-md-6"><input type="text" id="bpmnAiDesc" class="form-control form-control-sm" placeholder="@(isRtl?"وصف أو تعليمات":"Description or instructions")"></div>
                                        <div class="col-md-2"><button type="button" class="btn btn-primary btn-sm w-100" id="bpmnAiGoBtn"><i data-lucide="play" class="w-4 h-4 inline-block"></i> @(isRtl?"تنفيذ":"Go")</button></div>
                                    </div>
                                    <div id="bpmnAiStatus" class="text-xs text-muted mt-1 d-none"></div>
                                </div>
                                <!-- Save panel -->
                                <div id="bpmnSavePanel" class="p-3 border-bottom bg-white d-none">
                                    <div class="row g-2 align-items-end">
                                        <div class="col-md-5">
                                            <label class="form-label text-xs mb-1">@(isRtl?"حفظ إلى عملية:":"Save to process:")</label>
                                            <select id="bpmnSaveProcessSelect" class="form-select form-select-sm"><option value="">@(isRtl?"-- اختر --":"-- Select --")</option></select>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label text-xs mb-1">@(isRtl?"أو اسم جديد:":"Or new name:")</label>
                                            <input type="text" id="bpmnSaveNewName" class="form-control form-control-sm" placeholder="@(isRtl?"اسم العملية الجديدة":"New process name")">
                                        </div>
                                        <div class="col-md-3 d-flex gap-2">
                                            <button type="button" class="btn btn-success btn-sm flex-grow-1" id="bpmnSaveGoBtn"><i data-lucide="check" class="w-4 h-4 inline-block"></i> @(isRtl?"حفظ":"Save")</button>
                                            <button type="button" class="btn btn-outline-secondary btn-sm" id="bpmnSaveCancelBtn">@(isRtl?"إلغاء":"Cancel")</button>
                                        </div>
                                    </div>
                                    <div id="bpmnSaveStatus" class="text-xs mt-1 d-none"></div>
                                </div>
                                <div id="bpmnDrawCanvas" style="height:420px;background:#fff;position:relative;"></div>
                            </div>
                        </div>
                        <!-- Element info (shared) -->
                        <div id="bpmnElementInfo" class="p-2 border-top bg-light d-none">
                            <div class="d-flex align-items-center gap-2">
                                <i data-lucide="mouse-pointer-click" class="w-4 h-4" style="color:#005B99"></i>
                                <span class="text-sm">@(isRtl ? "العنصر المحدد:" : "Selected Element:")</span>
                                <code id="bpmnSelectedElementId" class="bg-blue-50 text-blue-700 px-2 py-1 rounded text-xs"></code>
                                <button type="button" class="btn btn-primary btn-sm ms-auto" id="bpmnUseRefBtn">
                                    <i data-lucide="check" class="w-4 h-4 inline-block"></i>
                                    @(isRtl ? "استخدام المرجع" : "Use Reference")
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Old Step 4 (Target & Current Values) deleted — its inputs live
           per-card in Step 2 (.m-current / .m-target), and TargetDate moved
           into Step 1's Classification block. *@

        @{
            // Slider rendering helper — reused for all 9 scoring sliders on
            // Steps 5 + 6. Each slider starts "untouched": the range input
            // sits at mid-point but the hidden input (which the model binder
            // reads) is empty, and the badge shows "—". Once the user drags,
            // the hidden value is populated and the badge turns blue.
            Func<string, string, string, string, Microsoft.AspNetCore.Html.IHtmlContent> renderSlider =
                (field, label, weight, legend) =>
            {
                var encLabel = System.Net.WebUtility.HtmlEncode(label);
                var encLegend = System.Net.WebUtility.HtmlEncode(legend);
                return new Microsoft.AspNetCore.Html.HtmlString(
                    $@"<div class=""score-slider"" data-field=""{field}"">
                        <div class=""flex items-center justify-between mb-0.5"">
                            <label class=""text-xs text-gray-700 font-medium"">{encLabel} <span class=""text-gray-400"">({weight})</span></label>
                            <span class=""score-badge inline-flex items-center justify-center text-xs font-bold text-white rounded px-2 py-0"" style=""background:#9ca3af;min-width:26px;height:18px"">—</span>
                        </div>
                        <input type=""range"" min=""1"" max=""10"" value=""5"" class=""form-range score-slider-input"" data-touched=""false"" />
                        <input type=""hidden"" name=""{field}"" id=""{field}"" value="""" />
                        <div class=""text-[10px] text-gray-500 italic mt-0.5"">{encLegend}</div>
                    </div>"
                );
            };
        }

        @* Was Step 5 — now part of Step 3 (Score & Plan).
           Initiative-level Impact/Effort + Business Readiness sliders. *@
        <div class="wizard-content bg-white rounded-lg shadow-sm p-4 mb-3 hidden" data-step="3">
            <div class="flex items-center gap-2 mb-3 flex-wrap">
                <i data-lucide="target" class="w-4 h-4" style="color:#005B99"></i>
                <h3 class="text-base font-semibold text-gray-900 mb-0">@(isRtl ? "الربع والجاهزية" : "Quadrant & Readiness")</h3>
                <button type="button" id="aiSuggestScoring"
                        class="ml-auto inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-md border-0 text-white"
                        style="background:linear-gradient(90deg,#7c3aed 0%,#4f46e5 100%);">
                    <i data-lucide="sparkles" style="width:12px;height:12px;"></i>
                    <span id="aiSuggestScoringLabel">@(isRtl ? "اقتراح ذكي للنتيجة" : "Suggest scores with AI")</span>
                </button>
            </div>
            <div id="aiScoringResult" class="hidden mb-3 p-2.5 rounded-md border text-xs" style="background:#f5f3ff;border-color:#ddd6fe;color:#5b21b6;">
                <div class="flex items-center gap-2 mb-1">
                    <i data-lucide="sparkles" style="width:12px;height:12px;"></i>
                    <strong>@(isRtl ? "اقتراح الذكاء الاصطناعي" : "AI suggestion")</strong>
                    <span id="aiScoringQuadrant" class="px-1.5 py-0.5 rounded text-[10px] font-bold" style="background:#ede9fe;"></span>
                </div>
                <div id="aiScoringReasoning"></div>
            </div>

            <!-- Initiative-level Impact × Effort + live quadrant badge -->
            <div class="mb-3 p-3 rounded-md border border-gray-200 bg-gray-50">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
                    <div class="score-slider" data-field="ImpactScore">
                        <div class="flex items-center justify-between mb-0.5">
                            <label class="text-xs text-gray-700 font-medium">@(isRtl ? "التأثير" : "Impact")</label>
                            <span class="score-badge inline-flex items-center justify-center text-xs font-bold text-white rounded px-2 py-0" id="ImpactScoreBadge" style="background:#005B99;min-width:26px;height:18px">5</span>
                        </div>
                        <input type="range" min="1" max="10" value="5" class="form-range impact-effort-slider" data-target="ImpactScore" data-badge="ImpactScoreBadge" />
                        <input asp-for="ImpactScore" type="hidden" id="ImpactScore" value="5" />
                        <div class="text-[10px] text-gray-500 italic mt-0.5">@(isRtl ? "10 = تأثير استراتيجي عالٍ جداً" : "10 = very high strategic impact")</div>
                    </div>
                    <div class="score-slider" data-field="EffortScore">
                        <div class="flex items-center justify-between mb-0.5">
                            <label class="text-xs text-gray-700 font-medium">@(isRtl ? "الجهد" : "Effort")</label>
                            <span class="score-badge inline-flex items-center justify-center text-xs font-bold text-white rounded px-2 py-0" id="EffortScoreBadge" style="background:#005B99;min-width:26px;height:18px">5</span>
                        </div>
                        <input type="range" min="1" max="10" value="5" class="form-range impact-effort-slider" data-target="EffortScore" data-badge="EffortScoreBadge" />
                        <input asp-for="EffortScore" type="hidden" id="EffortScore" value="5" />
                        <div class="text-[10px] text-gray-500 italic mt-0.5">@(isRtl ? "10 = جهد تنفيذ كبير جداً" : "10 = very high delivery effort")</div>
                    </div>
                    <div>
                        <label class="text-xs text-gray-700 font-medium">@(isRtl ? "الربع" : "Quadrant")</label>
                        <div id="quadrantBadge" class="mt-0.5 px-3 py-1.5 rounded-md text-center text-sm font-semibold" style="background:#e0f2fe;color:#075985">—</div>
                        <div class="text-[10px] text-gray-500 italic mt-0.5" id="quadrantHint"></div>
                    </div>
                </div>
            </div>

            <!-- Business Readiness (30%) — 3 sliders -->
            <div>
                <h4 class="text-xs font-bold text-gray-900 mb-2 flex items-center gap-2">
                    <span class="inline-block w-2.5 h-2.5 rounded-full" style="background:#005B99"></span>
                    @(isRtl ? "الجاهزية المؤسسية (30%)" : "Business Readiness (30%)")
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    @renderSlider("EaseOfImplementation", Shared["Label_EaseOfImplementation"].Value, "10%",
                        isRtl ? "1 = صعب، 10 = سهل" : "1 = hard, 10 = easy")
                    @renderSlider("BudgetEstimation", Shared["Label_BudgetEstimation"].Value, "15%",
                        isRtl ? "1 = لا يوجد تمويل، 10 = الميزانية مؤمّنة" : "1 = no funding, 10 = budget locked in")
                    @renderSlider("ProjectDependency", Shared["Label_ProjectDependency"].Value, "5%",
                        isRtl ? "1 = يعتمد على الكثير، 10 = مستقل" : "1 = blocked by deps, 10 = independent")
                </div>
            </div>
        </div>

        @* Was Step 6 — now part of Step 3. 6 weighted criteria driving
           the 70% half of the composite score. *@
        <div class="wizard-content bg-white rounded-lg shadow-sm p-4 mb-3 hidden" data-step="3">
            <div class="flex items-center gap-2 mb-3">
                <i data-lucide="scale" class="w-4 h-4" style="color:#34C38F"></i>
                <h3 class="text-base font-semibold text-gray-900">@(isRtl ? "القيمة المؤسسية" : "Business Value")</h3>
                <span class="text-xs text-gray-400">— @(isRtl ? "70% من النتيجة" : "70% of total score")</span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-3">
                @renderSlider("StrategicAlignmentScore", Shared["Label_StrategicAlignment"].Value, "15%",
                    isRtl ? "10 = توافق كامل مع خطة دبي 2033" : "10 = fully aligned with Dubai Plan 2033")
                @renderSlider("LeadershipDirections", Shared["Label_LeadershipDirections"].Value, "10%",
                    isRtl ? "10 = توجيه صريح من القيادة" : "10 = explicit leadership mandate")
                @renderSlider("QualityOfLife", Shared["Label_QualityOfLife"].Value, "15%",
                    isRtl ? "10 = أثر كبير على جودة الحياة" : "10 = major QoL impact for beneficiaries")
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-3">
                @renderSlider("InnovationAndFutureShaping", Shared["Label_InnovationFutureShaping"].Value, "5%",
                    isRtl ? "10 = ابتكار تحويلي" : "10 = transformational innovation")
                @renderSlider("FinancialAndEconomicImpact", Shared["Label_FinancialEconomicImpact"].Value, "10%",
                    isRtl ? "10 = عائد اقتصادي كبير" : "10 = high economic return")
                @renderSlider("SustainabilityScore", Shared["Label_Sustainability"].Value, "15%",
                    isRtl ? "10 = يدعم الحياد المناخي 2050" : "10 = supports UAE Net Zero 2050")
            </div>

            <!-- Compact score preview -->
            <div class="p-2 rounded-md border text-xs flex items-center justify-between gap-2 flex-wrap" style="background:#f8fafc">
                <span class="font-medium text-gray-700">@(isRtl ? "النتيجة:" : "Score:")</span>
                <div class="flex items-center gap-3 flex-wrap">
                    <span style="color:#005B99"><strong>@(isRtl ? "الجاهزية" : "Readiness")</strong> <span id="readinessScore">—</span></span>
                    <span style="color:#34C38F"><strong>@(isRtl ? "القيمة" : "Value")</strong> <span id="valueScore">—</span></span>
                    <span class="px-2 py-0.5 rounded-full text-white font-bold" style="background:linear-gradient(135deg,#005B99,#003d6b)">
                        @(isRtl ? "الإجمالي" : "Total") <span id="totalScore">—</span>
                    </span>
                </div>
            </div>
        </div>

        @* Was Step 7 — now part of Step 3. Team members + action plan, tabbed
           so they no longer stack and double the vertical scroll on Step 3. *@
        <div class="wizard-content bg-white rounded-lg shadow-sm p-4 mb-3 hidden" data-step="3">
            <div class="flex items-center gap-2 mb-3">
                <i data-lucide="users" class="w-4 h-4" style="color:#005B99"></i>
                <h3 class="text-base font-semibold text-gray-900">@(isRtl ? "الفريق وخطة العمل" : "Team & Action Plan")</h3>
            </div>

            <!-- Tab strip — tabs sit on the same horizontal axis instead of
                 stacked panels so users see both at once. Counts on each tab
                 mirror live row counts so the cost of switching is visible. -->
            <div class="t3-tabs d-flex gap-2 border-bottom mb-3" role="tablist">
                <button type="button" class="t3-tab active" data-target="t3pane-team" role="tab" aria-selected="true">
                    <i data-lucide="user-plus" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                    <span>@Shared["Label_TeamMembers"]</span>
                    <span class="t3-count" id="t3CountTeam">0</span>
                </button>
                <button type="button" class="t3-tab" data-target="t3pane-actions" role="tab" aria-selected="false">
                    <i data-lucide="list-todo" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                    <span>@(isRtl ? "خطط العمل" : "Action Plans")</span>
                    <span class="t3-count" id="t3CountActions">0</span>
                </button>
            </div>

            <!-- Team pane -->
            <div id="t3pane-team" class="t3-pane" role="tabpanel">
                <div class="flex items-center justify-end mb-2">
                    <button type="button" class="btn btn-outline-primary btn-sm py-0 px-2" onclick="addTeamRow()">
                        <i data-lucide="plus" class="w-3 h-3 inline-block"></i>
                        @(isRtl ? "إضافة عضو" : "Add Member")
                    </button>
                </div>
                <div id="teamRows" class="space-y-1">
                    <p class="text-gray-400 text-xs" id="noTeamMsg">@(isRtl ? "أضف أعضاء الفريق" : "Add team members")</p>
                </div>
            </div>

            <!-- Actions pane -->
            <div id="t3pane-actions" class="t3-pane d-none" role="tabpanel">
                <div class="flex items-center justify-end mb-2">
                    <button type="button" class="btn btn-outline-primary btn-sm py-0 px-2" onclick="addActionRow()">
                        <i data-lucide="plus" class="w-3 h-3 inline-block"></i>
                        @(isRtl ? "إضافة إجراء" : "Add Action")
                    </button>
                </div>
                <div id="actionRows" class="space-y-1">
                    <p class="text-gray-400 text-xs" id="noActionMsg">@(isRtl ? "أضف إجراءات التنفيذ" : "Add implementation actions")</p>
                </div>
            </div>
        </div>

        <!-- Hidden fields for team/action data -->
        <input type="hidden" name="TeamUserIds" id="hdnTeamUserIds" />
        <input type="hidden" name="TeamRoles" id="hdnTeamRoles" />
        <input type="hidden" name="TeamNotes" id="hdnTeamNotes" />
        <input type="hidden" name="ActionNames" id="hdnActionNames" />
        <input type="hidden" name="ActionNamesAr" id="hdnActionNamesAr" />
        <input type="hidden" name="ActionAssignees" id="hdnActionAssignees" />
        <input type="hidden" name="ActionDueDates" id="hdnActionDueDates" />
        <!-- Resume marker. Set when wizard hydrates from ?draftId=X so the
             post-create handler can drop the draft once the initiative is in. -->
        <input type="hidden" name="DraftId" id="hdnDraftId" value="@(ViewBag.ResumeDraftId ?? "")" />

        <!-- Sticky bottom action bar — Previous (ghost) on the leading
             edge, Next/Create (primary/success) on the trailing edge.
             Sticks to viewport bottom inside the main column. -->
        <div class="wiz-actionbar">
            <button type="button" id="prevBtn" class="wiz-btn-prev" disabled>
                <i data-lucide="@(isRtl ? "chevron-right" : "chevron-left")" class="w-3.5 h-3.5" aria-hidden="true"></i>
                @Shared["Button_Previous"]
            </button>
            <button type="button" id="saveDraftBtn" class="btn btn-outline-secondary btn-sm inline-flex items-center gap-1 ms-2" title="@(isRtl?"احفظ الحالة الحالية للعودة لاحقًا (Ctrl+S)":"Save current state to resume later (Ctrl+S)")">
                <i data-lucide="bookmark" class="w-3.5 h-3.5" aria-hidden="true"></i>
                <span id="saveDraftLabel">@(isRtl?"احفظ كمسودة":"Save as Draft")</span>
            </button>
            <span id="autoSaveStatus" class="text-muted ms-2" style="font-size:var(--fs-xs);min-width:140px;" aria-live="polite"></span>
            <div class="wiz-actionbar-spacer"></div>
            <button type="button" id="nextBtn" class="btn btn-primary inline-flex items-center gap-2">
                @Shared["Button_Next"]
                <i data-lucide="@(isRtl ? "chevron-left" : "chevron-right")" class="w-4 h-4" aria-hidden="true"></i>
            </button>
            <button type="button" id="previewBtn" class="btn btn-outline-primary inline-flex items-center gap-2 hidden me-2" title="@(isRtl?"معاينة قبل الإنشاء":"Preview before creating")">
                <i data-lucide="eye" class="w-3.5 h-3.5" aria-hidden="true"></i>
                @(isRtl ? "معاينة" : "Preview")
            </button>
            <button type="submit" id="submitBtn" class="btn btn-success inline-flex items-center gap-2 hidden">
                <i data-lucide="check" class="w-3.5 h-3.5" aria-hidden="true"></i>
                @Shared["Button_CreateInitiative"]
            </button>
        </div>
    </form>

    @* Preview-before-submit modal — read-only render of everything the
       user has typed. Visible only on Step 3. Built lazily by JS so we
       don't pay the DOM cost until the user actually opens it. *@
    <div id="wizPreviewModal" class="wiz-preview-overlay hidden" role="dialog" aria-modal="true" aria-labelledby="wizPreviewTitle">
        <div class="wiz-preview-card">
            <div class="wiz-preview-header">
                <h3 id="wizPreviewTitle">
                    <i data-lucide="file-check-2" class="w-4 h-4 inline-block" aria-hidden="true"></i>
                    @(isRtl ? "معاينة المبادرة قبل الإنشاء" : "Review initiative before creating")
                </h3>
                <button type="button" class="btn btn-sm btn-link" id="wizPreviewClose" aria-label="@(isRtl?"إغلاق":"Close")">
                    <i data-lucide="x" class="w-4 h-4" aria-hidden="true"></i>
                </button>
            </div>
            <div class="wiz-preview-body" id="wizPreviewBody">
                <!-- Populated on open -->
            </div>
            <div class="wiz-preview-footer">
                <button type="button" class="btn btn-outline-secondary" id="wizPreviewEdit">
                    <i data-lucide="pencil" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                    @(isRtl ? "العودة للتحرير" : "Back to editing")
                </button>
                <button type="button" class="btn btn-outline-primary" id="wizPreviewPrint">
                    <i data-lucide="printer" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                    @(isRtl ? "طباعة" : "Print")
                </button>
                <button type="button" class="btn btn-success" id="wizPreviewConfirm">
                    <i data-lucide="check" class="w-3.5 h-3.5 inline-block" aria-hidden="true"></i>
                    @(isRtl ? "تأكيد وإنشاء" : "Confirm & Create")
                </button>
            </div>
        </div>
    </div>
        </main>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.CspNonce()">
	        let currentStep = 1;
	        const totalSteps = 3;  // Consolidated 7→3: Define / Measure & Target / Score & Plan
        let measurementCounter = 0;

        const measurementTypeOptions = [
            { value: 'Satisfaction', labelEn: 'Satisfaction', labelAr: 'الرضا' },
            { value: 'Cost', labelEn: 'Cost', labelAr: 'التكلفة' },
            { value: 'Time', labelEn: 'Time', labelAr: 'الوقت' },
            { value: 'Productivity', labelEn: 'Productivity', labelAr: 'الإنتاجية' },
            { value: 'Capacity', labelEn: 'Capacity', labelAr: 'السعة' },
            { value: 'NumberOfVisits', labelEn: 'No. of Visits', labelAr: 'عدد الزيارات' },
            { value: 'NumberOfDocuments', labelEn: 'No. of Documents', labelAr: 'عدد المستندات' },
            { value: 'Custom', labelEn: 'Custom', labelAr: 'مخصص' }
        ];
        const periodOptions = [
            { value: 'Daily', labelEn: 'Daily', labelAr: 'يومي' },
            { value: 'Weekly', labelEn: 'Weekly', labelAr: 'أسبوعي' },
            { value: 'Monthly', labelEn: 'Monthly', labelAr: 'شهري' },
            { value: 'Quarterly', labelEn: 'Quarterly', labelAr: 'ربع سنوي' },
            { value: 'Annually', labelEn: 'Annually', labelAr: 'سنوي' },
            { value: 'Custom', labelEn: 'Custom', labelAr: 'مخصص' }
        ];
        const methodOptions = [
            { value: 'Survey', labelEn: 'Survey', labelAr: 'استبيان' },
            { value: 'SystemReport', labelEn: 'System Report', labelAr: 'تقرير النظام' },
            { value: 'ManualCount', labelEn: 'Manual Count', labelAr: 'عد يدوي' },
            { value: 'Automated', labelEn: 'Automated', labelAr: 'آلي' },
            { value: 'Observation', labelEn: 'Observation', labelAr: 'ملاحظة' },
            { value: 'Audit', labelEn: 'Audit', labelAr: 'تدقيق' },
            { value: 'Custom', labelEn: 'Custom', labelAr: 'مخصص' }
        ];
        const priorityOptions = [
            { value: 'H1', labelEn: 'H1', labelAr: 'H1', color: '#dc2626', bg: '#fee2e2' },
            { value: 'H2', labelEn: 'H2', labelAr: 'H2', color: '#ea580c', bg: '#ffedd5' },
            { value: 'H3', labelEn: 'H3', labelAr: 'H3', color: '#16a34a', bg: '#dcfce7' }
        ];
        const priorityOrder = { H1: 1, H2: 2, H3: 3 };
        // Impact × Effort → Priority Matrix (Lean Six Sigma best practice)
        // High impact + Low effort = H1 (Quick Win), High+Med = H1, Med+Low = H1
        // High+High = H2, Med+Med = H2, Low+Low = H2
        // Low+Med = H3, Low+High = H3, Med+High = H3 (Deprioritise)
        const impactEffortMatrix = {
            'High:Low': 'H1', 'High:Medium': 'H1', 'Medium:Low': 'H1',
            'High:High': 'H2', 'Medium:Medium': 'H2', 'Low:Low': 'H2',
            'Low:Medium': 'H3', 'Low:High': 'H3', 'Medium:High': 'H3'
        };
        function calcPriority(impact, effort) {
            return impactEffortMatrix[impact + ':' + effort] || 'H2';
        }
        const isRtl = @(isRtl ? "true" : "false");

        function getAppliesToOptions() {
            const pChks = document.querySelectorAll('.cs-chk[data-csid="processes"]:checked');
            const sChks = document.querySelectorAll('.cs-chk[data-csid="services"]:checked');
            let o = '<option value="">' + (isRtl ? '-- اختر --' : '-- Select --') + '</option>';
            pChks.forEach(c => { o += '<option value="process:' + c.value + '">' + (isRtl ? 'عملية: ' : 'Process: ') + labelFor(c) + '</option>'; });
            sChks.forEach(c => { o += '<option value="service:' + c.value + '">' + (isRtl ? 'خدمة: ' : 'Service: ') + labelFor(c) + '</option>'; });
            return o;
        }
        function getAppliesToLabel(val) {
            if (!val) return isRtl ? 'غير محدد' : 'Unassigned';
            const parts = val.split(':'); const type = parts[0]; const id = parts.slice(1).join(':');
            if (type === 'process') { const c = document.querySelector('.cs-chk[data-csid="processes"][value="' + id + '"]'); return (isRtl ? 'عملية: ' : 'Process: ') + (c ? labelFor(c) : id); }
            if (type === 'service') { const c = document.querySelector('.cs-chk[data-csid="services"][value="' + id + '"]'); return (isRtl ? 'خدمة: ' : 'Service: ') + (c ? labelFor(c) : id); }
            return val;
        }
        function refreshAppliesToDropdowns() {
            const opts = getAppliesToOptions();
            document.querySelectorAll('.m-applies').forEach(sel => { const v = sel.value; sel.innerHTML = opts; if (v) sel.value = v; });
        }
        // Always prefer the human-readable label. Falls back through:
        //   1. data-label attribute (set at render time)
        //   2. sibling span textContent (rendered by Razor)
        //   3. raw value (last resort)
        function labelFor(chk) {
            const attr = chk.getAttribute('data-label');
            if (attr && attr.trim()) return attr.trim();
            const span = chk.closest('label')?.querySelector('span');
            if (span && span.textContent.trim()) return span.textContent.trim();
            return chk.value;
        }

        function buildScopeBanner() {
            const pChks = document.querySelectorAll('.cs-chk[data-csid="processes"]:checked');
            const sChks = document.querySelectorAll('.cs-chk[data-csid="services"]:checked');
            if (!pChks.length && !sChks.length) return '';
            let chips = '';
            pChks.forEach(c => { chips += '<span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-blue-100 text-blue-800 text-xs"><i data-lucide="git-branch" class="w-3 h-3"></i>' + labelFor(c) + '</span>'; });
            sChks.forEach(c => { chips += '<span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-green-100 text-green-800 text-xs"><i data-lucide="briefcase" class="w-3 h-3"></i>' + labelFor(c) + '</span>'; });
            return '<div class="p-3 mb-4 rounded-lg border" style="background:linear-gradient(135deg,#f0f7ff,#e8f4f8);border-color:#b3d4fc"><div class="d-flex align-items-center gap-2 mb-2"><i data-lucide="layers" class="w-4 h-4" style="color:#005B99"></i><strong class="text-sm" style="color:#005B99">' + (isRtl ? 'النطاق المحدد' : 'Selected Scope') + '</strong></div><div class="flex flex-wrap gap-1">' + chips + '</div></div>';
        }

        // Build a measurement card with grouped sections:
        //   1. "What" (Name EN/AR, Type, Unit, Direction)
        //   2. "Scope" (Applies To)
        //   3. "Advanced" collapsible (Weight %, Period, Method, BPMN)
        //
        // Impact/Effort moved out of the card entirely — they now live on
        // Step 4 at the initiative level, which is the correct level of
        // abstraction. Per-measurement priority is no longer a thing.
        function addMeasurementRow() {
            measurementCounter++;
            const container = document.getElementById('measurementRows');
            const card = document.createElement('div');
            card.id = 'mRow_' + measurementCounter;
            card.className = 'measurement-card border rounded-lg shadow-sm';
            let typeOpts = measurementTypeOptions.map(o => '<option value="' + o.value + '">' + (isRtl ? o.labelAr : o.labelEn) + '</option>').join('');
            let periodOpts = '<option value="">' + (isRtl ? '-- اختر --' : '-- Select --') + '</option>' + periodOptions.map(o => '<option value="' + o.value + '">' + (isRtl ? o.labelAr : o.labelEn) + '</option>').join('');
            let methodOpts = '<option value="">' + (isRtl ? '-- اختر --' : '-- Select --') + '</option>' + methodOptions.map(o => '<option value="' + o.value + '">' + (isRtl ? o.labelAr : o.labelEn) + '</option>').join('');
            let appliesOpts = getAppliesToOptions();
            const lblWhat     = isRtl ? 'المعلومات الأساسية' : 'Basic info';
            const lblScope    = isRtl ? 'النطاق' : 'Scope';
            const lblAdvanced = isRtl ? 'إعدادات متقدمة' : 'Advanced settings';
            const lblDirection = isRtl ? 'اتجاه التحسين' : 'Direction of improvement';
            const tipDirection = isRtl
                ? 'اختر "أعلى أفضل" للرضا / الإنتاجية، و"أقل أفضل" للوقت / التكلفة / معدل الأخطاء'
                : 'Use "Higher is better" for satisfaction / throughput, "Lower is better" for time / cost / error rate';

            const lblKpiLink     = isRtl ? 'الربط بمؤشر' : 'KPI catalog link';
            const lblKpiLinkBtn  = isRtl ? 'اربط بمؤشر من المكتبة' : 'Link to KPI from catalog';
            const lblKpiSearch   = isRtl ? 'ابحث بالكود أو الاسم…' : 'Search by code or name…';
            const lblKpiUnlink   = isRtl ? 'إلغاء الربط' : 'Unlink';
            const lblKpiNoResult = isRtl ? 'لا توجد نتائج' : 'No matches';

            card.innerHTML =
                '<div class="card-header d-flex align-items-center gap-2 py-2 px-3" style="background:linear-gradient(135deg,#005B99 0%,#003d6b 100%)">' +
                    '<span class="text-white fw-semibold" style="font-size: var(--fs-sm)">' + (isRtl ? 'مقياس' : 'Measurement') + ' #' + measurementCounter + '</span>' +
                    '<button type="button" class="btn btn-sm ms-auto px-2 py-0" style="color:#ffcdd2;border:1px solid rgba(255,255,255,.3)" onclick="removeMeasurementRow(' + measurementCounter + ')" title="Delete" aria-label="Delete"><i data-lucide="trash-2" class="w-3.5 h-3.5" aria-hidden="true"></i></button>' +
                '</div>' +
                '<div class="card-body p-3">' +
                    // KPI link block — when linked, shows a chip with code+name and "Unlink".
                    // When unlinked, shows "Link to KPI" button that reveals an inline search box.
                    // Picking a KPI pre-fills name-en, name-ar, unit, direction, type.
                    '<div class="m-kpi-block mb-3" data-counter="' + measurementCounter + '">' +
                        '<input type="hidden" class="m-kpi-definition-id" value="" />' +
                        '<div class="m-kpi-empty d-flex align-items-center gap-2">' +
                            '<button type="button" class="btn btn-sm btn-outline-primary" onclick="toggleKpiPicker(this, true)">' +
                                '<i data-lucide="link" class="w-3.5 h-3.5 inline-block"></i> ' + lblKpiLinkBtn +
                            '</button>' +
                            '<span class="text-xs text-gray-500">' + (isRtl ? 'أو املأ يدوياً أدناه' : 'or fill the fields below manually') + '</span>' +
                        '</div>' +
                        '<div class="m-kpi-linked d-none align-items-center gap-2 px-2 py-1 rounded" style="background:#eff6ff;border:1px solid #bfdbfe">' +
                            '<i data-lucide="link-2" class="w-4 h-4" style="color:#005B99"></i>' +
                            '<span class="text-xs text-gray-600">' + lblKpiLink + ':</span>' +
                            '<span class="m-kpi-label fw-semibold" style="color:#005B99;font-size: var(--fs-sm)"></span>' +
                            '<button type="button" class="btn btn-sm btn-link p-0 ms-auto" style="font-size: var(--fs-xs);color:#dc2626" onclick="unlinkKpi(this)">' +
                                '<i data-lucide="x" class="w-3 h-3 inline-block"></i> ' + lblKpiUnlink +
                            '</button>' +
                        '</div>' +
                        '<div class="m-kpi-picker d-none mt-2 p-2 rounded" style="background:#f8fafc;border:1px solid #e5e7eb">' +
                            '<input type="text" class="form-control form-control-sm m-kpi-search" placeholder="' + lblKpiSearch + '" oninput="onKpiSearchInput(this)" />' +
                            '<div class="m-kpi-results mt-2" style="max-height:240px;overflow-y:auto"></div>' +
                        '</div>' +
                    '</div>' +
                    // Section 1 — What (Name + Type + Unit + Direction)
                    '<div class="mb-3">' +
                        '<div class="text-xs font-semibold text-gray-500 uppercase mb-2 flex items-center gap-1"><i data-lucide="info" class="w-3 h-3"></i>' + lblWhat + '</div>' +
                        '<div class="row g-2 mb-2">' +
                            '<div class="col-md-6"><label class="form-label mb-0 text-xs text-gray-600">' + (isRtl ? 'الاسم بالإنجليزية' : 'Name (English)') + '</label>' +
                                '<input type="text" class="form-control form-control-sm m-name-en" placeholder="' + (isRtl ? 'الاسم بالإنجليزية' : 'English name') + '" /></div>' +
                            '<div class="col-md-6"><label class="form-label mb-0 text-xs text-gray-600">' + (isRtl ? 'الاسم بالعربية' : 'Name (Arabic)') + '</label>' +
                                '<input type="text" class="form-control form-control-sm m-name-ar" dir="rtl" placeholder="' + (isRtl ? 'الاسم بالعربية' : 'Arabic name') + '" /></div>' +
                        '</div>' +
                        '<div class="row g-2 mb-2">' +
                            '<div class="col-md-8"><label class="form-label mb-0 text-xs text-gray-600">' + (isRtl ? 'النوع' : 'Type') + '</label>' +
                                '<select class="form-select form-select-sm m-type">' + typeOpts + '</select></div>' +
                            '<div class="col-md-4"><label class="form-label mb-0 text-xs text-gray-600">' + (isRtl ? 'الوحدة' : 'Unit') + '</label>' +
                                '<input type="text" class="form-control form-control-sm m-unit" placeholder="%" /></div>' +
                        '</div>' +
                        // Direction-of-improvement segmented toggle (defaults to HigherBetter)
                        '<div class="mt-2">' +
                            '<label class="form-label mb-1 text-xs text-gray-600 flex items-center gap-1">' + lblDirection +
                            '<span title="' + tipDirection + '" style="cursor:help"><i data-lucide="help-circle" class="w-3 h-3 text-gray-400"></i></span></label>' +
                            '<input type="hidden" class="m-direction" value="HigherBetter" />' +
                            '<div class="btn-group btn-group-sm" role="group">' +
                                '<button type="button" class="btn btn-outline-primary dir-btn active" data-dir="HigherBetter" onclick="setDirection(this)">' +
                                    '<i data-lucide="arrow-up" class="w-3 h-3 inline-block"></i> ' + (isRtl ? 'أعلى أفضل' : 'Higher is better') +
                                '</button>' +
                                '<button type="button" class="btn btn-outline-primary dir-btn" data-dir="LowerBetter" onclick="setDirection(this)">' +
                                    '<i data-lucide="arrow-down" class="w-3 h-3 inline-block"></i> ' + (isRtl ? 'أقل أفضل' : 'Lower is better') +
                                '</button>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                    // Section 2 — Scope
                    '<div class="mb-3">' +
                        '<div class="text-xs font-semibold text-gray-500 uppercase mb-2 flex items-center gap-1"><i data-lucide="layers" class="w-3 h-3"></i>' + lblScope + '</div>' +
                        '<label class="form-label mb-0 text-xs text-gray-600">' + (isRtl ? 'ينطبق على' : 'Applies To') + '</label>' +
                        '<select class="form-select form-select-sm m-applies">' + appliesOpts + '</select>' +
                    '</div>' +
                    // Section 3 — Advanced (collapsible: Period, Method, BPMN)
                    '<details class="mt-2">' +
                        '<summary class="text-xs font-semibold text-gray-500 uppercase cursor-pointer select-none flex items-center gap-1 py-1"><i data-lucide="sliders-horizontal" class="w-3 h-3"></i>' + lblAdvanced + '</summary>' +
                        '<div class="mt-2 pt-2 border-top">' +
                            '<div class="row g-2">' +
                                '<div class="col-md-4"><label class="form-label mb-0 text-xs text-gray-600">' + (isRtl ? 'فترة القياس' : 'Period') + '</label>' +
                                    '<select class="form-select form-select-sm m-period">' + periodOpts + '</select></div>' +
                                '<div class="col-md-4"><label class="form-label mb-0 text-xs text-gray-600">' + (isRtl ? 'طريقة القياس' : 'Method') + '</label>' +
                                    '<select class="form-select form-select-sm m-method">' + methodOpts + '</select></div>' +
                                '<div class="col-md-4"><label class="form-label mb-0 text-xs text-gray-600">BPMN</label>' +
                                    '<div class="input-group input-group-sm"><input type="text" class="form-control form-control-sm m-bpmn" placeholder="' + (isRtl ? 'مرجع' : 'Ref') + '" readonly style="cursor:pointer" />' +
                                    '<button type="button" class="btn btn-outline-primary" onclick="openBpmnModal(this)" title="Browse BPMN" aria-label="Browse BPMN"><i data-lucide="search" class="w-3.5 h-3.5" aria-hidden="true"></i></button></div></div>' +
                            '</div>' +
                        '</div>' +
                    '</details>' +
                    // Section 4 — Now → Target (was Step 4 before consolidation; inlined here)
                    '<div class="mt-3 pt-3 border-top">' +
                        '<div class="text-xs font-semibold text-gray-500 uppercase mb-2 flex items-center gap-1"><i data-lucide="target" class="w-3 h-3"></i>' + (isRtl ? 'القيم الحالية والمستهدفة' : 'Now → Target') + '</div>' +
                        '<div class="row g-2">' +
                            '<div class="col-md-6"><label class="form-label mb-0 text-xs text-gray-600">' + (isRtl ? 'القيمة الحالية (الآن)' : 'Current value (now)') + '</label>' +
                                '<input type="number" step="any" class="form-control form-control-sm m-current" placeholder="' + (isRtl ? 'الآن' : 'Now') + '" oninput="checkInlineSanity(this)" /></div>' +
                            '<div class="col-md-6"><label class="form-label mb-0 text-xs text-gray-600">' + (isRtl ? 'القيمة المستهدفة' : 'Target value') + '</label>' +
                                '<input type="number" step="any" class="form-control form-control-sm m-target" placeholder="' + (isRtl ? 'الهدف' : 'Goal') + '" oninput="checkInlineSanity(this)" />' +
                                '<div class="m-target-sanity hidden text-xs mt-1" style="color:#b45309"></div></div>' +
                        '</div>' +
                    '</div>' +
                '</div>';
            container.appendChild(card);
            toggleEmptyState();
            updateWeightTotal();
            lucide.createIcons();
        }

        // Segmented-toggle helper for the direction buttons. Writes the
        // selected value into the hidden .m-direction input on the card.
        function setDirection(btn) {
            const card = btn.closest('.measurement-card');
            if (!card) return;
            card.querySelectorAll('.dir-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const hidden = card.querySelector('.m-direction');
            if (hidden) hidden.value = btn.dataset.dir || 'HigherBetter';
        }

        // ─── KPI catalog picker ─────────────────────────────────────────
        // The "Link to KPI" button on each measurement card opens an inline
        // typeahead. Picking a KPI pre-fills name-en, name-ar, unit, type,
        // direction and stores the catalog Id in .m-kpi-definition-id so the
        // saved row carries KpiDefinitionId for cross-improvement aggregation.
        function toggleKpiPicker(btn, show) {
            const block = btn.closest('.m-kpi-block');
            if (!block) return;
            const picker = block.querySelector('.m-kpi-picker');
            picker.classList.toggle('d-none', !show);
            if (show) {
                const input = picker.querySelector('.m-kpi-search');
                input.focus();
                // Pre-load top suggestions on open (empty query).
                fetchKpiResults('', picker.querySelector('.m-kpi-results'));
            }
        }

        let _kpiSearchTimer = null;
        function onKpiSearchInput(input) {
            const block = input.closest('.m-kpi-block');
            const out = block.querySelector('.m-kpi-results');
            clearTimeout(_kpiSearchTimer);
            _kpiSearchTimer = setTimeout(() => fetchKpiResults(input.value, out), 200);
        }

        async function fetchKpiResults(q, outEl) {
            try {
                const r = await fetch('/KpiLibrary/Search?q=' + encodeURIComponent(q || ''));
                if (!r.ok) { outEl.innerHTML = ''; return; }
                const rows = await r.json();
                if (!rows || rows.length === 0) {
                    outEl.innerHTML = '<div class="text-xs text-gray-500 px-2 py-2">' +
                        (isRtl ? 'لا توجد نتائج' : 'No matches') + '</div>';
                    return;
                }
                outEl.innerHTML = rows.map(k => {
                    const name = isRtl ? (k.nameAr || k.nameEn) : (k.nameEn || k.nameAr);
                    return '<button type="button" class="d-flex align-items-center gap-2 w-100 text-start px-2 py-1 rounded border-0 bg-transparent kpi-result" ' +
                        'data-id="' + k.id + '" data-code="' + (k.code||'') + '" data-name-en="' + (k.nameEn||'').replace(/"/g,'&quot;') +
                        '" data-name-ar="' + (k.nameAr||'').replace(/"/g,'&quot;') + '" data-unit="' + (k.unit||'') +
                        '" data-direction="' + (k.direction||'') + '" data-default-type="' + (k.defaultType||'Custom') + '" ' +
                        'onclick="pickKpi(this)" onmouseover="this.style.background=\'#eff6ff\'" onmouseout="this.style.background=\'transparent\'">' +
                        '<code style="font-size:var(--fs-xs);color:#005B99;font-weight:700">' + (k.code||'') + '</code>' +
                        '<span class="text-sm">' + (name||'') + '</span>' +
                        '<span class="text-xs text-gray-500 ms-auto">' + (k.unit||'') + '</span>' +
                        '</button>';
                }).join('');
            } catch (e) {
                outEl.innerHTML = '<div class="text-xs text-gray-400 px-2 py-2">' + (isRtl ? 'تعذّر البحث' : 'Search failed') + '</div>';
            }
        }

        function pickKpi(btn) {
            const block = btn.closest('.m-kpi-block');
            const card  = btn.closest('.measurement-card');
            const id    = btn.dataset.id;
            const code  = btn.dataset.code;
            const ne    = btn.dataset.nameEn;
            const na    = btn.dataset.nameAr;
            const unit  = btn.dataset.unit;
            const dir   = btn.dataset.direction;
            const dtype = btn.dataset.defaultType;

            // Persist link
            block.querySelector('.m-kpi-definition-id').value = id;
            const display = code + ' — ' + (isRtl ? (na || ne) : (ne || na));
            block.querySelector('.m-kpi-label').textContent = display;
            block.querySelector('.m-kpi-empty').classList.add('d-none');
            block.querySelector('.m-kpi-picker').classList.add('d-none');
            block.querySelector('.m-kpi-linked').classList.remove('d-none');
            block.querySelector('.m-kpi-linked').classList.add('d-flex');

