        // ── Live Prioritization Score ───────────────────────────
        // Only reads values from the *hidden* inputs (which are empty until
        // the user has dragged each slider). This guarantees the composite
        // Total stays "—" for un-scored initiatives — no more synthetic 5.0
        // contaminating the portfolio average.
        function calcScores() {
            const get = id => { const el = document.getElementById(id); return el && el.value !== '' ? parseFloat(el.value) : null; };
            const ease = get('EaseOfImplementation'), budget = get('BudgetEstimation'), dep = get('ProjectDependency');
            const strat = get('StrategicAlignmentScore'), lead = get('LeadershipDirections'), qol = get('QualityOfLife');
            const innov = get('InnovationAndFutureShaping'), fin = get('FinancialAndEconomicImpact'), sust = get('SustainabilityScore');

            let readiness = '—', value = '—', total = '—';
            if (ease !== null && budget !== null && dep !== null) {
                readiness = ((ease * 10 + budget * 15 + dep * 5) / 30).toFixed(1);
            }
            if (strat !== null && lead !== null && qol !== null && innov !== null && fin !== null && sust !== null) {
                value = ((strat * 15 + lead * 10 + qol * 15 + innov * 5 + fin * 10 + sust * 15) / 70).toFixed(1);
            }
            if (readiness !== '—' && value !== '—') {
                total = (parseFloat(readiness) * 0.30 + parseFloat(value) * 0.70).toFixed(2);
            }
            document.getElementById('readinessScore').textContent = readiness;
            document.getElementById('valueScore').textContent = value;
            document.getElementById('totalScore').textContent = total;
        }

        // Recompute the Impact×Effort quadrant badge on Step 4 and drive
        // the downstream initiative priority that syncHiddenFields uses.
        function updateQuadrantBadge() {
            const impact = parseInt(document.getElementById('ImpactScore')?.value || '', 10);
            const effort = parseInt(document.getElementById('EffortScore')?.value || '', 10);
            const badge = document.getElementById('quadrantBadge');
            const hint  = document.getElementById('quadrantHint');
            if (!badge || !hint) return;
            if (!impact || !effort) {
                badge.textContent = '—';
                badge.style.background = '#e5e7eb';
                badge.style.color = '#6b7280';
                hint.textContent = '';
                return;
            }
            const hi = impact >= 6, hiE = effort >= 6;
            let label, bg, color, tip;
            if (hi && !hiE) {
                label = isRtl ? 'فوز سريع (H1)' : 'Quick Win (H1)';
                bg = '#dcfce7'; color = '#166534';
                tip = isRtl ? 'تأثير عالٍ، جهد منخفض — نفّذه الآن' : 'High impact, low effort — execute now';
            } else if (hi && hiE) {
                label = isRtl ? 'مشروع كبير (H2)' : 'Major Project (H2)';
                bg = '#dbeafe'; color = '#1e40af';
                tip = isRtl ? 'تأثير عالٍ، جهد عالٍ — خطّط له بعناية' : 'High impact, high effort — plan carefully';
            } else if (!hi && !hiE) {
                label = isRtl ? 'إضافة سريعة (H2)' : 'Fill-In (H2)';
                bg = '#fef3c7'; color = '#92400e';
                tip = isRtl ? 'تأثير منخفض، جهد منخفض — إذا سمح الوقت' : 'Low impact, low effort — if time permits';
            } else {
                label = isRtl ? 'مهمة شاقة (H3)' : 'Thankless Task (H3)';
                bg = '#fee2e2'; color = '#991b1b';
                tip = isRtl ? 'تأثير منخفض، جهد عالٍ — أعد النظر' : 'Low impact, high effort — reconsider';
            }
            badge.textContent = label;
            badge.style.background = bg;
            badge.style.color = color;
            hint.textContent = tip;
        }

	        function showClientError(message) {
	            const el = document.getElementById('clientError');
	            if (!el) return;
	            el.textContent = message;
	            el.classList.remove('hidden');
	        }

	        function clearClientError() {
	            const el = document.getElementById('clientError');
	            if (!el) return;
	            el.textContent = '';
	            el.classList.add('hidden');
	            // Also clear any previously-highlighted fields
	            document.querySelectorAll('.wizard-invalid').forEach(e => e.classList.remove('wizard-invalid'));
	        }

	        // Flash-highlight an offending field + scroll it into view.
	        function markInvalid(el) {
	            if (!el) return;
	            el.classList.add('wizard-invalid');
	            try { el.scrollIntoView({ block: 'center', behavior: 'smooth' }); } catch {}
	            try { el.focus({ preventScroll: true }); } catch {}
	        }

	        function validateStep(step) {
	            clearClientError();
	            const t = (en, ar) => (isRtl ? ar : en);

	            // Step 1 (Define) = scope + title (Description / Source / Owner /
	            // InnovationType / Horizon / TargetDate are all optional).
	            if (step === 1) {
	                const processIds = csGetValues('processes');
	                const serviceIds = csGetValues('services');
	                const titleEnEl = document.querySelector('[name="TitleEn"]');
	                const titleArEl = document.querySelector('[name="TitleAr"]');
	                const titleEn = titleEnEl?.value || '';
	                const titleAr = titleArEl?.value || '';
	                if (!processIds.length && !serviceIds.length) {
	                    showClientError(t('Please select a Process or a Service for improvement.', 'يرجى اختيار عملية أو خدمة للتحسين.'));
	                    markInvalid(document.getElementById('csWrap_processes'));
	                    return false;
	                }
	                if (!titleEn.trim() || !titleAr.trim()) {
	                    showClientError(t('Please enter both English and Arabic titles.', 'يرجى إدخال العنوان باللغتين الإنجليزية والعربية.'));
	                    markInvalid(!titleEn.trim() ? titleEnEl : titleArEl);
	                    return false;
	                }
	            }

	            // Step 2 (Measure & Target) = at least one measurement card,
	            // each card must have Unit + Name + AppliesTo + Now + Target.
	            // Now/Target are inlined inside each card (.m-current / .m-target)
	            // — the standalone Step-4 grid is gone.
	            if (step === 2) {
	                const rows = document.querySelectorAll('#measurementRows .measurement-card');
	                if (!rows.length) {
	                    showClientError(t('Please add at least one measurement.', 'يرجى إضافة مقياس واحد على الأقل.'));
	                    return false;
	                }
	                for (const row of rows) {
	                    const nameEnEl  = row.querySelector('.m-name-en');
	                    const nameArEl  = row.querySelector('.m-name-ar');
	                    const unitEl    = row.querySelector('.m-unit');
	                    const appliesEl = row.querySelector('.m-applies');
	                    const curEl     = row.querySelector('.m-current');
	                    const tgtEl     = row.querySelector('.m-target');
	                    const nameEn = nameEnEl?.value || '';
	                    const nameAr = nameArEl?.value || '';
	                    const unit   = unitEl?.value   || '';
	                    const applies= appliesEl?.value|| '';
	                    const cur    = curEl?.value    || '';
	                    const tgt    = tgtEl?.value    || '';
	                    if (!applies) {
	                        showClientError(t('Each measurement must specify which process or service it applies to.', 'يجب تحديد العملية أو الخدمة لكل مقياس.'));
	                        markInvalid(appliesEl);
	                        return false;
	                    }
	                    if (!unit.trim() || (!nameEn.trim() && !nameAr.trim())) {
	                        showClientError(t('Each measurement must have a Unit and a Name (English or Arabic).', 'يجب أن يحتوي كل مقياس على وحدة قياس واسم (إنجليزي أو عربي).'));
	                        markInvalid(!unit.trim() ? unitEl : nameEnEl);
	                        return false;
	                    }
	                    if (cur.trim() === '') {
	                        showClientError(t('Please enter the current (baseline) value for every measurement.', 'يرجى إدخال القيمة الحالية لجميع المقاييس.'));
	                        markInvalid(curEl);
	                        return false;
	                    }
	                    if (tgt.trim() === '') {
	                        showClientError(t('Please enter the target value for every measurement.', 'يرجى إدخال القيمة المستهدفة لجميع المقاييس.'));
	                        markInvalid(tgtEl);
	                        return false;
	                    }
	                }
	            }

	            // Step 3 (Score & Plan) = no blocking validation. All sliders
	            // optional; team + action lists optional.

	            return true;
	        }

        // Track the furthest step the user has reached so the stepper can
        // allow clicking back into it without re-validating everything.
        let maxVisitedStep = 1;

        function showStep(step) {
            // After 7→3 consolidation: a macro step can contain MULTIPLE panes
            // sharing the same data-step value. Reveal them all together.
            document.querySelectorAll('.wizard-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.wizard-step').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.wizard-content[data-step="' + step + '"]').forEach(el => el.classList.remove('hidden'));
            document.querySelector('.wizard-step[data-step="' + step + '"]').classList.add('active');
            document.getElementById('currentStep').textContent = step;
            // Progress bar was removed from the chrome (stepper is the progress bar now)
            document.getElementById('progressBar')?.style?.setProperty('width', ((step / totalSteps) * 100) + '%');
            document.getElementById('prevBtn').disabled = step === 1;
            document.getElementById('nextBtn').classList.toggle('hidden', step === totalSteps);
            document.getElementById('submitBtn').classList.toggle('hidden', step !== totalSteps);
            document.getElementById('previewBtn')?.classList.toggle('hidden', step !== totalSteps);

            if (step > maxVisitedStep) maxVisitedStep = step;

            // Mark prior steps with a completed class so CSS can render a check
            document.querySelectorAll('.wizard-step').forEach(el => {
                const n = parseInt(el.dataset.step, 10);
                el.classList.toggle('completed', n < step);
            });

            // Macro-step 2 = Measure & Target. Show scope banner, refresh
            // process/service dropdowns inside measurement cards, and re-paint
            // weight total / empty state.
            if (step === 2) {
                const banner = buildScopeBanner();
                document.querySelectorAll('.scope-banner-container').forEach(el => { el.innerHTML = banner; });
                refreshAppliesToDropdowns();
                toggleEmptyState();
                updateWeightTotal();
                // Re-evaluate inline sanity warnings for any cards already filled.
                document.querySelectorAll('.measurement-card .m-target').forEach(inp => checkInlineSanity(inp));
            }

            // Macro-step 3 = Score & Plan. Recompute composite score so the
            // mini Readiness/Value/Total banner reflects current inputs.
            if (step === 3) calcScores();

            // Scroll to top so the user always sees the new step's title
            window.scrollTo({ top: 0, behavior: 'smooth' });

            lucide.createIcons();
        }

        // Make stepper circles clickable — can jump to any already-visited step.
        document.querySelectorAll('.wizard-step').forEach(el => {
            el.addEventListener('click', () => {
                const target = parseInt(el.dataset.step, 10);
                if (!target) return;
                if (target <= maxVisitedStep && target !== currentStep) {
                    currentStep = target;
                    showStep(target);
                }
            });
        });

	        document.getElementById('nextBtn').addEventListener('click', () => {
	            if (!validateStep(currentStep)) return;
	            if (currentStep < totalSteps) {
	                currentStep++;
	                showStep(currentStep);
	            }
	        });
	        // Chip-select (multi-select) helpers
	        let openCS = null;
	        function csToggle(id) {
	            const drop = document.getElementById('csDrop_' + id);
	            if (!drop) return;
	            if (openCS && openCS !== id) document.getElementById('csDrop_' + openCS)?.classList.add('hidden');
	            drop.classList.toggle('hidden');
	            openCS = drop.classList.contains('hidden') ? null : id;
	        }
	        function csFilter(id, query) {
	            const q = (query || '').toLowerCase();
	            document.querySelectorAll('.cs-opt input.cs-chk[data-csid="' + id + '"]').forEach(chk => {
	                const label = (chk.getAttribute('data-label') || '').toLowerCase();
	                chk.closest('label')?.classList.toggle('hidden', q && !label.includes(q));
	            });
	        }
	        function csGetValues(id) {
	            return Array.from(document.querySelectorAll('.cs-chk[data-csid="' + id + '"]:checked')).map(c => c.value);
	        }
	        function csUpdate(id) {
	            const chips = document.getElementById('csChips_' + id);
	            const ph = document.getElementById('csPh_' + id);
	            if (!chips || !ph) return;
	            chips.innerHTML = '';
	            const selected = Array.from(document.querySelectorAll('.cs-chk[data-csid="' + id + '"]:checked'));
	            selected.forEach(chk => {
	                const span = document.createElement('span');
	                span.className = 'inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-blue-50 text-blue-700 text-xs border border-blue-100';
	                span.innerHTML = '<span class="truncate max-w-[180px]">' + labelFor(chk) + '</span><button type="button" class="ml-1" onclick="csRemove(\'' + id + '\',\'' + chk.value + '\')">×</button>';
	                chips.appendChild(span);
	            });
	            ph.classList.toggle('hidden', selected.length > 0);
	        }
	        function csRemove(id, val) {
	            const chk = document.querySelector('.cs-chk[data-csid="' + id + '"][value="' + val.replace(/"/g, '\\"') + '"]');
	            if (chk) chk.checked = false;
	            csUpdate(id);
	        }
	        function addCSHidden(form, csId, inputName) {
	            form.querySelectorAll('input[type="hidden"][data-cs-hidden="' + csId + '"]').forEach(e => e.remove());
	            csGetValues(csId).forEach(v => {
	                const inp = document.createElement('input');
	                inp.type = 'hidden';
	                inp.name = inputName;
	                inp.value = v;
	                inp.setAttribute('data-cs-hidden', csId);
	                form.appendChild(inp);
	            });
	        }
	        document.addEventListener('click', (e) => {
	            if (!openCS) return;
	            const wrap = document.getElementById('csWrap_' + openCS);
	            if (wrap && !wrap.contains(e.target)) {
	                document.getElementById('csDrop_' + openCS)?.classList.add('hidden');
	                openCS = null;
	            }
	        });

	        document.getElementById('prevBtn').addEventListener('click', () => { if (currentStep > 1) { currentStep--; showStep(currentStep); } });
	        document.getElementById('wizardForm').addEventListener('submit', function(e) {
	            // Validate all steps forward, navigate to first failing step
	            for (let s = 1; s <= totalSteps; s++) {
	                if (!validateStep(s)) {
	                    e.preventDefault();
	                    currentStep = s;
	                    showStep(s);
	                    return;
	                }
	            }
		            // Multi-select process/service -> hidden arrays for model binding
		            addCSHidden(this, 'processes', 'SelectedProcessIds');
		            addCSHidden(this, 'services', 'SelectedServiceIds');
		            // Legacy single FK fields (first selected), to keep older parts of the app working
		            document.getElementById('hdnSingleProcessId').value = (csGetValues('processes')[0] || '');
		            document.getElementById('hdnSingleServiceId').value = (csGetValues('services')[0] || '');
	            // Now/Target inputs live inside each measurement card after the
	            // 7→3 step consolidation — no separate render step required.
	            syncHiddenFields();
	        });

	        // Cancel confirmation — don't lose work silently. Swal is async so
	        // we have to preventDefault synchronously and navigate manually on
	        // confirm.
	        document.getElementById('wizardCancelBtn')?.addEventListener('click', function(e) {
	            const hasWork = document.querySelector('[name="TitleEn"]')?.value?.trim() ||
	                document.querySelector('[name="TitleAr"]')?.value?.trim() ||
	                document.querySelectorAll('#measurementRows .measurement-card').length > 0 ||
	                csGetValues('processes').length > 0 ||
	                csGetValues('services').length > 0;
	            if (!hasWork) return;
	            e.preventDefault();
	            const href = this.getAttribute('href') || this.dataset.href || '/Improvements';
	            Swal.fire({
	                icon: 'warning',
	                title: isRtl ? 'إلغاء المعالج؟' : 'Cancel wizard?',
	                text:  isRtl ? 'ستفقد كل ما أدخلته.' : 'You will lose everything you entered.',
	                showCancelButton: true,
	                confirmButtonText: isRtl ? 'نعم، ألغِ' : 'Yes, cancel',
	                cancelButtonText:  isRtl ? 'العودة للتحرير' : 'Keep editing',
	                confirmButtonColor: '#dc2626',
	                cancelButtonColor:  '#64748b'
	            }).then(r => { if (r.isConfirmed) { window.__wizardSubmitting = true; window.location.href = href; } });
	        });

	        // Score slider wiring: on first interaction, mark the slider touched,
	        // write the value into the hidden input (so it gets posted), flip
	        // the badge from grey/"—" to blue/value, then recalculate.
	        document.querySelectorAll('.score-slider-input').forEach(range => {
	            const wrap = range.closest('.score-slider');
	            const field = wrap?.dataset?.field;
	            const hidden = field ? document.getElementById(field) : null;
	            const badge = wrap?.querySelector('.score-badge');
	            range.addEventListener('input', () => {
	                range.dataset.touched = 'true';
	                if (hidden) hidden.value = range.value;
	                if (badge) {
	                    badge.textContent = range.value;
	                    badge.style.background = '#005B99';
	                }
	                calcScores();
	            });
	        });

	        // Initiative-level Impact / Effort sliders drive the quadrant badge
	        // and the hidden ImpactScore / EffortScore inputs that the model
	        // binder uses. These always have a value (default 5) because
	        // CalculateQuadrant() runs server-side unconditionally.
	        document.querySelectorAll('.impact-effort-slider').forEach(range => {
	            const targetId = range.dataset.target;
	            const badgeId  = range.dataset.badge;
	            const hidden = targetId ? document.getElementById(targetId) : null;
	            const badge  = badgeId ? document.getElementById(badgeId) : null;
	            const update = () => {
	                if (hidden) hidden.value = range.value;
	                if (badge)  badge.textContent = range.value;
	                updateQuadrantBadge();
	            };
	            update();
	            range.addEventListener('input', update);
	        });

	        // ── AI Scoring Suggestion ─────────────────────────────
	        // Pulls Title/Description from earlier steps + the first checked
	        // linked process (if any), POSTs to /AI/SuggestInitiativeScoring,
	        // then writes the returned Impact/Effort onto the sliders so the
	        // hidden inputs stay in sync and the quadrant badge updates.
	        (function () {
	            const aiBtn = document.getElementById('aiSuggestScoring');
	            const aiLabel = document.getElementById('aiSuggestScoringLabel');
	            const aiPanel = document.getElementById('aiScoringResult');
	            const aiQuad  = document.getElementById('aiScoringQuadrant');
	            const aiReason = document.getElementById('aiScoringReasoning');
	            if (!aiBtn) return;

	            function setSlider(targetId, value) {
	                const slider = document.querySelector('.impact-effort-slider[data-target="' + targetId + '"]');
	                if (!slider) return;
	                slider.value = String(value);
	                slider.dispatchEvent(new Event('input', { bubbles: true }));
	            }

	            function firstCheckedProcessLabel() {
	                const c = document.querySelector('.cs-chk[data-csid="processes"]:checked');
	                return c ? (c.getAttribute('data-label') || '') : '';
	            }

	            aiBtn.addEventListener('click', async function () {
	                const titleEn = (document.getElementById('TitleEn') || {}).value || '';
	                const titleAr = (document.getElementById('TitleAr') || {}).value || '';
	                if (!titleEn.trim() && !titleAr.trim()) {
	                    Swal.fire({
	                        icon: 'info',
	                        text: isRtl ? 'يرجى إدخال العنوان أولاً.' : 'Please enter a title first.',
	                        confirmButtonColor: '#005B99'
	                    });
	                    return;
	                }

	                aiBtn.disabled = true;
	                const originalLabel = aiLabel.textContent;
	                aiLabel.textContent = isRtl ? 'جاري التحليل...' : 'Analyzing...';

	                try {
	                    const token = (document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]') || {}).value;
	                    const res = await fetch('/AI/SuggestInitiativeScoring', {
	                        method: 'POST',
	                        headers: {
	                            'Content-Type': 'application/json',
	                            'RequestVerificationToken': token || ''
	                        },
	                        body: JSON.stringify({
	                            titleEn: titleEn,
	                            titleAr: titleAr,
	                            descriptionEn: (document.getElementById('DescriptionEn') || {}).value || '',
	                            descriptionAr: (document.getElementById('DescriptionAr') || {}).value || '',
	                            processName: firstCheckedProcessLabel(),
	                            scope: ''
	                        })
	                    });
	                    const data = await res.json();
	                    if (data && data.success) {
	                        setSlider('ImpactScore', data.impact);
	                        setSlider('EffortScore', data.effort);
	                        const quadLabels = {
	                            'QuickWin': isRtl ? 'فوز سريع' : 'Quick Win',
	                            'BigBet': isRtl ? 'رهان كبير' : 'Big Bet',
	                            'Fill-In': isRtl ? 'مهمة ثانوية' : 'Fill-In',
	                            'ThanklessTask': isRtl ? 'مهمة مرهقة' : 'Thankless Task'
	                        };
	                        aiQuad.textContent = quadLabels[data.quadrant] || data.quadrant || '';
	                        aiReason.textContent = data.reasoning || '';
	                        aiPanel.classList.remove('hidden');
	                    } else {
	                        Swal.fire({
	                            icon: 'error',
	                            text: (data && data.error) || (isRtl ? 'فشل الاقتراح' : 'Suggestion failed'),
	                            confirmButtonColor: '#005B99'
	                        });
	                    }
	                } catch (e) {
	                    Swal.fire({
	                        icon: 'error',
	                        text: e.message || (isRtl ? 'خطأ في الشبكة' : 'Network error'),
	                        confirmButtonColor: '#005B99'
	                    });
	                } finally {
	                    aiBtn.disabled = false;
	                    aiLabel.textContent = originalLabel;
	                }
	            });
	        })();

        // ── BPMN Modal ──────────────────────────────────────────
        let bpmnBrowseViewer = null;
        let bpmnDrawModeler = null;
        let bpmnCurrentRow = null;
        let bpmnAiMode = null;
        const BPMN_EMPTY = '<?xml version="1.0" encoding="UTF-8"?><bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn"><bpmn:process id="Process_1" isExecutable="false"><bpmn:startEvent id="StartEvent_1"/></bpmn:process><bpmndi:BPMNDiagram id="BPMNDiagram_1"><bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1"><bpmndi:BPMNShape id="_BPMNShape_StartEvent_1" bpmnElement="StartEvent_1"><dc:Bounds x="173" y="203" width="36" height="36"/></bpmndi:BPMNShape></bpmndi:BPMNPlane></bpmndi:BPMNDiagram></bpmn:definitions>';

        function attachElementClick(inst) {
            inst.get('eventBus').on('element.click', function(ev) {
                const el = ev.element;
                if (el && el.id && el.type !== 'bpmn:Process' && el.type !== 'bpmn:Collaboration') {
                    document.getElementById('bpmnSelectedElementId').textContent = el.id + (el.businessObject?.name ? ' (' + el.businessObject.name + ')' : '');
                    document.getElementById('bpmnSelectedElementId').setAttribute('data-ref', el.id);
                    document.getElementById('bpmnElementInfo').classList.remove('d-none');
                }
            });
        }

        function populateBpmnDropdown(sel) {
            sel.innerHTML = '<option value="">' + (isRtl ? '-- اختر عملية --' : '-- Select a Process --') + '</option>';
            document.querySelectorAll('.cs-chk[data-csid="processes"]:checked').forEach(c => {
                const opt = document.createElement('option'); opt.value = c.value;
                opt.textContent = c.getAttribute('data-label') || c.value; sel.appendChild(opt);
            });
            fetch('/AI/GetProcessesWithBPMN').then(r => r.json()).then(data => {
                if (data && data.length) {
                    const existing = new Set(Array.from(sel.options).map(o => o.value));
                    data.forEach(p => { if (!existing.has(p.id)) { const o = document.createElement('option'); o.value = p.id; o.textContent = (isRtl ? p.nameAr : p.nameEn) || p.code || p.id; sel.appendChild(o); } });
                }
            }).catch(() => {});
        }

        function openBpmnModal(btn) {
            bpmnCurrentRow = btn.closest('.measurement-card');
            const modal = new bootstrap.Modal(document.getElementById('bpmnModal'));
            populateBpmnDropdown(document.getElementById('bpmnProcessSelect'));
            document.getElementById('bpmnModalEmpty').classList.remove('d-none');
            document.getElementById('bpmnModalEmpty').innerHTML = '<div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted"><i data-lucide="file-code-2" class="w-12 h-12 mb-3" style="opacity:.4"></i><p class="text-sm">' + (isRtl ? 'اختر عملية لعرض مخططها' : 'Select a process to view its diagram') + '</p></div>';
            document.getElementById('bpmnElementInfo').classList.add('d-none');
            document.getElementById('bpmnAiPanel').classList.add('d-none');
            document.getElementById('bpmnSavePanel').classList.add('d-none');
            if (bpmnBrowseViewer) { try { bpmnBrowseViewer.destroy(); } catch(e){} bpmnBrowseViewer = null; }
            modal.show(); lucide.createIcons();
        }

        // Init draw modeler on tab show
        document.getElementById('bpmnDrawTab')?.addEventListener('shown.bs.tab', async function() {
            if (!bpmnDrawModeler && typeof BpmnJS !== 'undefined') {
                bpmnDrawModeler = new BpmnJS({ container: document.getElementById('bpmnDrawCanvas'), keyboard: { bindTo: document } });
                await bpmnDrawModeler.importXML(BPMN_EMPTY);
                bpmnDrawModeler.get('canvas').zoom('fit-viewport');
                attachElementClick(bpmnDrawModeler);
            }
            lucide.createIcons();
        });

        // Browse: load process
        document.getElementById('bpmnProcessSelect')?.addEventListener('change', function() {
            const pid = this.value;
            if (!pid) { document.getElementById('bpmnModalEmpty').classList.remove('d-none'); document.getElementById('bpmnElementInfo').classList.add('d-none'); return; }
            document.getElementById('bpmnModalEmpty').innerHTML = '<div class="d-flex align-items-center justify-content-center h-100"><div class="spinner-border text-primary"></div></div>';
            document.getElementById('bpmnModalEmpty').classList.remove('d-none');
            fetch('/AI/LoadProcessBPMN?id=' + encodeURIComponent(pid)).then(r => r.json()).then(data => {
                if (data.success && data.bpmnXml) {
                    document.getElementById('bpmnModalEmpty').classList.add('d-none');
                    if (bpmnBrowseViewer) { try { bpmnBrowseViewer.destroy(); } catch(e){} }
                    bpmnBrowseViewer = new BpmnJS({ container: document.getElementById('bpmnBrowseCanvas') });
                    bpmnBrowseViewer.importXML(data.bpmnXml).then(() => { bpmnBrowseViewer.get('canvas').zoom('fit-viewport'); attachElementClick(bpmnBrowseViewer); });
                } else {
                    document.getElementById('bpmnModalEmpty').innerHTML = '<div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted"><p class="text-sm">' + (isRtl ? 'لا يوجد مخطط' : 'No diagram found') + '</p></div>';
                }
            }).catch(() => { document.getElementById('bpmnModalEmpty').innerHTML = '<div class="text-center text-danger p-4">Error loading diagram</div>'; });
        });

        // Draw toolbar
        document.getElementById('bpmnNewBtn')?.addEventListener('click', async () => { if (bpmnDrawModeler) { await bpmnDrawModeler.importXML(BPMN_EMPTY); bpmnDrawModeler.get('canvas').zoom('fit-viewport'); } });
        document.getElementById('bpmnZoomInBtn')?.addEventListener('click', () => { if (bpmnDrawModeler) bpmnDrawModeler.get('canvas').zoom(bpmnDrawModeler.get('canvas').zoom() * 1.2); });
        document.getElementById('bpmnZoomOutBtn')?.addEventListener('click', () => { if (bpmnDrawModeler) bpmnDrawModeler.get('canvas').zoom(bpmnDrawModeler.get('canvas').zoom() / 1.2); });
        document.getElementById('bpmnFitBtn')?.addEventListener('click', () => { if (bpmnDrawModeler) bpmnDrawModeler.get('canvas').zoom('fit-viewport'); });

        // AI Generate / Refine
        document.getElementById('bpmnAiGenBtn')?.addEventListener('click', () => { bpmnAiMode = 'generate'; document.getElementById('bpmnAiPanel').classList.toggle('d-none'); document.getElementById('bpmnSavePanel').classList.add('d-none'); document.getElementById('bpmnAiTitle').placeholder = isRtl ? 'اسم العملية' : 'Process name'; document.getElementById('bpmnAiDesc').placeholder = isRtl ? 'وصف العملية' : 'Description'; });
        document.getElementById('bpmnAiRefineBtn')?.addEventListener('click', () => { bpmnAiMode = 'refine'; document.getElementById('bpmnAiPanel').classList.toggle('d-none'); document.getElementById('bpmnSavePanel').classList.add('d-none'); document.getElementById('bpmnAiTitle').placeholder = isRtl ? 'عنوان (اختياري)' : 'Title (optional)'; document.getElementById('bpmnAiDesc').placeholder = isRtl ? 'تعليمات التحسين' : 'Refinement instructions'; });

        document.getElementById('bpmnAiGoBtn')?.addEventListener('click', async () => {
            const title = document.getElementById('bpmnAiTitle').value.trim();
            const desc = document.getElementById('bpmnAiDesc').value.trim();
            const st = document.getElementById('bpmnAiStatus'); st.classList.remove('d-none'); st.className = 'text-xs text-primary mt-1'; st.textContent = isRtl ? 'جاري التوليد...' : 'Generating...';
            try {
                if (bpmnAiMode === 'generate') {
                    if (!title) { st.textContent = isRtl ? 'أدخل اسم العملية' : 'Enter process name'; st.className = 'text-xs text-danger mt-1'; return; }
                    const j = await (await fetch('/AI/GenerateBPMN', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({title, description: desc||title}) })).json();
                    if (!j.success) throw new Error(j.error);
                    await bpmnDrawModeler.importXML(j.bpmnXml); bpmnDrawModeler.get('canvas').zoom('fit-viewport');
                } else {
                    if (!desc) { st.textContent = isRtl ? 'أدخل تعليمات' : 'Enter instructions'; st.className = 'text-xs text-danger mt-1'; return; }
                    const {xml} = await bpmnDrawModeler.saveXML({format:true});
                    const j = await (await fetch('/AI/RefineBPMN', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({currentBpmnXml:xml, instructions:desc}) })).json();
                    if (!j.success) throw new Error(j.error);
                    await bpmnDrawModeler.importXML(j.bpmnXml); bpmnDrawModeler.get('canvas').zoom('fit-viewport');
                }
                attachElementClick(bpmnDrawModeler); st.textContent = isRtl ? 'تم بنجاح!' : 'Done!'; st.className = 'text-xs text-success mt-1';
            } catch(e) { st.textContent = e.message; st.className = 'text-xs text-danger mt-1'; }
        });

        // Save to Process
        document.getElementById('bpmnSaveToProcessBtn')?.addEventListener('click', () => {
            const sp = document.getElementById('bpmnSavePanel'); sp.classList.toggle('d-none'); document.getElementById('bpmnAiPanel').classList.add('d-none');
            const sel = document.getElementById('bpmnSaveProcessSelect');
            sel.innerHTML = '<option value="">' + (isRtl ? '-- اختر --' : '-- Select --') + '</option>';
            document.querySelectorAll('.cs-chk[data-csid="processes"]:checked').forEach(c => { const o = document.createElement('option'); o.value = c.value; o.textContent = c.getAttribute('data-label') || c.value; sel.appendChild(o); });
            fetch('/AI/GetProcesses').then(r=>r.json()).then(d => { if(d.success && d.processes) { const ex = new Set(Array.from(sel.options).map(o=>o.value)); d.processes.forEach(p => { if(!ex.has(p.id)){const o=document.createElement('option');o.value=p.id;o.textContent=p.code+' - '+(isRtl?p.nameAr:p.nameEn);sel.appendChild(o);}}); } }).catch(()=>{});
        });
        document.getElementById('bpmnSaveCancelBtn')?.addEventListener('click', () => document.getElementById('bpmnSavePanel').classList.add('d-none'));
        document.getElementById('bpmnSaveGoBtn')?.addEventListener('click', async () => {
            const pid = document.getElementById('bpmnSaveProcessSelect').value;
            const newName = document.getElementById('bpmnSaveNewName').value.trim();
            const st = document.getElementById('bpmnSaveStatus'); st.classList.remove('d-none');
            if (!pid && !newName) { st.textContent = isRtl ? 'اختر عملية أو أدخل اسم جديد' : 'Select a process or enter a new name'; st.className = 'text-xs text-danger mt-1'; return; }
            st.textContent = isRtl ? 'جاري الحفظ...' : 'Saving...'; st.className = 'text-xs text-primary mt-1';
            try {
                const {xml} = await bpmnDrawModeler.saveXML({format:true});
                const j = await (await fetch('/AI/SaveBPMNToProcess', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({processId:pid||null, processName:newName||null, bpmnXml:xml}) })).json();
                if (!j.success) throw new Error(j.error);
                st.textContent = j.message || (isRtl ? 'تم الحفظ!' : 'Saved!'); st.className = 'text-xs text-success mt-1';
            } catch(e) { st.textContent = e.message; st.className = 'text-xs text-danger mt-1'; }
        });

        // Use Reference
        document.getElementById('bpmnUseRefBtn')?.addEventListener('click', function() {
            const ref = document.getElementById('bpmnSelectedElementId')?.getAttribute('data-ref');
            if (ref && bpmnCurrentRow) { const inp = bpmnCurrentRow.querySelector('.m-bpmn'); if (inp) inp.value = ref; }
            bootstrap.Modal.getInstance(document.getElementById('bpmnModal'))?.hide();
        });

        // ─── Step 3 tabs (Team / Actions) ─────────────────────────────────
        // Tabs replace the stacked panels so users see both options at once
        // instead of having to scroll past Team to find Actions. Counts are
        // wired via MutationObserver so they stay in sync with add/remove
        // without touching the existing addTeamRow / addActionRow helpers.
        function t3RefreshCounts() {
            const teamCount = document.querySelectorAll('#teamRows .p-3').length;
            const actionCount = document.querySelectorAll('#actionRows .p-3').length;
            const tCount = document.getElementById('t3CountTeam');
            const aCount = document.getElementById('t3CountActions');
            if (tCount) tCount.textContent = teamCount;
            if (aCount) aCount.textContent = actionCount;
        }
        document.querySelectorAll('.t3-tab').forEach(tab => {
            tab.addEventListener('click', function () {
                document.querySelectorAll('.t3-tab').forEach(t => {
                    t.classList.remove('active');
                    t.setAttribute('aria-selected', 'false');
                });
                this.classList.add('active');
                this.setAttribute('aria-selected', 'true');
                document.querySelectorAll('.t3-pane').forEach(p => p.classList.add('d-none'));
                document.getElementById(this.dataset.target)?.classList.remove('d-none');
            });
        });
        ['teamRows', 'actionRows'].forEach(id => {
            const el = document.getElementById(id);
            if (!el) return;
            new MutationObserver(t3RefreshCounts).observe(el, { childList: true });
        });

        // ─── Quick-add measurement templates ───────────────────────────────
        // Each template is { type, direction, unit, nameEn, nameAr } that
        // gets applied to a freshly added card. Saves the user from
        // re-picking the same Type/Direction/Unit combo every time.
        const qaTemplates = {
            time:         { type: 'Time',         direction: 'LowerBetter',  unit: (isRtl ? 'دقائق' : 'minutes'),
                            nameEn: 'Processing time',          nameAr: 'وقت المعالجة' },
            cost:         { type: 'Cost',         direction: 'LowerBetter',  unit: 'AED',
                            nameEn: 'Cost per transaction',     nameAr: 'تكلفة كل معاملة' },
            satisfaction: { type: 'Satisfaction', direction: 'HigherBetter', unit: '%',
                            nameEn: 'Customer satisfaction',    nameAr: 'رضا المتعاملين' },
            productivity: { type: 'Productivity', direction: 'HigherBetter', unit: (isRtl ? 'لكل يوم' : 'per day'),
                            nameEn: 'Throughput',               nameAr: 'الإنتاجية اليومية' },
            errors:       { type: 'Custom',       direction: 'LowerBetter',  unit: '%',
                            nameEn: 'Error rate',               nameAr: 'نسبة الأخطاء' },
            visits:       { type: 'NumberOfVisits', direction: 'LowerBetter', unit: (isRtl ? 'لكل متعامل' : 'per customer'),
                            nameEn: 'Visits per customer',      nameAr: 'عدد الزيارات لكل متعامل' }
        };
        // Build a measurement card from a template and target value.
        function applyTemplateToTarget(tpl, targetVal) {
            addMeasurementRow();
            const card = document.querySelector('#measurementRows .measurement-card:last-child');
            if (!card) return;
            const setOn = (sel, val) => {
                const el = card.querySelector(sel);
                if (!el) return;
                el.value = val;
                el.dispatchEvent(new Event('change', { bubbles: true }));
            };
            setOn('.m-type',      tpl.type);
            setOn('.m-direction', tpl.direction);
            setOn('.m-unit',      tpl.unit);
            setOn('.m-name-en',   tpl.nameEn);
            setOn('.m-name-ar',   tpl.nameAr);
            if (targetVal) setOn('.m-applies', targetVal);
            card.querySelectorAll('.dir-btn').forEach(b => b.classList.toggle('active', b.dataset.dir === tpl.direction));
        }

        // Picker state — which template the user just clicked.
        let __qaPendingTpl = null;
        function openTargetPicker(tpl, anchorBtn) {
            __qaPendingTpl = tpl;
            const procIds = (typeof csGetValues === 'function') ? csGetValues('processes') : [];
            const svcIds  = (typeof csGetValues === 'function') ? csGetValues('services')  : [];
            // Build list with labels pulled off the chip checkboxes
            const items = [];
            procIds.forEach(id => {
                const c = document.querySelector('.cs-chk[data-csid="processes"][value="' + id + '"]');
                items.push({ value: 'process:' + id, label: (isRtl ? 'عملية: ' : 'Process: ') + (c?.getAttribute('data-label') || id) });
            });
            svcIds.forEach(id => {
                const c = document.querySelector('.cs-chk[data-csid="services"][value="' + id + '"]');
                items.push({ value: 'service:' + id, label: (isRtl ? 'خدمة: ' : 'Service: ') + (c?.getAttribute('data-label') || id) });
            });

            const list = document.getElementById('qaPickerList');
            const title = document.getElementById('qaPickerTitle');
            title.textContent = (isRtl ? 'تطبيق على — ' : 'Apply to — ') + (isRtl ? tpl.nameAr : tpl.nameEn);
            list.innerHTML = items.map(it =>
                '<label><input type="checkbox" class="qa-pick-chk" value="' +
                it.value.replace(/"/g, '&quot;') + '" checked /> <span>' +
                it.label.replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c])) +
                '</span></label>'
            ).join('');
            const picker = document.getElementById('qaTargetPicker');
            picker.classList.remove('hidden');
            if (window.lucide) lucide.createIcons();
        }
        function closeTargetPicker() {
            __qaPendingTpl = null;
            document.getElementById('qaTargetPicker')?.classList.add('hidden');
        }

        document.querySelectorAll('.qa-tpl').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                const tpl = qaTemplates[this.dataset.tpl];
                if (!tpl) return;
                const procIds = (typeof csGetValues === 'function') ? csGetValues('processes') : [];
                const svcIds  = (typeof csGetValues === 'function') ? csGetValues('services')  : [];
                const totalScope = procIds.length + svcIds.length;
                if (totalScope <= 1) {
                    // 0 scope items → blank-applies card so the template still
                    // works on a fresh wizard. 1 scope item → no point asking,
                    // just create it pre-pointed.
                    const onlyTarget = procIds.length === 1 ? 'process:' + procIds[0]
                                     : svcIds.length === 1 ? 'service:' + svcIds[0]
                                     : '';
                    applyTemplateToTarget(tpl, onlyTarget);
                    if (typeof updateStepChecklist === 'function') updateStepChecklist();
                    return;
                }
                openTargetPicker(tpl, this);
            });
        });

        document.getElementById('qaPickerClose')?.addEventListener('click', closeTargetPicker);
        document.getElementById('qaPickerSelectAll')?.addEventListener('click', () => {
            document.querySelectorAll('#qaPickerList .qa-pick-chk').forEach(c => { c.checked = true; });
        });
        document.getElementById('qaPickerSelectNone')?.addEventListener('click', () => {
            document.querySelectorAll('#qaPickerList .qa-pick-chk').forEach(c => { c.checked = false; });
        });
        document.getElementById('qaPickerApply')?.addEventListener('click', () => {
            if (!__qaPendingTpl) return closeTargetPicker();
            const picked = Array.from(document.querySelectorAll('#qaPickerList .qa-pick-chk:checked')).map(c => c.value);
            const tpl = __qaPendingTpl;
            // 0 picked = create one blank-applies card so the template still
            // lands somewhere. Otherwise one card per checked target.
            const list = picked.length === 0 ? [''] : picked;
            list.forEach(t => applyTemplateToTarget(tpl, t));
            if (typeof updateStepChecklist === 'function') updateStepChecklist();
            if (list.length > 1 && typeof setAutoSaveStatus === 'function') {
                setAutoSaveStatus(isRtl ? 'تم إنشاء ' + list.length + ' مقاييس' : 'Created ' + list.length + ' measurements');
                setTimeout(() => { try { setAutoSaveStatus(''); } catch(e) {} }, 2200);
            }
            closeTargetPicker();
        });
        // Click outside closes the picker
        document.addEventListener('click', function (e) {
            const picker = document.getElementById('qaTargetPicker');
            if (!picker || picker.classList.contains('hidden')) return;
            if (e.target.closest('#qaTargetPicker') || e.target.closest('.qa-tpl')) return;
            closeTargetPicker();
        });

        // ─── Live KPI strip ────────────────────────────────────────────────
        // Updates the chip counts under the wizard header on any form change.
        // Adds a brief 'kpi-bump' class when a value changes so the user
        // sees the feedback even if their eyes are on a different field.
        function updateWizKpiStrip() {
            const counts = {
                processes:    (typeof csGetValues === 'function') ? csGetValues('processes').length : 0,
                services:     (typeof csGetValues === 'function') ? csGetValues('services').length : 0,
                measurements: document.querySelectorAll('#measurementRows .measurement-card').length,
                team:         document.querySelectorAll('#teamRows .p-3').length,
                actions:      document.querySelectorAll('#actionRows .p-3').length
            };
            Object.entries(counts).forEach(([key, val]) => {
                const numEl = document.querySelector('[data-kpi-num="' + key + '"]');
                const chipEl = document.querySelector('[data-kpi="' + key + '"]');
                if (!numEl || !chipEl) return;
                const prev = parseInt(numEl.textContent, 10) || 0;
                if (prev !== val) {
                    numEl.textContent = val;
                    chipEl.classList.toggle('has-value', val > 0);
                    chipEl.classList.add('kpi-bump');
                    setTimeout(() => chipEl.classList.remove('kpi-bump'), 200);
                }
            });
        }
        document.addEventListener('input', updateWizKpiStrip);
        document.addEventListener('change', updateWizKpiStrip);
        // Initial paint after DOM ready (covers hydrate-from-draft too)
        setTimeout(updateWizKpiStrip, 0);

        // ─── Preview-before-submit modal ───────────────────────────────────
        // Reads everything off the live form (running syncHiddenFields and
        // syncTeamAndActionFields first so hidden values reflect current
        // truth) and renders a read-only summary. User can print, edit
        // (close), or confirm-and-submit.
        function htmlEscape(s) {
            return (s ?? '').toString().replace(/[<>&"]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c]));
        }
        function buildPreviewHtml() {
            try { syncHiddenFields(); } catch (e) {}
            const t = (en, ar) => (isRtl ? ar : en);
            const titleEn = document.querySelector('[name="TitleEn"]')?.value?.trim() || '';
            const titleAr = document.querySelector('[name="TitleAr"]')?.value?.trim() || '';
            const descEn  = document.querySelector('[name="DescriptionEn"]')?.value?.trim() || '';
            const descAr  = document.querySelector('[name="DescriptionAr"]')?.value?.trim() || '';
            const innovType = document.querySelector('[name="InnovationType"]')?.value || '';
            const horizon   = document.querySelector('[name="Horizon"]')?.value || '';
            const targetDate = document.querySelector('[name="TargetDate"]')?.value || '';
            const impact = document.getElementById('ImpactScore')?.value || '—';
            const effort = document.getElementById('EffortScore')?.value || '—';
            const total  = document.getElementById('totalScore')?.textContent?.trim() || '—';

            // Scope chips
            const procLabels = Array.from(document.querySelectorAll('.cs-chk[data-csid="processes"]:checked'))
                .map(c => c.getAttribute('data-label') || c.value);
            const svcLabels  = Array.from(document.querySelectorAll('.cs-chk[data-csid="services"]:checked'))
                .map(c => c.getAttribute('data-label') || c.value);

            // Measurements
            const mCards = Array.from(document.querySelectorAll('#measurementRows .measurement-card'));
            const measurementsHtml = mCards.length === 0
                ? '<p class="empty">' + t('No measurements added.', 'لم تتم إضافة مقاييس.') + '</p>'
                : '<table><thead><tr>' +
                    '<th>' + t('Name', 'الاسم') + '</th>' +
                    '<th>' + t('Type', 'النوع') + '</th>' +
                    '<th>' + t('Unit', 'الوحدة') + '</th>' +
                    '<th>' + t('Now', 'الحالي') + '</th>' +
                    '<th>' + t('Target', 'الهدف') + '</th>' +
                  '</tr></thead><tbody>' +
                  mCards.map(c => {
                      const name = c.querySelector('.m-name-en')?.value || c.querySelector('.m-name-ar')?.value || '';
                      const type = c.querySelector('.m-type')?.value || '';
                      const unit = c.querySelector('.m-unit')?.value || '';
                      const cur  = c.querySelector('.m-current')?.value || '';
                      const tgt  = c.querySelector('.m-target')?.value || '';
                      return '<tr>' +
                          '<td>' + htmlEscape(name) + '</td>' +
                          '<td>' + htmlEscape(type) + '</td>' +
                          '<td>' + htmlEscape(unit) + '</td>' +
                          '<td>' + htmlEscape(cur) + '</td>' +
                          '<td>' + htmlEscape(tgt) + '</td>' +
                      '</tr>';
                  }).join('') +
                  '</tbody></table>';

            // Team
            const teamRows = Array.from(document.querySelectorAll('#teamRows .p-3'));
            const teamHtml = teamRows.length === 0
                ? '<p class="empty">' + t('No team members assigned.', 'لم يتم تعيين أعضاء الفريق.') + '</p>'
                : '<table><thead><tr>' +
                    '<th>' + t('Member', 'العضو') + '</th>' +
                    '<th>' + t('Role', 'الدور') + '</th>' +
                    '<th>' + t('Notes', 'ملاحظات') + '</th>' +
                  '</tr></thead><tbody>' +
                  teamRows.map(r => {
                      const userSel = r.querySelector('.tm-user');
                      const roleSel = r.querySelector('.tm-role');
                      const notes = r.querySelector('.tm-notes')?.value || '';
                      const userName = userSel?.options[userSel.selectedIndex]?.text || '';
                      const roleName = roleSel?.options[roleSel.selectedIndex]?.text || '';
                      return '<tr><td>' + htmlEscape(userName) + '</td><td>' + htmlEscape(roleName) + '</td><td>' + htmlEscape(notes) + '</td></tr>';
                  }).join('') +
                  '</tbody></table>';

            // Actions
            const actionRows = Array.from(document.querySelectorAll('#actionRows .p-3'));
            const actionHtml = actionRows.length === 0
                ? '<p class="empty">' + t('No action items.', 'لا توجد إجراءات.') + '</p>'
                : '<table><thead><tr>' +
                    '<th>' + t('Action', 'الإجراء') + '</th>' +
                    '<th>' + t('Assignee', 'المسؤول') + '</th>' +
                    '<th>' + t('Due', 'الاستحقاق') + '</th>' +
                  '</tr></thead><tbody>' +
                  actionRows.map(r => {
                      const name = r.querySelector('.ac-name')?.value || r.querySelector('.ac-name-ar')?.value || '';
                      const assignSel = r.querySelector('.ac-assignee');
                      const assignee = assignSel?.options[assignSel.selectedIndex]?.text || '';
                      const due = r.querySelector('.ac-due')?.value || '';
                      return '<tr><td>' + htmlEscape(name) + '</td><td>' + htmlEscape(assignee) + '</td><td>' + htmlEscape(due) + '</td></tr>';
                  }).join('') +
                  '</tbody></table>';

            return '' +
                '<h4>' + t('Title', 'العنوان') + '</h4>' +
                '<p><strong>EN:</strong> ' + (titleEn ? htmlEscape(titleEn) : '<span class="empty">' + t('(empty)', '(فارغ)') + '</span>') + '</p>' +
                '<p><strong>AR:</strong> ' + (titleAr ? htmlEscape(titleAr) : '<span class="empty">' + t('(empty)', '(فارغ)') + '</span>') + '</p>' +
                (descEn || descAr ? '<h4>' + t('Description', 'الوصف') + '</h4>' +
                    (descEn ? '<p>' + htmlEscape(descEn) + '</p>' : '') +
                    (descAr ? '<p dir="rtl">' + htmlEscape(descAr) + '</p>' : '') : '') +
                '<h4>' + t('Scope', 'النطاق') + '</h4>' +
                (procLabels.length === 0 && svcLabels.length === 0
                    ? '<p class="empty">' + t('No process or service selected.', 'لم يتم اختيار عملية أو خدمة.') + '</p>'
                    : '<p>' +
                        procLabels.map(l => '<span class="pv-pill">' + t('Process: ', 'عملية: ') + htmlEscape(l) + '</span>').join('') +
                        svcLabels.map(l => '<span class="pv-pill">' + t('Service: ', 'خدمة: ') + htmlEscape(l) + '</span>').join('') +
                    '</p>') +
                (innovType || horizon || targetDate
                    ? '<h4>' + t('Classification', 'التصنيف') + '</h4>' +
                      '<p>' +
                          (innovType  ? '<span class="pv-pill">' + t('Type: ', 'النوع: ') + htmlEscape(innovType) + '</span>' : '') +
                          (horizon    ? '<span class="pv-pill">' + t('Horizon: ', 'الأفق: ') + htmlEscape(horizon) + '</span>' : '') +
                          (targetDate ? '<span class="pv-pill">' + t('Target date: ', 'تاريخ الهدف: ') + htmlEscape(targetDate) + '</span>' : '') +
                      '</p>'
                    : '') +
                '<h4>' + t('Measurements', 'المقاييس') + '</h4>' +
                measurementsHtml +
                '<h4>' + t('Scoring', 'التقييم') + '</h4>' +
                '<p>' +
                    '<span class="pv-pill">' + t('Impact: ', 'الأثر: ') + htmlEscape(impact) + '</span>' +
                    '<span class="pv-pill">' + t('Effort: ', 'الجهد: ') + htmlEscape(effort) + '</span>' +
                    '<span class="pv-pill">' + t('Total: ', 'الإجمالي: ') + htmlEscape(total) + '</span>' +
                '</p>' +
                '<h4>' + t('Team', 'الفريق') + '</h4>' + teamHtml +
                '<h4>' + t('Action Plan', 'خطة العمل') + '</h4>' + actionHtml;
        }
        function openWizPreview() {
            const body = document.getElementById('wizPreviewBody');
            if (body) body.innerHTML = buildPreviewHtml();
            document.getElementById('wizPreviewModal')?.classList.remove('hidden');
            if (window.lucide) lucide.createIcons();
        }
        function closeWizPreview() {
            document.getElementById('wizPreviewModal')?.classList.add('hidden');
        }
        document.getElementById('previewBtn')?.addEventListener('click', openWizPreview);
        document.getElementById('wizPreviewClose')?.addEventListener('click', closeWizPreview);
        document.getElementById('wizPreviewEdit')?.addEventListener('click', closeWizPreview);
        document.getElementById('wizPreviewPrint')?.addEventListener('click', () => window.print());
        document.getElementById('wizPreviewConfirm')?.addEventListener('click', () => {
            closeWizPreview();
            document.getElementById('submitBtn')?.click();
        });
        // Esc to close
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && !document.getElementById('wizPreviewModal')?.classList.contains('hidden')) {
                closeWizPreview();
            }
        });

        // ─── Inline step checklist (Option F) ──────────────────────────────
        // Computes the missing-fields list for steps 1 + 2 and updates the
        // .wiz-checklist banner in real time. Replaces the previous "click
        // Next, hit a wall, read the error" loop with continuous guidance.
        function updateStepChecklist() {
            const t = (en, ar) => (isRtl ? ar : en);

            // Step 1: Scope (process or service) + bilingual title
            (function step1() {
                const el = document.querySelector('.wiz-checklist[data-step-checklist="1"]');
                if (!el) return;
                const missing = [];
                const processIds = (typeof csGetValues === 'function') ? csGetValues('processes') : [];
                const serviceIds = (typeof csGetValues === 'function') ? csGetValues('services') : [];
                const titleEn = document.querySelector('[name="TitleEn"]')?.value?.trim();
                const titleAr = document.querySelector('[name="TitleAr"]')?.value?.trim();
                if (!processIds.length && !serviceIds.length) missing.push(t('a Process or a Service', 'عملية أو خدمة'));
                if (!titleEn) missing.push(t('English title', 'العنوان بالإنجليزية'));
                if (!titleAr) missing.push(t('Arabic title', 'العنوان بالعربية'));
                renderChecklist(el, missing);
            })();

            // Step 2: at least one measurement card with all required fields
            (function step2() {
                const el = document.querySelector('.wiz-checklist[data-step-checklist="2"]');
                if (!el) return;
                const cards = document.querySelectorAll('#measurementRows .measurement-card');
                const missing = [];
                if (!cards.length) {
                    missing.push(t('add at least one measurement', 'أضف مقياسًا واحدًا على الأقل'));
                } else {
                    let incomplete = 0;
                    cards.forEach(c => {
                        const nameEn = c.querySelector('.m-name-en')?.value?.trim();
                        const nameAr = c.querySelector('.m-name-ar')?.value?.trim();
                        const unit   = c.querySelector('.m-unit')?.value?.trim();
                        const cur    = c.querySelector('.m-current')?.value?.trim();
                        const tgt    = c.querySelector('.m-target')?.value?.trim();
                        const applies= c.querySelector('.m-applies')?.value?.trim();
                        if (!unit || (!nameEn && !nameAr) || !applies || cur === '' || tgt === '') incomplete++;
                    });
                    if (incomplete > 0) {
                        missing.push(t(
                            incomplete + (incomplete === 1 ? ' measurement is missing required fields' : ' measurements are missing required fields'),
                            incomplete + (incomplete === 1 ? ' مقياس ينقصه حقول إلزامية' : ' مقاييس تنقصها حقول إلزامية')
                        ));
                    }
                }
                renderChecklist(el, missing);
            })();
        }

        function renderChecklist(el, missing) {
            const t = (en, ar) => (isRtl ? ar : en);
            const txt = el.querySelector('.wiz-checklist-text');
            const icon = el.querySelector('[data-lucide]');
            if (missing.length === 0) {
                el.dataset.state = 'ok';
                if (icon) { icon.setAttribute('data-lucide', 'check-circle-2'); }
                if (txt) txt.textContent = t('Ready to continue.', 'جاهز للمتابعة.');
            } else {
                el.dataset.state = 'missing';
                if (icon) { icon.setAttribute('data-lucide', 'circle-dashed'); }
                if (txt) txt.textContent = t('Still need: ', 'ما زال يلزم: ') + missing.join(' · ');
            }
            if (window.lucide) lucide.createIcons();
        }

        // Live wiring: any change in the wizard form updates the checklist.
        // Also recompute on add/remove of measurement cards.
        document.addEventListener('input', updateStepChecklist);
        document.addEventListener('change', updateStepChecklist);
        const __mRows = document.getElementById('measurementRows');
        // childList only — subtree:true caused a feedback loop because
        // lucide.createIcons() inside addMeasurementRow() swaps <i> tags
        // for <svg> nested in the new card, fires the observer, which
        // re-runs renderChecklist + lucide.createIcons → freeze.
        if (__mRows) new MutationObserver(updateStepChecklist).observe(__mRows, { childList: true });
        // First paint after DOM ready
        setTimeout(updateStepChecklist, 0);

        // ─── Save as Draft + Resume ───────────────────────────────────────
        // Per-user snapshot of the wizard form. Stored as opaque JSON on the
        // server. Title is best-effort from TitleEn so the drafts list shows
        // something more useful than a UUID.
        function getWizardSnapshot() {
            // Push live measurement / chip / score state into the hidden
            // fields first so FormData captures the current truth.
            try { syncHiddenFields(); } catch (e) { /* may throw if step not yet rendered — payload is still useful */ }
            const data = {};
            const form = document.getElementById('wizardForm');
            new FormData(form).forEach((v, k) => {
                if (k === '__RequestVerificationToken') return;
                if (k === 'DraftId') return;
                if (k in data) {
                    if (Array.isArray(data[k])) data[k].push(v);
                    else data[k] = [data[k], v];
                } else data[k] = v;
            });
            // Also capture the chip selections explicitly (they're already
            // mirrored to SelectedProcessIds[] hidden inputs by addCSHidden,
            // but only on submit — store directly so resume is reliable).
            data.__chips = {
                processes: csGetValues('processes'),
                services: csGetValues('services')
            };
            return data;
        }

        // Dirty / in-flight flags so the auto-save timer doesn't double-post
        // and so we don't save an untouched form on first load.
        let __wizardDirty = false;
        let __saveInFlight = false;

        function setAutoSaveStatus(text) {
            const el = document.getElementById('autoSaveStatus');
            if (el) el.textContent = text || '';
        }

        function fmtClock(d) {
            try { return d.toLocaleTimeString(isRtl ? 'ar-AE' : 'en-GB', { hour: '2-digit', minute: '2-digit' }); }
            catch { return d.toISOString().substring(11,16); }
        }

        async function saveDraftCall(opts) {
            opts = opts || {};
            const isAuto = opts.auto === true;
            if (__saveInFlight) return;
            const btn = document.getElementById('saveDraftBtn');
            const lbl = document.getElementById('saveDraftLabel');
            const oldText = lbl.textContent;
            __saveInFlight = true;
            if (!isAuto) { btn.disabled = true; lbl.textContent = (isRtl ? 'جاري الحفظ…' : 'Saving…'); }
            else { setAutoSaveStatus(isRtl ? 'جاري الحفظ تلقائيًا…' : 'Auto-saving…'); }
            try {
                const payload = getWizardSnapshot();
                const titleEn = document.querySelector('[name="TitleEn"]')?.value?.trim();
                const titleAr = document.querySelector('[name="TitleAr"]')?.value?.trim();
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const body = {
                    Id: document.getElementById('hdnDraftId').value || null,
                    Title: titleEn || titleAr || '',
                    PayloadJson: JSON.stringify(payload)
                };
                const res = await fetch('@Url.Action("SaveDraft", "Improvements")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token || '' },
                    body: JSON.stringify(body),
                    credentials: 'same-origin',
                    redirect: 'manual'
                });
                // Cookie-auth + ajax pitfall: an expired session redirects to
                // /Account/Login which returns 200 OK with HTML. Detect that
                // *before* trying to parse JSON so the user gets a useful
                // error instead of "Save failed".
                if (res.type === 'opaqueredirect' || res.status === 0 || res.status === 401 || res.status === 403) {
                    throw new Error('AUTH');
                }
                const ct = res.headers.get('content-type') || '';
                if (!res.ok || !ct.includes('application/json')) {
                    if (ct.includes('text/html')) throw new Error('AUTH');
                    throw new Error('HTTP ' + res.status);
                }
                const j = await res.json();
                document.getElementById('hdnDraftId').value = j.id;
                __wizardDirty = false;
                const stamp = fmtClock(new Date());
                setAutoSaveStatus((isRtl ? 'تم الحفظ ' : 'Saved ') + stamp);
                if (!isAuto) {
                    lbl.textContent = (isRtl ? 'تم الحفظ ✓' : 'Saved ✓');
                    setTimeout(() => { lbl.textContent = oldText; btn.disabled = false; }, 1800);
                }
            } catch (e) {
                const isAuthLost = (e && e.message === 'AUTH');
                const failMsg = isAuthLost
                    ? (isRtl ? 'انتهت الجلسة — أعد تحميل الصفحة' : 'Session expired — please reload')
                    : (isRtl ? 'فشل الحفظ' : 'Save failed');
                setAutoSaveStatus(failMsg);
                if (!isAuto) {
                    lbl.textContent = failMsg;
                    setTimeout(() => { lbl.textContent = oldText; btn.disabled = false; }, 3500);
                }
            } finally {
                __saveInFlight = false;
            }
        }
        document.getElementById('saveDraftBtn')?.addEventListener('click', () => saveDraftCall());

        // Dirty tracking — any input/change/click inside the wizard form
        // marks the snapshot dirty. Auto-save reads this flag.
        const __wizForm = document.getElementById('wizardForm');
        if (__wizForm) {
            const markDirty = () => { __wizardDirty = true; };
            __wizForm.addEventListener('input',  markDirty);
            __wizForm.addEventListener('change', markDirty);
        }

        // Auto-save loop — fires every 30s. Only posts when:
        //   1. The form has been touched since the last save (dirty), AND
        //   2. There's enough content to be worth keeping (title or any
        //      measurement card), AND
        //   3. No save is currently in flight.
        // First fire is at t=30s, not on load — so a casual visit doesn't
        // create a phantom draft.
        setInterval(function autoSaveTick() {
            if (!__wizardDirty || __saveInFlight) return;
            const titleEn = document.querySelector('[name="TitleEn"]')?.value?.trim();
            const titleAr = document.querySelector('[name="TitleAr"]')?.value?.trim();
            const hasMeasurements = document.querySelectorAll('#measurementRows .measurement-card').length > 0;
            if (!titleEn && !titleAr && !hasMeasurements) return;
            saveDraftCall({ auto: true });
        }, 30000);

        // Hydrate from a resumed draft. Server already set ResumeDraftId via
        // ?draftId=X; we fetch the payload and replay it into the form.
        async function hydrateFromDraft(draftId) {
            try {
                const res = await fetch('@Url.Action("LoadDraft", "Improvements")?id=' + encodeURIComponent(draftId));
                if (!res.ok) return;
                const j = await res.json();
                const payload = JSON.parse(j.payloadJson);
                const form = document.getElementById('wizardForm');

                // Phase 1 — restore scalar form values by name
                Object.keys(payload).forEach(k => {
                    if (k === '__chips') return;
                    const v = payload[k];
                    const els = form.querySelectorAll('[name="' + k + '"]');
                    if (els.length === 0) return;
                    els.forEach(el => {
                        if (el.type === 'checkbox') {
                            // pipe-separated arrays for chips handled below
                            el.checked = (v === 'on' || v === 'true' || v === el.value);
                        } else if (el.type === 'radio') {
                            el.checked = (el.value === v);
                        } else {
                            el.value = Array.isArray(v) ? v.join(',') : (v ?? '');
                        }
                    });
                });

                // Phase 2 — restore chip selections (processes / services)
                if (payload.__chips) {
                    (payload.__chips.processes || []).forEach(id => {
                        const c = document.querySelector('.cs-chk[data-csid="processes"][value="' + id + '"]');
                        if (c) { c.checked = true; }
                    });
                    if (typeof csUpdate === 'function') csUpdate('processes');
                    (payload.__chips.services || []).forEach(id => {
                        const c = document.querySelector('.cs-chk[data-csid="services"][value="' + id + '"]');
                        if (c) { c.checked = true; }
                    });
                    if (typeof csUpdate === 'function') csUpdate('services');
                }

                // Phase 3 — re-build measurement cards from the pipe-separated
                // hidden fields. Phase 1 set the hidden values; we now rebuild
                // visible cards and copy values back into them.
                // Separators here MUST match syncHiddenFields() in the
                // same file. Using the wrong separator collapses an entire
                // pipe-joined string into applies[0] etc., and every card
                // beyond the first hydrates with empty per-card values.
                const names    = (payload.MeasurementNames    || '').split('|');
                const namesAr  = (payload.MeasurementNamesAr  || '').split('|');
                const types    = (payload.MeasurementTypes    || '').split(',');
                const units    = (payload.MeasurementUnits    || '').split('|');
                const targets  = (payload.MeasurementTargets  || '').split(',');
                const asIs     = (payload.MeasurementAsIs     || '').split(',');
                const weights  = (payload.MeasurementWeights  || '').split(',');
                const applies  = (payload.MeasurementAppliesTo|| '').split('|');
                const periods  = (payload.MeasurementPeriods  || '').split('|');
                const methods  = (payload.MeasurementMethods  || '').split('|');
                const tobe     = (payload.MeasurementToBe     || '').split(',');
                const bpmn     = (payload.MeasurementBpmn     || '').split('|');
                const dirs     = (payload.MeasurementDirections || '').split('|');
                const kpiIds   = (payload.MeasurementKpiDefinitionIds || '').split('|');

                const count = Math.max(names.length, types.length);
                const hasAnyMeasurement = count > 0 && (names[0] || types[0]);
                if (hasAnyMeasurement) {
                    document.getElementById('measurementRows').innerHTML = '';
                    measurementCounter = 0;
                    for (let i = 0; i < count; i++) {
                        addMeasurementRow();
                    }
                    // Now populate each card's class-named inputs
                    document.querySelectorAll('#measurementRows .measurement-card').forEach((card, i) => {
                        const set = (sel, val) => { const el = card.querySelector(sel); if (el && val !== undefined) el.value = val; };
                        set('.m-name-en',  names[i]);
                        set('.m-name-ar',  namesAr[i]);
                        set('.m-type',     types[i]);
                        set('.m-unit',     units[i]);
                        set('.m-target',   targets[i]);
                        set('.m-current',  asIs[i]);
                        set('.m-weight',   weights[i]);
                        set('.m-applies', applies[i]);
                        set('.m-period',   periods[i]);
                        set('.m-method',   methods[i]);
                        set('.m-tobe',     tobe[i]);
                        set('.m-bpmn',     bpmn[i]);
                        set('.m-direction', dirs[i] || 'HigherBetter');
                        set('.m-kpi-definition-id', kpiIds[i]);
                        // Restore direction button visual state
                        const dirVal = dirs[i] || 'HigherBetter';
                        card.querySelectorAll('.dir-btn').forEach(b => {
                            b.classList.toggle('active', b.dataset.dir === dirVal);
                        });
                    });
                    if (typeof updateWeightTotal === 'function') updateWeightTotal();
                }

                lucide.createIcons();
                // Hydration triggers many input events — clear dirty so the
                // 30s auto-save doesn't immediately re-post the same payload.
                setTimeout(() => { __wizardDirty = false; setAutoSaveStatus(isRtl ? 'تم استئناف المسودة' : 'Draft resumed'); }, 0);
            } catch (e) {
                console.warn('Draft hydration failed:', e);
            }
        }

        const __resumeDraftId = '@(ViewBag.ResumeDraftId ?? "")';
        if (__resumeDraftId) {
            // Defer until step-1 fields exist
            setTimeout(() => hydrateFromDraft(__resumeDraftId), 50);
        }

        // Keyboard shortcuts — power-user accelerators.
        //   Ctrl/Cmd + S     → save draft (without leaving the page)
        //   Ctrl/Cmd + Enter → advance to next step (or submit on last step)
        //   Ctrl/Cmd + ←     → previous step (Ctrl + → in RTL)
        //   Ctrl/Cmd + →     → next step (Ctrl + ← in RTL)
        // RTL flips arrows because the user's mental model of "forward" maps
        // to the rightward arrow in LTR and leftward in RTL.
        document.addEventListener('keydown', function (e) {
            const meta = e.ctrlKey || e.metaKey;
            if (!meta) return;
            // Ignore inside contenteditable / textareas to keep native UX
            if (e.target.tagName === 'TEXTAREA' && e.key === 'Enter' && !e.shiftKey) {
                return;
            }
            if (e.key.toLowerCase() === 's') {
                e.preventDefault();
                saveDraftCall();
                return;
            }
            if (e.key === 'Enter') {
                e.preventDefault();
                if (currentStep === totalSteps) {
                    document.getElementById('submitBtn')?.click();
                } else {
                    document.getElementById('nextBtn')?.click();
                }
                return;
            }
            const fwdKey = isRtl ? 'ArrowLeft'  : 'ArrowRight';
            const backKey= isRtl ? 'ArrowRight' : 'ArrowLeft';
            if (e.key === fwdKey) {
                e.preventDefault();
                document.getElementById('nextBtn')?.click();
            } else if (e.key === backKey) {
                e.preventDefault();
                document.getElementById('prevBtn')?.click();
            }
        });

        // Browser-level "you have unsaved changes" prompt — fires when the
        // user closes the tab, navigates away, or hits Back. Skipped when
        // the form is being submitted (the actual create flow) or when the
        // user explicitly cancels via the in-page wizardCancelBtn handler.
        let __submitting = false;
        document.getElementById('wizardForm')?.addEventListener('submit', () => { __submitting = true; });
        window.addEventListener('beforeunload', function (e) {
            if (__submitting) return;
            if (window.__wizardSubmitting) return;  // user already confirmed Cancel
            if (!__wizardDirty) return;
            // Modern browsers ignore the custom string but require these two
            // calls to surface their built-in confirmation dialog.
            e.preventDefault();
            e.returnValue = '';
        });

        showStep(1);
        lucide.createIcons();
    </script>
