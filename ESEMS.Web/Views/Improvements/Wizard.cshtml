        opacity: 0.4;
        cursor: not-allowed;
    }

    /* ── Field-level validation highlight ───────────────────── */
    .wizard-invalid,
    .wizard-invalid .cs-trigger {
        border-color: #dc2626 !important;
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.15) !important;
        animation: wizardShake 0.4s ease-in-out;
    }
    @@keyframes wizardShake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-4px); }
        75% { transform: translateX(4px); }
    }

    /* Score sliders */
    .score-slider-input {
        accent-color: #005B99;
        width: 100%;
        cursor: pointer;
    }
    .score-badge {
        transition: background 0.2s;
    }

    /* Measurement card section dividers */
    .measurement-card details > summary {
        list-style: none;
    }
    .measurement-card details > summary::-webkit-details-marker {
        display: none;
    }
    .measurement-card details > summary::after {
        content: '+';
        float: inline-end;
        font-weight: bold;
    }
    .measurement-card details[open] > summary::after {
        content: '−';
    }

    /* Step 3 tabs — pill-style strip on the section bottom border. */
    .t3-tabs { border-bottom-color: #e5e7eb; }
    .t3-tab {
        background: transparent;
        border: 0;
        border-bottom: 2px solid transparent;
        padding: .45rem .85rem;
        margin-bottom: -1px;
        color: #6b7280;
        font-size: var(--fs-sm);
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        cursor: pointer;
        transition: color .15s ease, border-color .15s ease;
    }
    .t3-tab:hover { color: #005B99; }
    .t3-tab.active {
        color: #005B99;
        border-bottom-color: #005B99;
    }
    .t3-count {
        display: inline-block;
        background: #e5e7eb;
        color: #374151;
        font-size: var(--fs-xs);
        font-weight: 700;
        line-height: 1;
        padding: .15rem .4rem;
        border-radius: 999px;
        min-width: 18px;
        text-align: center;
    }
    .t3-tab.active .t3-count { background: #005B99; color: #fff; }

    /* Inline step-completion checklist — sits at the top of each macro
       step, updates live as the user types. Subtle but always-visible
       guidance that replaces the need to bounce off Next-button errors. */
    .wiz-checklist {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem .75rem;
        margin-bottom: .85rem;
        border-radius: 6px;
        font-size: var(--fs-sm);
        line-height: 1.35;
        transition: background-color .2s ease, border-color .2s ease, color .2s ease;
    }
    .wiz-checklist[data-state="missing"] {
        background: #fefce8;
        border: 1px solid #fde047;
        color: #854d0e;
    }
    .wiz-checklist[data-state="ok"] {
        background: #f0fdf4;
        border: 1px solid #86efac;
        color: #166534;
    }
    .wiz-checklist svg { flex-shrink: 0; }

    /* Live KPI strip — sits under the page header. Each chip pulses
       briefly when its count changes so the user catches the feedback. */
    .wiz-kpi-strip {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        padding: .5rem .85rem;
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
    }
    .wiz-kpi {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .25rem .6rem;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        font-size: var(--fs-xs);
        color: #64748b;
        transition: background-color .25s ease, color .25s ease, border-color .25s ease;
    }
    .wiz-kpi-num {
        font-weight: 700;
        color: #0f172a;
        min-width: 12px;
        text-align: center;
    }
    /* Once a chip has any count > 0, promote to brand colour */
    .wiz-kpi.has-value {
        background: #eff6ff;
        border-color: #bfdbfe;
        color: #1e40af;
    }
    .wiz-kpi.has-value .wiz-kpi-num { color: #005B99; }
    /* Brief pulse on count change */
    .wiz-kpi.kpi-bump { transform: scale(1.06); transition: transform .15s ease-out; }

    /* Quick-add target picker — popover anchored above the template strip
       (qaTemplates sits at the bottom of step 2, so opening downward would
       push the picker off the section). */
    .qa-picker {
        position: absolute;
        bottom: 100%;
        inset-inline-start: 0;
        margin-bottom: .35rem;
        min-width: 320px;
        max-width: 480px;
        background: #fff;
        border: 1px solid #d1d5db;
