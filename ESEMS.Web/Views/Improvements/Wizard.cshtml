        // mkey() and the renderTargetInputs() function were removed during the
        // 7→3 step consolidation — Now/Target inputs live directly inside each
        // measurement card now, so there's no separate render step or per-row
        // grid-by-AppliesTo grouping. checkTargetSanity (the older standalone
        // helper) was replaced with checkInlineSanity below, which reads from
        // .m-current / .m-target inside the card itself.

        // Inline sanity check — runs on every input of .m-current / .m-target inside
        // a measurement card. Mirrors checkTargetSanity below but reads directly
        // from the card instead of from the (now-removed) per-row data-idx grid.
        function checkInlineSanity(inp) {
            const card = inp.closest('.measurement-card');
            if (!card) return;
            const dir = card.querySelector('.m-direction')?.value || 'HigherBetter';
            const cur = parseFloat(card.querySelector('.m-current')?.value);
            const tgt = parseFloat(card.querySelector('.m-target')?.value);
            const sanity = card.querySelector('.m-target-sanity');
            if (!sanity) return;
            if (isNaN(cur) || isNaN(tgt) || cur === tgt) {
                sanity.classList.add('hidden');
                return;
            }
            let warn = null;
            if (dir === 'HigherBetter' && tgt < cur) {
                warn = isRtl
                    ? 'قيمة الهدف أقل من القيمة الحالية لمقياس "أعلى أفضل"'
                    : 'Target is lower than Current for a "Higher is better" metric.';
            } else if (dir === 'LowerBetter' && tgt > cur) {
                warn = isRtl
                    ? 'قيمة الهدف أعلى من القيمة الحالية لمقياس "أقل أفضل"'
                    : 'Target is higher than Current for a "Lower is better" metric.';
            }
            if (warn) {
                sanity.textContent = '⚠ ' + warn;
                sanity.classList.remove('hidden');
            } else {
                sanity.classList.add('hidden');
            }
        }

        // Sanity check: warn when the user's target contradicts the direction-
        // of-improvement they picked on Step 2. Non-blocking, advisory only.
        function checkTargetSanity(inp) {
            const row = inp.closest('.target-row');
            if (!row) return;
            const dir = row.dataset.direction || 'HigherBetter';
            const asIsEl = row.querySelector('.asis-val');
            const tgtEl  = row.querySelector('.target-val');
            const sanity = row.querySelector('.target-sanity');
            if (!asIsEl || !tgtEl || !sanity) return;

            const asIs = parseFloat(asIsEl.value);
            const tgt  = parseFloat(tgtEl.value);
            // Only warn when both values are present and non-equal
            if (isNaN(asIs) || isNaN(tgt) || asIs === tgt) {
                sanity.classList.add('hidden');
                return;
            }
            let warn = null;
            if (dir === 'HigherBetter' && tgt < asIs) {
                warn = isRtl
                    ? 'قيمة الهدف أقل من القيمة الحالية لمقياس "أعلى أفضل". هل هذا مقصود؟'
                    : 'Target is lower than Current for a "Higher is better" metric. Is that intentional?';
            } else if (dir === 'LowerBetter' && tgt > asIs) {
                warn = isRtl
                    ? 'قيمة الهدف أعلى من القيمة الحالية لمقياس "أقل أفضل". هل هذا مقصود؟'
                    : 'Target is higher than Current for a "Lower is better" metric. Is that intentional?';
            }
            if (warn) {
                sanity.textContent = '⚠ ' + warn;
                sanity.classList.remove('hidden');
            } else {
                sanity.classList.add('hidden');
            }
        }

        function syncHiddenFields() {
            // getMeasurements() preserves the insertion order of the cards,
            // which is what Step 3's merged target+as-is view also uses (via
            // data-idx). Priority is no longer per-measurement; all rows get
            // the same priority derived from the initiative-level quadrant.
            const items = getMeasurements();
            const initiativePriority = getInitiativePriority();
            let types=[], names=[], namesAr=[], units=[], targets=[], asIs=[], toBe=[], weights=[];
            let appliesArr=[], periodsArr=[], methodsArr=[], bpmnArr=[], prioritiesArr=[], directionsArr=[], kpiIdsArr=[];
            items.forEach((m, i) => {
                prioritiesArr.push(initiativePriority);
                types.push(m.type);
                names.push(m.nameEn);
                namesAr.push(m.nameAr);
                units.push(m.unit);
                weights.push(m.weight);
                appliesArr.push(m.appliesTo);
                periodsArr.push(m.period);
                methodsArr.push(m.method);
                bpmnArr.push(m.bpmn);
                directionsArr.push(m.direction || 'HigherBetter');
                kpiIdsArr.push(m.kpiDefinitionId || '');
                // After 7→3 step consolidation: target / current values now live
                // inside each measurement card (.m-current / .m-target). The old
                // standalone Step-4 render (.target-val[data-idx]) is gone.
                targets.push(m.target || '');
                asIs.push(m.current || '');
                toBe.push(m.target || ''); // To-Be defaults to Target
            });
            document.getElementById('hdnMeasurementTypes').value = types.join(',');
            document.getElementById('hdnMeasurementNames').value = names.join('|');
            document.getElementById('hdnMeasurementNamesAr').value = namesAr.join('|');
            document.getElementById('hdnMeasurementUnits').value = units.join('|');
            document.getElementById('hdnMeasurementTargets').value = targets.join(',');
            document.getElementById('hdnMeasurementAsIs').value = asIs.join(',');
            document.getElementById('hdnMeasurementToBe').value = toBe.join(',');
            document.getElementById('hdnMeasurementWeights').value = weights.join(',');
            document.getElementById('hdnMeasurementAppliesTo').value = appliesArr.join('|');
            document.getElementById('hdnMeasurementPeriods').value = periodsArr.join('|');
            document.getElementById('hdnMeasurementMethods').value = methodsArr.join('|');
            document.getElementById('hdnMeasurementBpmn').value = bpmnArr.join('|');
            document.getElementById('hdnMeasurementPriorities').value = prioritiesArr.join('|');
            document.getElementById('hdnMeasurementDirections').value = directionsArr.join('|');
            document.getElementById('hdnMeasurementKpiDefinitionIds').value = kpiIdsArr.join('|');

            // Sync team/action hidden fields
            syncTeamAndActionFields();
        }

        // Initiative-level priority (H1/H2/H3) derived from Step 4 Impact × Effort.
        // Kept as a helper so syncHiddenFields and calcScores can both read it.
        function getInitiativePriority() {
            const impact = parseInt(document.getElementById('ImpactScore')?.value || '', 10);
            const effort = parseInt(document.getElementById('EffortScore')?.value || '', 10);
            if (!impact || !effort) return 'H2';
            const hi = impact >= 6, hiEff = effort >= 6;
            // Quick Win (high impact, low effort) = H1
            // Major Project (high impact, high effort) = H2
            // Fill-In (low impact, low effort) = H2
            // Thankless Task (low impact, high effort) = H3
            if (hi && !hiEff) return 'H1';
            if (!hi && hiEff) return 'H3';
            return 'H2';
        }

