        function getMeasurements() {
            const rows = document.querySelectorAll('#measurementRows .measurement-card');
            let items = [];
            rows.forEach(row => {
                items.push({
                    type: row.querySelector('.m-type')?.value || 'Custom',
                    nameEn: row.querySelector('.m-name-en')?.value || '',
                    nameAr: row.querySelector('.m-name-ar')?.value || '',
