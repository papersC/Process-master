@model IEnumerable<WorkloadScenario>
@using ESEMS.Web.Models.Enums
@functions {
    string StatusLabel(WorkloadScenarioStatus s, bool rtl) => s switch {
        WorkloadScenarioStatus.Draft    => rtl ? "مسودة" : "Draft",
        WorkloadScenarioStatus.InReview => rtl ? "قيد المراجعة" : "Review",
        WorkloadScenarioStatus.Approved => rtl ? "معتمد" : "Approved",
        WorkloadScenarioStatus.Archived => rtl ? "مؤرشف" : "Archived",
        _                               => s.ToString()
    };
}
@{
    ViewData["Title"] = "Workload Analysis";
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("ar");
    var totalScenarios = (int)(ViewBag.TotalScenarios ?? 0);
    var totalFTE = (decimal)(ViewBag.TotalFTERequired ?? 0m);
    var totalGap = (decimal)(ViewBag.TotalFTEGap ?? 0m);
    var defaultUtil = (decimal)(ViewBag.DefaultUtilization ?? 0.80m);
    var chartLabels = ViewBag.ChartLabels as List<string> ?? new List<string>();
    var chartFTE = ViewBag.ChartFTERequired as List<decimal> ?? new List<decimal>();
    var chartHeadcount = ViewBag.ChartHeadcount as List<decimal> ?? new List<decimal>();

    var list = Model?.ToList() ?? new List<WorkloadScenario>();
    var draftCount    = list.Count(s => s.Status == WorkloadScenarioStatus.Draft);
    var inReviewCount = list.Count(s => s.Status == WorkloadScenarioStatus.InReview);
    var approvedCount = list.Count(s => s.Status == WorkloadScenarioStatus.Approved);
    var archivedCount = list.Count(s => s.Status == WorkloadScenarioStatus.Archived);
    var statusMix = new[] { draftCount, inReviewCount, approvedCount, archivedCount };
}

<partial name="_WaStyles" />

<div class="wa-page">
    <div class="wa-pageheader">
        <div>
            <h1 class="wa-pagetitle"><i data-lucide="layout-dashboard" aria-hidden="true"></i>@(isRtl ? "تحليل أعباء العمل" : "Workload Analysis")</h1>
            <p class="wa-pagesub">@(isRtl ? "موجز تنفيذي لتخطيط القوى العاملة وتحديد الفجوات" : "Executive briefing — workforce planning and gap analysis")</p>
        </div>
        <div class="wa-actions">
            <a asp-action="Compare" class="wa-btn wa-btn-outline"><i data-lucide="git-compare" class="w-4 h-4" aria-hidden="true"></i>@(isRtl ? "مقارنة" : "Compare")</a>
            <a asp-action="Index" class="wa-btn wa-btn-outline"><i data-lucide="list" class="w-4 h-4" aria-hidden="true"></i>@(isRtl ? "كل السيناريوهات" : "All Scenarios")</a>
            <a asp-action="Config" class="wa-btn wa-btn-outline"><i data-lucide="settings" class="w-4 h-4" aria-hidden="true"></i>@(isRtl ? "الإعدادات" : "Config")</a>
            <a asp-action="Create" class="wa-btn wa-btn-primary"><i data-lucide="plus" class="w-4 h-4" aria-hidden="true"></i>@(isRtl ? "سيناريو جديد" : "New Scenario")</a>
        </div>
    </div>

    @* 4 executive KPIs. Numbers are pulled across approved scenarios — same as the controller. *@
    <div class="wa-kpis">
        <div class="wa-kpi">
            <div class="wa-kpi-icon" style="background:#eff6ff;color:#1d4ed8;"><i data-lucide="layers" class="w-4 h-4"></i></div>
            <div class="wa-kpi-text">
                <div class="wa-kpi-label">@(isRtl ? "السيناريوهات" : "Scenarios")</div>
                <div class="wa-kpi-value">@totalScenarios.ToString("N0")</div>
                <div class="wa-kpi-sub">@(isRtl ? "إجمالي بكل الحالات" : "all statuses")</div>
            </div>
        </div>
        <div class="wa-kpi">
            <div class="wa-kpi-icon" style="background:#f0fdf4;color:#15803d;"><i data-lucide="users" class="w-4 h-4"></i></div>
            <div class="wa-kpi-text">
                <div class="wa-kpi-label">@(isRtl ? "إجمالي الموارد المطلوبة" : "Total FTE Required")</div>
                <div class="wa-kpi-value">@totalFTE.ToString("N1")</div>
                <div class="wa-kpi-sub">@(isRtl ? "السيناريوهات المعتمدة" : "approved scenarios")</div>
            </div>
        </div>
        @{
            var gapCls = totalGap > 0 ? "wa-kpi-bad" : (totalGap < 0 ? "wa-kpi-good" : "");
            var gapBg  = totalGap > 0 ? "#fef2f2" : (totalGap < 0 ? "#f0fdf4" : "#f1f5f9");
            var gapFg  = totalGap > 0 ? "#b91c1c" : (totalGap < 0 ? "#15803d" : "#475569");
            var gapIcon = totalGap > 0 ? "trending-up" : (totalGap < 0 ? "trending-down" : "minus");
            var gapPrefix = totalGap > 0 ? "+" : "";
            var gapMeaning = totalGap > 0
                ? (isRtl ? "نقص في التوظيف" : "Understaffed")
                : (totalGap < 0 ? (isRtl ? "فائض في التوظيف" : "Overstaffed") : (isRtl ? "متوازن" : "Balanced"));
        }
        <div class="wa-kpi @gapCls">
            <div class="wa-kpi-icon" style="background:@gapBg;color:@gapFg;"><i data-lucide="@gapIcon" class="w-4 h-4"></i></div>
            <div class="wa-kpi-text">
                <div class="wa-kpi-label">@(isRtl ? "الفجوة الإجمالية" : "Total FTE Gap")</div>
                <div class="wa-kpi-value">@gapPrefix@totalGap.ToString("N1")</div>
                <div class="wa-kpi-sub">@gapMeaning</div>
            </div>
        </div>
        <div class="wa-kpi">
            <div class="wa-kpi-icon" style="background:#f5f3ff;color:#6d28d9;"><i data-lucide="gauge" class="w-4 h-4"></i></div>
            <div class="wa-kpi-text">
                <div class="wa-kpi-label">@(isRtl ? "الاستخدام المستهدف" : "Target Utilization")</div>
                <div class="wa-kpi-value">@((defaultUtil * 100m).ToString("N0"))<span style="font-size: var(--fs-xs);font-weight:600;color:#6b7280;margin-inline-start:.15rem;">%</span></div>
                <div class="wa-kpi-sub">@(isRtl ? "من الوقت المتاح" : "of available time")</div>
            </div>
        </div>
    </div>

    @* 2-up: chart on left, status-mix donut + workflow shortcuts on right. *@
    <div style="display:grid;grid-template-columns:1.6fr 1fr;gap:.6rem;">
        <div class="wa-card">
            <div class="wa-card-head">
                <div class="wa-card-title"><i data-lucide="bar-chart-3" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "FTE المطلوب مقابل العدد الحالي" : "FTE Required vs Current Headcount")</div>
                <a asp-action="Index" class="wa-btn wa-btn-ghost wa-btn-sm">@(isRtl ? "كل السيناريوهات" : "All scenarios") <i data-lucide="@(isRtl ? "arrow-left" : "arrow-right")" class="w-3 h-3"></i></a>
            </div>
            <div class="wa-card-body">
                @if (chartLabels.Any())
                {
                    <div class="wa-chart-wrap wa-chart-md"><canvas id="wdFteChart"></canvas></div>
                }
                else
                {
                    <div class="wa-empty">
                        <div class="wa-empty-icon"><i data-lucide="bar-chart-3" class="w-10 h-10"></i></div>
                        <div class="wa-empty-title">@(isRtl ? "لا توجد سيناريوهات معتمدة" : "No approved scenarios yet")</div>
                        <div class="wa-empty-msg">@(isRtl ? "اعتمد سيناريوهاً واحداً على الأقل لرؤية الفجوة هنا." : "Approve at least one scenario to see the gap here.")</div>
                    </div>
                }
            </div>
        </div>
        <div class="wa-card">
            <div class="wa-card-head">
                <div class="wa-card-title"><i data-lucide="pie-chart" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "توزيع الحالات" : "Status Mix")</div>
                <span class="wa-card-count">@totalScenarios</span>
            </div>
            <div class="wa-card-body">
                @if (totalScenarios > 0)
                {
                    <div class="wa-chart-wrap wa-chart-md"><canvas id="wdStatusChart"></canvas></div>
                }
                else
                {
                    <div class="wa-empty">
                        <div class="wa-empty-icon"><i data-lucide="pie-chart" class="w-10 h-10"></i></div>
                        <div class="wa-empty-title">@(isRtl ? "لا توجد بيانات" : "No data yet")</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Activity timeline — recent scenarios with status, FTE, gap, view link. Sticky thead. *@
    <div class="wa-card">
        <div class="wa-card-head">
            <div class="wa-card-title">
                <i data-lucide="clock" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "النشاط الأخير" : "Recent Activity")
                @* F-OP-006: "showing N of M" when the dashboard list is truncated.
                   The controller passes up to 10; totalScenarios reflects the full set. *@
                @if (totalScenarios > list.Count)
                {
                    <span class="wa-card-count" title="@(isRtl ? "اعرض الكل لمشاهدة الباقي" : "Use View all to see the rest")">@(isRtl ? $"يعرض {list.Count} من {totalScenarios}" : $"showing {list.Count} of {totalScenarios}")</span>
                }
                else
                {
                    <span class="wa-card-count">@list.Count</span>
                }
            </div>
            <a asp-action="Index" class="wa-btn wa-btn-ghost wa-btn-sm">@(isRtl ? "عرض الكل" : "View all") <i data-lucide="@(isRtl ? "arrow-left" : "arrow-right")" class="w-3 h-3"></i></a>
        </div>
        <div class="wa-card-body" style="padding:0;">
            @if (list.Any())
            {
                <div class="wa-table-wrap" style="max-height:320px;">
                    <table class="wa-table">
                        <thead>
                            <tr>
                                <th>@(isRtl ? "الرمز" : "Code")</th>
                                <th>@(isRtl ? "الاسم" : "Name")</th>
                                <th>@(isRtl ? "الوحدة" : "Unit")</th>
                                <th>@(isRtl ? "السنة" : "Year")</th>
                                <th class="wa-num">FTE</th>
                                <th class="wa-num">@(isRtl ? "الفجوة" : "Gap")</th>
                                <th>@(isRtl ? "الحالة" : "Status")</th>
                                <th style="text-align:end;width:60px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in list)
                            {
                                var gapPositive = s.FTEGap > 0;
                                var gapColor = gapPositive ? "#b91c1c" : (s.FTEGap < 0 ? "#15803d" : "#6b7280");
                                <tr class="@(gapPositive ? "wa-row-warm" : "")">
                                    <td><a asp-action="Details" asp-route-id="@s.Id" style="color:#005B99;font-weight:600;text-decoration:none;font-family:ui-monospace,monospace;letter-spacing:.04em;">@s.Code</a></td>
                                    <td style="font-weight:600;color:#111827;">@s.Name</td>
                                    <td style="color:#6b7280;">@(s.OwningUnit?.Name ?? "—")</td>
                                    <td style="color:#6b7280;">@s.FiscalYear</td>
                                    <td class="wa-num wa-mono" style="font-weight:700;">@s.TotalFTE.ToString("N1")</td>
                                    <td class="wa-num wa-mono" style="font-weight:700;color:@gapColor;">@(gapPositive ? "+" : "")@s.FTEGap.ToString("N1")</td>
                                    <td><span class="wa-status-pill wa-status-@s.Status">@StatusLabel(s.Status, isRtl)</span></td>
                                    <td style="text-align:end;"><a asp-action="Details" asp-route-id="@s.Id" class="wa-btn wa-btn-ghost wa-btn-sm" style="padding:.2rem .4rem;" aria-label="@(isRtl ? "عرض" : "View")"><i data-lucide="eye" class="w-3.5 h-3.5" aria-hidden="true"></i></a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="wa-empty">
                    <div class="wa-empty-icon"><i data-lucide="users" class="w-10 h-10"></i></div>
                    <div class="wa-empty-title">@(isRtl ? "لا توجد سيناريوهات" : "No scenarios yet")</div>
                    <div class="wa-empty-msg">@(isRtl ? "أنشئ سيناريو لبدء تحليل أعباء العمل." : "Create a scenario to start analyzing workload.")</div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();
        const isRtl = @(isRtl ? "true" : "false");
        if (isRtl) { Chart.defaults.plugins.legend.rtl = true; Chart.defaults.plugins.legend.textDirection = 'rtl'; }

        const fteCanvas = document.getElementById('wdFteChart');
        if (fteCanvas) {
            new Chart(fteCanvas, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartLabels)),
                    datasets: [
                        { label: '@(isRtl ? "FTE مطلوب" : "FTE Required")', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartFTE)), backgroundColor: 'rgba(0,91,153,.85)', borderRadius: 6 },
                        { label: '@(isRtl ? "العدد الحالي" : "Current Headcount")', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartHeadcount)), backgroundColor: 'rgba(52,195,143,.85)', borderRadius: 6 }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom', labels: { padding: 12, usePointStyle: true, font: { size: 11 } } }, tooltip: { backgroundColor: 'rgba(0,0,0,.85)', padding: 10 } },
                    scales: { x: { grid: { display: false }, reverse: isRtl, position: isRtl ? 'top' : 'bottom', ticks: { font: { size: 10 } } }, y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,.05)' }, ticks: { font: { size: 10 } } } }
                }
            });
        }

        const statusCanvas = document.getElementById('wdStatusChart');
        if (statusCanvas) {
            new Chart(statusCanvas, {
                type: 'doughnut',
                data: {
                    labels: [
                        '@(isRtl ? "مسودة" : "Draft")',
                        '@(isRtl ? "قيد المراجعة" : "Review")',
                        '@(isRtl ? "معتمد" : "Approved")',
                        '@(isRtl ? "مؤرشف" : "Archived")'
                    ],
                    datasets: [{
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(statusMix)),
                        backgroundColor: ['#cbd5e1', '#fbbf24', '#34d399', '#94a3b8'],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    cutout: '62%',
                    plugins: { legend: { position: 'bottom', labels: { padding: 10, usePointStyle: true, font: { size: 11 } } } }
                }
            });
        }
    </script>
}
