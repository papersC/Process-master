@model IEnumerable<ESEMS.Web.Models.Improvement.KpiDefinition>
@{
    ViewData["Title"] = "KPI Library";
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    var externalMode      = ViewBag.ExternalMode as bool? ?? false;
    var externalProvider  = ViewBag.ExternalProviderName as string;
    var externalIndexUrl  = ViewBag.ExternalIndexUrl as string;
    var externalCreateUrl = ViewBag.ExternalCreateUrl as string;
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.85rem;">
    <div>
        <h1 style="font-size: var(--fs-lg);font-weight:600;color:#111827;margin:0;display:flex;align-items:center;gap:.5rem;">
            <i data-lucide="library" style="width:20px;height:20px;color:#005B99;"></i>
            @(isRtl ? "مكتبة المؤشرات (KPI)" : "KPI Library")
        </h1>
        <p style="margin:.2rem 0 0;font-size: var(--fs-xs);color:#6b7280;">
            @(isRtl
                ? "كتالوج مركزي للمؤشرات. تستخدمه نماذج المقاييس لاختيار اسم مؤشر موحد بدلاً من كتابته يدوياً."
                : "Canonical metric catalog. Measurement forms pick from this list to avoid free-text drift across initiatives.")
        </p>
    </div>
    @if (externalMode)
    {
        @* Read-only mode: external performance system owns KPIs. Open-out button replaces Add. *@
        @if (!string.IsNullOrEmpty(externalCreateUrl))
        {
            <a href="@externalCreateUrl" target="_blank" rel="noopener" class="btn" style="background:#fff;border:1px solid #cbd5e1;color:#005B99;padding:.42rem .85rem;border-radius:.375rem;font-size: var(--fs-xs);font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.4rem;">
                <i data-lucide="external-link" style="width:14px;height:14px;"></i>
                @(isRtl ? $"إضافة في {externalProvider}" : $"Add in {externalProvider}")
            </a>
        }
    }
    else
    {
        <a asp-action="Create" class="btn btn-primary" style="background:#005B99;border:none;color:#fff;padding:.42rem .85rem;border-radius:.375rem;font-size: var(--fs-xs);font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.4rem;">
            <i data-lucide="plus" style="width:14px;height:14px;"></i>
            @(isRtl ? "إضافة مؤشر" : "Add KPI")
        </a>
    }
</div>

@if (externalMode)
{
    <div style="padding:.65rem .85rem;background:#eff6ff;border:1px solid #bfdbfe;color:#1e3a8a;border-radius:.375rem;margin-bottom:.6rem;font-size: var(--fs-xs);display:flex;align-items:center;gap:.5rem;">
        <i data-lucide="info" style="width:16px;height:16px;flex-shrink:0;"></i>
        <span style="flex:1;">
            @(isRtl
                ? $"تتم إدارة المؤشرات في النظام الخارجي ({externalProvider}). الإضافة والتعديل والإيقاف معطلة هنا. السجلات أدناه للعرض فقط (آخر حالة محلية)."
                : $"KPIs are managed in the external system ({externalProvider}). Add / Edit / Retire are disabled here. The rows below show the last-known local state, read-only.")
        </span>
        @if (!string.IsNullOrEmpty(externalIndexUrl))
        {
            <a href="@externalIndexUrl" target="_blank" rel="noopener" style="color:#1e3a8a;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:.3rem;flex-shrink:0;">
                @(isRtl ? "افتح النظام" : "Open system")
                <i data-lucide="external-link" style="width:13px;height:13px;"></i>
            </a>
        }
    </div>
}

@if (TempData["Success"] is string success)
{
    <div style="padding:.6rem .8rem;background:#ecfdf5;border:1px solid #a7f3d0;color:#065f46;border-radius:.375rem;margin-bottom:.6rem;font-size: var(--fs-xs);">@success</div>
}
@if (TempData["Info"] is string info)
{
    <div style="padding:.6rem .8rem;background:#eff6ff;border:1px solid #bfdbfe;color:#1e3a8a;border-radius:.375rem;margin-bottom:.6rem;font-size: var(--fs-xs);">@info</div>
}

<div style="background:#fff;border:1px solid #e5e7eb;border-radius:.5rem;overflow:hidden;">
    <table style="width:100%;border-collapse:collapse;font-size: var(--fs-xs);">
        <thead>
            <tr style="background:#f9fafb;border-bottom:1px solid #e5e7eb;">
                <th style="text-align:start;padding:.55rem .75rem;color:#374151;font-weight:600;">@(isRtl ? "الكود" : "Code")</th>
                <th style="text-align:start;padding:.55rem .75rem;color:#374151;font-weight:600;">@(isRtl ? "الاسم" : "Name")</th>
                <th style="text-align:start;padding:.55rem .75rem;color:#374151;font-weight:600;">@(isRtl ? "الوحدة" : "Unit")</th>
                <th style="text-align:start;padding:.55rem .75rem;color:#374151;font-weight:600;">@(isRtl ? "النوع" : "Type")</th>
                <th style="text-align:start;padding:.55rem .75rem;color:#374151;font-weight:600;">@(isRtl ? "الاتجاه" : "Direction")</th>
                <th style="text-align:start;padding:.55rem .75rem;color:#374151;font-weight:600;">@(isRtl ? "الحالة" : "Status")</th>
                <th style="text-align:end;padding:.55rem .75rem;color:#374151;font-weight:600;">@(isRtl ? "إجراءات" : "Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="7" style="text-align:center;padding:1.25rem;color:#9ca3af;font-size: var(--fs-xs);">
                    @(isRtl ? "الكتالوج فارغ. أضف مؤشراً لتبدأ." : "Catalog is empty. Add a KPI to get started.")
                </td></tr>
            }
            else
            {
                @foreach (var k in Model)
                {
                    <tr style="border-bottom:1px solid #f1f5f9;@(k.IsActive ? "" : "opacity:.6;")">
                        <td style="padding:.5rem .75rem;font-family:monospace;font-weight:600;color:#005B99;">@k.Code</td>
                        <td style="padding:.5rem .75rem;color:#111827;">@(isRtl ? k.NameAr : k.NameEn)</td>
                        <td style="padding:.5rem .75rem;color:#374151;">@k.UnitOfMeasure</td>
                        <td style="padding:.5rem .75rem;color:#374151;">@k.DefaultType</td>
                        <td style="padding:.5rem .75rem;color:#374151;">@k.Direction</td>
                        <td style="padding:.5rem .75rem;">
                            @if (k.IsActive)
                            {
                                <span style="display:inline-block;padding:.1rem .4rem;background:#dcfce7;color:#166534;border-radius:.25rem;font-size: var(--fs-xs);font-weight:700;">@(isRtl ? "نشط" : "Active")</span>
                            }
                            else
                            {
                                <span style="display:inline-block;padding:.1rem .4rem;background:#f3f4f6;color:#6b7280;border-radius:.25rem;font-size: var(--fs-xs);font-weight:700;">@(isRtl ? "متقاعد" : "Retired")</span>
                            }
                        </td>
                        <td style="padding:.5rem .75rem;text-align:end;">
                            @if (externalMode)
                            {
                                <span style="color:#9ca3af;font-size: var(--fs-xs);font-style:italic;">@(isRtl ? "للعرض فقط" : "Read-only")</span>
                            }
                            else
                            {
                                <a asp-action="Edit" asp-route-id="@k.Id" style="color:#005B99;text-decoration:none;font-weight:600;margin-inline-end:.5rem;">
                                    @(isRtl ? "تعديل" : "Edit")
                                </a>
                                if (k.IsActive)
                                {
                                    <form asp-action="Retire" asp-route-id="@k.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" style="background:none;border:none;color:#6b7280;cursor:pointer;font-weight:600;font-size: var(--fs-xs);padding:0;">@(isRtl ? "تقاعد" : "Retire")</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Restore" asp-route-id="@k.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" style="background:none;border:none;color:#005B99;cursor:pointer;font-weight:600;font-size: var(--fs-xs);padding:0;">@(isRtl ? "استعادة" : "Restore")</button>
                                    </form>
                                }
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script nonce="@Context.CspNonce()">if (window.lucide) lucide.createIcons();</script>
}
