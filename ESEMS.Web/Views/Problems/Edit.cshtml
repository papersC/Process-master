@model Problem
@{
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    var titleEditProblem = isRtl ? "تعديل المشكلة" : "Edit Problem";
    ViewData["Title"] = titleEditProblem;
}

@*  Two-column form mirroring Processes/Edit and Services/Edit (.pc-*):
    - Left: Identity / Classification / Linking / Analysis cards stacked
    - Right: sticky sidebar with read-only Problem Number, live status +
      priority pills, Known Error toggle pill, and Save/Cancel actions.
    Controller Edit POST signature unchanged: Edit(string id, Problem problem). *@

<style>
    .pc-shell { display: grid; grid-template-columns: minmax(0,1fr) 320px; gap: .75rem; align-items: start; }
    @@media (max-width: 992px) { .pc-shell { grid-template-columns: 1fr; } }
    .pc-header { display: flex; align-items: center; justify-content: space-between; padding: .25rem 0 .4rem; border-bottom: 1px solid #e5e7eb; margin-bottom: .6rem; }
    .pc-header h1 { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .5rem; }
    .pc-header p { margin: 0; font-size: var(--fs-xs); color: #6b7280; }
    .pc-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; border: none; }
    .pc-btn-primary { background: #005B99; color: #fff; } .pc-btn-primary:hover { background: #003d6b; color: #fff; }
    .pc-btn-outline { background: #fff; color: #005B99; border: 1px solid #cbd5e1; } .pc-btn-outline:hover { background: #f1f5f9; }
    .pc-btn-ghost { background: transparent; color: #374151; border: 1px solid #d1d5db; } .pc-btn-ghost:hover { background: #f9fafb; }
    .pc-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .9rem 1rem; margin-bottom: .6rem; }
    .pc-card-h { display: flex; align-items: center; gap: .5rem; padding-bottom: .55rem; margin-bottom: .75rem; border-bottom: 1px solid #f1f5f9; }
    .pc-card-h h2 { margin: 0; font-size: var(--fs-sm); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .45rem; }
    .pc-card-h .pc-card-sub { font-size: var(--fs-xs); color: #6b7280; margin-inline-start: auto; }
    .pc-label { display: block; font-size: var(--fs-xs); font-weight: 600; color: #374151; margin-bottom: .25rem; }
    .pc-label .req { color: #dc2626; }
    .pc-input, .pc-select, .pc-textarea { width: 100%; padding: .42rem .65rem; border: 1px solid #d1d5db; border-radius: .375rem; font-size: var(--fs-sm); background: #fff; color: #111827; }
    .pc-input:focus, .pc-select:focus, .pc-textarea:focus { outline: none; border-color: #005B99; box-shadow: 0 0 0 3px rgba(0,91,153,.12); }
    .pc-input[readonly] { background: #f1f5f9; color: #64748b; cursor: not-allowed; }
    .pc-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: .65rem; }
    .pc-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: .65rem; }
    .pc-grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: .65rem; }
    @@media (max-width: 768px) { .pc-grid-2, .pc-grid-3, .pc-grid-4 { grid-template-columns: 1fr; } }
    .pc-row { margin-bottom: .65rem; }
    .pc-help { font-size: var(--fs-xs); color: #6b7280; margin-top: .2rem; }
    .pc-err { font-size: var(--fs-xs); color: #dc2626; margin-top: .2rem; display: block; }
    .pc-side { position: sticky; top: 1rem; display: flex; flex-direction: column; gap: .55rem; }
    .pc-summary-row { display: flex; align-items: center; justify-content: space-between; padding: .35rem 0; font-size: var(--fs-xs); color: #374151; border-bottom: 1px dashed #f1f5f9; gap: .5rem; }
    .pc-summary-row:last-child { border-bottom: none; }
    .pc-pill { display: inline-block; padding: .12rem .55rem; font-size: var(--fs-xs); font-weight: 700; border-radius: .25rem; background: #eff6ff; color: #1d4ed8; min-width: 1.5rem; text-align: center; }
    .pc-pill-info     { background: #dbeafe; color: #1e40af; }
    .pc-pill-primary  { background: #ddd6fe; color: #6d28d9; }
    .pc-pill-warning  { background: #fef3c7; color: #92400e; }
    .pc-pill-success  { background: #dcfce7; color: #166534; }
    .pc-pill-danger   { background: #fee2e2; color: #991b1b; }
    .pc-pill-secondary{ background: #f1f5f9; color: #475569; }
    .pc-pill-on { background: #d1fae5; color: #065f46; }
    .pc-pill-off { background: #f1f5f9; color: #6b7280; }
    .pc-side-actions { display: flex; flex-direction: column; gap: .35rem; padding-top: .25rem; }
    .pc-side-actions .pc-btn { justify-content: center; padding: .55rem .85rem; }
    .pc-checkbox-row { display: inline-flex; align-items: center; gap: .45rem; cursor: pointer; }
    .pc-checkbox-row input { width: 1rem; height: 1rem; accent-color: #005B99; }
</style>

<div class="pc-header">
    <div>
        <h1><i data-lucide="edit" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>@titleEditProblem</h1>
        <p>@Model.ProblemNumber — @(isRtl ? Model.NameAr : Model.NameEn)</p>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="pc-btn pc-btn-outline">
        <i data-lucide="@(isRtl ? "arrow-right" : "arrow-left")" class="w-4 h-4" aria-hidden="true"></i>@(isRtl ? "رجوع" : "Back")
    </a>
</div>

<form asp-action="Edit" method="post" id="editForm" data-guard-unsaved>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ProblemNumber" />
    <input type="hidden" asp-for="IdentifiedAt" />
    <input type="hidden" asp-for="CreatedAt" />
    <input type="hidden" asp-for="CreatedById" />
    <input type="hidden" asp-for="UpdatedAt" />
    <input type="hidden" asp-for="UpdatedById" />
    <input type="hidden" asp-for="Version" />

    <div asp-validation-summary="ModelOnly" style="margin-bottom:.6rem;padding:.6rem .8rem;background:#fef2f2;border:1px solid #fecaca;border-radius:.375rem;color:#b91c1c;font-size: var(--fs-xs);"></div>

    <div class="pc-shell">
        <!-- ============ MAIN COLUMN ============ -->
        <div>
            <!-- Identity -->
            <div class="pc-card">
                <div class="pc-card-h">
                    <h2><i data-lucide="file-text" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "الهوية" : "Identity")</h2>
                    <span class="pc-card-sub">@(isRtl ? "الاسم والوصف والتصنيف" : "Name, description, classification")</span>
                </div>

                <div class="pc-grid-3 pc-row">
                    <div>
                        <label class="pc-label">@Shared["Label_ProblemNumber"]</label>
                        <input value="@Model.ProblemNumber" class="pc-input" readonly />
                        <div class="pc-help">@(isRtl ? "غير قابل للتعديل" : "Not editable")</div>
                    </div>
                    <div>
                        <label asp-for="Status" class="pc-label">@Shared["Label_Status"] <span class="req">*</span></label>
                        <select asp-for="Status" id="StatusSel"
                                asp-items="@(new SelectList(Enum.GetValues<ProblemStatus>().Select(v => new { Value = v.ToString(), Display = Shared[$"ProblemStatus_{v}"].Value }), "Value", "Display"))"
                                class="pc-select"></select>
                        <span asp-validation-for="Status" class="pc-err"></span>
                    </div>
                    <div>
                        <label asp-for="Category" class="pc-label">@Shared["Label_Category"] <span class="req">*</span></label>
                        <select asp-for="Category" id="CategorySel" class="pc-select">
                            <option value="Hardware">@Shared["Category_Hardware"]</option>
                            <option value="Software">@Shared["Category_Software"]</option>
                            <option value="Network">@Shared["Category_Network"]</option>
                            <option value="Security">@Shared["Category_Security"]</option>
                            <option value="Process">@Shared["Category_Process"]</option>
                            <option value="Other">@Shared["Category_Other"]</option>
                        </select>
                        <span asp-validation-for="Category" class="pc-err"></span>
                    </div>
                </div>

                <div class="pc-grid-2 pc-row">
                    <div>
                        <label asp-for="NameEn" class="pc-label">@Shared["Label_TitleEnglish"] <span class="req">*</span></label>
                        <input asp-for="NameEn" class="pc-input" />
                        <span asp-validation-for="NameEn" class="pc-err"></span>
                    </div>
                    <div>
                        <label asp-for="NameAr" class="pc-label">@Shared["Label_TitleArabic"]</label>
                        <input asp-for="NameAr" dir="rtl" class="pc-input" />
                        <span asp-validation-for="NameAr" class="pc-err"></span>
                    </div>
                </div>

                <div class="pc-grid-2 pc-row">
                    <div>
                        <label asp-for="DescriptionEn" class="pc-label">@Shared["Label_DescriptionEnglish"] <span class="req">*</span></label>
                        <textarea asp-for="DescriptionEn" rows="3" class="pc-textarea"></textarea>
                        <span asp-validation-for="DescriptionEn" class="pc-err"></span>
                    </div>
                    <div>
                        <label asp-for="DescriptionAr" class="pc-label">@(isRtl ? "الوصف بالعربية" : "Description (Arabic)")</label>
                        <textarea asp-for="DescriptionAr" dir="rtl" rows="3" class="pc-textarea"></textarea>
                    </div>
                </div>

                <label class="pc-checkbox-row">
                    <input asp-for="IsKnownError" id="KnownErrorChk" />
                    <span style="font-size: var(--fs-xs);color:#374151;">@Shared["Label_MarkAsKnownError"]</span>
                </label>
            </div>

            <!-- Classification -->
            <div class="pc-card">
                <div class="pc-card-h">
                    <h2><i data-lucide="alert-triangle" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "التصنيف" : "Classification")</h2>
                    <span class="pc-card-sub">@(isRtl ? "الأولوية والتأثير والتكلفة" : "Priority, impact, cost")</span>
                </div>

                <div class="pc-grid-3">
                    <div>
                        <label asp-for="Priority" class="pc-label">@Shared["Label_Priority"] <span class="req">*</span></label>
                        <select asp-for="Priority" id="PrioritySel" class="pc-select">
                            <option value="1">@Shared["Priority_Critical"]</option>
                            <option value="2">@Shared["Priority_High"]</option>
                            <option value="3">@Shared["Priority_Medium"]</option>
                            <option value="4">@Shared["Priority_Low"]</option>
                        </select>
                        <span asp-validation-for="Priority" class="pc-err"></span>
                    </div>
                    <div>
                        <label asp-for="Impact" class="pc-label">@Shared["Label_Impact"] <span class="req">*</span></label>
                        <select asp-for="Impact" class="pc-select">
                            <option value="1">@Shared["Impact_Critical"]</option>
                            <option value="2">@Shared["Impact_High"]</option>
                            <option value="3">@Shared["Impact_Medium"]</option>
                            <option value="4">@Shared["Impact_Low"]</option>
                        </select>
                        <span asp-validation-for="Impact" class="pc-err"></span>
                    </div>
                    <div>
                        <label asp-for="EstimatedCostImpact" class="pc-label">@(isRtl ? "أثر التكلفة" : "Cost Impact") (AED)</label>
                        <input asp-for="EstimatedCostImpact" type="number" step="0.01" class="pc-input" />
                    </div>
                </div>
            </div>

            <!-- Linking -->
            <div class="pc-card">
                <div class="pc-card-h">
                    <h2><i data-lucide="link" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@Shared["Label_RelatedItems"]</h2>
                    <span class="pc-card-sub">@(isRtl ? "الخدمة، العملية، الأصل، الجهة المعيّنة" : "Service, process, asset, assignee")</span>
                </div>

                <div class="pc-grid-2 pc-row">
                    <div>
                        <label asp-for="ServiceId" class="pc-label">@Shared["Label_AffectedService"]</label>
                        <select asp-for="ServiceId" asp-items="@ViewBag.Services" class="pc-select">
                            <option value="">@Shared["Placeholder_SelectService"]</option>
                        </select>
                    </div>
                    <div>
                        <label asp-for="ProcessId" class="pc-label">@Shared["Label_RelatedProcess"]</label>
                        <select asp-for="ProcessId" asp-items="@ViewBag.Processes" class="pc-select">
                            <option value="">@Shared["Placeholder_SelectProcess"]</option>
                        </select>
                    </div>
                </div>

                <div class="pc-grid-2">
                    <div>
                        <label asp-for="AssetId" class="pc-label">@Shared["Label_AffectedAsset"]</label>
                        <select asp-for="AssetId" asp-items="@ViewBag.Assets" class="pc-select">
                            <option value="">@Shared["Placeholder_SelectAsset"]</option>
                        </select>
                    </div>
                    <div>
                        <label asp-for="AssignedToUnitId" class="pc-label">@Shared["Label_AssignTo"]</label>
                        <select asp-for="AssignedToUnitId" asp-items="@ViewBag.OrganizationUnits" class="pc-select">
                            <option value="">@Shared["Placeholder_SelectUnit"]</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Analysis & Solutions -->
            <div class="pc-card">
                <div class="pc-card-h">
                    <h2><i data-lucide="microscope" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "التحليل والحلول" : "Analysis & Solutions")</h2>
                    <span class="pc-card-sub">@(isRtl ? "السبب الجذري، الحل المؤقت، الحل الدائم" : "Root cause, workaround, permanent solution")</span>
                </div>

                <div class="pc-row">
                    <label asp-for="RootCauseAnalysis" class="pc-label">
                        <i data-lucide="microscope" class="w-3.5 h-3.5 inline-block" style="color:#005B99;" aria-hidden="true"></i>
                        @Shared["Label_RootCauseAnalysis"]
                    </label>
                    <textarea asp-for="RootCauseAnalysis" rows="4" class="pc-textarea"></textarea>
                </div>

                <div class="pc-row">
                    <label asp-for="Workaround" class="pc-label">
                        <i data-lucide="wrench" class="w-3.5 h-3.5 inline-block" style="color:#005B99;" aria-hidden="true"></i>
                        @Shared["Label_Workaround"]
                    </label>
                    <textarea asp-for="Workaround" rows="3" class="pc-textarea"></textarea>
                    <div class="pc-help">@(isRtl ? "حل مؤقت يُستخدم لتقليل أثر المشكلة قبل الحل الدائم" : "Temporary workaround used to mitigate the problem before the permanent fix")</div>
                </div>

                <div>
                    <label asp-for="PermanentSolution" class="pc-label">
                        <i data-lucide="check-circle-2" class="w-3.5 h-3.5 inline-block" style="color:#005B99;" aria-hidden="true"></i>
                        @Shared["Label_PermanentSolution"]
                    </label>
                    <textarea asp-for="PermanentSolution" rows="3" class="pc-textarea"></textarea>
                </div>
            </div>
        </div>

        <!-- ============ STICKY SIDEBAR ============ -->
        <aside class="pc-side">
            <div class="pc-card" style="margin-bottom:0;">
                <div class="pc-card-h">
                    <h2><i data-lucide="hash" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@Shared["Label_ProblemNumber"]</h2>
                </div>
                <div style="font-family:monospace;font-size: var(--fs-sm);font-weight:700;color:#005B99;background:#eff6ff;padding:.4rem .6rem;border-radius:.25rem;text-align:center;letter-spacing:.05em;">
                    @Model.ProblemNumber
                </div>
                <div class="pc-help" style="margin-top:.4rem;">@(isRtl ? "يُولَّد تلقائيًا — غير قابل للتعديل" : "Auto-generated — not editable")</div>
            </div>

            <div class="pc-card" style="margin-bottom:0;">
                <div class="pc-card-h">
                    <h2><i data-lucide="info" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "ملخص" : "Summary")</h2>
                </div>
                <div class="pc-summary-row">
                    <span><i data-lucide="circle" class="w-3.5 h-3.5 inline-block" style="color:#6b7280;" aria-hidden="true"></i> @Shared["Label_Status"]</span>
                    <span class="pc-pill" id="sumStatus">—</span>
                </div>
                <div class="pc-summary-row">
                    <span><i data-lucide="alert-triangle" class="w-3.5 h-3.5 inline-block" style="color:#6b7280;" aria-hidden="true"></i> @Shared["Label_Priority"]</span>
                    <span class="pc-pill" id="sumPriority">—</span>
                </div>
                <div class="pc-summary-row">
                    <span><i data-lucide="folder" class="w-3.5 h-3.5 inline-block" style="color:#6b7280;" aria-hidden="true"></i> @Shared["Label_Category"]</span>
                    <span class="pc-pill" id="sumCategory">—</span>
                </div>
                <div class="pc-summary-row">
                    <span><i data-lucide="alert-octagon" class="w-3.5 h-3.5 inline-block" style="color:#6b7280;" aria-hidden="true"></i> @(isRtl ? "خطأ معروف" : "Known Error")</span>
                    <span class="pc-pill pc-pill-off" id="sumKnown">@(isRtl ? "لا" : "No")</span>
                </div>
            </div>

            <div class="pc-side-actions">
                <button type="submit" class="pc-btn pc-btn-primary">
                    <i data-lucide="save" class="w-4 h-4" aria-hidden="true"></i>@Shared["Button_SaveChanges"]
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="pc-btn pc-btn-ghost">
                    <i data-lucide="x" class="w-4 h-4" aria-hidden="true"></i>@Shared["Button_Cancel"]
                </a>
            </div>
        </aside>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();
        const isRtl = @Html.Raw(isRtl ? "true" : "false");

        const statusSel   = document.getElementById('StatusSel');
        const prioritySel = document.getElementById('PrioritySel');
        const categorySel = document.getElementById('CategorySel');
        const knownChk    = document.getElementById('KnownErrorChk');

        // Map priority value → sidebar pill class for at-a-glance criticality.
        const priorityClass = (v) => v === '1' ? 'pc-pill-danger'
                                   : v === '2' ? 'pc-pill-warning'
                                   : v === '3' ? 'pc-pill-info'
                                   : 'pc-pill-secondary';

        // Map status (enum value) → pill class.
        const statusClass = (v) => v === 'Resolved' ? 'pc-pill-success'
                                 : v === 'RootCauseIdentified' ? 'pc-pill-warning'
                                 : v === 'InvestigationInProgress' ? 'pc-pill-primary'
                                 : v === 'New' ? 'pc-pill-info'
                                 : 'pc-pill-secondary';

        function refreshSidebar() {
            const setPill = (id, text, cls) => {
                const el = document.getElementById(id);
                if (!el) return;
                el.textContent = text || '—';
                el.className = 'pc-pill ' + cls;
            };

            const sText = statusSel?.options[statusSel.selectedIndex]?.text?.trim() || '—';
            setPill('sumStatus', sText, statusClass(statusSel?.value || ''));

            const pText = prioritySel?.options[prioritySel.selectedIndex]?.text?.trim() || '—';
            setPill('sumPriority', pText, priorityClass(prioritySel?.value || ''));

            const cText = categorySel?.options[categorySel.selectedIndex]?.text?.trim() || '—';
            setPill('sumCategory', cText, 'pc-pill');

            const known = !!(knownChk?.checked);
            const ke = document.getElementById('sumKnown');
            if (ke) {
                ke.textContent = known ? (isRtl ? 'نعم' : 'Yes') : (isRtl ? 'لا' : 'No');
                ke.className = 'pc-pill ' + (known ? 'pc-pill-warning' : 'pc-pill-off');
            }
        }
        statusSel?.addEventListener('change',  refreshSidebar);
        prioritySel?.addEventListener('change', refreshSidebar);
        categorySel?.addEventListener('change', refreshSidebar);
        knownChk?.addEventListener('change',    refreshSidebar);
        refreshSidebar();
    </script>
}
