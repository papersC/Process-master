@model Category
@{
    ViewData["Title"] = Shared["Action_AddCategory"].Value;
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

@*  Two-column form: left = Identity card (Names EN/AR, Descriptions EN/AR);
    right = sticky sidebar with APQC code preview, helper tip card, and
    Save/Cancel action bar. Same .pc-* design system as Processes/Create.
    Code is auto-assigned by CategoriesController.Create — no form field for
    it. Owning Unit removed: ownership belongs at L3 (Process), not L1
    (Category). *@

<style>
    .pc-shell { display: grid; grid-template-columns: minmax(0,1fr) 320px; gap: .75rem; align-items: start; }
    @@media (max-width: 992px) { .pc-shell { grid-template-columns: 1fr; } }
    .pc-header { display: flex; align-items: center; justify-content: space-between; padding: .25rem 0 .4rem; border-bottom: 1px solid #e5e7eb; margin-bottom: .6rem; }
    .pc-header h1 { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .5rem; }
    .pc-header p { margin: 0; font-size: var(--fs-xs); color: #6b7280; }
    .pc-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; border: none; }
    .pc-btn-primary { background: #005B99; color: #fff; } .pc-btn-primary:hover { background: #003d6b; color: #fff; }
    .pc-btn-outline { background: #fff; color: #005B99; border: 1px solid #cbd5e1; } .pc-btn-outline:hover { background: #f1f5f9; }
    .pc-btn-ghost { background: transparent; color: #374151; border: 1px solid #d1d5db; } .pc-btn-ghost:hover { background: #f9fafb; }
    .pc-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .9rem 1rem; margin-bottom: .6rem; }
    .pc-card-h { display: flex; align-items: center; gap: .5rem; padding-bottom: .55rem; margin-bottom: .75rem; border-bottom: 1px solid #f1f5f9; }
    .pc-card-h h2 { margin: 0; font-size: var(--fs-sm); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .45rem; }
    .pc-card-h .pc-card-sub { font-size: var(--fs-xs); color: #6b7280; margin-inline-start: auto; }
    .pc-label { display: block; font-size: var(--fs-xs); font-weight: 600; color: #374151; margin-bottom: .25rem; }
    .pc-label .req { color: #dc2626; }
    .pc-input, .pc-select, .pc-textarea { width: 100%; padding: .42rem .65rem; border: 1px solid #d1d5db; border-radius: .375rem; font-size: var(--fs-sm); background: #fff; color: #111827; }
    .pc-input:focus, .pc-select:focus, .pc-textarea:focus { outline: none; border-color: #005B99; box-shadow: 0 0 0 3px rgba(0,91,153,.12); }
    .pc-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: .65rem; }
    @@media (max-width: 768px) { .pc-grid-2 { grid-template-columns: 1fr; } }
    .pc-row { margin-bottom: .65rem; }
    .pc-help { font-size: var(--fs-xs); color: #6b7280; margin-top: .2rem; }
    .pc-err { font-size: var(--fs-xs); color: #dc2626; margin-top: .2rem; display: block; }
    .pc-side { position: sticky; top: 1rem; display: flex; flex-direction: column; gap: .55rem; }
    .pc-tip-row { display: flex; align-items: flex-start; gap: .45rem; padding: .35rem 0; font-size: var(--fs-xs); color: #374151; line-height: 1.4; }
    .pc-tip-row i { color: #005B99; flex-shrink: 0; margin-top: .12rem; }
    .pc-side-actions { display: flex; flex-direction: column; gap: .35rem; padding-top: .25rem; }
    .pc-side-actions .pc-btn { justify-content: center; padding: .55rem .85rem; }
</style>

<div class="pc-header">
    <div>
        <h1><i data-lucide="folder-plus" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>@ViewData["Title"]</h1>
        <p>@Shared["Text_CreateNewAPQCCategory"]</p>
    </div>
    <a asp-action="Index" class="pc-btn pc-btn-outline">
        <i data-lucide="@(isRtl ? "arrow-right" : "arrow-left")" class="w-4 h-4" aria-hidden="true"></i>@Shared["Action_Back"]
    </a>
</div>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" style="margin-bottom:.6rem;padding:.6rem .8rem;background:#fef2f2;border:1px solid #fecaca;border-radius:.375rem;color:#b91c1c;font-size: var(--fs-xs);"></div>

    <div class="pc-shell">
        <!-- ============ MAIN COLUMN ============ -->
        <div>
            <div class="pc-card">
                <div class="pc-card-h">
                    <h2><i data-lucide="layers" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@Shared["Label_CategoryDetails"]</h2>
                    <span class="pc-card-sub">@(isRtl ? "تفاصيل التصنيف الأساسية" : "Basic category information")</span>
                </div>

                <div class="pc-grid-2 pc-row">
                    <div>
                        <label asp-for="NameEn" class="pc-label">@Shared["Label_NameEn"] <span class="req">*</span></label>
                        <input asp-for="NameEn" class="pc-input" />
                        <span asp-validation-for="NameEn" class="pc-err"></span>
                    </div>
                    <div>
                        <label asp-for="NameAr" class="pc-label">@Shared["Label_NameAr"] <span class="req">*</span></label>
                        <input asp-for="NameAr" dir="rtl" class="pc-input" />
                        <span asp-validation-for="NameAr" class="pc-err"></span>
                    </div>
                </div>

                <div class="pc-grid-2">
                    <div>
                        <label asp-for="DescriptionEn" class="pc-label">@Shared["Label_DescriptionEn"]</label>
                        <textarea asp-for="DescriptionEn" rows="4" class="pc-textarea"></textarea>
                    </div>
                    <div>
                        <label asp-for="DescriptionAr" class="pc-label">@Shared["Label_DescriptionAr"]</label>
                        <textarea asp-for="DescriptionAr" dir="rtl" rows="4" class="pc-textarea"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- ============ STICKY SIDEBAR ============ -->
        <aside class="pc-side">
            <div class="pc-card" style="margin-bottom:0;">
                <div class="pc-card-h">
                    <h2><i data-lucide="hash" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "رمز التصنيف" : "Category Code")</h2>
                </div>
                <div style="font-size: var(--fs-xs);color:#6b7280;margin-bottom:.3rem;">@(isRtl ? "يُولد تلقائيًا عند الحفظ" : "Auto-generated on save")</div>
                <div style="font-family:monospace;font-size: var(--fs-sm);font-weight:700;color:#005B99;background:#eff6ff;padding:.4rem .6rem;border-radius:.25rem;text-align:center;letter-spacing:.05em;">
                    L1.&mdash;
                </div>
                <div class="pc-help" style="margin-top:.4rem;">@(isRtl ? "ستُسند الفئة الفرعية والترتيب تلقائيًا حسب التسلسل الهرمي APQC" : "APQC numbering and sort order are assigned by hierarchy")</div>
            </div>

            <div class="pc-card" style="margin-bottom:0;">
                <div class="pc-card-h">
                    <h2><i data-lucide="info" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "إرشادات" : "Guidance")</h2>
                </div>
                <div class="pc-tip-row">
                    <i data-lucide="folder-tree" class="w-3.5 h-3.5" aria-hidden="true"></i>
                    <span>@(isRtl ? "التصنيفات هي المستوى الأول من تسلسل APQC وتجمّع مجموعات العمليات." : "Categories are APQC Level 1 — they group ProcessGroups underneath.")</span>
                </div>
                <div class="pc-tip-row">
                    <i data-lucide="languages" class="w-3.5 h-3.5" aria-hidden="true"></i>
                    <span>@(isRtl ? "أدخل الاسم بالإنجليزية والعربية كلاهما — يظهر للمستخدمين حسب لغتهم." : "Both English and Arabic names are required — shown to users in their selected language.")</span>
                </div>
                <div class="pc-tip-row">
                    <i data-lucide="building-2" class="w-3.5 h-3.5" aria-hidden="true"></i>
                    <span>@(isRtl ? "الوحدة المالكة اختيارية وتُستخدم في الفلاتر وتقارير الملكية." : "Owning Unit is optional — used for ownership filters and reports.")</span>
                </div>
            </div>

            <div class="pc-side-actions">
                <button type="submit" class="pc-btn pc-btn-primary">
                    <i data-lucide="save" class="w-4 h-4" aria-hidden="true"></i>
                    @Shared["Button_Save"]
                </button>
                <a asp-action="Index" class="pc-btn pc-btn-ghost">
                    <i data-lucide="x" class="w-4 h-4" aria-hidden="true"></i>
                    @Shared["Button_Cancel"]
                </a>
            </div>
        </aside>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();
    </script>
}
