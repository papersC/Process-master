@model Category
@{
    ViewData["Title"] = Shared["Action_EditCategory"].Value;
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<!-- Page Header with Back Button -->
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">@ViewData["Title"]</h1>
        <p class="text-sm text-gray-500 mt-1">@(isRtl ? Model.NameAr : Model.NameEn)</p>
    </div>
    <a asp-action="Index" class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
        <i data-lucide="@(isRtl ? "arrow-right" : "arrow-left")" class="w-4 h-4"></i>
        @Shared["Action_Back"]
    </a>
</div>

<!-- Form Card -->
<div class="max-w-4xl">
    <div class="bg-white rounded-lg shadow-sm">
        <!-- Card Header -->
        <div class="border-b border-gray-200 px-6 py-4">
            <div class="flex items-center gap-2">
                <i data-lucide="edit" class="w-5 h-5 text-primary-500"></i>
                <h2 class="text-base font-semibold text-gray-900">@Shared["Label_CategoryDetails"]</h2>
            </div>
        </div>

        <!-- Card Body -->
        <div class="p-6">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="CreatedById" />
                <input type="hidden" asp-for="UpdatedAt" />
                <input type="hidden" asp-for="UpdatedById" />
                <input type="hidden" asp-for="Version" />
                <div asp-validation-summary="ModelOnly" class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"></div>

                @* Code is system-managed. We show it as a read-only badge for
                   reference and carry it through the form via hidden input;
                   the controller Patch step ignores posted values either way. *@
                <input type="hidden" asp-for="Code" />

                <!-- Row 1: Code (read-only) + Owning Unit -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">@Shared["Column_Code"]</label>
                        <div class="w-full px-3 py-2 border border-gray-200 bg-gray-50 text-gray-600 rounded-lg text-sm font-mono">@Model.Code</div>
                    </div>
                </div>

                <!-- Row 2: Names -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label asp-for="NameEn" class="block text-sm font-medium text-gray-700 mb-1">@Shared["Label_NameEn"] <span class="text-red-500">*</span></label>
                        <input asp-for="NameEn" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
                        <span asp-validation-for="NameEn" class="text-red-500 text-xs mt-1"></span>
                    </div>
                    <div>
                        <label asp-for="NameAr" class="block text-sm font-medium text-gray-700 mb-1">@Shared["Label_NameAr"] <span class="text-red-500">*</span></label>
                        <input asp-for="NameAr" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500" dir="rtl" />
                        <span asp-validation-for="NameAr" class="text-red-500 text-xs mt-1"></span>
                    </div>
                </div>

                <!-- Row 3: Descriptions -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                    <div>
                        <label asp-for="DescriptionEn" class="block text-sm font-medium text-gray-700 mb-1">@Shared["Label_DescriptionEn"]</label>
                        <textarea asp-for="DescriptionEn" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500"></textarea>
                    </div>
                    <div>
                        <label asp-for="DescriptionAr" class="block text-sm font-medium text-gray-700 mb-1">@Shared["Label_DescriptionAr"]</label>
                        <textarea asp-for="DescriptionAr" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 focus:border-primary-500" dir="rtl"></textarea>
                    </div>
                </div>

                <!-- Form Footer -->
                <div class="border-t border-gray-200 pt-4 flex items-center justify-between">
                    <a asp-action="Index" class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
                        <i data-lucide="x" class="w-4 h-4"></i>
                        @Shared["Button_Cancel"]
                    </a>
                    <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-primary-500 text-white text-sm font-medium rounded-lg hover:bg-primary-600 transition-colors shadow-sm">
                        <i data-lucide="save" class="w-4 h-4"></i>
                        @Shared["Button_SaveChanges"]
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.CspNonce()">lucide.createIcons();</script>
}

