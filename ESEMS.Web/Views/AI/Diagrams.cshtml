@using System.Globalization
@inject IStringLocalizer<SharedResource> Shared
@{
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    ViewData["Title"] = Shared["Title_BPMNModeler"].Value;
}

<!-- bpmn-js CSS -->
<link rel="stylesheet" href="~/lib/bpmn-js/diagram-js.css">
<link rel="stylesheet" href="~/lib/bpmn-js/bpmn-js.css">
<link rel="stylesheet" href="~/lib/bpmn-js/bpmn-embedded.css">

<div id="bpmnPage" class="row">
    <!-- Side Panel -->
    <div class="col-lg-3 side-panel">
        <div class="accordion" id="bpmnSideAccordion">
            <!-- AI Generator -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#panelAI">
                        <i data-lucide="sparkles" class="h-4 w-4 text-primary @(isRtl ? "ms-2" : "me-2")"></i>
                        @(isRtl ? "مولد BPMN بالذكاء الاصطناعي" : "AI BPMN Generator")
                    </button>
                </h2>
                <div id="panelAI" class="accordion-collapse collapse show" data-bs-parent="#bpmnSideAccordion">
                    <div class="accordion-body">
                        <div class="mb-3">
                            <label for="processTitle" class="form-label small">@(isRtl ? "اسم العملية" : "Process Name")</label>
                            <input id="processTitle" type="text" class="form-control form-control-sm" placeholder="@(isRtl ? "مثال: طلب إسكان" : "e.g., Housing Application")" />
                        </div>
                        <div class="mb-3">
                            <label for="processDescription" class="form-label small">@(isRtl ? "الوصف" : "Description")</label>
                            <textarea id="processDescription" rows="3" class="form-control form-control-sm" placeholder="@(isRtl ? "صف العملية التجارية..." : "Describe the business process...")"></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button id="btnAiGenerate" class="btn btn-primary btn-sm flex-grow-1">
                                <i data-lucide="wand-2" class="h-4 w-4 me-1"></i>
                                @(isRtl ? "توليد BPMN" : "Generate BPMN")
                            </button>
                            <button id="btnOptimizePrompt" class="btn btn-warning btn-sm d-flex align-items-center justify-content-center" title="@(isRtl ? "تحسين الوصف" : "Optimize Description")" style="width:34px;padding:0;">
                                <i data-lucide="wand" class="h-4 w-4"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Load from Process -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#panelLoadProcess">
                        <i data-lucide="folder-open" class="h-4 w-4 text-purple-600 @(isRtl ? "ms-2" : "me-2")"></i>
                        @(isRtl ? "تحميل من العمليات" : "Load from Process")
                    </button>
                </h2>
                <div id="panelLoadProcess" class="accordion-collapse collapse" data-bs-parent="#bpmnSideAccordion">
                    <div class="accordion-body">
                        <p class="text-muted small mb-2">@(isRtl ? "ابحث عن عملية لتحميل مخطط BPMN الخاص بها" : "Search for a process to load its BPMN diagram")</p>
                        <div class="mb-3 search-dropdown">
                            <input type="text" id="searchLoadProcess" class="form-control form-control-sm"
                                   placeholder="@(isRtl ? "اكتب للبحث بالاسم أو الرمز..." : "Type to search by name or code...")"
                                   autocomplete="off" />
                            <input type="hidden" id="selectLoadProcess" />
                            <div id="loadProcessResults" class="search-results"></div>
                        </div>
                        <button id="btnLoadFromProcess" class="btn btn-outline-primary btn-sm w-100">
                            <i data-lucide="download" class="h-4 w-4 me-1"></i>
                            @(isRtl ? "تحميل المخطط" : "Load Diagram")
                        </button>
                        <div id="loadedProcessInfo" class="mt-2 small text-muted d-none">
                            <i data-lucide="check-circle" class="h-3 w-3 me-1 text-success"></i>
                            <span id="loadedProcessName"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Import -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#panelImport">
                        <i data-lucide="upload" class="h-4 w-4 text-info @(isRtl ? "ms-2" : "me-2")"></i>
                        @(isRtl ? "استيراد" : "Import")
                    </button>
                </h2>
                <div id="panelImport" class="accordion-collapse collapse" data-bs-parent="#bpmnSideAccordion">
                    <div class="accordion-body">
                        <button id="btnImportXml" class="btn btn-outline-secondary btn-sm w-100 mb-2">
                            <i data-lucide="file-code" class="h-4 w-4 me-1"></i>
                            @(isRtl ? "استيراد BPMN XML" : "Import BPMN XML")
                        </button>
                        <input id="importBpmnFile" type="file" class="d-none" accept=".bpmn,.xml" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Canvas -->
    <div class="col-lg-9">
        <div class="card">
            <!-- Toolbar -->
            <div class="card-header bg-light py-2">
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <div class="btn-group btn-group-sm">
                        <button id="btnNew" class="btn btn-outline-secondary" title="@(isRtl ? "جديد" : "New")">
                            <i data-lucide="file-plus" class="h-4 w-4"></i>
                        </button>
                    </div>
                    <div class="btn-group btn-group-sm">
                        <button id="btnUndo" class="btn btn-outline-secondary" title="@Shared["BPMN_Undo"].Value">
                            <i data-lucide="undo-2" class="h-4 w-4"></i>
                        </button>
                        <button id="btnRedo" class="btn btn-outline-secondary" title="@Shared["BPMN_Redo"].Value">
                            <i data-lucide="redo-2" class="h-4 w-4"></i>
                        </button>
                    </div>

                    @* Pool / Lane creation. Horizontal pools stack lanes
                       vertically (lt-> rt or rt->lt flow); vertical pools
                       lay lanes side-by-side (top->bottom flow). For RTL
                       diagrams, new pools stagger leftward and lane
                       "before/after" swap to bpmn-js's bottom/top so the
                       new lane lands on the visually-correct side. *@
                    <div class="btn-group btn-group-sm" role="group">
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-outline-primary dropdown-toggle d-flex align-items-center gap-1"
                                    data-bs-toggle="dropdown" aria-expanded="false"
                                    title="@(isRtl ? "إضافة مسبح" : "Add Pool")">
                                <i data-lucide="rectangle-horizontal" class="h-4 w-4"></i>
                                <span class="d-none d-xl-inline small">@(isRtl ? "مسبح" : "Pool")</span>
                            </button>
                            <ul class="dropdown-menu">
                                <li>
                                    <button type="button" class="dropdown-item d-flex align-items-center gap-2 ai-add-pool" data-orientation="horizontal">
                                        <i data-lucide="rectangle-horizontal" style="width: 16px; height: 16px;"></i>
                                        <span>@(isRtl ? "مسبح أفقي (المسارات أسفل بعضها)" : "Horizontal Pool (lanes stack vertically)")</span>
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item d-flex align-items-center gap-2 ai-add-pool" data-orientation="vertical">
                                        <i data-lucide="rectangle-vertical" style="width: 16px; height: 16px;"></i>
                                        <span>@(isRtl ? "مسبح عمودي (المسارات جنباً إلى جنب)" : "Vertical Pool (lanes side-by-side)")</span>
                                    </button>
                                </li>
                            </ul>
                        </div>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-outline-primary dropdown-toggle d-flex align-items-center gap-1"
                                    data-bs-toggle="dropdown" aria-expanded="false"
                                    title="@(isRtl ? "إضافة مسار" : "Add Lane")">
                                <i data-lucide="rows-3" class="h-4 w-4"></i>
                                <span class="d-none d-xl-inline small">@(isRtl ? "مسار" : "Lane")</span>
                            </button>
                            <ul class="dropdown-menu">
                                <li>
                                    <button type="button" class="dropdown-item d-flex align-items-center gap-2 ai-add-lane" data-location="before">
                                        <i data-lucide="arrow-up" style="width: 14px; height: 14px;"></i>
                                        <span>@(isRtl ? "قبل المحدد" : "Before selection")</span>
                                    </button>
                                </li>
                                <li>
                                    <button type="button" class="dropdown-item d-flex align-items-center gap-2 ai-add-lane" data-location="after">
                                        <i data-lucide="arrow-down" style="width: 14px; height: 14px;"></i>
                                        <span>@(isRtl ? "بعد المحدد" : "After selection")</span>
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="btn-group btn-group-sm">
                        <button id="btnZoomIn" class="btn btn-outline-secondary" title="@(isRtl ? "تكبير" : "Zoom In")">
                            <i data-lucide="zoom-in" class="h-4 w-4"></i>
                        </button>
                        <button id="btnZoomOut" class="btn btn-outline-secondary" title="@(isRtl ? "تصغير" : "Zoom Out")">
                            <i data-lucide="zoom-out" class="h-4 w-4"></i>
                        </button>
                        <button id="btnFit" class="btn btn-outline-secondary" title="@(isRtl ? "ملاءمة" : "Fit")">
                            <i data-lucide="maximize-2" class="h-4 w-4"></i>
                        </button>
                    </div>
                    <!-- Fill Color Picker -->
                    <div class="dropdown color-dropdown">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle d-flex align-items-center gap-1" type="button" data-bs-toggle="dropdown" title="@(isRtl ? "لون التعبئة" : "Fill Color")">
                            <i data-lucide="paint-bucket" class="h-4 w-4"></i>
                            <span class="d-none d-xl-inline small">@(isRtl ? "تعبئة" : "Fill")</span>
                        </button>
                        <div class="dropdown-menu p-2">
                            <div class="color-grid mb-2">
                                <button class="color-swatch" style="background:#dbeafe" data-fill="#dbeafe" data-stroke="#2563eb" title="Blue"></button>
                                <button class="color-swatch" style="background:#dcfce7" data-fill="#dcfce7" data-stroke="#16a34a" title="Green"></button>
                                <button class="color-swatch" style="background:#fef9c3" data-fill="#fef9c3" data-stroke="#ca8a04" title="Yellow"></button>
                                <button class="color-swatch" style="background:#fee2e2" data-fill="#fee2e2" data-stroke="#dc2626" title="Red"></button>
                                <button class="color-swatch" style="background:#f3e8ff" data-fill="#f3e8ff" data-stroke="#9333ea" title="Purple"></button>
                                <button class="color-swatch" style="background:#ffedd5" data-fill="#ffedd5" data-stroke="#ea580c" title="Orange"></button>
                                <button class="color-swatch" style="background:#ccfbf1" data-fill="#ccfbf1" data-stroke="#0d9488" title="Teal"></button>
                                <button class="color-swatch" style="background:#fce7f3" data-fill="#fce7f3" data-stroke="#db2777" title="Pink"></button>
                                <button class="color-swatch" style="background:#e2e8f0" data-fill="#e2e8f0" data-stroke="#475569" title="Slate"></button>
                                <button class="color-swatch" style="background:#ffffff;border-color:#aaa" data-reset="true" title="@(isRtl ? "إزالة اللون" : "Reset")">
                                    <i data-lucide="x" style="width:14px;height:14px;margin:2px;color:#999"></i>
                                </button>
                            </div>
                            <div class="d-flex align-items-center gap-2 border-top pt-2">
                                <label class="small text-muted mb-0">@(isRtl ? "مخصص" : "Custom")</label>
                                <input type="color" id="customFillColor" value="#dbeafe" class="form-control form-control-color p-0 border-0" style="width:28px;height:28px">
                                <input type="color" id="customStrokeColor" value="#2563eb" class="form-control form-control-color p-0 border-0" style="width:28px;height:28px" title="@(isRtl ? "لون الحد" : "Stroke")">
                                <button id="btnApplyCustomColor" class="btn btn-sm btn-outline-primary py-0 px-2">
                                    <i data-lucide="check" class="h-3 w-3"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <!-- Font Size Picker -->
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle d-flex align-items-center gap-1" type="button" data-bs-toggle="dropdown" title="@(isRtl ? "حجم الخط" : "Font Size")">
                            <i data-lucide="type" class="h-4 w-4"></i>
                            <span id="currentFontSizeLabel" class="small">12px</span>
                        </button>
                        <ul class="dropdown-menu" style="min-width:100px">
                            <li><button class="dropdown-item small" data-font-size="10">10px</button></li>
                            <li><button class="dropdown-item small fw-bold" data-font-size="12">12px @(isRtl ? "(افتراضي)" : "(Default)")</button></li>
                            <li><button class="dropdown-item small" data-font-size="14">14px</button></li>
                            <li><button class="dropdown-item small" data-font-size="16">16px</button></li>
                            <li><button class="dropdown-item small" data-font-size="18">18px</button></li>
                            <li><button class="dropdown-item small" data-font-size="20">20px</button></li>
                            <li><button class="dropdown-item small" data-font-size="24">24px</button></li>
                        </ul>
                    </div>
                    <!-- Font Family Picker -->
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle d-flex align-items-center gap-1" type="button" data-bs-toggle="dropdown" title="@(isRtl ? "نوع الخط" : "Font Family")">
                            <i data-lucide="a-large-small" class="h-4 w-4"></i>
                            <span id="currentFontFamilyLabel" class="small d-none d-xl-inline">Arial</span>
                        </button>
                        <ul class="dropdown-menu" style="min-width:160px">
                            <li><button class="dropdown-item small fw-bold" style="font-family:Arial" data-font-family="Arial, sans-serif" data-font-label="Arial">Arial @(isRtl ? "(افتراضي)" : "(Default)")</button></li>
                            <li><button class="dropdown-item small" style="font-family:Verdana" data-font-family="Verdana, sans-serif" data-font-label="Verdana">Verdana</button></li>
                            <li><button class="dropdown-item small" style="font-family:Tahoma" data-font-family="Tahoma, sans-serif" data-font-label="Tahoma">Tahoma</button></li>
                            <li><button class="dropdown-item small" style="font-family:Calibri" data-font-family="Calibri, sans-serif" data-font-label="Calibri">Calibri</button></li>
                            <li><button class="dropdown-item small" style="font-family:Georgia" data-font-family="Georgia, serif" data-font-label="Georgia">Georgia</button></li>
                            <li><button class="dropdown-item small" style="font-family:'Times New Roman'" data-font-family="Times New Roman, serif" data-font-label="Times New Roman">Times New Roman</button></li>
                            <li><button class="dropdown-item small" style="font-family:'Courier New'" data-font-family="Courier New, monospace" data-font-label="Courier New">Courier New</button></li>
                            <li><button class="dropdown-item small" style="font-family:'Segoe UI'" data-font-family="Segoe UI, sans-serif" data-font-label="Segoe UI">Segoe UI</button></li>
                        </ul>
                    </div>
                    <button id="btnSaveToProcess" class="btn btn-success btn-sm">
                        <i data-lucide="save" class="h-4 w-4 me-1"></i>
                        @(isRtl ? "حفظ للعملية" : "Save to Process")
                    </button>
                    @* "Enhance Drawing" — server-side tidies the current
                       diagram: resizes tasks to fit labels, pushes
                       overlapping shapes apart with RTL-aware direction,
                       re-routes edges around obstacles with orthogonal
                       waypoints, centres edge labels. Empty diagrams fall
                       back to the picker modal so the button still does
                       something useful on a fresh canvas. *@
                    <button id="btnEnhanceDrawing" type="button" class="btn btn-info btn-sm text-white d-flex align-items-center gap-1" title="@(isRtl ? "تحسين الرسم الحالي تلقائياً" : "Auto-tidy the current diagram")">
                        <i data-lucide="sparkles" class="h-4 w-4"></i>
                        <span>@(isRtl ? "تحسين الرسم" : "Enhance Drawing")</span>
                    </button>
                    <span id="toolbarLinkedBadge" class="linked-process-badge d-none">
                        <i data-lucide="link" style="width:12px;height:12px"></i>
                        <span id="toolbarLinkedName"></span>
                    </span>
                    <div class="btn-group btn-group-sm @(isRtl ? "me-auto" : "ms-auto")">
                        <button id="btnExportXml" class="btn btn-outline-primary" title="@(isRtl ? "تصدير XML" : "Export XML")">
                            <i data-lucide="download" class="h-4 w-4 me-1"></i>XML
                        </button>
                        <button id="btnExportSvg" class="btn btn-outline-primary" title="@(isRtl ? "تصدير SVG" : "Export SVG")">
                            SVG
                        </button>
                        <button id="btnExportPng" class="btn btn-outline-primary" title="@(isRtl ? "تصدير PNG" : "Export PNG")">
                            PNG
                        </button>
                    </div>
                    <button id="btnFocus" class="btn btn-outline-secondary btn-sm" title="@(isRtl ? "وضع التركيز" : "Focus Mode")">
                        <i data-lucide="expand" class="h-4 w-4"></i>
                    </button>
                </div>
            </div>

            <!-- Status -->
            <div class="px-3 py-2 bg-light border-bottom small text-muted d-flex align-items-center gap-2">
                <i data-lucide="info" class="h-4 w-4"></i>
                <span id="bpmnStatus">@(isRtl ? "جاهز - اسحب العناصر من اللوحة اليسرى" : "Ready - Drag elements from the left palette")</span>
            </div>

            <!-- Error -->
            <div id="bpmnError" class="alert alert-danger m-3 d-none small"></div>

            <!-- Canvas -->
            <div id="bpmnCanvas" class="position-relative">
                <div id="loadingOverlay" class="loading-overlay d-none">
                    <div class="text-center">
                        <div class="spinner mb-3"></div>
                        <p class="text-muted fw-medium">@(isRtl ? "جاري التوليد..." : "Generating...")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Enhance Drawing Modal — pick a process, fetch & auto-tidy its BPMN -->
<div class="modal fade" id="enhanceDrawingModal" tabindex="-1" aria-labelledby="enhanceDrawingModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="enhanceDrawingModalLabel">
                    <i data-lucide="sparkles" style="width:18px;height:18px;margin-inline-end:6px;color:#0ea5e9"></i>
                    @(isRtl ? "تحسين رسم BPMN" : "Enhance BPMN Drawing")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info small py-2 mb-3 d-flex align-items-start gap-2">
                    <i data-lucide="info" style="width:14px;height:14px;flex-shrink:0;margin-top:2px"></i>
                    <div>
                        @(isRtl
                            ? "اختر عملية لديها رسم BPMN. سيقوم النظام بتحميل الرسم وإعادة توجيه الأسهم بشكل متعامد، وتوسيط النصوص على الحواف، وتكبير المهام التي لا تتسع لنصها، ثم عرض النتيجة في المحرر للحفظ."
                            : "Pick a process that already has a BPMN diagram. The server will fetch it, re-route every edge with orthogonal waypoints, centre labels on the new midpoints, grow tasks whose labels overflow, then drop the cleaned diagram into the editor.")
                    </div>
                </div>
                <label class="form-label small fw-semibold">@(isRtl ? "العملية" : "Process")</label>
                <div class="search-dropdown position-relative">
                    <input type="text" id="enhanceProcessSearch" class="form-control form-control-sm"
                           placeholder="@(isRtl ? "اكتب للبحث بالاسم أو الرمز..." : "Type to search by name or code...")"
                           autocomplete="off" />
                    <input type="hidden" id="enhanceProcessId" />
                    <div id="enhanceProcessResults" class="search-results border bg-white shadow-sm" style="display:none;position:absolute;left:0;right:0;top:100%;max-height:240px;overflow:auto;z-index:5;"></div>
                </div>
                <div id="enhanceSelectedProcess" class="mt-2 small text-muted d-none">
                    <i data-lucide="check-circle" style="width:14px;height:14px;color:#16a34a;"></i>
                    <span id="enhanceSelectedName"></span>
                </div>
                <div id="enhanceStatus" class="mt-3 small d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">
                    @(isRtl ? "إلغاء" : "Cancel")
                </button>
                <button type="button" id="btnRunEnhance" class="btn btn-sm btn-info text-white" disabled>
                    <i data-lucide="wand-2" style="width:14px;height:14px;margin-inline-end:4px"></i>
                    @(isRtl ? "تحميل وتحسين" : "Load & Enhance")
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Save to Process Modal -->
<div class="modal fade" id="saveToProcessModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(isRtl ? "حفظ المخطط للعملية" : "Save Diagram to Process")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Currently linked process indicator -->
                <div id="linkedProcessBanner" class="d-none mb-3 p-2 bg-light rounded border">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="small">
                            <i data-lucide="link" class="h-3 w-3 me-1 text-primary" style="width:14px;height:14px"></i>
                            <span class="text-muted">@(isRtl ? "مرتبط بـ:" : "Linked to:")</span>
                            <span id="linkedProcessLabel" class="fw-semibold"></span>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1" onclick="unlinkProcess()" title="@(isRtl ? "إلغاء الربط" : "Unlink")">
                            <i data-lucide="unlink" style="width:12px;height:12px"></i>
                        </button>
                    </div>
                    <div class="small text-muted mt-1">@(isRtl ? "سيتم تحديث المخطط لهذه العملية" : "Diagram will be updated for this process")</div>
                </div>
                <!-- Search existing process -->
                <div id="saveSearchSection">
                    <div class="mb-3">
                        <label class="form-label">@(isRtl ? "البحث عن عملية موجودة" : "Search Existing Process")</label>
                        <div class="search-dropdown">
                            <input type="text" id="searchSaveProcess" class="form-control form-control-sm"
                                   placeholder="@(isRtl ? "اكتب للبحث بالاسم أو الرمز..." : "Type to search by name or code...")"
                                   autocomplete="off" />
                            <input type="hidden" id="selectProcess" />
                            <div id="saveProcessResults" class="search-results"></div>
                        </div>
                    </div>
                    <div class="text-center my-3">
                        <span class="text-muted">@(isRtl ? "أو" : "OR")</span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@(isRtl ? "إنشاء عملية جديدة" : "Create New Process")</label>
                        <input type="text" id="newProcessName" class="form-control" placeholder="@(isRtl ? "اسم العملية" : "Process Name")" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted">@(isRtl ? "وصف التغيير (اختياري)" : "Change Description (optional)")</label>
                    <input type="text" id="changeDescription" class="form-control form-control-sm" placeholder="@(isRtl ? "مثال: إضافة خطوة الموافقة" : "e.g., Added approval step")" />
                </div>
                <div id="saveError" class="alert alert-danger d-none"></div>
                <div id="saveSuccess" class="alert alert-success d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@(isRtl ? "إلغاء" : "Cancel")</button>
                <button type="button" id="btnConfirmSave" class="btn btn-primary">
                    <i data-lucide="save" class="h-4 w-4 me-1"></i>
                    @(isRtl ? "حفظ" : "Save")
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/bpmn-js/bpmn-modeler.production.min.js" asp-append-version="true"></script>
    <script src="~/js/bpmn-modeler-app.js" asp-append-version="true"></script>
    @{
        // Build localized strings dictionary and serialize with Unicode support
        var bpmnStrings = new Dictionary<string, string> {
            ["warning"] = Shared["Label_Warning"].Value,
            ["error"] = isRtl ? "خطأ" : "Error",
            ["noResults"] = Shared["Text_NoResultsFound"].Value,
            ["selectProcess"] = isRtl ? "الرجاء البحث واختيار عملية" : "Please search and select a process",
            ["selectProcedure"] = isRtl ? "الرجاء اختيار إجراء" : "Please select a procedure",
            ["selectOrCreateProcess"] = isRtl ? "الرجاء اختيار عملية أو إدخال اسم عملية جديدة" : "Please select a process or enter a new process name",
            ["loadingDiagram"] = isRtl ? "جاري تحميل المخطط..." : "Loading diagram...",
            ["diagramLoaded"] = isRtl ? "تم تحميل المخطط - جاهز للتحسين" : "Diagram loaded - Ready for refinement",
            ["loaded"] = isRtl ? "تم التحميل!" : "Loaded!",
            ["bpmnLoadedSuccess"] = isRtl ? "تم تحميل مخطط BPMN بنجاح." : "BPMN diagram loaded successfully.",
            ["loadFailed"] = isRtl ? "فشل التحميل" : "Load failed",
            ["savedSuccessfully"] = isRtl ? "تم الحفظ بنجاح!" : "Saved successfully!",
            ["procedureDiagramLoaded"] = isRtl ? "تم تحميل مخطط الإجراء" : "Procedure diagram loaded",
            ["procedureBpmnLoaded"] = isRtl ? "تم تحميل مخطط BPMN الخاص بالإجراء بنجاح." : "Procedure BPMN diagram loaded successfully.",
            ["enterDescriptionFirst"] = isRtl ? "الرجاء إدخال وصف العملية أولاً" : "Please enter a process description first",
            ["optimizingDescription"] = isRtl ? "جاري تحسين الوصف..." : "Optimizing description...",
            ["descriptionOptimized"] = isRtl ? "تم تحسين الوصف بنجاح" : "Description optimized successfully",
            ["optimized"] = isRtl ? "تم التحسين!" : "Optimized!",
            ["descriptionOptimizedText"] = isRtl ? "تم تحسين وصف العملية. يمكنك الآن توليد المخطط." : "Process description optimized. You can now generate the diagram.",
            ["optimizeFailed"] = isRtl ? "فشل تحسين الوصف" : "Description optimization failed",
            ["errorSaving"] = isRtl ? "حدث خطأ أثناء الحفظ" : "Error saving diagram",
            ["ready"] = Shared["BPMN_Ready"].Value,
            ["readyEdit"] = Shared["BPMN_ReadyEdit"].Value,
            ["movingElement"] = Shared["BPMN_MovingElement"].Value,
            ["elementMoved"] = Shared["BPMN_ElementMoved"].Value,
            ["elementCreated"] = Shared["BPMN_ElementCreated"].Value,
            ["connectionCreated"] = Shared["BPMN_ConnectionCreated"].Value,
            ["dragToReposition"] = Shared["BPMN_DragToReposition"].Value,
            ["initError"] = Shared["BPMN_InitializationError"].Value,
            ["diagramLoadedSuccess"] = Shared["BPMN_DiagramLoaded"].Value,
            ["importFailed"] = Shared["BPMN_ImportFailed"].Value,
            ["enterProcessName"] = Shared["BPMN_EnterProcessName"].Value,
            ["generatingAI"] = Shared["BPMN_GeneratingAI"].Value,
            ["aiGenerated"] = Shared["BPMN_AIGenerated"].Value,
            ["generateFailed"] = Shared["BPMN_GenerateFailed"].Value,
            ["generationFailed"] = Shared["BPMN_GenerationFailed"].Value,
            ["networkError"] = Shared["BPMN_NetworkError"].Value,
            ["enterRefinement"] = Shared["BPMN_EnterRefinement"].Value,
            ["noDiagramToRefine"] = Shared["BPMN_NoDiagramToRefine"].Value,
            ["refiningAI"] = Shared["BPMN_RefiningAI"].Value,
            ["diagramRefined"] = Shared["BPMN_DiagramRefined"].Value,
            ["refineFailed"] = Shared["BPMN_RefineFailed"].Value,
            ["refinementFailed"] = Shared["BPMN_RefinementFailed"].Value,
            ["xmlExported"] = Shared["BPMN_XMLExported"].Value,
            ["svgExported"] = Shared["BPMN_SVGExported"].Value,
            ["svgExportFailed"] = Shared["BPMN_SVGExportFailed"].Value,
            ["pngExported"] = Shared["BPMN_PNGExported"].Value,
            ["pngExportFailed"] = Shared["BPMN_PNGExportFailed"].Value,
            ["newDiagramConfirm"] = Shared["BPMN_NewDiagramConfirm"].Value,
            ["newDiagramCreated"] = Shared["BPMN_NewDiagramCreated"].Value,
            ["exitFocusMode"] = Shared["BPMN_ExitFocusMode"].Value,
            ["focusMode"] = Shared["BPMN_FocusMode"].Value,
            ["selectElements"] = Shared["BPMN_SelectElements"].Value,
            ["colorApplied"] = Shared["BPMN_ColorApplied"].Value,
            ["colorReset"] = Shared["BPMN_ColorReset"].Value,
            ["fontUpdated"] = Shared["BPMN_FontUpdated"].Value,
            ["convertingVisio"] = Shared["BPMN_ConvertingVisio"].Value,
            ["visioConverted"] = Shared["BPMN_VisioConverted"].Value,
            ["visioConvertFailed"] = Shared["BPMN_VisioConvertFailed"].Value,
            ["visioError"] = Shared["BPMN_VisioError"].Value
        };
        var jsonOptions = new System.Text.Json.JsonSerializerOptions {
            Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping,
            PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
        };
        var linkedProcessId = ViewBag.LinkedProcessId as string;
        var linkedProcessName = isRtl ? (ViewBag.LinkedProcessNameAr as string) : (ViewBag.LinkedProcessName as string);
        var linkedProcessCode = ViewBag.LinkedProcessCode as string;
        var linkedProcessXml = ViewBag.LinkedProcessXml as string;
        var configObj = new {
            isRtl = isRtl,
            strings = bpmnStrings,
            linkedProcess = string.IsNullOrWhiteSpace(linkedProcessId) ? null : new {
                id = linkedProcessId,
                name = linkedProcessName,
                code = linkedProcessCode,
                xml = linkedProcessXml
            }
        };
        var configJson = System.Text.Json.JsonSerializer.Serialize(configObj, jsonOptions);
    }
    <script nonce="@Context.CspNonce()">
        window.bpmnPageConfig = @Html.Raw(configJson);
    </script>
    <script src="~/js/bpmn-page.js" asp-append-version="true"></script>

    @* Pool / Lane creation with RTL awareness. RTL detection combines the
       page culture (Razor's isRtl) with a content check on the modeler's
       current XML — that way an English UI viewing an Arabic process
       still flips the stagger and lane direction.
       For BPMN, "horizontal pool" = isHorizontal=true (lanes stack
       vertically). bpmn-js's addLane(target, 'top'|'bottom') is relative
       to the pool's stacking axis. To honour reading order we map:
         LTR + "after"  → 'bottom'  (next lane is south / east)
         LTR + "before" → 'top'     (new lane is north / west)
         RTL + "after"  → 'top'     (next lane is north / WEST for v-pool)
         RTL + "before" → 'bottom'  (new lane is south / EAST for v-pool)
       Only the X-axis flips in RTL because Arabic reading direction
       affects horizontal layout, not vertical. *@
    <script nonce="@Context.CspNonce()">
    (function () {
        var PAGE_RTL = @(isRtl ? "true" : "false");

        function aiBpmnType(el) { return el && el.businessObject ? el.businessObject.$type : null; }
        function aiFindAncestor(el, types) {
            for (var cur = el; cur; cur = cur.parent) {
                if (types.indexOf(aiBpmnType(cur)) >= 0) return cur;
            }
            return null;
        }

        // Content-level RTL check: scan label/name text for the Arabic
        // Unicode block. Combined with the page culture so a mixed-locale
        // user still gets RTL behaviour on an Arabic diagram.
        var arabicRangeRe = /[؀-ۿݐ-ݿࢠ-ࣿ]/;
        async function isCurrentDiagramRtl() {
            if (PAGE_RTL) return true;
            if (!window.bpmnModeler) return false;
            try {
                var res = await window.bpmnModeler.saveXML({ format: false });
                var xml = (res && res.xml) || '';
                return arabicRangeRe.test(xml);
            } catch (e) { return false; }
        }

        async function aiAddPool(orientation) {
            if (!window.bpmnModeler) return;
            try {
                var modeler = window.bpmnModeler;
                var elementFactory = modeler.get('elementFactory');
                var modeling = modeler.get('modeling');
                var canvas = modeler.get('canvas');
                var root = canvas.getRootElement();
                var isHorizontal = orientation !== 'vertical';
                var isRtl = await isCurrentDiagramRtl();

                // Stagger new pools so they don't overlap existing ones.
                // Direction follows reading order — LTR pushes new pools
                // to the right of the cluster, RTL to the left.
                var existingPools = (root.children || []).filter(function (c) {
                    return aiBpmnType(c) === 'bpmn:Participant';
                });
                var n = existingPools.length;
                var position;
                if (isHorizontal) {
                    position = { x: 400, y: 200 + n * 280 };
                } else {
                    var xStep = isRtl ? -280 : 280;
                    position = { x: 400 + n * xStep, y: 200 };
                }

                var participant = elementFactory.createParticipantShape({
                    type: 'bpmn:Participant',
                    isExpanded: true
                });
                if (!isHorizontal) {
                    var w = participant.width || 600;
                    var h = participant.height || 250;
                    participant.width = h;
                    participant.height = w;
                }
                var created = modeling.createShape(participant, position, root);
                if (!isHorizontal && created.di) {
                    modeling.updateModdleProperties(created, created.di, { isHorizontal: false });
                }
                modeler.get('selection').select(created);
            } catch (err) {
                console.error('AI Add Pool failed:', err);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({ icon: 'error', title: PAGE_RTL ? 'تعذر إضافة المسبح' : 'Could not add pool', text: err.message, confirmButtonColor: '#005B99' });
                }
            }
        }

        async function aiAddLane(direction) {
            if (!window.bpmnModeler) return;
            try {
                var modeler = window.bpmnModeler;
                var selection = modeler.get('selection').get();
                var target = selection.length ? aiFindAncestor(selection[0], ['bpmn:Lane', 'bpmn:Participant']) : null;

                if (!target) {
                    var root = modeler.get('canvas').getRootElement();
                    var pools = (root.children || []).filter(function (c) { return aiBpmnType(c) === 'bpmn:Participant'; });
                    if (pools.length === 1) {
                        target = pools[0];
                    } else if (pools.length === 0) {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'info',
                                title: PAGE_RTL ? 'لا يوجد مسبح' : 'No pool yet',
                                text: PAGE_RTL ? 'أضف مسبحاً أولاً ثم أضف المسارات بداخله.' : 'Add a pool first, then add lanes inside it.',
                                confirmButtonColor: '#005B99'
                            });
                        }
                        return;
                    } else {
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'info',
                                title: PAGE_RTL ? 'حدد مسبحاً أو مساراً' : 'Select a pool or lane',
                                text: PAGE_RTL ? 'لديك أكثر من مسبح — انقر على المسبح المستهدف أولاً.' : 'Multiple pools on the canvas — click the target pool first.',
                                confirmButtonColor: '#005B99'
                            });
                        }
                        return;
                    }
                }

                // Figure out the target pool's orientation. For a vertical
                // pool in RTL, "after" should land on the LEFT (west) side
                // and "before" on the right; bpmn-js's 'top' is the
                // primary-axis start ("west" for vertical pools), 'bottom'
                // is the primary-axis end. So swap direction → location
                // when the parent is vertical AND content is RTL.
                var pool = aiFindAncestor(target, ['bpmn:Participant']) || target;
                var poolIsHorizontal = !pool.di || pool.di.isHorizontal !== false;
                var isRtl = await isCurrentDiagramRtl();
                // Default LTR mapping: after → bottom, before → top.
                var location = direction === 'before' ? 'top' : 'bottom';
                if (!poolIsHorizontal && isRtl) {
                    // RTL + vertical pool: flip — "after" goes west, "before" east.
                    location = direction === 'before' ? 'bottom' : 'top';
                }

                modeler.get('modeling').addLane(target, location);
            } catch (err) {
                console.error('AI Add Lane failed:', err);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({ icon: 'error', title: PAGE_RTL ? 'تعذر إضافة المسار' : 'Could not add lane', text: err.message, confirmButtonColor: '#005B99' });
                }
            }
        }

        document.querySelectorAll('.ai-add-pool').forEach(function (btn) {
            btn.addEventListener('click', function () { aiAddPool(btn.dataset.orientation); });
        });
        document.querySelectorAll('.ai-add-lane').forEach(function (btn) {
            btn.addEventListener('click', function () { aiAddLane(btn.dataset.location); });
        });
    })();
    </script>

    @* Enhance Drawing — primary action: enhance whatever is currently in
       the modeler (the diagram the user has been working on, whether
       drawn from scratch, AI-generated, or loaded via "Load from
       Process"). Fallback: when the canvas is empty, open the
       process-picker modal so the button still does something useful. *@
    <script nonce="@Context.CspNonce()">
    (function () {
        var IS_RTL = @(isRtl ? "true" : "false");
        var modalEl = document.getElementById('enhanceDrawingModal');
        if (!modalEl) return;

        var input    = document.getElementById('enhanceProcessSearch');
        var hidden   = document.getElementById('enhanceProcessId');
        var resultsBox = document.getElementById('enhanceProcessResults');
        var selected = document.getElementById('enhanceSelectedProcess');
        var selectedName = document.getElementById('enhanceSelectedName');
        var statusEl = document.getElementById('enhanceStatus');
        var runBtn   = document.getElementById('btnRunEnhance');
        var enhanceBtn = document.getElementById('btnEnhanceDrawing');

        var processes = [];
        var loaded = false;

        // Antiforgery token helper — required by the POST endpoint that
        // takes ad-hoc XML. Reads from the hidden form the layout emits.
        function getAntiForgeryToken() {
            var el = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
            return el ? el.value : '';
        }

        // "Is this an empty / default diagram?" — used to decide whether
        // the button should enhance in place or open the picker modal.
        // Counts task / event / gateway shape openings; a fresh template
        // has the default start event, which is fine to enhance too, so
        // we only treat "zero shapes" as truly empty.
        function diagramHasContent(xml) {
            if (!xml) return false;
            return /<bpmn:(?:userTask|serviceTask|task|manualTask|sendTask|receiveTask|scriptTask|businessRuleTask|subProcess|callActivity|exclusiveGateway|parallelGateway|inclusiveGateway|eventBasedGateway|intermediateThrowEvent|intermediateCatchEvent|startEvent|endEvent)\b/.test(xml);
        }

        // Light-touch status indicator that doesn't fight with the
        // existing #bpmnStatus banner (which shares this script's host
        // card). Re-used after the run so the user knows what happened.
        function setStatus(msg, kind) {
            var s = document.getElementById('bpmnStatus');
            if (!s) return;
            s.textContent = msg;
            s.style.color = kind === 'error' ? '#dc2626' : (kind === 'success' ? '#16a34a' : '');
        }

        async function enhanceCurrent() {
            if (!window.bpmnModeler) {
                setStatus(IS_RTL ? 'المحرر غير جاهز' : 'Modeler not ready', 'error');
                return;
            }
            try {
                enhanceBtn.disabled = true;
                setStatus(IS_RTL ? 'جاري تحسين الرسم…' : 'Enhancing diagram…');
                var xmlRes = await window.bpmnModeler.saveXML({ format: true });
                var xml = (xmlRes && xmlRes.xml) || '';

                // No real content? Drop into the picker modal so the user
                // can pick something to enhance instead of staring at an
                // empty canvas.
                if (!diagramHasContent(xml)) {
                    enhanceBtn.disabled = false;
                    setStatus('');
                    var m = bootstrap.Modal.getOrCreateInstance(modalEl);
                    m.show();
                    return;
                }

                var resp = await fetch('/AI/EnhanceBpmnXml', {
                    method: 'POST',
                    credentials: 'include',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: JSON.stringify({ bpmnXml: xml })
                });
                var d = await resp.json();
                if (!d || !d.success || !d.bpmnXml) {
                    setStatus((d && d.error) || (IS_RTL ? 'فشل التحسين' : 'Enhance failed'), 'error');
                    return;
                }
                await window.bpmnModeler.importXML(d.bpmnXml);
                try { window.bpmnModeler.get('canvas').zoom('fit-viewport'); } catch (e) {}
                setStatus(IS_RTL ? 'تم تحسين الرسم' : 'Diagram enhanced', 'success');
            } catch (err) {
                console.error('Enhance current failed:', err);
                setStatus(err.message || (IS_RTL ? 'فشل التحسين' : 'Enhance failed'), 'error');
            } finally {
                enhanceBtn.disabled = false;
            }
        }

        if (enhanceBtn) enhanceBtn.addEventListener('click', enhanceCurrent);

        function escHtml(s) {
            return (s == null ? '' : String(s)).replace(/[&<>"']/g, function (c) {
                return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', '\'': '&#39;' })[c];
            });
        }

        async function loadProcesses() {
            if (loaded) return;
            try {
                var r = await fetch('/AI/GetProcessesWithBPMN', { credentials: 'include' });
                var d = await r.json();
                if (d && d.success && Array.isArray(d.processes)) processes = d.processes;
                loaded = true;
            } catch (e) { console.error('Enhance: failed to load process list', e); }
        }

        function renderResults(filtered) {
            if (!filtered.length) {
                resultsBox.innerHTML = '<div class="p-2 text-muted small">' +
                    (IS_RTL ? 'لا توجد نتائج' : 'No results') + '</div>';
                resultsBox.style.display = 'block';
                return;
            }
            resultsBox.innerHTML = filtered.slice(0, 40).map(function (p) {
                return '<button type="button" class="enhance-result d-block w-100 text-start border-0 bg-transparent py-1 px-2 small" ' +
                       'data-id="' + escHtml(p.id) + '" data-name="' + escHtml(p.Name || p.name) + '">' +
                       '<code class="text-muted me-1">' + escHtml(p.Code || p.code) + '</code> ' +
                       escHtml(p.Name || p.name) +
                       '</button>';
            }).join('');
            resultsBox.style.display = 'block';
        }

        input.addEventListener('focus', async function () {
            await loadProcesses();
            renderResults(processes);
        });

        input.addEventListener('input', function () {
            var q = input.value.trim().toLowerCase();
            if (!loaded || !processes.length) { renderResults([]); return; }
            if (!q) { renderResults(processes); return; }
            renderResults(processes.filter(function (p) {
                var name = (p.Name || p.name || '').toLowerCase();
                var code = (p.Code || p.code || '').toLowerCase();
                return name.indexOf(q) >= 0 || code.indexOf(q) >= 0;
            }));
        });

        resultsBox.addEventListener('click', function (ev) {
            var btn = ev.target && ev.target.closest ? ev.target.closest('.enhance-result') : null;
            if (!btn) return;
            ev.preventDefault();
            hidden.value = btn.getAttribute('data-id');
            var name = btn.getAttribute('data-name');
            input.value = name;
            selectedName.textContent = name;
            selected.classList.remove('d-none');
            resultsBox.style.display = 'none';
            runBtn.disabled = false;
        });

        // Hide results when clicking outside the dropdown.
        document.addEventListener('click', function (ev) {
            if (!resultsBox || resultsBox.style.display === 'none') return;
            if (resultsBox.contains(ev.target) || ev.target === input) return;
            resultsBox.style.display = 'none';
        });

        // Reset on close so a second open starts clean.
        modalEl.addEventListener('hidden.bs.modal', function () {
            input.value = '';
            hidden.value = '';
            selected.classList.add('d-none');
            statusEl.classList.add('d-none');
            statusEl.textContent = '';
            runBtn.disabled = true;
            resultsBox.style.display = 'none';
        });

        runBtn.addEventListener('click', async function () {
            var processId = hidden.value;
            if (!processId) return;
            statusEl.className = 'mt-3 small text-muted';
            statusEl.textContent = IS_RTL ? 'جاري التحميل والتحسين…' : 'Loading and enhancing…';
            statusEl.classList.remove('d-none');
            runBtn.disabled = true;
            try {
                var r = await fetch('/AI/EnhanceProcessBPMN?id=' + encodeURIComponent(processId), { credentials: 'include' });
                var d = await r.json();
                if (!d || !d.success || !d.bpmnXml) {
                    statusEl.className = 'mt-3 small text-danger';
                    statusEl.textContent = (d && d.error) || (IS_RTL ? 'فشل التحميل' : 'Load failed');
                    runBtn.disabled = false;
                    return;
                }
                if (!window.bpmnModeler) {
                    statusEl.className = 'mt-3 small text-danger';
                    statusEl.textContent = IS_RTL ? 'المحرر غير جاهز' : 'Modeler not ready yet';
                    runBtn.disabled = false;
                    return;
                }
                await window.bpmnModeler.importXML(d.bpmnXml);
                try { window.bpmnModeler.get('canvas').zoom('fit-viewport'); } catch (e) {}
                statusEl.className = 'mt-3 small text-success';
                statusEl.textContent = IS_RTL ? 'تم تحميل المخطط المحسّن' : 'Enhanced diagram loaded';
                setTimeout(function () {
                    bootstrap.Modal.getInstance(modalEl)?.hide();
                }, 600);
            } catch (e) {
                statusEl.className = 'mt-3 small text-danger';
                statusEl.textContent = e.message || (IS_RTL ? 'فشل التحميل' : 'Load failed');
                runBtn.disabled = false;
            }
        });
    })();
    </script>
}
