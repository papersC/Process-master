@{
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    ViewData["Title"] = isRtl ? "مساحتي" : "My Space";

    // Static category catalogue — myspace.js reads the active filter from
    // the (now-hidden) #msCategoryFilter select. Sidebar buttons set its
    // value and dispatch 'change'.
    var categories = new (string Value, string Label)[]
    {
        ("",          isRtl ? "كل الملفات"  : "All Files"),
        ("General",   isRtl ? "عام"        : "General"),
        ("Policy",    isRtl ? "سياسة"       : "Policy"),
        ("Procedure", isRtl ? "إجراء"       : "Procedure"),
        ("Standard",  isRtl ? "معيار"       : "Standard"),
        ("Evidence",  isRtl ? "أدلة"        : "Evidence"),
        ("Report",    isRtl ? "تقرير"       : "Report"),
    };
}

@*
    File-explorer two-pane redesign.
    Left rail: user card + category facets (drives the existing
    #msCategoryFilter via click → set value → dispatch 'change').
    Main pane: compact toolbar (search + Upload), persistent drop zone,
    table of files (loaded by myspace.js into #msTableBody).

    All myspace.js DOM hooks preserved:
    msSearchInput, msCategoryFilter, msDocCount, msDropZone, msFileInput,
    msEmptyState, msLoading, msTableWrap, msTableBody, msUploadToast,
    msUploadPct, msUploadBar, btnUploadFiles, btnUploadFirst.
*@

<style>
    .ms-shell { display: flex; gap: .75rem; height: calc(100vh - 140px); min-height: 580px; }
    .ms-rail { flex: 0 0 230px; background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; display: flex; flex-direction: column; min-height: 0; overflow: hidden; }
    .ms-rail-user { padding: .9rem 1rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; gap: .65rem; background: linear-gradient(135deg, #005B99 0%, #003d6b 100%); color: #fff; }
    .ms-rail-user .ms-avatar { width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .ms-rail-user h2 { margin: 0; font-size: var(--fs-sm); font-weight: 600; line-height: 1.2; }
    .ms-rail-user p { margin: 0; font-size: var(--fs-xs); color: rgba(255,255,255,.8); line-height: 1.3; }
    .ms-rail-section-title { font-size: var(--fs-xs); font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: #6b7280; padding: .85rem 1rem .35rem; }
    .ms-rail-categories { flex: 1 1 0; min-height: 0; overflow-y: auto; padding-bottom: .5rem; }
    .ms-cat { display: flex; width: 100%; box-sizing: border-box; background: transparent; border: none; border-inline-start: 3px solid transparent; align-items: center; gap: .55rem; padding: .45rem 1rem; cursor: pointer; font-size: var(--fs-sm); color: #374151; text-align: start; transition: background .15s, border-color .15s; }
    .ms-cat:hover { background: #f9fafb; }
    .ms-cat.active { background: #eff6ff; border-inline-start-color: #005B99; color: #005B99; font-weight: 600; }
    .ms-cat .ms-cat-label { flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ms-cat .ms-cat-icon { width: 16px; height: 16px; flex-shrink: 0; color: #6b7280; }
    .ms-cat.active .ms-cat-icon { color: #005B99; }
    .ms-rail-footer { border-top: 1px solid #f1f5f9; padding: .65rem 1rem; font-size: var(--fs-xs); color: #6b7280; flex: 0 0 auto; }

    .ms-main { flex: 1 1 0; background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; display: flex; flex-direction: column; min-width: 0; min-height: 0; overflow: hidden; }
    .ms-toolbar { display: flex; align-items: center; gap: .55rem; padding: .65rem .85rem; border-bottom: 1px solid #f1f5f9; flex: 0 0 auto; }
    .ms-toolbar .ms-search { flex: 1 1 0; max-width: 480px; position: relative; }
    .ms-toolbar .ms-search input { width: 100%; padding: .42rem .7rem; padding-inline-start: 2.1rem; border: 1px solid #d1d5db; border-radius: .375rem; font-size: var(--fs-sm); background: #fff; }
    .ms-toolbar .ms-search input:focus { outline: none; border-color: #005B99; box-shadow: 0 0 0 3px rgba(0, 91, 153, .12); }
    .ms-toolbar .ms-search .ms-search-icon { position: absolute; top: 50%; transform: translateY(-50%); inset-inline-start: .65rem; color: #9ca3af; pointer-events: none; width: 14px; height: 14px; }
    .ms-toolbar .ms-spacer { flex: 1 1 auto; }
    .ms-btn-primary { background: #005B99; color: #fff; border: none; border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .35rem; cursor: pointer; transition: background .15s; }
    .ms-btn-primary:hover { background: #003d6b; color: #fff; }

    .ms-content { flex: 1 1 0; min-height: 0; display: flex; flex-direction: column; }
    .ms-dropzone { margin: .75rem .85rem 0; border: 1.5px dashed #cbd5e1; background: #fafbff; border-radius: .5rem; padding: .85rem 1rem; font-size: var(--fs-xs); color: #475569; display: flex; align-items: center; gap: .65rem; flex: 0 0 auto; }
    .ms-dropzone.dragging { border-color: #005B99; background: #eff6ff; color: #005B99; }
    .ms-dropzone .ms-dropzone-icon { color: #94a3b8; flex-shrink: 0; }
    .ms-table-wrap { flex: 1 1 0; min-height: 0; overflow: auto; padding: .35rem .85rem .85rem; }
    .ms-table-wrap table { width: 100%; font-size: var(--fs-sm); }
    .ms-table-wrap thead { position: sticky; top: 0; background: #f8fafc; z-index: 1; }
    .ms-table-wrap th { font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: .04em; color: #6b7280; font-weight: 600; padding: .55rem .65rem; text-align: start; border-bottom: 1px solid #e5e7eb; }
    .ms-table-wrap td { padding: .5rem .65rem; border-bottom: 1px solid #f3f4f6; color: #374151; }
    .ms-table-wrap tbody tr:hover td { background: #f9fafb; }

    .ms-state { flex: 1 1 0; display: flex; align-items: center; justify-content: center; flex-direction: column; padding: 1.5rem; }
    /* When myspace.js toggles `.hidden` on a state container we have to
       beat the .ms-state { display: flex } above on specificity. */
    .ms-state.hidden, .ms-table-wrap.hidden { display: none !important; }
    .ms-state .ms-state-icon { width: 64px; height: 64px; border-radius: 50%; background: #f1f5f9; display: flex; align-items: center; justify-content: center; margin-bottom: .85rem; color: #94a3b8; }
    .ms-state h3 { margin: 0; font-size: var(--fs-sm); font-weight: 600; color: #334155; }
    .ms-state p { margin: .35rem 0 0; font-size: var(--fs-xs); color: #64748b; max-width: 380px; text-align: center; }
    .ms-state .ms-btn-primary { margin-top: 1rem; }

    @@media (max-width: 900px) {
        .ms-shell { flex-direction: column; height: auto; min-height: 0; }
        .ms-rail { flex: 0 0 auto; }
        .ms-rail-categories { max-height: 200px; }
    }
</style>

<div class="ms-shell">

    @* ─────────── Left rail: user card + category facets ─────────── *@
    <aside class="ms-rail">
        <div class="ms-rail-user">
            <div class="ms-avatar">
                <i data-lucide="user" class="w-5 h-5" aria-hidden="true"></i>
            </div>
            <div style="min-width:0;flex:1;">
                <h2>@(User.Identity?.Name ?? (isRtl ? "المستخدم" : "User"))</h2>
                <p>@(isRtl ? "مكتبة الوثائق الشخصية" : "Personal document library")</p>
            </div>
        </div>

        <div class="ms-rail-section-title">@(isRtl ? "التصنيفات" : "Categories")</div>
        <nav class="ms-rail-categories" aria-label="@(isRtl ? "التصنيفات" : "Categories")">
            @foreach (var cat in categories)
            {
                var icon = cat.Value switch
                {
                    ""          => "files",
                    "General"   => "file",
                    "Policy"    => "shield",
                    "Procedure" => "git-branch",
                    "Standard"  => "check-circle",
                    "Evidence"  => "clipboard-check",
                    "Report"    => "bar-chart-3",
                    _           => "file"
                };
                <button type="button"
                        class="ms-cat @(cat.Value == "" ? "active" : "")"
                        data-ms-cat="@cat.Value"
                        aria-pressed="@(cat.Value == "" ? "true" : "false")">
                    <i data-lucide="@icon" class="ms-cat-icon" aria-hidden="true"></i>
                    <span class="ms-cat-label">@cat.Label</span>
                </button>
            }
        </nav>

        <div class="ms-rail-footer">
            <span id="msDocCount">0 @(isRtl ? "ملفات" : "files")</span>
        </div>

        @* Hidden select — myspace.js reads the active value from here.
           Sidebar buttons sync into it via click. *@
        <select id="msCategoryFilter" style="display:none;">
            @foreach (var cat in categories)
            {
                <option value="@cat.Value">@cat.Label</option>
            }
        </select>
    </aside>

    @* ─────────── Main pane: toolbar + drop zone + table/states ─────────── *@
    <section class="ms-main">
        <div class="ms-toolbar">
            <div class="ms-search">
                <i data-lucide="search" class="ms-search-icon" aria-hidden="true"></i>
                <input type="text" id="msSearchInput"
                       placeholder="@(isRtl ? "ابحث بالاسم أو الوصف أو الوسم..." : "Search by name, description, or tag...")"
                       aria-label="@(isRtl ? "بحث" : "Search files")" />
            </div>
            <div class="ms-spacer"></div>
            <button type="button" id="btnUploadFiles" class="ms-btn-primary">
                <i data-lucide="upload" class="w-4 h-4" aria-hidden="true"></i>
                @(isRtl ? "رفع ملفات" : "Upload Files")
            </button>
        </div>

        <div class="ms-content">
            @* Persistent drop zone — myspace.js toggles 'dragging' on drag-over *@
            <div id="msDropZone" class="ms-dropzone">
                <i data-lucide="upload-cloud" class="ms-dropzone-icon" aria-hidden="true" style="width:20px;height:20px;"></i>
                <span>@(isRtl ? "أفلت الملفات هنا للرفع، أو استخدم زر «رفع ملفات»" : "Drop files here to upload, or use the Upload Files button")</span>
            </div>

            @* Hidden file input — opened by btnUploadFiles / btnUploadFirst *@
            <input type="file" id="msFileInput" class="hidden" multiple
                   aria-label="@(isRtl ? "اختر ملفات للرفع" : "Choose files to upload")"
                   accept=".pdf,.xlsx,.xls,.docx,.doc,.png,.jpg,.jpeg,.gif,.bmp,.csv,.pptx,.ppt,.txt" />

            @* Empty state — myspace.js shows when zero results *@
            <div id="msEmptyState" class="ms-state hidden">
                <div class="ms-state-icon">
                    <i data-lucide="folder-plus" class="w-8 h-8" aria-hidden="true"></i>
                </div>
                <h3>@(isRtl ? "مساحتك فارغة" : "Your space is empty")</h3>
                <p>@(isRtl ? "ابدأ برفع المستندات لاستخدامها عند ربطها بعمليات أو سجلات أخرى" : "Upload documents so you can re-use them when linking to processes and other records")</p>
                <button type="button" id="btnUploadFirst" class="ms-btn-primary">
                    <i data-lucide="upload" class="w-4 h-4" aria-hidden="true"></i>
                    @(isRtl ? "ارفع أول ملف" : "Upload your first file")
                </button>
            </div>

            @* Loading state — myspace.js hides on first response *@
            <div id="msLoading" class="ms-state">
                <div class="inline-block animate-spin rounded-full h-8 w-8" style="border:2px solid #005B99;border-top-color:transparent;"></div>
            </div>

            @* Documents table — myspace.js renders rows into #msTableBody *@
            <div id="msTableWrap" class="ms-table-wrap hidden">
                <table>
                    <thead>
                        <tr>
                            <th style="width:42px"></th>
                            <th>@(isRtl ? "اسم الملف" : "File Name")</th>
                            <th>@(isRtl ? "الفئة" : "Category")</th>
                            <th>@(isRtl ? "الحجم" : "Size")</th>
                            <th>@(isRtl ? "تاريخ الرفع" : "Uploaded")</th>
                            <th style="width:120px;text-align:end;"></th>
                        </tr>
                    </thead>
                    <tbody id="msTableBody"></tbody>
                </table>
            </div>
        </div>
    </section>
</div>

@* Upload progress toast — fixed-position, unchanged *@
<div id="msUploadToast" class="fixed bottom-4 @(isRtl ? "left-4" : "right-4") w-80 bg-white rounded-lg shadow-lg border border-gray-200 p-3 hidden" style="z-index:1080;">
    <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-semibold text-gray-700">@(isRtl ? "جارٍ الرفع..." : "Uploading...")</span>
        <span id="msUploadPct" class="text-xs text-blue-600 font-semibold">0%</span>
    </div>
    <div class="h-1.5 bg-gray-200 rounded-full overflow-hidden">
        <div id="msUploadBar" class="h-full" style="width:0%;background:#005B99;transition:width .15s;"></div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.CspNonce()">
        // Localized labels consumed by myspace.js — unchanged contract.
        window.__myspaceLabels = {
            files: @Html.Raw("'" + (isRtl ? "ملفات" : "files") + "'"),
            confirmDeleteTitle: @Html.Raw("'" + (isRtl ? "حذف الملف" : "Delete file") + "'"),
            confirmDelete: @Html.Raw("'" + (isRtl ? "هل تريد حذف هذا الملف؟ لن يؤثر على السجلات المرتبطة به." : "Delete this file? Existing links to it will not be affected.") + "'"),
            confirmDeleteBtn: @Html.Raw("'" + (isRtl ? "حذف" : "Delete") + "'"),
            cancel: @Html.Raw("'" + (isRtl ? "إلغاء" : "Cancel") + "'"),
            deleteFailed: @Html.Raw("'" + (isRtl ? "فشل الحذف" : "Delete failed") + "'"),
            uploadFailed: @Html.Raw("'" + (isRtl ? "فشل الرفع" : "Upload failed") + "'"),
            categories: {
                General:   @Html.Raw("'" + (isRtl ? "عام" : "General") + "'"),
                Policy:    @Html.Raw("'" + (isRtl ? "سياسة" : "Policy") + "'"),
                Procedure: @Html.Raw("'" + (isRtl ? "إجراء" : "Procedure") + "'"),
                Standard:  @Html.Raw("'" + (isRtl ? "معيار" : "Standard") + "'"),
                Evidence:  @Html.Raw("'" + (isRtl ? "أدلة" : "Evidence") + "'"),
                Report:    @Html.Raw("'" + (isRtl ? "تقرير" : "Report") + "'")
            },
            download: @Html.Raw("'" + (isRtl ? "تنزيل" : "Download") + "'"),
            delete:   @Html.Raw("'" + (isRtl ? "حذف" : "Delete") + "'")
        };

        // Bridge: sidebar category buttons -> existing #msCategoryFilter <select>.
        // myspace.js listens on the select's 'change' event. We forward clicks
        // by setting the select value and dispatching the same event, so the
        // existing filter logic doesn't need to change.
        (function () {
            var select = document.getElementById('msCategoryFilter');
            var buttons = document.querySelectorAll('.ms-cat[data-ms-cat]');
            function setActive(btn) {
                buttons.forEach(function (b) {
                    b.classList.toggle('active', b === btn);
                    b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
                });
            }
            buttons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var value = btn.getAttribute('data-ms-cat') || '';
                    if (select && select.value !== value) {
                        select.value = value;
                        select.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                    setActive(btn);
                });
            });
            // Reverse bridge: if myspace.js or any other code mutates the
            // select directly, reflect it back into the sidebar.
            if (select) {
                select.addEventListener('change', function () {
                    var match = document.querySelector('.ms-cat[data-ms-cat="' + select.value + '"]');
                    if (match) setActive(match);
                });
            }
        })();
    </script>
    <script src="~/js/myspace.js" asp-append-version="true"></script>
    <script nonce="@Context.CspNonce()">lucide.createIcons();</script>
}
