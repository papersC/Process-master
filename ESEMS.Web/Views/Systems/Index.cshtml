@model IEnumerable<ESEMS.Web.Models.Services.SystemDefinition>
@{
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isRtl = culture.StartsWith("ar");
    ViewData["Title"] = isRtl ? "الأنظمة" : "Systems";
    var usage = ViewBag.Usage as Dictionary<string, int> ?? new Dictionary<string, int>();
    var total = Model.Count();
    var active = Model.Count(s => s.IsActive);
    var linked = usage.Values.Sum();
}

<style>
    .lt-shell { display:flex; flex-direction:column; gap:.6rem; }
    .lt-header { display:flex; align-items:center; justify-content:space-between; padding:.25rem 0 .4rem; border-bottom:1px solid #e5e7eb; }
    .lt-header h1 { margin:0; font-size:var(--fs-base); font-weight:600; color:#111827; display:flex; align-items:center; gap:.5rem; }
    .lt-header p { margin:0; font-size:var(--fs-xs); color:#6b7280; }
    .lt-btn { border-radius:.375rem; padding:.42rem .85rem; font-size:var(--fs-xs); font-weight:600; display:inline-flex; align-items:center; gap:.4rem; cursor:pointer; text-decoration:none; border:none; }
    .lt-btn-primary { background:#005B99; color:#fff; } .lt-btn-primary:hover { background:#003d6b; color:#fff; }
    .lt-kpi-strip { display:flex; gap:.5rem; padding:.55rem .65rem; background:#fff; border:1px solid #e5e7eb; border-radius:.5rem; flex-wrap:wrap; }
    .lt-kpi { display:flex; align-items:center; gap:.55rem; padding:.25rem .65rem; flex:1 1 180px; min-width:180px; border-inline-end:1px dashed #e5e7eb; }
    .lt-kpi:last-child { border-inline-end:none; }
    .lt-kpi-icon { width:34px; height:34px; border-radius:.375rem; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0; }
    .lt-kpi-icon.kpi-blue { background:#eff6ff; color:#005B99; }
    .lt-kpi-icon.kpi-green { background:#ecfdf5; color:#047857; }
    .lt-kpi-icon.kpi-purple { background:#f5f3ff; color:#7c3aed; }
    .lt-kpi-num { font-size:var(--fs-base); font-weight:700; color:#111827; line-height:1; }
    .lt-kpi-label { font-size:var(--fs-xs); color:#6b7280; text-transform:uppercase; letter-spacing:.03em; }
    .lt-card { background:#fff; border:1px solid #e5e7eb; border-radius:.5rem; overflow:hidden; }
    .lt-table-wrap table { width:100%; font-size:var(--fs-sm); border-collapse:collapse; }
    .lt-table-wrap thead { position:sticky; top:0; background:#f8fafc; }
    .lt-table-wrap th { font-size:var(--fs-xs); text-transform:uppercase; letter-spacing:.04em; color:#6b7280; font-weight:600; padding:.55rem .75rem; text-align:start; border-bottom:1px solid #e5e7eb; white-space:nowrap; }
    .lt-table-wrap td { padding:.5rem .75rem; border-bottom:1px solid #f3f4f6; color:#374151; vertical-align:middle; }
    .lt-table-wrap tbody tr:hover td { background:#f9fafb; }
    .lt-pill { display:inline-block; padding:.15rem .5rem; font-size:var(--fs-xs); font-weight:600; border-radius:.25rem; }
    .lt-pill-code { background:#eff6ff; color:#1d4ed8; }
    .lt-pill-on { background:#ecfdf5; color:#047857; }
    .lt-pill-off { background:#f3f4f6; color:#6b7280; }
    .lt-actions { display:inline-flex; gap:.35rem; }
    .lt-actions a, .lt-actions button { color:#005B99; padding:.2rem; border-radius:.25rem; background:none; border:none; cursor:pointer; }
    .lt-actions a:hover, .lt-actions button:hover { background:#eff6ff; }
    .lt-actions button.danger { color:#b91c1c; }
    .lt-actions button.danger:hover { background:#fef2f2; }
</style>

<div class="lt-shell">
    <div class="lt-header">
        <div>
            <h1><i data-lucide="server" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "الأنظمة" : "Systems")</h1>
            <p>@(isRtl ? "أنظمة تقنية المعلومات المتاحة للاختيار في العمليات والمهام." : "IT systems available to select on processes and tasks.")</p>
        </div>
        <a asp-action="Create" class="lt-btn lt-btn-primary">
            <i data-lucide="plus" class="w-4 h-4" aria-hidden="true"></i>@(isRtl ? "إضافة نظام" : "Add System")
        </a>
    </div>

    <div class="lt-kpi-strip">
        <div class="lt-kpi">
            <div class="lt-kpi-icon kpi-blue"><i data-lucide="server" class="w-4 h-4"></i></div>
            <div><div class="lt-kpi-num">@total</div><div class="lt-kpi-label">@(isRtl ? "إجمالي الأنظمة" : "Total")</div></div>
        </div>
        <div class="lt-kpi">
            <div class="lt-kpi-icon kpi-green"><i data-lucide="check-circle-2" class="w-4 h-4"></i></div>
            <div><div class="lt-kpi-num">@active</div><div class="lt-kpi-label">@(isRtl ? "نشطة" : "Active")</div></div>
        </div>
        <div class="lt-kpi">
            <div class="lt-kpi-icon kpi-purple"><i data-lucide="git-branch" class="w-4 h-4"></i></div>
            <div><div class="lt-kpi-num">@linked</div><div class="lt-kpi-label">@(isRtl ? "استخدامات مرتبطة" : "Linked Uses")</div></div>
        </div>
    </div>

    <div class="lt-card">
        <div class="lt-table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>@(isRtl ? "الرمز" : "Code")</th>
                        <th>@(isRtl ? "الاسم" : "Name")</th>
                        <th>@(isRtl ? "النوع" : "Type")</th>
                        <th style="text-align:center;">@(isRtl ? "الاستخدام" : "Used By")</th>
                        <th>@(isRtl ? "الترتيب" : "Order")</th>
                        <th>@(isRtl ? "الحالة" : "Status")</th>
                        <th style="text-align:end;">@(isRtl ? "إجراءات" : "Actions")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var s in Model)
                {
                    var used = usage.TryGetValue(s.Id, out var u) ? u : 0;
                    <tr>
                        <td><span class="lt-pill lt-pill-code">@s.Code</span></td>
                        <td>
                            <div style="font-weight:600;color:#111827;">@(isRtl ? s.NameAr : s.NameEn)</div>
                            @if (!string.IsNullOrEmpty(s.Vendor))
                            {
                                <div style="font-size:var(--fs-xs);color:#6b7280;">@s.Vendor@(string.IsNullOrEmpty(s.SystemVersion) ? "" : $" · {s.SystemVersion}")</div>
                            }
                        </td>
                        <td>@(string.IsNullOrEmpty(s.SystemType) ? "—" : s.SystemType)</td>
                        <td style="text-align:center;">@used</td>
                        <td>@s.DisplayOrder</td>
                        <td>
                            @if (s.IsActive)
                            {
                                <span class="lt-pill lt-pill-on">@(isRtl ? "نشط" : "Active")</span>
                            }
                            else
                            {
                                <span class="lt-pill lt-pill-off">@(isRtl ? "متوقف" : "Inactive")</span>
                            }
                        </td>
                        <td style="text-align:end;">
                            <div class="lt-actions">
                                <a asp-action="Edit" asp-route-id="@s.Id" title="@(isRtl ? "تعديل" : "Edit")"><i data-lucide="edit-3" class="w-4 h-4"></i></a>
                                <form asp-action="Delete" asp-route-id="@s.Id" method="post" style="display:inline;" onsubmit="return confirm('@(isRtl ? "حذف هذا النظام؟" : "Delete this system?")');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="danger" title="@(isRtl ? "حذف" : "Delete")"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" style="text-align:center;color:#6b7280;padding:1.5rem;">@(isRtl ? "لا توجد أنظمة بعد." : "No systems yet.")</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
