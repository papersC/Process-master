    <script nonce="@Context.CspNonce()">
        // Initialize Lucide icons
        lucide.createIcons();

        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            const verticalMenuBtn = document.getElementById('vertical-menu-btn');
	            const topbar = document.getElementById('page-topbar');

	            function syncTopbarHeight() {
	                if (!topbar) return;
	                const h = topbar.offsetHeight || 0;
	                if (h > 0) {
	                    document.documentElement.style.setProperty('--esems-topbar-height', h + 'px');
	                }
	            }

	            syncTopbarHeight();
	            window.addEventListener('resize', syncTopbarHeight);

            // Unified sidebar toggle (mobile and desktop)
            if (verticalMenuBtn) {
                verticalMenuBtn.addEventListener('click', function() {
                    // On mobile: toggle sidebar open/close
                    if (window.innerWidth < 768) {
                        sidebar.classList.toggle('open');
                        overlay.classList.toggle('active');
                    } else {
	                        // On desktop: toggle sidebar collapsed/expanded (CSS handles content offset)
                        sidebar.classList.toggle('collapsed');
                        // Re-initialize icons after collapse
                        setTimeout(() => lucide.createIcons(), 100);
                    }
                });
            }

            // Close sidebar when clicking overlay (mobile)
            if (overlay) {
                overlay.addEventListener('click', function() {
                    sidebar.classList.remove('open');
                    overlay.classList.remove('active');
                });
            }

            // DataTables initialization with localization
            if (typeof $.fn.dataTable !== 'undefined' && typeof window.ESEMS.Localization.getDataTablesConfig === 'function') {
                // Skip empty tables (only a colspan empty-state row) — initializing
                // DataTables on them throws "Incorrect column count" (tn/18) because
                // the placeholder's single cell doesn't match the header column count.
                $('.datatable').filter(function () {
                    return Array.prototype.some.call(this.querySelectorAll('tbody > tr'),
                        function (r) { return !r.querySelector('td[colspan]'); });
                }).DataTable({
                    language: window.ESEMS.Localization.getDataTablesConfig(),
                    pagingType: 'full_numbers',
                    pageLength: 10
                });
            }

            // Collapsible sidebar menu functionality
            const menuToggles = document.querySelectorAll('.nav-menu-toggle');
            menuToggles.forEach(toggle => {
                toggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    const menuId = this.getAttribute('data-menu');
                    const submenu = document.getElementById(menuId);
                    const arrow = this.querySelector('.menu-arrow');

                    if (submenu) {
                        // Accordion behaviour: opening one section collapses the
                        // rest. Decide intent first, then close every submenu
                        // (and reset its arrow), then open the clicked one —
                        // unless it was already open, in which case it stays
                        // closed (click-to-toggle preserved).
                        const willOpen = !submenu.classList.contains('open');

                        menuToggles.forEach(t => {
                            const sm = document.getElementById(t.getAttribute('data-menu'));
                            if (sm) sm.classList.remove('open');
                            const ar = t.querySelector('.menu-arrow');
                            if (ar) ar.classList.remove('rotate-180');
                        });

                        if (willOpen) {
                            submenu.classList.add('open');
                            if (arrow) arrow.classList.add('rotate-180');
                        }

                        // Re-initialize icons for newly visible items
                        setTimeout(() => lucide.createIcons(), 100);
                    }
                });
            });

            // Quick Search (Ctrl+K) functionality
            document.addEventListener('keydown', function(e) {
                if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                    e.preventDefault();
                    const searchModal = document.getElementById('quickSearchModal');
                    if (searchModal) {
                        const bsModal = new bootstrap.Modal(searchModal);
                        bsModal.show();
                        setTimeout(() => {
                            document.getElementById('quickSearchInput')?.focus();
                        }, 200);
                    }
                }
            });

            // Toast auto-dismiss after 5 seconds
            document.querySelectorAll('.esems-toast').forEach(function(toast) {
                setTimeout(function() {
                    toast.classList.add('esems-toast-hiding');
                    setTimeout(function() { toast.remove(); }, 400);
                }, 5000);
            });

            // Back to Top button
            var backToTopBtn = document.getElementById('backToTopBtn');
            var mainContent = document.getElementById('main-content');
            if (backToTopBtn && mainContent) {
                mainContent.addEventListener('scroll', function() {
                    if (mainContent.scrollTop > 300) {
                        backToTopBtn.classList.add('visible');
                    } else {
                        backToTopBtn.classList.remove('visible');
                    }
                });
                backToTopBtn.addEventListener('click', function() {
                    mainContent.scrollTo({ top: 0, behavior: 'smooth' });
                });
            }

            // Re-create icons for breadcrumb
            lucide.createIcons();
        });

	        function lockScreen() { /* no-op (kept for ERM-compatible SetLanguage) */ }
	        function unLockScreen() { /* no-op (kept for ERM-compatible SetLanguage) */ }

	        function SetLanguage(culture) {
	            lockScreen();
	            const tokenEl = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
	            const antiForgeryToken = tokenEl ? tokenEl.value : '';

	            // F-CC-005: read PathBase from the meta tag so this works under
	            // sub-app hosting (ejraa360.com/App). Also send the returnUrl
	            // *without* the PathBase prefix (the server's redirectUrl is
	            // resolved via the cookie + the same PathBase, so re-prefixing
	            // it on the client side would double up to /App/App/…).
	            const pathBaseMeta = document.querySelector('meta[name="path-base"]');
	            const pathBase = (pathBaseMeta && pathBaseMeta.getAttribute('content')) || '';
	            const fullPath = window.location.pathname + window.location.search + window.location.hash;
	            const returnUrl = pathBase && fullPath.indexOf(pathBase) === 0
	                ? fullPath.substring(pathBase.length) || '/'
	                : fullPath;

	            fetch(pathBase + '/Base/ChangeLanguage', {
	                method: 'POST',
	                headers: {
	                    'Content-Type': 'application/json',
	                    // BaseController.ChangeLanguage ignores antiforgery, but keeping the header matches ERM behavior
	                    'RequestVerificationToken': antiForgeryToken
	                },
	                body: JSON.stringify({ culture: culture, returnUrl: returnUrl })
	            })
	            .then(r => {
	                if (!r.ok) throw new Error('HTTP error! Status: ' + r.status);
	                return r.json();
	            })
	            .then(data => {
	                if (data && data.success) {
	                    // Server returns a path relative to PathBase; re-prefix so
	                    // the browser navigates to the right place under /App.
	                    const target = data.redirectUrl || '/';
	                    const final = target.startsWith('http')
	                        ? target
	                        : pathBase + (target.startsWith('/') ? target : '/' + target);
	                    window.location.href = final;
	                }
	            })
	            .catch(err => {
	                console.error('SetLanguage error:', err);
	                unLockScreen();
	            });
	        }

	        // Backward compatibility (older pages call changeLanguage)
	        function changeLanguage(culture) { SetLanguage(culture); }

	        function ClearClientCache() {
	            // UX-017: confirm before wiping storage + reloading (destructive,
	            // previously fired with no warning). Mirrors the SweetAlert
	            // confirm pattern used by list-page delete actions.
	            const doClear = () => {
	                try { localStorage.clear(); } catch (e) { }
	                try { sessionStorage.clear(); } catch (e) { }

	                const forceReload = () => {
	                    try {
	                        const url = new URL(window.location.href);
	                        url.searchParams.set('_', Date.now().toString());
	                        window.location.replace(url.toString());
	                    } catch (e) {
	                        window.location.reload();
	                    }
	                };

	                if (window.caches && caches.keys) {
	                    caches.keys()
	                        .then(keys => Promise.all(keys.map(k => caches.delete(k))))
	                        .finally(forceReload);
	                } else {
	                    forceReload();
	                }
	            };

	            if (typeof Swal !== 'undefined') {
	                Swal.fire({
	                    title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Confirm_ClearCacheTitle"].Value)),
	                    text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Confirm_ClearCacheText"].Value)),
	                    icon: 'warning',
	                    showCancelButton: true,
	                    confirmButtonColor: '#005B99',
	                    cancelButtonColor: '#6b7280',
	                    confirmButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Confirm_ClearCacheConfirm"].Value)),
	                    cancelButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Button_Cancel"].Value))
	                }).then((result) => { if (result.isConfirmed) doClear(); });
	            } else {
	                doClear();
	            }
	        }

        // Quick Search functionality
        // Shared HTML-escape used by every spot that interpolates server data
        // into innerHTML below. Without it the search index becomes a stored-XSS
        // vector — any user with Create permission could put <script> in a name
        // and execute on every searcher's page.
        function spEscapeHtml(v) {
            if (v == null) return '';
            return String(v).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
        }
        function spSafeUrl(u) {
            // Block javascript: / data: / vbscript: scheme injection in href.
            const s = String(u || '');
            if (/^\s*(javascript|data|vbscript):/i.test(s)) return '#';
            return spEscapeHtml(s);
        }
        let searchTimeout;
        const quickSearchInput = document.getElementById('quickSearchInput');
        const quickSearchResults = document.getElementById('quickSearchResults');

        if (quickSearchInput) {
            quickSearchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                const query = this.value.trim();

                if (query.length < 2) {
                    quickSearchResults.innerHTML = `
                        <div class="text-center text-muted py-4">
                            <i data-lucide="command" class="h-8 w-8 mb-2 mx-auto d-block"></i>
                            <p class="mb-1">@(isRtl ? "اكتب للبحث أو استخدم الاختصارات" : "Type to search or use shortcuts")</p>
                        </div>`;
                    lucide.createIcons();
                    return;
                }

                searchTimeout = setTimeout(() => performQuickSearch(query), 300);
            });

            // Close modal on ESC
            document.getElementById('quickSearchModal')?.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    bootstrap.Modal.getInstance(this)?.hide();
                }
            });
        }

        async function performQuickSearch(query) {
            quickSearchResults.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>';

            try {
                const response = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
                const data = await response.json();

                if (data.results && data.results.length > 0) {
                    quickSearchResults.innerHTML = data.results.map((item, index) => `
                        <a href="${spSafeUrl(item.url)}" class="d-flex align-items-center gap-3 p-3 text-decoration-none text-dark hover-bg-light rounded ${index === 0 ? 'bg-light' : ''}" data-search-item>
                            <div class="flex-shrink-0">
                                <span class="badge bg-${item.type === 'Process' ? 'primary' : item.type === 'Service' ? 'success' : item.type === 'Risk' ? 'danger' : 'secondary'}">${spEscapeHtml(item.type)}</span>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-medium">${spEscapeHtml(item.name)}</div>
                                <small class="text-muted">${spEscapeHtml(item.description || '')}</small>
                            </div>
                            <i data-lucide="@(isRtl ? "arrow-left" : "arrow-right")" class="h-4 w-4 text-muted"></i>
                        </a>
                    `).join('');
                } else {
                    quickSearchResults.innerHTML = `
                        <div class="text-center text-muted py-4">
                            <i data-lucide="search-x" class="h-8 w-8 mb-2 mx-auto d-block"></i>
                            <p>@(isRtl ? "لا توجد نتائج" : "No results found")</p>
                        </div>`;
                }
                lucide.createIcons();
            } catch (error) {
                console.error('Search error:', error);
                quickSearchResults.innerHTML = '<div class="text-center text-danger py-4">' + spEscapeHtml(window.ESEMS_I18N.searchFailed) + '</div>';
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    <script nonce="@Context.CspNonce()">
        // ═══════════════════════════════════════════════════════════════
        // ESEMS table enhancer (DataTables) — global init for every
        // .esems-datatable across the app. Provides sortable headers,
        // client-side search across all columns, pagination, per-page
        // selector, empty-state, and full Arabic/RTL support.
        // ═══════════════════════════════════════════════════════════════
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof jQuery === 'undefined' || typeof jQuery.fn.DataTable === 'undefined') return;

            var isRtl = document.documentElement.dir === 'rtl';

            // Full bilingual language pack — every user-visible string.
            var languageEn = {
                search: '',
                searchPlaceholder: 'Search all columns…',
                lengthMenu: 'Rows per page _MENU_',
                info: 'Showing _START_–_END_ of _TOTAL_',
                infoEmpty: 'No records',
                infoFiltered: '(filtered from _MAX_ total)',
                zeroRecords: 'No matching records found',
