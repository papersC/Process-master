@inject Microsoft.Extensions.Configuration.IConfiguration AppConfig
@{
    var culture = CultureInfo.CurrentUICulture.Name;
    var isRtl = culture.StartsWith("ar");
    var dir = isRtl ? "rtl" : "ltr";
    var lang = isRtl ? "ar" : "en";

    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    // Hide every AI surface (top-bar button, floating bubble, sidebar link)
    // when AzureOpenAI isn't configured. Buttons that would just 500 on click
    // are worse than no buttons — confuses users and looks broken on demos.
    // Treat known-stub values as also-disabled.
    var aiApiKey = AppConfig["AzureOpenAI:ApiKey"];
    var aiEnabled = !string.IsNullOrWhiteSpace(aiApiKey)
        && !string.Equals(aiApiKey, "YOUR_API_KEY_HERE", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(aiApiKey, "REPLACE_ME", StringComparison.OrdinalIgnoreCase);
    // F-CC-LO-7: expose to child views so includes of _AiAnalysisPanel
    // (and any other AI-only markup) can short-circuit when AI is unconfigured
    // instead of shipping dead DOM nodes / dead inline scripts.
    ViewData["AiEnabled"] = aiEnabled;
    var displayName = isAuthenticated ? (User.Identity?.Name ?? Shared["Label_User"].Value) : Shared["Label_Guest"].Value;
    var userEmail = isAuthenticated
        ? (User.FindFirst(ClaimTypes.Email)?.Value ?? User.Identity?.Name ?? "admin@company.com")
        : "admin@company.com";

    // Derive 1–2 letter initials for the avatar. Tries (in order):
    //   1. First letter of GivenName + first letter of Surname (best — e.g. "KA")
    //   2. First letters of the first two whitespace-separated tokens of
    //      displayName (handles "Khaled Almiani" or "محمد علي")
    //   3. First letter of displayName (covers usernames like "admin")
    //   4. The literal "G" for unauthenticated guests, kept short to fit the circle
    string ComputeInitials(string source)
    {
        if (string.IsNullOrWhiteSpace(source)) return "?";
        // Strip the email-domain part if a username was actually an email.
        var at = source.IndexOf('@');
        if (at > 0) source = source.Substring(0, at);
        // Replace dots / underscores so "khaled.almiani" → "khaled almiani".
        var parts = source.Replace('.', ' ').Replace('_', ' ')
            .Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        if (parts.Length == 1) return parts[0].Length > 0 ? parts[0].Substring(0, 1).ToUpperInvariant() : "?";
        return (parts[0].Substring(0, 1) + parts[^1].Substring(0, 1)).ToUpperInvariant();
    }
    var givenName = User?.FindFirst(ClaimTypes.GivenName)?.Value;
    var surname   = User?.FindFirst(ClaimTypes.Surname)?.Value;
    var userInitials = (!string.IsNullOrWhiteSpace(givenName) && !string.IsNullOrWhiteSpace(surname))
        ? (givenName.Substring(0, 1) + surname.Substring(0, 1)).ToUpperInvariant()
        : ComputeInitials(displayName);
    var roles = isAuthenticated
        ? string.Join(", ", User.Claims
            .Where(c => c.Type == ClaimTypes.Role)
            .Select(c => c.Value)
            .Distinct())
        : string.Empty;

    // Avatar initial — prefer the user's display name, fall back to email,
    // then '?'. Two chars for "First Last", one otherwise.
    string AvatarInitials()
    {
        string Source(string? s) => string.IsNullOrWhiteSpace(s) ? "" : s.Trim();
        var src = Source(displayName);
        if (src.Length == 0) src = Source(userEmail);
        if (src.Length == 0) return "?";
        var parts = src.Split(new[] { ' ', '.', '_', '@' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2 && parts[0].Length > 0 && parts[1].Length > 0)
            return (parts[0][0].ToString() + parts[1][0]).ToUpperInvariant();
        return src.Substring(0, 1).ToUpperInvariant();
    }
    var avatarInitial = AvatarInitials();

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
	    ViewData["Title"] ??= "Dashboard";
	    var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";

	    // Keep ERM header variables (so we can copy the header markup 1:1)
	    ViewBag.DisplayName = displayName;
	    ViewBag.UserRole = roles;

    // ── Sidebar permission gating ──
    // Read the user's Permission claims into a fast lookup so we can
    // conditionally disable sidebar sections. Items the user lacks
    // access to are rendered grayed-out with a lock icon rather than
    // hidden, per the user's request ("visible but disabled").
    var userPerms = new HashSet<string>(
        isAuthenticated
            ? User.FindAll("Permission").Select(c => c.Value)
            : Enumerable.Empty<string>(),
        StringComparer.Ordinal);
    // Also check legacy ClaimTypes.Role for sessions signed in before
    // Plan X emitted Permission claims. ADMIN role = full access.
    var isLegacyAdmin = isAuthenticated && User.IsInRole("ADMIN");
    bool HasModuleAccess(string perm) =>
        isLegacyAdmin
        || userPerms.Contains("*.*")
        || userPerms.Contains(perm)
        || (perm.IndexOf('.') is int d && d > 0 && userPerms.Contains(perm[..d] + ".*"));

    var canProcess     = HasModuleAccess("Process.View");
    var canService     = HasModuleAccess("Service.View");
    var canAsset       = HasModuleAccess("Asset.View");
    var canRisk        = HasModuleAccess("Risk.View");
    var canImprovement = HasModuleAccess("Improvement.View");
    var canAi          = HasModuleAccess("Ai.View");
    var canWorkload    = HasModuleAccess("Workload.View");
    var canAdmin       = HasModuleAccess("Settings.View") || HasModuleAccess("Users.View");
    var canIncident    = HasModuleAccess("Incident.View");
    var canProblem     = HasModuleAccess("Problem.View");
    var canWorkflow    = HasModuleAccess("Workflow.View");
    // Action/cross-module gates so sidebar links match what the target controller
    // actually requires (avoids "visible link → 403"). Mirror the controller policies:
    var canChangeRequest  = HasModuleAccess("ChangeRequest.View"); // ChangeRequestsController
    var canWorkloadCreate = HasModuleAccess("Workload.Create");    // WorkloadAnalysis/Create
    var canWorkloadConfig = HasModuleAccess("Workload.Edit");      // WorkloadAnalysis/Config
    // "My Approvals" → WorkflowController is [Authorize(CanApprove)]: ANY *.Approve
    // permission (or the *.* admin claim), NOT Workflow.View.
    var canApprove = isLegacyAdmin || userPerms.Contains("*.*")
        || userPerms.Any(p => p.EndsWith(".Approve", StringComparison.Ordinal));

    // F-CC-001: tooltip text for locked sidebar sections names the specific
    // permission the user is missing, so they can request it from their admin.
    string LockTitle(string perm) => isRtl
        ? $"الوصول مقيد — تتطلب صلاحية: {perm}"
        : $"Access restricted — requires permission: {perm}";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="path-base" content="@Context.Request.PathBase" />
    <title>@pageTitle - ESEMS</title>
		    <link rel="preconnect" href="https://fonts.googleapis.com" />
		    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Poppins:300,400,500,600,700&display=swap" />
		    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" />

	    @* Use the same Skote CSS bundle as ERM so the topbar/header looks identical *@
