    <script nonce="@Context.CspNonce()">
        // SEC-007: attach the anti-forgery token to every same-origin mutating
        // request so the global AutoValidateAntiforgeryToken filter accepts AJAX
        // (notifications, MySpace DELETE, AI fetches, etc.). Header name is
        // configured server-side (AntiforgeryOptions.HeaderName).
        (function () {
            function csrfToken() {
                var el = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            }
            var _fetch = window.fetch;
            if (_fetch) {
                window.fetch = function (input, init) {
                    init = init || {};
                    var method = (init.method || (input && typeof input !== 'string' && input.method) || 'GET').toUpperCase();
                    var url = (typeof input === 'string') ? input : (input && input.url) || '';
                    var external = /^https?:\/\//i.test(url) && url.indexOf(window.location.origin) !== 0;
                    if (!external && ['POST', 'PUT', 'DELETE', 'PATCH'].indexOf(method) !== -1) {
                        var h = new Headers(init.headers || (typeof input !== 'string' && input ? input.headers : undefined) || {});
                        if (!h.has('RequestVerificationToken')) h.set('RequestVerificationToken', csrfToken());
                        init.headers = h;
                    }
                    return _fetch.call(this, input, init);
                };
            }
            if (window.jQuery) {
                jQuery.ajaxSetup({
                    beforeSend: function (xhr, settings) {
                        var m = (settings.type || 'GET').toUpperCase();
                        if (!settings.crossDomain && ['POST', 'PUT', 'DELETE', 'PATCH'].indexOf(m) !== -1) {
                            xhr.setRequestHeader('RequestVerificationToken', csrfToken());
                        }
                    }
                });
            }
        })();
    </script>

