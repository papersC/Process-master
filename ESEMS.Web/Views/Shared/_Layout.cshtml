	            <main id="main-content" role="main" class="flex-1 overflow-y-auto p-6 bg-gray-50">
                @* Server-side TempData success/error feedback. Earlier versions
                   were a static colored banner that pushed page content down on
                   every save. Now: a centered SweetAlert2 popup matching the
                   pattern used elsewhere in the app (Improvements wizard, AI
                   actions, Workload edit). Auto-dismisses (2.5 s success, 4 s
                   error). The hidden TempDataFeedback inputs let the inline
                   script read the values without re-emitting the strings as
                   raw markup. *@
                @{
                    var __tdSuccess = TempData["Success"] as string;
                    var __tdError   = TempData["Error"] as string;
                }
                @if (!string.IsNullOrWhiteSpace(__tdSuccess) || !string.IsNullOrWhiteSpace(__tdError))
                {
                    <input type="hidden" id="tempDataSuccess" value="@__tdSuccess" />
                    <input type="hidden" id="tempDataError"   value="@__tdError" />
                    <script nonce="@Context.CspNonce()">
                        document.addEventListener('DOMContentLoaded', function () {
                            if (typeof Swal === 'undefined') return;
                            var ok = document.getElementById('tempDataSuccess')?.value || '';
                            var err = document.getElementById('tempDataError')?.value || '';
                            if (ok) {
                                Swal.fire({
                                    icon: 'success',
                                    title: ok,
                                    showConfirmButton: false,
                                    timer: 2500,
                                    timerProgressBar: true,
                                    confirmButtonColor: '#005B99'
                                });
                            } else if (err) {
                                Swal.fire({
                                    icon: 'error',
                                    title: err,
                                    confirmButtonText: 'OK',
                                    confirmButtonColor: '#005B99'
                                });
                            }
                        });
                    </script>
                }

                <!-- Breadcrumb Navigation -->
                @await Html.PartialAsync("_Breadcrumb")

                @RenderBody()
	            </main>
	        </div>
