            #esemsAiBubble:hover { transform: scale(1.08); box-shadow: 0 12px 30px rgba(0,91,153,.45), 0 4px 8px rgba(0,0,0,.15); }
            #esemsAiBubble:active { transform: scale(.96); }
            #esemsAiBubble:focus-visible { outline: 3px solid rgba(0,91,153,.5); outline-offset: 3px; }
            #esemsAiBubble.is-chat-open { opacity: 0; transform: scale(.6); pointer-events: none; }
            #esemsAiBubble .esems-bubble-icon { width: 26px; height: 26px; }
            /* "Ask AI" hint label — slides in on hover so users discover what
