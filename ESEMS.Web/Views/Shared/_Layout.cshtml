        </style>
        <button type="button" id="esemsAiBubble"
                aria-label="@(isRtl ? "افتح المساعد الذكي" : "Open AI Assistant")"
                title="@(isRtl ? "افتح المساعد الذكي · اسأل عن أي مبادرة، خدمة، عملية، أو خطر (Alt+I)" : "Open AI Assistant · Ask about any initiative, service, process or risk (Alt+I)")">
