            };

            document.querySelectorAll('.esems-datatable').forEach(function(table) {
                if (jQuery.fn.DataTable.isDataTable(table)) return;

                // Skip empty tables: when the only tbody row is a colspan empty-state
                // placeholder (no real data rows), DataTables throws "Incorrect column
                // count" (tn/18) because that single cell doesn't match the header
                // column count. The static empty-state markup renders fine on its own.
                var hasDataRow = Array.prototype.some.call(
