    <script src="~/lib/microsoft-signalr/signalr.min.js" asp-append-version="true"></script>
    <script nonce="@Context.CspNonce()">
    // ── Notification System ──
    async function loadNotifications() {
        try {
            const res = await fetch('/api/notifications?unreadOnly=true&take=5', { credentials: 'include' });
            if (!res.ok) return;
            const items = await res.json();
            const badge = document.getElementById('notifBadge');
            const countLabel = document.getElementById('notifCountLabel');
            const list = document.getElementById('notifPreviewList');
            const count = items.length;
            if (badge) {
                if (count > 0) {
                    badge.textContent = count > 99 ? '99+' : count;
                    badge.style.display = '';
                    badge.classList.add('notif-has-unread');
                } else {
                    badge.style.display = 'none';
                    badge.classList.remove('notif-has-unread');
                }
            }
            if (countLabel) countLabel.textContent = count + ' @(isRtl ? "جديد" : "New")';
            if (list) {
                if (count === 0) {
                    list.innerHTML = '<div class="text-center py-5 text-muted small"><i data-lucide="bell-off" style="width:32px;height:32px;opacity:.3;" class="mb-2"></i><div>@(isRtl ? "لا توجد إشعارات جديدة" : "No new notifications")</div></div>';
                    if (window.lucide) lucide.createIcons();
                    return;
                }
                // PM-style: unread left border + type color + dot indicator
                function typeColor(type) {
                    switch ((type || '').toLowerCase()) {
                        case 'error': case 'danger': return '#F46A6A';
                        case 'warning': return '#F1B44C';
                        case 'success': return '#34C38F';
                        default: return '#005B99';
                    }
                }
                var approveLabel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(isRtl ? "اعتماد" : "Approve"));
                list.innerHTML = items.map(n => {
                    var color = typeColor(n.type);
                    var unread = !n.isRead;
                    var bg = unread ? '#f8fafc' : '#fff';
                    var borderLeft = unread ? `4px solid ${color}` : '4px solid transparent';
                    var title = @(isRtl ? "n.titleAr || n.titleEn" : "n.titleEn || n.titleAr") || '';
                    var message = @(isRtl ? "n.messageAr || n.messageEn" : "n.messageEn || n.messageAr") || '';
                    // UX-016: format with the app culture (from <html lang>) so
                    // Arabic users get Arabic-locale dates, not the browser locale.
                    var when = new Date(n.createdAt).toLocaleString(document.documentElement.lang === 'ar' ? 'ar-AE' : 'en-GB');
                    var canApprove = !!n.approvableWorkflowId;
                    var approveBtn = canApprove
                        ? `<button type="button" class="btn btn-sm" style="background:#34C38F;color:#fff;font-size:var(--fs-xs);padding:.2rem .55rem;margin-top:.35rem;border-radius:.25rem;border:none;display:inline-flex;align-items:center;gap:.25rem;" data-notif-approve="${n.id}" title="${approveLabel}"><i data-lucide="check" style="width:12px;height:12px;"></i>${approveLabel}</button>`
                        : '';
                    return `<a class="d-flex align-items-start gap-2 px-3 py-3 border-bottom text-decoration-none" style="cursor:pointer;background:${bg};border-left:${borderLeft};color:#111827;transition:background .15s;" onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='${bg}'" href="${n.actionUrl || '#'}" onclick="event.stopPropagation();markNotifRead('${n.id}')">
                        <div style="width:10px;height:10px;border-radius:50%;background:${color};flex-shrink:0;margin-top:6px;"></div>
                        <div style="flex:1;min-width:0;">
                            <div class="${unread ? 'fw-bold' : 'fw-medium'}" style="font-size: var(--fs-sm);">${title}</div>
                            <div class="text-muted text-truncate" style="font-size: var(--fs-xs);">${message}</div>
                            <div class="text-muted" style="font-size: var(--fs-xs);margin-top:2px;">${when}</div>
                            ${approveBtn}
                        </div>
                    </a>`;
                }).join('');
                // Click handler for the dynamically rendered notification rows —
                // delegated so the inline onclick (which would die under CSP
                // without 'unsafe-inline') is no longer needed.
                list.querySelectorAll('a[data-notif-id]').forEach(a => {
                    a.addEventListener('click', e => {
                        e.stopPropagation();
                        markNotifRead(a.getAttribute('data-notif-id'));
                    });
                });
            }
        } catch(e) { }
    }
    async function markNotifRead(id) { await fetch('/api/notifications/'+id+'/read', {method:'POST',credentials:'include'}); loadNotifications(); }
    async function markAllNotificationsRead() { await fetch('/api/notifications/read-all', {method:'POST',credentials:'include'}); loadNotifications(); }

    // Inline approve from the bell dropdown. Delegated so it survives re-renders.
    document.addEventListener('click', async function (e) {
        var btn = e.target.closest('[data-notif-approve]');
        if (!btn) return;
        e.preventDefault();
        e.stopPropagation();
        var notifId = btn.getAttribute('data-notif-approve');
        btn.disabled = true;
        btn.style.opacity = '.65';
        try {
            var res = await fetch('/api/notifications/' + notifId + '/approve', { method: 'POST', credentials: 'include' });
            if (res.ok) {
                await loadNotifications();
            } else {
                btn.disabled = false;
                btn.style.opacity = '';
            }
        } catch (err) {
            btn.disabled = false;
            btn.style.opacity = '';
        }
    });

    // ── SignalR Real-time ──
    if (typeof signalR !== 'undefined') {
        // SignalR connections bypass the fetch wrapper (WebSocket/SSE/long-poll),
        // so we explicitly prepend SP_PATHBASE for sub-app hosting.
        const conn = new signalR.HubConnectionBuilder().withUrl((window.SP_PATHBASE || '') + '/hubs/notifications').withAutomaticReconnect().build();
        conn.on('ReceiveNotification', function(n) {
            // Per Khaled: real-time notifications must NOT pop up a toast at
            // the top-right. The bell badge counter + the notification list
            // are the only signals — users see the message when they choose
            // to look. Bell-shake animation kept as an unobtrusive cue that
            // something new arrived.
            loadNotifications();
            var bellIcon = document.getElementById('notifBellIcon');
            if (bellIcon) {
                bellIcon.classList.remove('notif-bell-shake');
                void bellIcon.offsetWidth; // force reflow so the animation restarts
                bellIcon.classList.add('notif-bell-shake');
                setTimeout(function() { bellIcon.classList.remove('notif-bell-shake'); }, 800);
            }
        });
        conn.start().catch(function(err) { console.log('SignalR connection error:', err); });
    }

    // ── AI Assistant Chat ──
    (function() {
        const chatEl = document.getElementById('spAiChat');
        const bodyEl = document.getElementById('spAiChatBody');
        const inputEl = document.getElementById('spAiInput');
        const sendBtn = document.getElementById('spAiSendBtn');
        const closeBtn = document.getElementById('spAiChatClose');
        const suggestionsEl = document.getElementById('spAiSuggestions');
        const toggleBtn = document.getElementById('spAiAssistantBtn');
        const bubbleBtn = document.getElementById('esemsAiBubble');
        let history = [];

        function setChatOpen(open) {
            chatEl.style.display = open ? 'flex' : 'none';
            if (bubbleBtn) bubbleBtn.classList.toggle('is-chat-open', open);
            if (open) inputEl?.focus();
            if (window.lucide) lucide.createIcons();
        }
        function toggleChat() { setChatOpen(chatEl.style.display === 'none'); }

        if (toggleBtn) toggleBtn.addEventListener('click', toggleChat);
        if (bubbleBtn) bubbleBtn.addEventListener('click', toggleChat);
        if (closeBtn) closeBtn.addEventListener('click', () => setChatOpen(false));
        if (sendBtn) sendBtn.addEventListener('click', sendMessage);
        if (inputEl) inputEl.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); sendMessage(); } });
        document.addEventListener('keydown', e => { if (e.key === 'Escape' && chatEl.style.display === 'flex') setChatOpen(false); });

        function addMsg(text, isUser) {
            const div = document.createElement('div');
            div.style.cssText = `align-self:flex-${isUser?'end':'start'};background:${isUser?'#005B99':'#f3f4f6'};color:${isUser?'#fff':'#1f2937'};padding:.55rem .8rem;border-radius:14px;border-bottom-${isUser?'right':'left'}-radius:4px;font-size: var(--fs-sm);max-width:85%;white-space:pre-wrap;box-shadow:0 1px 2px rgba(0,0,0,.05);`;
            div.textContent = text;
            bodyEl.appendChild(div);
            bodyEl.scrollTop = bodyEl.scrollHeight;
        }

        async function ensureMarkedLoaded() {
            if (typeof marked !== 'undefined') return;
            await new Promise(function (r) {
                var s = document.createElement('script');
                s.src = (window.SP_PATHBASE || '') + '/lib/marked/marked.min.js';
                s.onload = r;
                document.head.appendChild(s);
            });
        }

        // FEAT-5: render an assistant reply as HTML (so the markdown links the
        // server injected for entity codes become clickable) + a chip strip
        // of the resolved entity references underneath.
        async function addAiMsg(text, entityLinks) {
            await ensureMarkedLoaded();
            const div = document.createElement('div');
            div.style.cssText = `align-self:flex-start;background:#f3f4f6;color:#1f2937;padding:.55rem .8rem;border-radius:14px;border-bottom-left-radius:4px;font-size: var(--fs-sm);max-width:85%;box-shadow:0 1px 2px rgba(0,0,0,.05);`;
            div.innerHTML = marked.parse(text || '');
            // Inline links inside the markdown should open the entity in a new tab
            // so the chat keeps its context.
            div.querySelectorAll('a[href^="/"]').forEach(function (a) { a.target = '_blank'; a.rel = 'noopener'; });
            bodyEl.appendChild(div);

            if (Array.isArray(entityLinks) && entityLinks.length > 0) {
                const chips = document.createElement('div');
                chips.style.cssText = 'align-self:flex-start;display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.15rem;max-width:85%;';
                entityLinks.forEach(function (l) {
                    const a = document.createElement('a');
                    a.href = (window.SP_PATHBASE || '') + l.url;
                    a.target = '_blank';
                    a.rel = 'noopener';
                    a.title = l.label || l.code;
                    a.textContent = l.code;
                    a.style.cssText = 'font-size:var(--fs-xs);padding:.18rem .55rem;border:1px solid #c4b5fd;border-radius:9999px;background:#f5f3ff;color:#5b21b6;text-decoration:none;';
                    chips.appendChild(a);
                });
                bodyEl.appendChild(chips);
            }
            bodyEl.scrollTop = bodyEl.scrollHeight;
        }

        function showSuggestions(suggestions) {
            if (!suggestionsEl || !suggestions?.length) return;
            // Build via DOM rather than string concat — prevents XSS through
            // server-supplied suggestion text and lets the click handler bind
            // without an inline onclick (CSP would otherwise need 'unsafe-inline').
            suggestionsEl.innerHTML = '';
            suggestions.forEach(s => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.style.cssText = 'font-size: var(--fs-xs);padding:.3rem .65rem;border:1px solid #e5e7eb;border-radius:9999px;background:#fff;color:var(--theme-color);cursor:pointer;';
                btn.textContent = String(s ?? '');
                btn.addEventListener('click', () => {
                    const inp = document.getElementById('spAiInput');
                    if (inp) inp.value = btn.textContent;
                    document.getElementById('spAiSendBtn')?.click();
                });
                suggestionsEl.appendChild(btn);
            });
        }

        async function sendMessage() {
            const q = inputEl?.value?.trim();
            if (!q) return;
            inputEl.value = '';
            addMsg(q, true);
            history.push({role:'user', content:q});

            const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value;
            addMsg('@(isRtl ? "جاري التفكير..." : "Thinking...")', false);

            try {
                const res = await fetch('/AI/AskAssistant', {
                    method: 'POST', credentials: 'include',
                    headers: { 'Content-Type':'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify({ question: q, conversationHistory: history.slice(-8) })
                });
                const data = await res.json();
                bodyEl.lastChild.remove(); // remove "Thinking..."
                if (data.success) {
                    await addAiMsg(data.answer, data.entityLinks);
                    history.push({role:'assistant', content:data.answer});
                    showSuggestions(data.suggestions);
                } else {
                    addMsg(data.error || window.ESEMS_I18N.error, false);
                }
            } catch(e) {
                bodyEl.lastChild.remove();
                addMsg(window.ESEMS_I18N.connectionError, false);
            }
        }
    })();

    // Load notifications on page load
    document.addEventListener('DOMContentLoaded', loadNotifications);

    // Global AI Analysis Function
    async function executeAiAnalysis(endpoint, bodyData, title) {
        if (typeof marked === 'undefined') {
            await new Promise(r => { const s = document.createElement('script'); s.src = (window.SP_PATHBASE || '') + '/lib/marked/marked.min.js'; s.onload = r; document.head.appendChild(s); });
        }
        const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value;
        const analyzingMsg = window.bpmnPageConfig && window.bpmnPageConfig.strings['AI_AnalyzingData']
            ? window.bpmnPageConfig.strings['AI_AnalyzingData']
            : ('@(isRtl ? "جاري التحليل الذكي... يرجى الانتظار." : "AI is analyzing... please wait.")');
        const closeText = '@(isRtl ? "إغلاق" : "Close")';

        Swal.fire({
            title: `<div class="d-flex align-items-center justify-content-center gap-2"><i data-lucide="sparkles" class="text-primary" style="width:24px;height:24px;"></i> <span style="font-size: var(--fs-lg);">${title}</span></div>`,
            html: `<div class="text-center py-4"><div class="spinner-border text-primary mb-3" role="status"></div><p class="text-muted mb-0">${analyzingMsg}</p></div>`,
            showConfirmButton: false,
            allowOutsideClick: false,
            didOpen: () => { if (typeof lucide !== 'undefined') lucide.createIcons(); }
        });

        try {
            // Check if endpoint contains query params vs bodyData
            let fetchOpts = {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            };
            if (bodyData) {
                fetchOpts.headers['Content-Type'] = 'application/json';
                fetchOpts.body = JSON.stringify(bodyData);
            }

            const res = await fetch(endpoint, fetchOpts);
            const data = await res.json();

            if (data.success && (data.analysis || data.suggestions || data.summary)) {
                const content = data.analysis || data.suggestions || data.summary;
                Swal.fire({
                    title: `<div class="d-flex align-items-center justify-content-center gap-2 mb-3"><i data-lucide="sparkles" class="text-primary" style="width:24px;height:24px;"></i> <span style="font-size: var(--fs-lg);">${title}</span></div>`,
                    html: `<div class="text-start prose prose-sm max-w-none text-gray-800" style="max-height: 60vh; overflow-y: auto; text-align: @(isRtl ? "right" : "left"); direction: @(isRtl ? "rtl" : "ltr");">${marked.parse(content)}</div>`,
                    width: '800px',
                    confirmButtonText: closeText,
                    confirmButtonColor: 'var(--theme-color)',
                    didOpen: () => { if (typeof lucide !== 'undefined') lucide.createIcons(); }
                });
            } else {
                Swal.fire(window.ESEMS_I18N.error, data.error || window.ESEMS_I18N.failedToAnalyze, 'error');
            }
        } catch (e) {
            Swal.fire(window.ESEMS_I18N.error, e.message, 'error');
        }
    }
    </script>
</body>
</html>
