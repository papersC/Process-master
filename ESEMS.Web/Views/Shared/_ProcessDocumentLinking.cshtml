@*
    Shared Document Linking block for Process Create/Edit.
    Renders a multi-file repeater plus a "From Computer"/"From My Space"
    toolbar. Each attached file gets its own Category / Type / Language.

    The form posts a JSON blob `DocumentLinksJson` that the ProcessesController
    deserializes into ProcessDocument rows.

    Expected ViewBag values:
      - ViewBag.DocumentCategories  : SelectList of <category id, name>
      - ViewBag.DocumentTypes       : SelectList of <type id, name>
      - ViewBag.DocumentLanguages   : IEnumerable<{Value,DisplayName}>
      - ViewBag.ExistingProcessDocuments (optional) : IEnumerable of existing
           links to prefill the list — anonymous objects
           { id, userDocumentId, originalName, fileSize, url,
             documentCategoryId, documentTypeId, documentLanguage }
*@
@{
    var isRtl = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    var categories = ViewBag.DocumentCategories as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var types = ViewBag.DocumentTypes as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var languages = ViewBag.DocumentLanguages as System.Collections.IEnumerable;
    var existingLinks = ViewBag.ExistingProcessDocuments as System.Collections.IEnumerable;
    var existingJson = existingLinks != null
        ? System.Text.Json.JsonSerializer.Serialize(existingLinks)
        : "[]";
}

<div class="mb-4 p-4 border border-gray-200 rounded-lg bg-gray-50" data-has-existing="@(existingLinks != null && existingLinks.Cast<object>().Any() ? "1" : "0")">
    <!-- Header with toggle -->
    <label class="flex items-center justify-between cursor-pointer">
        <div class="min-w-0">
            <span class="text-sm font-medium text-gray-900">@(isRtl ? "ربط الوثائق" : "Document Linking")</span>
            <p class="text-xs text-gray-500 mt-0.5">
                @(isRtl
                    ? "اربط هذه العملية بوثيقة أو أكثر (سياسة / إجراء / معيار ...). اختر من مساحتك أو ارفع ملفات جديدة."
                    : "Link one or more controlling documents (policy / procedure / standard...). Pick from My Space or upload new files.")
            </p>
        </div>
        <!-- Toggle switch -->
        <button type="button" id="docLinkingToggle" role="switch" aria-checked="false"
                class="relative inline-flex h-6 w-11 flex-shrink-0 rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none ml-3"
                style="background-color: #d1d5db;">
            <span id="docLinkingToggleKnob" class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"
                  style="transform: translateX(0);"></span>
        </button>
    </label>

    <!-- Hidden inputs: multi-file picker (for direct upload) + JSON blob posted to server -->
    <input type="file" id="docLinkComputerInput" class="hidden" multiple
           aria-label="@Shared["Label_UploadFiles"]"
           accept=".pdf,.xlsx,.xls,.docx,.doc,.png,.jpg,.jpeg,.gif,.bmp,.csv,.pptx,.ppt,.txt" />
    <input type="hidden" name="DocumentLinksJson" id="DocumentLinksJson" value="[]" />

    <!-- Collapsible body -->
    <div id="docLinkingFields" class="hidden mt-4">
        <div class="flex items-center justify-end gap-2 mb-3">
            <button type="button" id="btnDocFromComputer"
                    class="inline-flex items-center gap-2 px-3 py-1.5 text-xs font-medium text-white rounded-md transition"
                    style="background: #4169E1;">
                <i data-lucide="upload" class="w-3.5 h-3.5"></i>
                @(isRtl ? "من جهازي" : "From My Computer")
            </button>
            <button type="button" id="btnDocFromMySpace"
                    class="inline-flex items-center gap-2 px-3 py-1.5 text-xs font-medium text-blue-700 border border-blue-200 rounded-md hover:bg-blue-50 transition">
                <i data-lucide="folder-open" class="w-3.5 h-3.5"></i>
                @(isRtl ? "من مساحتي" : "From My Space")
            </button>
        </div>

        <!-- Upload progress toast -->
        <div id="docLinkUploadToast" class="mb-3 p-2 bg-blue-50 border border-blue-200 rounded text-xs text-blue-700 hidden">
            <div class="flex items-center justify-between mb-1">
                <span>@(isRtl ? "جارٍ رفع الملفات..." : "Uploading files...")</span>
                <span id="docLinkUploadPct" class="font-semibold">0%</span>
            </div>
            <div class="h-1 bg-blue-200 rounded overflow-hidden">
                <div id="docLinkUploadBar" class="h-full bg-blue-600" style="width:0%"></div>
            </div>
        </div>

        <!-- Empty state -->
        <div id="docLinkEmpty" class="text-center py-4 text-xs text-gray-400 border border-dashed border-gray-300 rounded bg-white">
            @(isRtl ? "لم يتم ربط أي وثائق بعد. ارفع ملفًا أو اختره من مساحتك." : "No documents linked yet. Upload a file or pick one from My Space.")
        </div>

        <!-- Repeater table -->
        <div id="docLinkTableWrap" class="hidden">
            <table class="w-full text-sm bg-white rounded border border-gray-200 overflow-hidden">
                <thead class="text-xs text-gray-500 uppercase bg-gray-50">
                    <tr>
                        <th class="px-3 py-2 text-start" style="width:36%">@(isRtl ? "الملف" : "File")</th>
                        <th class="px-3 py-2 text-start" style="width:20%">@(isRtl ? "فئة الوثيقة" : "Document Category")</th>
                        <th class="px-3 py-2 text-start" style="width:20%">@(isRtl ? "نوع الوثيقة" : "Document Type")</th>
                        <th class="px-3 py-2 text-start" style="width:18%">@(isRtl ? "لغة الوثيقة" : "Document Language")</th>
                        <th class="px-3 py-2 text-end" style="width:6%"></th>
                    </tr>
                </thead>
                <tbody id="docLinkTableBody" class="divide-y divide-gray-100"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- My Space picker modal (hidden by default) -->
<div id="mySpacePickerBackdrop" class="fixed inset-0 bg-black bg-opacity-50 hidden" style="z-index:1060;"></div>
<div id="mySpacePickerModal" class="fixed inset-0 hidden items-center justify-center p-4" style="z-index:1061;">
    <div class="bg-white rounded-lg shadow-xl border border-gray-200 w-full max-w-2xl flex flex-col" style="max-height:80vh;">
        <div class="flex items-center justify-between px-5 py-3 border-b border-gray-200">
            <div class="flex items-center gap-2">
                <i data-lucide="folder-open" class="w-5 h-5 text-blue-600"></i>
                <h3 class="text-sm font-semibold text-gray-900">@(isRtl ? "اختر من مساحتي" : "Pick from My Space")</h3>
            </div>
            <button type="button" id="mySpacePickerClose" class="text-gray-400 hover:text-gray-600">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <div class="px-5 py-3 border-b border-gray-100">
            <div class="relative">
                <i data-lucide="search" class="w-4 h-4 text-gray-400 absolute @(isRtl ? "right-3" : "left-3") top-1/2 -translate-y-1/2"></i>
                <input type="text" id="mySpacePickerSearch"
                       placeholder="@(isRtl ? "ابحث في ملفاتك..." : "Search your files...")"
                       aria-label="@(isRtl ? "ابحث في ملفاتك" : "Search your files")"
                       class="w-full @(isRtl ? "pr-9 pl-3" : "pl-9 pr-3") py-2 border border-gray-300 rounded-md text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
            </div>
        </div>
        <div id="mySpacePickerList" class="overflow-y-auto p-4 flex-1 space-y-1">
            <div class="text-center py-6 text-gray-400 text-sm">
                <div class="inline-block animate-spin rounded-full h-6 w-6 border-2 border-blue-500 border-t-transparent"></div>
            </div>
        </div>
        <div class="px-5 py-3 border-t border-gray-200 flex items-center justify-between gap-3">
            <a href="~/MySpace" target="_blank" class="text-xs text-blue-600 hover:underline inline-flex items-center gap-1">
                <i data-lucide="external-link" class="w-3.5 h-3.5"></i>
                @(isRtl ? "افتح مساحتي" : "Open My Space")
            </a>
            <button type="button" id="mySpacePickerCancel"
                    class="px-3 py-1.5 border border-gray-300 text-gray-700 text-xs font-medium rounded-md hover:bg-gray-50">
                @(isRtl ? "إغلاق" : "Close")
            </button>
        </div>
    </div>
</div>

<script nonce="@Context.CspNonce()" id="docLinkSelects" type="application/json">
@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
    categories = (categories ?? new Microsoft.AspNetCore.Mvc.Rendering.SelectList(new List<object>(), "Value", "Text"))
        .Select(x => new { value = x.Value, text = x.Text }),
    types = (types ?? new Microsoft.AspNetCore.Mvc.Rendering.SelectList(new List<object>(), "Value", "Text"))
        .Select(x => new { value = x.Value, text = x.Text }),
    languages = (languages ?? new List<object>())
        .Cast<object>()
        .Select(l => new {
            value = (string)l.GetType().GetProperty("Value")?.GetValue(l)!,
            text  = (string)l.GetType().GetProperty("DisplayName")?.GetValue(l)!
        })
}))
</script>
<script nonce="@Context.CspNonce()" id="docLinkExisting" type="application/json">@Html.Raw(existingJson)</script>
<script nonce="@Context.CspNonce()" id="docLinkLabels" type="application/json">
@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
    optional = isRtl ? "-- اختياري --" : "-- Select (Optional) --",
    remove = isRtl ? "إزالة" : "Remove",
    uploadFailed = isRtl ? "فشل الرفع" : "Upload failed",
    emptyMySpace = isRtl ? "مساحتك فارغة. يمكنك رفع ملفات من صفحة \"مساحتي\"." : "My Space is empty. Upload files on the My Space page.",
    noResults = isRtl ? "لا توجد نتائج" : "No results"
}))
</script>
<script src="~/js/process-document-linking.js" asp-append-version="true"></script>
