@model ErrorViewModel
@inject IStringLocalizer<SharedResource> Shared
@{
    ViewData["Title"] = Shared["Title_Error"].Value;
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<div class="min-h-[60vh] flex items-center justify-center px-4 py-12">
    <div class="max-w-md w-full text-center">
        <div class="mx-auto mb-6 w-24 h-24 rounded-full bg-red-50 border-4 border-red-200 flex items-center justify-center">
            <i data-lucide="alert-triangle" class="w-12 h-12 text-red-500"></i>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 mb-3">@Shared["Title_Error"]</h1>
        <p class="text-gray-600 mb-6">@Shared["Text_ErrorMessage"]</p>
        @if (Model.ShowRequestId)
        {
            <p class="text-xs text-gray-400 font-mono mb-6">
                <strong>@Shared["Label_RequestId"]:</strong> <code>@Model.RequestId</code>
            </p>
        }
        <div class="flex items-center justify-center gap-3">
            <a asp-controller="Dashboard" asp-action="Index" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition-colors">
                <i data-lucide="home" class="w-4 h-4"></i>
                @Shared["Nav_Dashboard"]
            </a>
            <button type="button" onclick="history.back()" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-100 text-gray-700 rounded-lg font-medium hover:bg-gray-200 transition-colors">
                <i data-lucide="@(isRtl ? "arrow-right" : "arrow-left")" class="w-4 h-4"></i>
                @(isRtl ? "رجوع" : "Go Back")
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.CspNonce()">if (window.lucide) lucide.createIcons();</script>
}
