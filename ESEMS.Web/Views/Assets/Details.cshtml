@model Asset
@inject ESEMS.Web.Services.Integrations.Contracts.IProcessPerformanceProvider PerfProvider
@{
    ViewData["Title"] = Model.AssetTag;
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isRtl = culture.StartsWith("ar");
    var statusClass = Model.Status switch { AssetStatus.Operational => "bg-green-100 text-green-800", AssetStatus.UnderMaintenance => "bg-orange-100 text-orange-800", AssetStatus.Retired => "bg-gray-100 text-gray-800", _ => "bg-blue-100 text-blue-800" };
    var criticalityClass = Model.Criticality switch { 1 => "bg-red-100 text-red-800", 2 => "bg-orange-100 text-orange-800", 3 => "bg-yellow-100 text-yellow-800", _ => "bg-gray-100 text-gray-800" };
    var criticalityLabel = Model.Criticality switch { 1 => Shared["Criticality_Critical"].Value, 2 => Shared["Criticality_High"].Value, 3 => Shared["Criticality_Medium"].Value, _ => Shared["Criticality_Low"].Value };
}

<!-- Modern Banner Header -->
<div class="mb-8 rounded-2xl shadow-xl overflow-hidden" style="background: linear-gradient(135deg, #005B99 0%, #003d6b 100%);">
    <div class="px-8 py-10">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-6">
                <div class="w-20 h-20 bg-white/10 backdrop-blur-sm rounded-2xl flex items-center justify-center">
                    <i data-lucide="package" class="w-10 h-10 text-white"></i>
                </div>
                <div>
                    <div class="flex items-center gap-3 mb-2">
                        <h1 class="text-4xl font-bold text-white">@Model.AssetTag</h1>
                        <span class="px-3 py-1 text-sm font-medium rounded-full @statusClass">@Model.Status</span>
                        <span class="px-3 py-1 text-sm font-medium rounded-full @criticalityClass">@criticalityLabel</span>
                    </div>
                    <p class="text-blue-100 text-lg">@(isRtl ? Model.NameAr : Model.NameEn)</p>
                </div>
            </div>
            <div class="flex items-center gap-3">
                <a asp-action="Index" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-blue-600 font-semibold rounded-lg hover:bg-blue-50 transition-all shadow-md">
                    <i data-lucide="@(isRtl ? "arrow-right" : "arrow-left")" class="w-5 h-5" style="stroke: #005B99;"></i>
                    <span style="color: #005B99;">@Shared["Button_BackToList"]</span>
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 backdrop-blur-sm text-white font-semibold rounded-lg hover:bg-white/20 transition-all border border-white/20">
                    <i data-lucide="edit" class="w-5 h-5"></i>
                    @Shared["Button_Edit"]
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Main Content Grid -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left Column -->
    <div class="lg:col-span-2 space-y-6">
        <!-- Description -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">@Shared["Label_Description"]</h3>
            <p class="text-gray-700 whitespace-pre-wrap">@(isRtl ? Model.DescriptionAr : Model.DescriptionEn)</p>
        </div>

        <!-- Specifications -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">@Shared["Label_Specifications"]</h3>
            <div class="grid grid-cols-2 gap-4">
                <div><span class="text-sm text-gray-500">@Shared["Label_Manufacturer"]</span><p class="font-medium">@(Model.Manufacturer ?? "-")</p></div>
                <div><span class="text-sm text-gray-500">@Shared["Label_Model"]</span><p class="font-medium">@(Model.Model ?? "-")</p></div>
                <div><span class="text-sm text-gray-500">@Shared["Label_SerialNumber"]</span><p class="font-medium">@(Model.SerialNumber ?? "-")</p></div>
                <div><span class="text-sm text-gray-500">@Shared["Label_Location"]</span><p class="font-medium">@(Model.Location ?? "-")</p></div>
            </div>
        </div>

        @* Real Estate panel — only renders when the asset actually carries
           housing data, so IT/equipment assets stay uncluttered. *@
        @{
            var hasRealEstate =
                !string.IsNullOrEmpty(Model.PlotNumber)
                || !string.IsNullOrEmpty(Model.Emirate)
                || !string.IsNullOrEmpty(Model.District)
                || !string.IsNullOrEmpty(Model.TitleDeedNumber)
                || Model.BuiltUpAreaSqm.HasValue
                || Model.LandAreaSqm.HasValue
                || Model.Floors.HasValue
                || Model.Units.HasValue
                || Model.Bedrooms.HasValue
                || Model.ConstructionStatus.HasValue
                || !string.IsNullOrEmpty(Model.ParentProjectId)
                || (Model.GpsLatitude.HasValue && Model.GpsLongitude.HasValue);
        }
        @if (hasRealEstate)
        {
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                        <i data-lucide="home" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>
                        @Shared["Section_RealEstate"]
                    </h3>
                    @if (Model.ConstructionStatus.HasValue)
                    {
                        var csClass = Model.ConstructionStatus.Value switch
                        {
                            ESEMS.Web.Models.Enums.ConstructionStatus.Design or ESEMS.Web.Models.Enums.ConstructionStatus.Tender => "bg-blue-100 text-blue-800",
                            ESEMS.Web.Models.Enums.ConstructionStatus.UnderConstruction => "bg-orange-100 text-orange-800",
                            ESEMS.Web.Models.Enums.ConstructionStatus.ReadyForHandover => "bg-yellow-100 text-yellow-800",
                            ESEMS.Web.Models.Enums.ConstructionStatus.HandedOver or ESEMS.Web.Models.Enums.ConstructionStatus.Occupied => "bg-green-100 text-green-800",
                            _ => "bg-gray-100 text-gray-800"
                        };
                        <span class="px-3 py-1 text-xs font-medium rounded-full @csClass">
                            @Shared[$"ConstructionStatus_{Model.ConstructionStatus.Value}"]
                        </span>
                    }
                </div>
                <div class="grid grid-cols-2 gap-4">
                    @if (!string.IsNullOrEmpty(Model.PlotNumber))
                    { <div><span class="text-sm text-gray-500">@Shared["Label_PlotNumber"]</span><p class="font-medium">@Model.PlotNumber</p></div> }
                    @if (!string.IsNullOrEmpty(Model.TitleDeedNumber))
                    { <div><span class="text-sm text-gray-500">@Shared["Label_TitleDeed"]</span><p class="font-medium">@Model.TitleDeedNumber</p></div> }
                    @if (!string.IsNullOrEmpty(Model.Emirate))
                    { <div><span class="text-sm text-gray-500">@Shared["Label_Emirate"]</span><p class="font-medium">@Model.Emirate</p></div> }
                    @if (!string.IsNullOrEmpty(Model.District))
                    { <div><span class="text-sm text-gray-500">@Shared["Label_District"]</span><p class="font-medium">@Model.District</p></div> }
                    @if (Model.LandAreaSqm.HasValue)
                    { <div><span class="text-sm text-gray-500">@Shared["Label_LandAreaSqm"]</span><p class="font-medium">@Model.LandAreaSqm.Value.ToString("N2") m²</p></div> }
                    @if (Model.BuiltUpAreaSqm.HasValue)
                    { <div><span class="text-sm text-gray-500">@Shared["Label_BuiltUpAreaSqm"]</span><p class="font-medium">@Model.BuiltUpAreaSqm.Value.ToString("N2") m²</p></div> }
                    @if (Model.Floors.HasValue)
                    { <div><span class="text-sm text-gray-500">@Shared["Label_Floors"]</span><p class="font-medium">@Model.Floors</p></div> }
                    @if (Model.Units.HasValue)
                    { <div><span class="text-sm text-gray-500">@Shared["Label_DwellingUnits"]</span><p class="font-medium">@Model.Units</p></div> }
                    @if (Model.Bedrooms.HasValue)
                    { <div><span class="text-sm text-gray-500">@Shared["Label_Bedrooms"]</span><p class="font-medium">@Model.Bedrooms</p></div> }
                    @if (Model.ParentProject != null)
                    {
                        <div>
                            <span class="text-sm text-gray-500">@Shared["Label_ParentProject"]</span>
                            <p class="font-medium">
                                <a asp-action="Details" asp-route-id="@Model.ParentProject.Id" style="color:#005B99;text-decoration:none;">
                                    @Model.ParentProject.AssetTag — @(isRtl ? Model.ParentProject.NameAr : Model.ParentProject.NameEn)
                                </a>
                            </p>
                        </div>
                    }
                    @if (Model.GpsLatitude.HasValue && Model.GpsLongitude.HasValue)
                    {
                        <div class="col-span-2">
                            <span class="text-sm text-gray-500">@Shared["Label_GpsLatitude"] / @Shared["Label_GpsLongitude"]</span>
                            <p class="font-medium">
                                <a href="https://www.google.com/maps?q=@Model.GpsLatitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@Model.GpsLongitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                   target="_blank" rel="noopener" style="color:#005B99;text-decoration:none;display:inline-flex;align-items:center;gap:.35rem;">
                                    @Model.GpsLatitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture),
                                    @Model.GpsLongitude.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)
                                    <i data-lucide="external-link" class="w-3 h-3" aria-hidden="true"></i>
                                </a>
                            </p>
                        </div>
                    }
                </div>
            </div>
        }

        @* Information Asset panel — only renders when the asset has any
           info-asset data, so IT/equipment/real-estate assets stay clean.
           Classification renders as a coloured pill driven by sensitivity
           level so the user spots Restricted records at a glance. *@
        @{
            var hasInfoAsset =
                Model.Classification.HasValue
                || Model.DataOwnerUserId.HasValue
                || Model.DataCustodianUserId.HasValue
                || Model.RetentionMonths.HasValue
                || !string.IsNullOrEmpty(Model.RegulatoryTags)
                || !string.IsNullOrEmpty(Model.StorageSystem)
                || !string.IsNullOrEmpty(Model.DataFormat)
                || Model.RecordCount.HasValue;
        }
        @if (hasInfoAsset)
        {
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                        <i data-lucide="database" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>
                        @Shared["Section_InformationAsset"]
                    </h3>
                    @if (Model.Classification.HasValue)
                    {
                        var icClass = Model.Classification.Value switch
                        {
                            InformationClassification.Public => "bg-green-100 text-green-800",
                            InformationClassification.Internal => "bg-blue-100 text-blue-800",
                            InformationClassification.Confidential => "bg-orange-100 text-orange-800",
                            InformationClassification.Restricted => "bg-red-100 text-red-800",
                            _ => "bg-gray-100 text-gray-800"
                        };
                        <span class="px-3 py-1 text-xs font-medium rounded-full @icClass">
                            @Shared[$"InformationClassification_{Model.Classification.Value}"]
                        </span>
                    }
                </div>
                @{
                    // F-RA-001: resolve Data Owner / Custodian ids → names via
                    // the dictionary populated in AssetsController.Details.
                    var usersById = ViewBag.UsersById as IDictionary<int, string>;
                    string UserName(int id) => usersById != null && usersById.TryGetValue(id, out var n) ? n : $"#{id}";
                }
                <div class="grid grid-cols-2 gap-4">
                    @if (Model.DataOwnerUserId.HasValue)
                    { <div><span class="text-sm text-gray-500">@Shared["Label_DataOwner"]</span><p class="font-medium">@UserName(Model.DataOwnerUserId.Value)</p></div> }
                    @if (Model.DataCustodianUserId.HasValue)
                    { <div><span class="text-sm text-gray-500">@Shared["Label_DataCustodian"]</span><p class="font-medium">@UserName(Model.DataCustodianUserId.Value)</p></div> }
                    @if (Model.RetentionMonths.HasValue)
                    { <div><span class="text-sm text-gray-500">@Shared["Label_RetentionMonths"]</span><p class="font-medium">@Model.RetentionMonths</p></div> }
                    @if (Model.RecordCount.HasValue)
                    { <div><span class="text-sm text-gray-500">@Shared["Label_RecordCount"]</span><p class="font-medium">@Model.RecordCount.Value.ToString("N0")</p></div> }
                    @if (!string.IsNullOrEmpty(Model.StorageSystem))
                    { <div><span class="text-sm text-gray-500">@Shared["Label_StorageSystem"]</span><p class="font-medium">@Model.StorageSystem</p></div> }
                    @if (!string.IsNullOrEmpty(Model.DataFormat))
                    { <div><span class="text-sm text-gray-500">@Shared["Label_DataFormat"]</span><p class="font-medium">@Model.DataFormat</p></div> }
                    @if (!string.IsNullOrEmpty(Model.RegulatoryTags))
                    {
                        <div class="col-span-2">
                            <span class="text-sm text-gray-500">@Shared["Label_RegulatoryTags"]</span>
                            <p class="font-medium">
                                @foreach (var tag in Model.RegulatoryTags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                {
                                    <span class="inline-block px-2 py-0.5 mr-1 mb-1 text-xs font-medium rounded bg-gray-100 text-gray-700">@tag</span>
                                }
                            </p>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Maintenance History -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">@Shared["Label_MaintenanceHistory"] (@Model.MaintenanceRecords.Count)</h3>
            @if (Model.MaintenanceRecords.Any())
            {
                <div class="space-y-3">
                    @foreach (var record in Model.MaintenanceRecords.OrderByDescending(r => r.PerformedDate).Take(5))
                    {
                        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                            <div>
                                <span class="text-sm font-medium text-gray-900">@record.Type</span>
                                <p class="text-xs text-gray-500">@record.PerformedDate.ToDubaiString("MMM dd, yyyy")</p>
                            </div>
                            <span class="text-sm text-gray-600">@(record.Cost?.ToString("N0") ?? "-") AED</span>
                        </div>
                    }
                </div>
            }
            else { <p class="text-gray-500 text-sm">@Shared["Text_NoMaintenanceRecords"]</p> }
        </div>
    </div>

    <!-- Right Column -->
    <div class="space-y-6">
        <!-- Financial Info -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">@Shared["Label_FinancialInfo"]</h3>
            <div class="space-y-3">
                <div class="flex justify-between"><span class="text-sm text-gray-500">@Shared["Label_PurchaseCost"]</span><span class="text-sm font-medium">@(Model.PurchaseCost?.ToString("N0") ?? "-") AED</span></div>
                <div class="flex justify-between"><span class="text-sm text-gray-500">@Shared["Label_CurrentValue"]</span><span class="text-sm font-medium">@(Model.CurrentValue?.ToString("N0") ?? "-") AED</span></div>
                <div class="flex justify-between"><span class="text-sm text-gray-500">@Shared["Label_DepreciationRate"]</span><span class="text-sm font-medium">@(Model.DepreciationRate?.ToString("N1") ?? "-")%</span></div>
                @if (Model.PurchaseDate.HasValue) { <div class="flex justify-between"><span class="text-sm text-gray-500">@Shared["Label_PurchaseDate"]</span><span class="text-sm font-medium">@Model.PurchaseDate.Value.ToDubaiString("MMM dd, yyyy")</span></div> }
            </div>
        </div>

        <!-- Warranty Info -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 @(Model.IsWarrantyValid() ? "border-s-4 border-s-green-500" : Model.WarrantyExpiryDate.HasValue ? "border-s-4 border-s-red-500" : "")">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">@Shared["Label_WarrantyInfo"]</h3>
            @if (Model.WarrantyExpiryDate.HasValue)
            {
                <div class="flex justify-between items-center">
                    <span class="text-sm text-gray-500">@Shared["Label_ExpiryDate"]</span>
                    <span class="px-2 py-1 text-xs font-medium rounded-full @(Model.IsWarrantyValid() ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                        @Model.WarrantyExpiryDate.Value.ToDubaiString("MMM dd, yyyy")
                    </span>
                </div>
            }
            else { <p class="text-gray-500 text-sm">@Shared["Text_NoWarrantyInfo"]</p> }
        </div>

        <!-- Maintenance Schedule -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 @(Model.IsMaintenanceDue() ? "border-s-4 border-s-red-500" : "")">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">@Shared["Label_Maintenance"]</h3>
            <div class="space-y-3">
                @if (Model.LastMaintenanceDate.HasValue) { <div class="flex justify-between"><span class="text-sm text-gray-500">@Shared["Label_LastMaintenance"]</span><span class="text-sm font-medium">@Model.LastMaintenanceDate.Value.ToDubaiString("MMM dd, yyyy")</span></div> }
                @if (Model.NextMaintenanceDate.HasValue)
                {
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-500">@Shared["Label_NextMaintenance"]</span>
                        <span class="text-sm font-medium @(Model.IsMaintenanceDue() ? "text-red-600" : "text-gray-900")">@Model.NextMaintenanceDate.Value.ToDubaiString("MMM dd, yyyy")</span>
                    </div>
                }
            </div>
        </div>

        <!-- Assignment Info -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">@Shared["Label_Assignment"]</h3>
            <div class="space-y-3">
                @if (Model.AssignedToUnit != null) { <div class="flex justify-between"><span class="text-sm text-gray-500">@Shared["Label_Unit"]</span><span class="text-sm font-medium">@(isRtl ? Model.AssignedToUnit.NameAr : Model.AssignedToUnit.NameEn)</span></div> }
                @if (Model.AssignedToUser != null) { <div class="flex justify-between"><span class="text-sm text-gray-500">@Shared["Label_User"]</span><span class="text-sm font-medium">@Model.AssignedToUser.GetLocalizedFullName()</span></div> }
                @if (Model.Category != null) { <div class="flex justify-between"><span class="text-sm text-gray-500">@Shared["Label_Category"]</span><span class="text-sm font-medium">@(isRtl ? Model.Category.NameAr : Model.Category.NameEn)</span></div> }
            </div>
        </div>

        <!-- Related Risks -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
                    <i data-lucide="shield-alert" class="w-5 h-5 text-red-600"></i>
                    @Shared["Label_RelatedRisks"]
                </h3>
                <div class="flex items-center gap-2">
                    <span class="px-3 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-700">@Model.AssetRisks.Count(ar => ar.IsActive)</span>
                    @if (User.HasClaim("Permission", "CanEdit"))
                    {
                        <button onclick="openLinkRiskModal()" class="inline-flex items-center gap-1 px-3 py-1 text-xs font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
                            <i data-lucide="plus" class="w-3 h-3"></i>
                            @Shared["Button_LinkRisk"]
                        </button>
                    }
                </div>
            </div>
            @if (Model.AssetRisks.Any(ar => ar.IsActive))
            {
                <div class="space-y-2">
                    @foreach (var assetRisk in Model.AssetRisks.Where(ar => ar.IsActive).OrderByDescending(ar => ar.ImpactLevel))
                    {
                        var risk = assetRisk.Risk;
                        var levelClass = risk.RiskLevel switch { RiskLevel.Critical => "bg-red-100 text-red-800", RiskLevel.High => "bg-orange-100 text-orange-800", RiskLevel.Medium => "bg-yellow-100 text-yellow-800", _ => "bg-green-100 text-green-800" };
                        var impactClass = assetRisk.ImpactLevel switch { 5 => "bg-red-100 text-red-800", 4 => "bg-orange-100 text-orange-800", 3 => "bg-yellow-100 text-yellow-800", _ => "bg-green-100 text-green-800" };
                        <div class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                            <div class="flex items-start justify-between gap-2">
                                <a asp-controller="EnterpriseRisks" asp-action="Details" asp-route-id="@risk.Id" class="flex-1">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="text-sm font-medium text-gray-900">@risk.RiskNumber</span>
                                        <span class="px-2 py-0.5 text-xs font-medium rounded-full @levelClass">@risk.RiskLevel</span>
                                        <span class="px-2 py-0.5 text-xs font-medium rounded-full @impactClass" title="Impact on this asset">Impact: @assetRisk.ImpactLevel</span>
                                    </div>
                                    <p class="text-xs text-gray-600">@(isRtl ? risk.NameAr : risk.NameEn)</p>
                                    @if (!string.IsNullOrEmpty(assetRisk.SpecificControls))
                                    {
                                        <p class="text-xs text-gray-500 mt-1"><i data-lucide="shield-check" class="w-3 h-3 inline"></i> @assetRisk.SpecificControls</p>
                                    }
                                    @if (!string.IsNullOrEmpty(assetRisk.Notes))
                                    {
                                        <p class="text-xs text-gray-500 mt-1"><i data-lucide="file-text" class="w-3 h-3 inline"></i> @assetRisk.Notes</p>
                                    }
                                </a>
                                @if (User.HasClaim("Permission", "CanEdit"))
                                {
                                    <div class="flex items-center gap-1">
                                        <button onclick="editAssetRisk('@Model.Id', '@risk.Id', @assetRisk.ImpactLevel, '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(assetRisk.SpecificControls ?? ""))', '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(assetRisk.Notes ?? ""))')" class="p-1 text-blue-600 hover:bg-blue-50 rounded" title="Edit">
                                            <i data-lucide="edit-2" class="w-4 h-4"></i>
                                        </button>
                                        <button onclick="unlinkRisk('@Model.Id', '@risk.Id')" class="p-1 text-red-600 hover:bg-red-50 rounded" title="Unlink">
                                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-6">
                    <i data-lucide="shield-check" class="w-12 h-12 text-gray-300 mx-auto mb-2"></i>
                    <p class="text-sm text-gray-500">@Shared["Text_NoRelatedRisks"]</p>
                </div>
            }
        </div>
    </div>
</div>

@* External-system risks — asset obsolescence, replacement risk, etc. Renders nothing
   when no risk system is configured. *@
<div class="mt-3">
    @await Html.PartialAsync("Integrations/_LinkedRisks", new LinkedPanelArgs {
        EntityType = LinkedEntityType.Asset,
        EntityId   = Model.Id,
        AnchorId   = "linked-risks-asset"
    })
</div>

@* External-system KPIs — uptime, utilization, MTBF, etc. Renders nothing when no
   performance system is configured. *@
@if (PerfProvider.IsEnabled)
{
    <div class="mt-3">
        @await Html.PartialAsync("Integrations/_LinkedKpis", new LinkedPanelArgs {
            EntityType = LinkedEntityType.Asset,
            EntityId   = Model.Id,
            AnchorId   = "linked-kpis-asset"
        })
    </div>
}

<!-- Link Risk Modal -->
<div id="linkRiskModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-lg shadow-xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
        <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
            <h3 class="text-lg font-semibold text-gray-900">Link Risk to Asset</h3>
            <button onclick="closeLinkRiskModal()" class="text-gray-400 hover:text-gray-600">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <div class="p-6">
            <div id="availableRisksContainer" class="space-y-2">
                <div class="text-center py-8">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600 mx-auto"></div>
                    <p class="text-sm text-gray-500 mt-2">Loading available risks...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Asset-Risk Modal -->
<div id="editAssetRiskModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-4 flex items-center justify-between rounded-t-lg">
            <h3 class="text-lg font-semibold text-white">@Shared["Title_EditRiskRelationship"]</h3>
            <button onclick="closeEditAssetRiskModal()" class="text-white hover:text-gray-200">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <form id="editAssetRiskForm" class="p-6 space-y-4">
            <input type="hidden" id="editAssetId" />
            <input type="hidden" id="editRiskId" />

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Impact Level (1-5)</label>
                <select id="editImpactLevel" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                    <option value="1">1 - Very Low</option>
                    <option value="2">2 - Low</option>
                    <option value="3">3 - Medium</option>
                    <option value="4">4 - High</option>
                    <option value="5">5 - Critical</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Specific Controls</label>
                <textarea id="editSpecificControls" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="@(isRtl ? "الضوابط المعمول بها لهذا الأصل..." : "Controls in place for this asset...")"></textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
                <textarea id="editNotes" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="@(isRtl ? "ملاحظات إضافية..." : "Additional notes...")"></textarea>
            </div>

            <div class="flex gap-3 pt-4">
                <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium">
                    Save Changes
                </button>
                <button type="button" onclick="closeEditAssetRiskModal()" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors font-medium">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script nonce="@Context.CspNonce()">
    const assetId = '@Model.Id';

    // UX helpers — Swal-based replacements for raw alert()/confirm()
    function showErr(msg) {
        Swal.fire({ icon: 'error', title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Js_Error"].Value)), text: msg, confirmButtonColor: '#005B99' });
    }
    async function confirmDestructive(text) {
        const r = await Swal.fire({
            icon: 'warning', title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Confirm_AreYouSure"].Value)), text,
            showCancelButton: true,
            confirmButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Label_Yes"].Value)), cancelButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Shared["Button_Cancel"].Value)),
            confirmButtonColor: '#dc2626', cancelButtonColor: '#64748b'
        });
        return r.isConfirmed;
    }

    // Open link risk modal
    function openLinkRiskModal() {
        document.getElementById('linkRiskModal').classList.remove('hidden');
        loadAvailableRisks();
    }

    // Close link risk modal
    function closeLinkRiskModal() {
        document.getElementById('linkRiskModal').classList.add('hidden');
    }

    // Load available risks
    async function loadAvailableRisks() {
        try {
            const response = await fetch(`/Assets/GetAvailableRisks?assetId=${assetId}`);
            const risks = await response.json();

            const container = document.getElementById('availableRisksContainer');

            if (risks.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-8">
                        <i data-lucide="shield-check" class="w-12 h-12 text-gray-300 mx-auto mb-2"></i>
                        <p class="text-sm text-gray-500">@Shared["Text_AllRisksLinkedToAsset"]</p>
                    </div>
                `;
                lucide.createIcons();
                return;
            }

            container.innerHTML = risks.map(risk => {
                const levelClass = {
                    'Critical': 'bg-red-100 text-red-800',
                    'High': 'bg-orange-100 text-orange-800',
                    'Medium': 'bg-yellow-100 text-yellow-800',
                    'Low': 'bg-green-100 text-green-800'
                }[risk.riskLevel] || 'bg-gray-100 text-gray-800';

                return `
                    <div class="p-4 border border-gray-200 rounded-lg hover:border-blue-300 transition-colors">
                        <div class="flex items-start justify-between gap-3">
                            <div class="flex-1">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-sm font-medium text-gray-900">${risk.riskNumber}</span>
                                    <span class="px-2 py-0.5 text-xs font-medium rounded-full ${levelClass}">${risk.riskLevel}</span>
                                    <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 text-gray-700">Score: ${risk.inherentRiskScore}</span>
                                </div>
                                <p class="text-sm text-gray-700 mb-1">${risk.nameEn}</p>
                                ${risk.categoryName ? `<p class="text-xs text-gray-500">${risk.categoryName}</p>` : ''}
                            </div>
                            <button onclick="linkRisk('${risk.id}')" class="px-3 py-1.5 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition-colors whitespace-nowrap">
                                Link Risk
                            </button>
                        </div>
                    </div>
                `;
            }).join('');

            lucide.createIcons();
        } catch (error) {
            console.error('Error loading risks:', error);
            document.getElementById('availableRisksContainer').innerHTML = `
                <div class="text-center py-8 text-red-600">
                    <p>Error loading risks. Please try again.</p>
                </div>
            `;
        }
    }

    // Link risk to asset
    async function linkRisk(riskId) {
        try {
            const response = await fetch('/Assets/LinkRisk', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    assetId: assetId,
                    riskId: riskId,
                    impactLevel: 3
                })
            });

            const result = await response.json();

            if (result.success) {
                closeLinkRiskModal();
                location.reload();
            } else {
                showErr(result.message || 'Error linking risk');
            }
        } catch (error) {
            console.error('Error linking risk:', error);
            showErr('Error linking risk. Please try again.');
        }
    }

    // Unlink risk from asset
    async function unlinkRisk(assetId, riskId) {
        if (!(await confirmDestructive('Are you sure you want to unlink this risk from the asset?'))) return;

        try {
            const response = await fetch('/Assets/UnlinkRisk', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    assetId: assetId,
                    riskId: riskId
                })
            });

            const result = await response.json();

            if (result.success) {
                location.reload();
            } else {
                showErr(result.message || 'Error unlinking risk');
            }
        } catch (error) {
            console.error('Error unlinking risk:', error);
            showErr('Error unlinking risk. Please try again.');
        }
    }

    // Edit asset-risk relationship
    function editAssetRisk(assetId, riskId, impactLevel, specificControls, notes) {
        document.getElementById('editAssetId').value = assetId;
        document.getElementById('editRiskId').value = riskId;
        document.getElementById('editImpactLevel').value = impactLevel;
        document.getElementById('editSpecificControls').value = specificControls || '';
        document.getElementById('editNotes').value = notes || '';
        document.getElementById('editAssetRiskModal').classList.remove('hidden');
    }

    // Close edit modal
    function closeEditAssetRiskModal() {
        document.getElementById('editAssetRiskModal').classList.add('hidden');
    }

    // Handle edit form submission
    document.getElementById('editAssetRiskForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const assetId = document.getElementById('editAssetId').value;
        const riskId = document.getElementById('editRiskId').value;
        const impactLevel = document.getElementById('editImpactLevel').value;
        const specificControls = document.getElementById('editSpecificControls').value;
        const notes = document.getElementById('editNotes').value;

        try {
            const response = await fetch('/Assets/UpdateAssetRisk', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: new URLSearchParams({
                    assetId: assetId,
                    riskId: riskId,
                    impactLevel: impactLevel,
                    specificControls: specificControls,
                    notes: notes
                })
            });

            const result = await response.json();

            if (result.success) {
                closeEditAssetRiskModal();
                location.reload();
            } else {
                showErr(result.message || 'Error updating relationship');
            }
        } catch (error) {
            console.error('Error updating relationship:', error);
            showErr('Error updating relationship. Please try again.');
        }
    });
</script>
}

