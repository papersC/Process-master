@model IEnumerable<Asset>
@using ESEMS.Web.Models.Enums
@{
    ViewData["Title"] = Shared["Title_AssetsOverview"].Value;
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("ar");
    var totalAssets = (int)(ViewBag.TotalAssets ?? 0);
    var operational = (int)(ViewBag.OperationalAssets ?? 0);
    var underMaint = (int)(ViewBag.UnderMaintenanceAssets ?? 0);
    var retired = Model.Count(a => a.Status == AssetStatus.Retired);
    var disposed = Model.Count(a => a.Status == AssetStatus.Disposed);
    var totalValue = (decimal)(ViewBag.TotalValue ?? 0m);
    var maintenanceDue = (int)(ViewBag.MaintenanceDue ?? 0);
    var warrantyExp = (int)(ViewBag.WarrantyExpiring ?? 0);
    var recent = Model.OrderByDescending(a => a.UpdatedAt).Take(10).ToList();
}

<style>
    .ad-shell { display: flex; flex-direction: column; gap: .6rem; height: calc(100vh - 140px); min-height: 600px; }
    .ad-header { display: flex; align-items: center; justify-content: space-between; padding: .25rem 0 .4rem; border-bottom: 1px solid #e5e7eb; flex: 0 0 auto; }
    .ad-header h1 { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .5rem; }
    .ad-header p { margin: 0; font-size: var(--fs-xs); color: #6b7280; }
    .ad-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; transition: background .15s; }
    .ad-btn-primary { background: #005B99; color: #fff; border: none; }
    .ad-btn-primary:hover { background: #003d6b; color: #fff; }
    .ad-btn-outline { background: #fff; color: #005B99; border: 1px solid #cbd5e1; }
    .ad-btn-outline:hover { background: #f1f5f9; }

    .ad-kpi-grid { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: .5rem; flex: 0 0 auto; }
    @@media (max-width: 1280px) { .ad-kpi-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .ad-kpi { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .65rem .85rem; display: flex; align-items: center; gap: .65rem; }
    .ad-kpi-bar { width: 4px; align-self: stretch; border-radius: 2px; flex-shrink: 0; }
    .ad-kpi-meta { flex: 1; min-width: 0; }
    .ad-kpi-label { font-size: var(--fs-xs); color: #6b7280; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ad-kpi-value { font-size: var(--fs-lg); font-weight: 700; color: #111827; line-height: 1.2; margin: 0; }
    .ad-kpi-value .ad-suffix { font-size: var(--fs-xs); font-weight: 600; color: #6b7280; }

    .ad-main { display: grid; grid-template-columns: 1.1fr 1.4fr; gap: .6rem; flex: 1 1 0; min-height: 0; }
    @@media (max-width: 1024px) { .ad-main { grid-template-columns: 1fr; } }
    .ad-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; display: flex; flex-direction: column; min-height: 0; overflow: hidden; }
    .ad-card-head { display: flex; align-items: center; justify-content: space-between; padding: .5rem .85rem; border-bottom: 1px solid #f1f5f9; flex: 0 0 auto; }
    .ad-card-head h6 { margin: 0; font-size: var(--fs-sm); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .4rem; }
    .ad-card-body { flex: 1 1 0; min-height: 0; padding: .65rem .85rem; position: relative; }
    .ad-chart-wrap { position: relative; height: 100%; max-width: 460px; max-height: 420px; margin: 0 auto; padding: 1rem .5rem .25rem; box-sizing: border-box; }
    .ad-chart-center { position: absolute; inset: 1rem .5rem .25rem; display: flex; flex-direction: column; align-items: center; justify-content: center; pointer-events: none; padding-bottom: 2.5rem; }
    .ad-chart-center .ad-chart-total { font-size: var(--fs-2xl); font-weight: 700; color: #111827; line-height: 1; }
    .ad-chart-center .ad-chart-label { font-size: var(--fs-xs); color: #6b7280; margin-top: .2rem; text-transform: uppercase; letter-spacing: .04em; }

    .ad-table-wrap { flex: 1 1 0; min-height: 0; overflow: auto; }
    .ad-table-wrap table { width: 100%; font-size: var(--fs-xs); border-collapse: collapse; }
    .ad-table-wrap thead { position: sticky; top: 0; background: #f8fafc; z-index: 1; }
    .ad-table-wrap th { font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: .04em; color: #6b7280; font-weight: 600; padding: .55rem .8rem; text-align: start; border-bottom: 1px solid #e5e7eb; white-space: nowrap; }
    .ad-table-wrap td { padding: .5rem .8rem; border-bottom: 1px solid #f3f4f6; color: #374151; }
    .ad-table-wrap tbody tr:hover td { background: #f9fafb; }
    .ad-status { display: inline-block; padding: .15rem .5rem; font-size: var(--fs-xs); font-weight: 600; border-radius: .25rem; }
    .ad-status-Operational { background: #ecfdf5; color: #047857; }
    .ad-status-UnderMaintenance { background: #fef3c7; color: #92400e; }
    .ad-status-Retired, .ad-status-Disposed { background: #f1f5f9; color: #475569; }
    .ad-status-Planned, .ad-status-Ordered, .ad-status-InTransit { background: #eff6ff; color: #1d4ed8; }

    .ad-alert { background: #fff7ed; border: 1px solid #fed7aa; border-radius: .5rem; padding: .6rem .85rem; display: flex; align-items: center; gap: .65rem; flex: 0 0 auto; }
    .ad-alert i { color: #ea580c; flex-shrink: 0; }
    .ad-alert .ad-alert-text { font-size: var(--fs-sm); color: #9a3412; }
    .ad-alert strong { font-weight: 700; }
</style>

<div class="ad-shell">
    <div class="ad-header">
        <div>
            <h1><i data-lucide="layout-dashboard" class="w-5 h-5" style="color:#005B99;" aria-hidden="true"></i>@Shared["Title_AssetsOverview"]</h1>
            <p>@Shared["Text_AnalyticsInsights"]</p>
        </div>
        <div style="display:flex;gap:.4rem;">
            <a asp-action="Index" class="ad-btn ad-btn-outline">
                <i data-lucide="list" class="w-4 h-4" aria-hidden="true"></i>@Shared["Button_ViewAllAssets"]
            </a>
            <a asp-action="Create" class="ad-btn ad-btn-primary">
                <i data-lucide="plus" class="w-4 h-4" aria-hidden="true"></i>@Shared["Action_AddAsset"]
            </a>
        </div>
    </div>

    <div class="ad-kpi-grid">
        <div class="ad-kpi"><span class="ad-kpi-bar" style="background:#005B99;"></span><div class="ad-kpi-meta"><p class="ad-kpi-label">@Shared["Label_TotalAssets"]</p><p class="ad-kpi-value">@totalAssets</p></div></div>
        <div class="ad-kpi"><span class="ad-kpi-bar" style="background:#34C38F;"></span><div class="ad-kpi-meta"><p class="ad-kpi-label">@Shared["Label_Operational"]</p><p class="ad-kpi-value">@operational</p></div></div>
        <div class="ad-kpi"><span class="ad-kpi-bar" style="background:#F1B44C;"></span><div class="ad-kpi-meta"><p class="ad-kpi-label">@Shared["AssetStatus_UnderMaintenance"]</p><p class="ad-kpi-value">@underMaint</p></div></div>
        <div class="ad-kpi"><span class="ad-kpi-bar" style="background:#10b981;"></span><div class="ad-kpi-meta"><p class="ad-kpi-label">@(isRtl ? "إجمالي القيمة" : "Total Value")</p><p class="ad-kpi-value">@totalValue.ToString("N0") <span class="ad-suffix">AED</span></p></div></div>
        <div class="ad-kpi"><span class="ad-kpi-bar" style="background:#F46A6A;"></span><div class="ad-kpi-meta"><p class="ad-kpi-label">@(isRtl ? "صيانة مستحقة" : "Maintenance Due")</p><p class="ad-kpi-value">@maintenanceDue</p></div></div>
        <div class="ad-kpi"><span class="ad-kpi-bar" style="background:#8b5cf6;"></span><div class="ad-kpi-meta"><p class="ad-kpi-label">@(isRtl ? "ضمان قارب على الانتهاء" : "Warranty Expiring")</p><p class="ad-kpi-value">@warrantyExp</p></div></div>
    </div>

    @if (maintenanceDue > 0 || warrantyExp > 0)
    {
        <div class="ad-alert">
            <i data-lucide="alert-triangle" class="w-4 h-4" aria-hidden="true"></i>
            <div class="ad-alert-text">
                @if (maintenanceDue > 0) { <span><strong>@maintenanceDue</strong> @(isRtl ? "أصلًا تحتاج صيانة خلال 30 يومًا" : "assets need maintenance within 30 days") · </span> }
                @if (warrantyExp > 0) { <span><strong>@warrantyExp</strong> @(isRtl ? "ضمانات تنتهي خلال 90 يومًا" : "warranties expire within 90 days") </span> }
            </div>
        </div>
    }

    <div class="ad-main">
        <div class="ad-card">
            <div class="ad-card-head">
                <h6><i data-lucide="pie-chart" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "حالة الأصول" : "Asset Status")</h6>
            </div>
            <div class="ad-card-body">
                <div class="ad-chart-wrap">
                    <canvas id="adStatusChart"></canvas>
                    <div class="ad-chart-center">
                        <span class="ad-chart-total">@totalAssets</span>
                        <span class="ad-chart-label">@Shared["Label_TotalAssets"]</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="ad-card">
            <div class="ad-card-head">
                <h6><i data-lucide="clock" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>@(isRtl ? "أصول حديثة" : "Recent Assets")</h6>
                <a asp-action="Index" style="font-size: var(--fs-xs);color:#005B99;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.25rem;">
                    @Shared["Action_ViewAll"]
                    <i data-lucide="@(isRtl ? "arrow-left" : "arrow-right")" class="w-3 h-3" aria-hidden="true"></i>
                </a>
            </div>
            <div class="ad-card-body" style="padding:0;">
                <div class="ad-table-wrap">
                    @if (recent.Any())
                    {
                        <table>
                            <thead>
                                <tr>
                                    <th>@(isRtl ? "الرمز" : "Tag")</th>
                                    <th>@Shared["Column_Name"]</th>
                                    <th>@(isRtl ? "الفئة" : "Category")</th>
                                    <th>@Shared["Column_Status"]</th>
                                    <th>@(isRtl ? "القيمة" : "Value")</th>
                                    <th style="width:60px;text-align:end;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var asset in recent)
                                {
                                    <tr>
                                        <td><code style="font-size: var(--fs-xs);color:#475569;">@asset.AssetTag</code></td>
                                        <td><span style="font-weight:500;color:#111827;">@(isRtl ? asset.NameAr : asset.NameEn)</span></td>
                                        <td>@(asset.Category != null ? (isRtl ? asset.Category.NameAr : asset.Category.NameEn) : "—")</td>
                                        <td><span class="ad-status ad-status-@asset.Status">@Shared[$"AssetStatus_{asset.Status}"]</span></td>
                                        <td><span style="color:#6b7280;">@(asset.CurrentValue?.ToString("N0") ?? "—") AED</span></td>
                                        <td style="text-align:end;">
                                            <a asp-action="Details" asp-route-id="@asset.Id" aria-label="@Shared["Button_View"]" style="color:#005B99;text-decoration:none;display:inline-flex;align-items:center;font-weight:600;">
                                                <i data-lucide="eye" class="w-3.5 h-3.5" aria-hidden="true"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div style="padding:2rem;text-align:center;color:#94a3b8;font-size: var(--fs-sm);">
                            <i data-lucide="package" class="w-8 h-8" aria-hidden="true" style="margin:0 auto .5rem;display:block;color:#cbd5e1;"></i>
                            @(isRtl ? "لا توجد أصول مسجلة" : "No assets registered")
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();
        const isRtl = @(isRtl ? "true" : "false");
        if (isRtl) { Chart.defaults.plugins.legend.rtl = true; Chart.defaults.plugins.legend.textDirection = 'rtl'; Chart.defaults.plugins.tooltip.rtl = true; Chart.defaults.plugins.tooltip.textDirection = 'rtl'; }

        // Audit fix: a doughnut with one populated slice (or one slice >= 95%)
        // looks "broken" — Chart.js paints it as a solid ring with no useful
        // legend. Swap it for an inline summary card instead so the user sees
        // the actual number, not a misleading visualisation.
        (function() {
            const labels = [
                @Html.Raw("'" + Shared["AssetStatus_Operational"].Value + "'"),
                @Html.Raw("'" + Shared["AssetStatus_UnderMaintenance"].Value + "'"),
                @Html.Raw("'" + Shared["AssetStatus_Retired"].Value + "'"),
                @Html.Raw("'" + Shared["AssetStatus_Disposed"].Value + "'")
            ];
            const data = [@operational, @underMaint, @retired, @disposed];
            const colors = ['#34C38F', '#F1B44C', '#94a3b8', '#cbd5e1'];
            const total = data.reduce((a, b) => a + b, 0);
            const populated = data.filter(v => v > 0).length;
            const dominantIdx = data.findIndex(v => total > 0 && (v / total) >= 0.95);
            const wrap = document.querySelector('.ad-chart-wrap');
            const canvas = document.getElementById('adStatusChart');

            if (total === 0) {
                if (canvas) canvas.style.display = 'none';
                return;
            }

            if (populated <= 1 || dominantIdx !== -1) {
                // Replace chart with a single-status callout — keep the centre
                // total visible so the KPI doesn't disappear.
                const idx = dominantIdx !== -1 ? dominantIdx : data.findIndex(v => v > 0);
                if (canvas) canvas.style.display = 'none';
                const center = wrap ? wrap.querySelector('.ad-chart-center') : null;
                if (center) center.style.position = 'static';
                const note = document.createElement('div');
                note.style.cssText = 'text-align:center;margin-top:.6rem;font-size:var(--fs-xs);color:#475569;';
                note.innerHTML = '<span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:'+colors[idx]+';margin-inline-end:.4rem;vertical-align:middle;"></span>' +
                                 '<strong style="color:#111827;">' + data[idx] + '</strong> ' + labels[idx] +
                                 (dominantIdx !== -1 && populated > 1 ? ' <span style="color:#94a3b8;">(' + ((data[idx]/total)*100).toFixed(0) + '%)</span>' : '');
                if (wrap) wrap.appendChild(note);
                return;
            }

            new Chart(canvas, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: colors,
                        hoverBackgroundColor: ['#5dd9a8', '#f4c56d', '#cbd5e1', '#e2e8f0'],
                        borderWidth: 3, borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false, cutout: '68%',
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 14, usePointStyle: true, font: { size: 12, weight: '500' } } },
                        tooltip: { backgroundColor: 'rgba(0,0,0,.85)', padding: 10,
                            callbacks: { label: function(c){ var t=c.dataset.data.reduce((a,b)=>a+b,0); var p=t>0?((c.parsed/t)*100).toFixed(1):'0'; return c.label+': '+c.parsed+' ('+p+'%)'; } } }
                    }
                }
            });
        })();
    </script>
}
