@model IEnumerable<Incident>
@{
    ViewData["Title"] = Shared["Title_Incidents"].Value;
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isRtl = culture.StartsWith("ar");

    var critical = Model.Count(i => i.Priority == 1 && i.Status != IncidentStatus.Closed);
    var open = Model.Count(i => i.Status != IncidentStatus.Resolved && i.Status != IncidentStatus.Closed);
    var slaBreached = Model.Count(i => i.SlaBreached);
    var resolved = Model.Count(i => i.Status == IncidentStatus.Resolved || i.Status == IncidentStatus.Closed);
}

@*  Compact .lt-header + tight 4-counter .lt-kpi-strip + clean .lt-card
    table with sticky header. Same .lt-* tokens used across Processes /
    Categories / ProcessGroups / Services index pages. The
    `esems-datatable` class is preserved so DataTables auto-init keeps
    handling search/sort/paging. *@

<style>
    .lt-shell { display: flex; flex-direction: column; gap: .6rem; }
    .lt-header { display: flex; align-items: center; justify-content: space-between; padding: .25rem 0 .4rem; border-bottom: 1px solid #e5e7eb; flex: 0 0 auto; }
    .lt-header h1 { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .5rem; }
    .lt-header p { margin: 0; font-size: var(--fs-xs); color: #6b7280; }
    .lt-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; border: none; }
    .lt-btn-primary { background: #005B99; color: #fff; } .lt-btn-primary:hover { background: #003d6b; color: #fff; }
    .lt-kpi-strip { display: flex; align-items: stretch; gap: .5rem; padding: .55rem .65rem; background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; flex-wrap: wrap; }
    .lt-kpi { display: flex; align-items: center; gap: .55rem; padding: .25rem .65rem; flex: 1 1 180px; min-width: 180px; border-inline-end: 1px dashed #e5e7eb; }
    .lt-kpi:last-child { border-inline-end: none; }
    .lt-kpi-icon { width: 34px; height: 34px; border-radius: .375rem; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .lt-kpi-icon.kpi-red    { background: #fef2f2; color: #dc2626; }
    .lt-kpi-icon.kpi-orange { background: #fff7ed; color: #c2410c; }
    .lt-kpi-icon.kpi-yellow { background: #fefce8; color: #a16207; }
    .lt-kpi-icon.kpi-green  { background: #ecfdf5; color: #047857; }
    .lt-kpi-num { font-size: var(--fs-base); font-weight: 700; color: #111827; line-height: 1; }
    .lt-kpi-label { font-size: var(--fs-xs); color: #6b7280; margin-top: .15rem; text-transform: uppercase; letter-spacing: .03em; white-space: nowrap; }
    @@media (max-width: 768px) { .lt-kpi { flex: 1 1 45%; border-inline-end: none; } }

    .lt-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; display: flex; flex-direction: column; overflow: hidden; }
    .lt-table-wrap { overflow: auto; }
    .lt-table-wrap table { width: 100%; font-size: var(--fs-sm); border-collapse: collapse; }
    .lt-table-wrap thead { position: sticky; top: 0; background: #f8fafc; z-index: 1; }
    .lt-table-wrap th { font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: .04em; color: #6b7280; font-weight: 600; padding: .55rem .75rem; text-align: start; border-bottom: 1px solid #e5e7eb; white-space: nowrap; }
    .lt-table-wrap td { padding: .5rem .75rem; border-bottom: 1px solid #f3f4f6; color: #374151; vertical-align: middle; }
    .lt-table-wrap tbody tr:hover td { background: #f9fafb; }
    .lt-pill { display: inline-block; padding: .15rem .5rem; font-size: var(--fs-xs); font-weight: 600; border-radius: .25rem; white-space: nowrap; }
    .lt-pill-pri-1 { background: #fef2f2; color: #b91c1c; }
    .lt-pill-pri-2 { background: #fff7ed; color: #c2410c; }
    .lt-pill-pri-3 { background: #fefce8; color: #a16207; }
    .lt-pill-pri-4 { background: #f1f5f9; color: #475569; }
    .lt-pill-st-New        { background: #eff6ff; color: #1d4ed8; }
    .lt-pill-st-InProgress { background: #f5f3ff; color: #6d28d9; }
    .lt-pill-st-Resolved   { background: #ecfdf5; color: #047857; }
    .lt-pill-st-Closed     { background: #f1f5f9; color: #475569; }
    .lt-pill-sla-breach   { background: #fef2f2; color: #b91c1c; }
    .lt-pill-sla-met      { background: #ecfdf5; color: #047857; }
    .lt-pill-sla-soon     { background: #fef2f2; color: #b91c1c; }
    .lt-pill-sla-warn     { background: #fefce8; color: #a16207; }
    .lt-pill-sla-ok       { background: #ecfdf5; color: #047857; }
    .lt-incnum { color: #005B99; font-weight: 600; text-decoration: none; }
    .lt-incnum:hover { text-decoration: underline; color: #003d6b; }
    .lt-actions { display: inline-flex; gap: .35rem; align-items: center; }
    .lt-actions a { color: #005B99; padding: .2rem; border-radius: .25rem; transition: background .15s; }
    .lt-actions a:hover { background: #eff6ff; }
    .lt-action-locked { color: #cbd5e1; padding: .2rem; display: inline-flex; align-items: center; cursor: not-allowed; }
</style>

<div class="lt-shell">
    <div class="lt-header">
        <div>
            <h1><i data-lucide="alert-circle" class="w-5 h-5" style="color:#F46A6A;" aria-hidden="true"></i>@Shared["Title_Incidents"]</h1>
            <p>@Shared["Text_ManageIncidents"]</p>
        </div>
        <a asp-action="Create" class="lt-btn lt-btn-primary">
            <i data-lucide="plus" class="w-4 h-4" aria-hidden="true"></i>@Shared["Button_ReportIncident"]
        </a>
    </div>

    <div class="lt-kpi-strip">
        <div class="lt-kpi">
            <div class="lt-kpi-icon kpi-red"><i data-lucide="alert-circle" class="w-4 h-4" aria-hidden="true"></i></div>
            <div>
                <div class="lt-kpi-num">@critical</div>
                <div class="lt-kpi-label">@Shared["Label_Critical"]</div>
            </div>
        </div>
        <div class="lt-kpi">
            <div class="lt-kpi-icon kpi-orange"><i data-lucide="clock" class="w-4 h-4" aria-hidden="true"></i></div>
            <div>
                <div class="lt-kpi-num">@open</div>
                <div class="lt-kpi-label">@Shared["Label_Open"]</div>
            </div>
        </div>
        <div class="lt-kpi">
            <div class="lt-kpi-icon kpi-yellow"><i data-lucide="alert-triangle" class="w-4 h-4" aria-hidden="true"></i></div>
            <div>
                <div class="lt-kpi-num">@slaBreached</div>
                <div class="lt-kpi-label">@Shared["Label_SLABreached"]</div>
            </div>
        </div>
        <div class="lt-kpi">
            <div class="lt-kpi-icon kpi-green"><i data-lucide="check-circle" class="w-4 h-4" aria-hidden="true"></i></div>
            <div>
                <div class="lt-kpi-num">@resolved</div>
                <div class="lt-kpi-label">@Shared["Label_Resolved"]</div>
            </div>
        </div>
    </div>

    <div class="lt-card">
        <div class="lt-table-wrap">
            <table class="esems-datatable" id="incidentsTable">
                <thead>
                    <tr>
                        <th>@Shared["Column_IncidentNumber"]</th>
                        <th>@Shared["Column_Title"]</th>
                        <th>@Shared["Column_Priority"]</th>
                        <th>@Shared["Column_Status"]</th>
                        <th>@Shared["Column_Service"]</th>
                        <th>@Shared["Column_SLA"]</th>
                        <th>@Shared["Column_ReportedAt"]</th>
                        <th style="text-align:end;">@Shared["Column_Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var incident in Model)
                    {
                        var priLabel = incident.Priority switch { 1 => Shared["Priority_Critical"].Value, 2 => Shared["Priority_High"].Value, 3 => Shared["Priority_Medium"].Value, _ => Shared["Priority_Low"].Value };
                        var priClass = incident.Priority switch { 1 => "lt-pill-pri-1", 2 => "lt-pill-pri-2", 3 => "lt-pill-pri-3", _ => "lt-pill-pri-4" };
                        var statusClass = $"lt-pill-st-{incident.Status}";
                        <tr>
                            <td><a asp-action="Details" asp-route-id="@incident.Id" class="lt-incnum">@incident.IncidentNumber</a></td>
                            <td>
                                <div style="font-weight:600;color:#111827;">@(isRtl ? incident.NameAr : incident.NameEn)</div>
                                <div style="font-size: var(--fs-xs);color:#6b7280;">@incident.Category</div>
                            </td>
                            <td><span class="lt-pill @priClass">@priLabel</span></td>
                            <td><span class="lt-pill @statusClass">@Shared[$"IncidentStatus_{incident.Status}"].Value</span></td>
                            <td style="color:#6b7280;">@(incident.Service != null ? (isRtl ? incident.Service.NameAr : incident.Service.NameEn) : "—")</td>
                            <td>
                                @if (incident.SlaBreached)
                                {
                                    <span class="lt-pill lt-pill-sla-breach">@Shared["Label_Breached"]</span>
                                }
                                else if (incident.Status == IncidentStatus.Resolved || incident.Status == IncidentStatus.Closed)
                                {
                                    <span class="lt-pill lt-pill-sla-met">@Shared["Label_Met"]</span>
                                }
                                else
                                {
                                    var remaining = (int)(incident.SlaDueDate - DateTime.UtcNow).TotalHours;
                                    var slaCls = remaining < 2 ? "lt-pill-sla-soon" : remaining < 8 ? "lt-pill-sla-warn" : "lt-pill-sla-ok";
                                    <span class="lt-pill @slaCls">@remaining h @Shared["Label_Remaining"]</span>
                                }
                            </td>
                            <td style="color:#6b7280;white-space:nowrap;">@incident.ReportedAt.ToDubaiString("MMM dd, yyyy HH:mm")</td>
                            <td style="text-align:end;">
                                <span class="lt-actions">
                                    <a asp-action="Details" asp-route-id="@incident.Id" title="@Shared["Tooltip_ViewDetails"]" aria-label="@Shared["Tooltip_ViewDetails"]"><i data-lucide="eye" class="w-4 h-4" aria-hidden="true"></i></a>
                                    <a asp-action="Edit" asp-route-id="@incident.Id" title="@Shared["Tooltip_EditRecord"]" aria-label="@Shared["Tooltip_EditRecord"]"><i data-lucide="edit" class="w-4 h-4" aria-hidden="true"></i></a>
                                    @* M-14 (Tier-3 a11y): role=img required for aria-label on <span>. *@
                                    <span class="lt-action-locked" role="img" title="@(isRtl ? "لا يمكن الحذف — مقفل للتدقيق" : "Cannot delete — audit-locked")" aria-label="@(isRtl ? "مقفل للتدقيق" : "Audit-locked")"><i data-lucide="trash-2" class="w-4 h-4" aria-hidden="true"></i></span>
                                </span>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" style="padding:3rem 1rem;text-align:center;color:#94a3b8;">
                            <i data-lucide="inbox" class="w-10 h-10" aria-hidden="true" style="margin:0 auto .5rem;display:block;color:#cbd5e1;"></i>
                            <div style="font-weight:500;">@(isRtl ? "لا توجد حوادث بعد" : "No incidents yet")</div>
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();
    </script>
}
