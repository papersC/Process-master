@model OrganizationUnit
@{
    ViewData["Title"] = Shared["Action_CreateOrganizationUnit"].Value;
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    var step1 = isRtl ? "الهوية والتسلسل" : "Identity & Hierarchy";
    var step2 = isRtl ? "الاتصال والوصف" : "Contact & Description";
}

<partial name="_WizardStyles" />

<div class="wiz-pageheader">
    <h1 class="wiz-pagetitle"><i data-lucide="building-2" style="width:20px;height:20px;color:#005B99;"></i>@ViewData["Title"]</h1>
    <div style="display:inline-flex;align-items:center;gap:.85rem;">
        <span class="wiz-stepcount">@(isRtl ? "الخطوة" : "Step") <b id="stepCounter">1</b> @(isRtl ? "من" : "of") 2</span>
        <a asp-action="Index" class="wiz-cancellink"><i data-lucide="x" style="width:14px;height:14px;"></i> @Shared["Action_Back"]</a>
    </div>
</div>

<form asp-action="Create" method="post" id="wizardForm" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" style="margin-bottom:.6rem;padding:.6rem .8rem;background:#fef2f2;border:1px solid #fecaca;border-radius:.375rem;color:#b91c1c;font-size: var(--fs-xs);"></div>

    <div class="wiz-grid">
        <aside class="wiz-rail">
            <ul class="wiz-steps" id="wizardSteps">
                <li class="wiz-step active" data-step="1" onclick="wizGoTo(1)">
                    <span class="wiz-stepnum">1</span>
                    <span class="wiz-steptext"><span class="wiz-steptitle">@step1</span><span class="wiz-stepsub">@(isRtl ? "الكود، الاسم، الأب" : "Code, name, parent")</span></span>
                </li>
                <li class="wiz-step" data-step="2" onclick="wizGoTo(2)">
                    <span class="wiz-stepnum">2</span>
                    <span class="wiz-steptext"><span class="wiz-steptitle">@step2</span><span class="wiz-stepsub">@(isRtl ? "البريد، الهاتف، الرئيس" : "Email, phone, head")</span></span>
                </li>
            </ul>
        </aside>

        <section class="wiz-main">
            <!-- Step 1 -->
            <div class="wiz-step-content active" data-step="1">
                <div class="wiz-stephdr"><i data-lucide="building-2" style="width:18px;height:18px;"></i><h2>@(isRtl ? "الخطوة" : "Step") 1: @step1</h2></div>

                <div class="pc-grid-4 pc-row">
                    <div>
                        <label asp-for="Code" class="pc-label">@Shared["Column_Code"] <span class="req">*</span></label>
                        <input asp-for="Code" id="CodeInp" class="pc-input" placeholder="@(isRtl ? "مثال: OU-IT" : "e.g., OU-IT")" />
                        <span asp-validation-for="Code" class="pc-err"></span>
                    </div>
                    <div>
                        <label asp-for="Level" class="pc-label">@Shared["Label_Level"]</label>
                        <input asp-for="Level" type="number" min="1" max="6" id="LevelInp" class="pc-input" />
                    </div>
                    <input asp-for="DisplayOrder" type="hidden" />
                    <div>
                        <label asp-for="UnitType" class="pc-label">@(isRtl ? "النوع" : "Unit Type")</label>
                        <select asp-for="UnitType" id="UnitTypeSel" class="pc-select">
                            <option value="">@(isRtl ? "— غير محدد —" : "— Unspecified —")</option>
                            <option value="Sector">@(isRtl ? "قطاع" : "Sector")</option>
                            <option value="Department">@(isRtl ? "إدارة" : "Department")</option>
                            <option value="Section">@(isRtl ? "قسم" : "Section")</option>
                            <option value="Center">@(isRtl ? "مركز" : "Center")</option>
                            <option value="Office">@(isRtl ? "مكتب" : "Office")</option>
                            <option value="OversightBody">@(isRtl ? "جهة رقابية" : "Oversight Body")</option>
                            <option value="ExecutiveLeadership">@(isRtl ? "قيادة تنفيذية" : "Executive Leadership")</option>
                        </select>
                    </div>
                    <div>
                        <label asp-for="ParentId" class="pc-label">@Shared["Label_ParentUnit"]</label>
                        <select asp-for="ParentId" id="ParentSel" asp-items="ViewBag.ParentUnits" class="pc-select">
                            <option value="">@Shared["Option_None"]</option>
                        </select>
                    </div>
                </div>

                <div class="pc-grid-2">
                    <div>
                        <label asp-for="NameEn" class="pc-label">@Shared["Label_NameEn"] <span class="req">*</span></label>
                        <input asp-for="NameEn" class="pc-input" />
                        <span asp-validation-for="NameEn" class="pc-err"></span>
                    </div>
                    <div>
                        <label asp-for="NameAr" class="pc-label">@Shared["Label_NameAr"] <span class="req">*</span></label>
                        <input asp-for="NameAr" dir="rtl" class="pc-input" />
                        <span asp-validation-for="NameAr" class="pc-err"></span>
                    </div>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="wiz-step-content" data-step="2">
                <div class="wiz-stephdr"><i data-lucide="contact" style="width:18px;height:18px;"></i><h2>@(isRtl ? "الخطوة" : "Step") 2: @step2</h2></div>

                <div class="pc-grid-2 pc-row">
                    <div>
                        <label asp-for="Email" class="pc-label">@Shared["Label_Email"]</label>
                        <input asp-for="Email" type="email" id="EmailInp" class="pc-input" />
                    </div>
                    <div>
                        <label asp-for="Phone" class="pc-label">@Shared["Label_Phone"]</label>
                        <input asp-for="Phone" id="PhoneInp" class="pc-input" />
                    </div>
                </div>

                <div class="pc-row">
                    <label asp-for="HeadUserId" class="pc-label">@Shared["Label_UnitHead"]</label>
                    <select asp-for="HeadUserId" id="HeadSel" asp-items="ViewBag.Users" class="pc-select">
                        <option value="">@Shared["Option_Optional"]</option>
                    </select>
                </div>

                <div class="pc-grid-2 pc-row">
                    <div>
                        <label asp-for="DescriptionEn" class="pc-label">@Shared["Label_DescriptionEn"]</label>
                        <textarea asp-for="DescriptionEn" rows="3" class="pc-textarea"></textarea>
                    </div>
                    <div>
                        <label asp-for="DescriptionAr" class="pc-label">@Shared["Label_DescriptionAr"]</label>
                        <textarea asp-for="DescriptionAr" dir="rtl" rows="3" class="pc-textarea"></textarea>
                    </div>
                </div>

                <label class="pc-checkbox-row">
                    <input asp-for="IsActive" id="IsActiveInp" />
                    <span style="font-size: var(--fs-xs);color:#374151;">@Shared["Label_IsActive"]</span>
                </label>
            </div>

            <div class="wiz-footer">
                <button type="button" class="pc-btn pc-btn-ghost" id="prevBtn" disabled>
                    <i data-lucide="@(isRtl ? "chevron-right" : "chevron-left")" style="width:16px;height:16px;"></i>
                    @(isRtl ? "السابق" : "Previous")
                </button>
                <button type="button" class="pc-btn pc-btn-primary" id="nextBtn">
                    @(isRtl ? "التالي" : "Next")
                    <i data-lucide="@(isRtl ? "chevron-left" : "chevron-right")" style="width:16px;height:16px;"></i>
                </button>
            </div>
        </section>

        <aside class="wiz-summary">
            <div class="wiz-sum-card">
                <div class="wiz-sum-hdr"><i data-lucide="hash"></i><h3>@Shared["Column_Code"]</h3></div>
                <div class="wiz-sum-codepreview" id="codePreview">—</div>
            </div>

            <div class="wiz-sum-card">
                <div class="wiz-sum-hdr"><i data-lucide="git-branch"></i><h3>@(isRtl ? "التسلسل" : "Hierarchy")</h3></div>
                <div class="wiz-sum-row"><span class="wiz-sum-label"><i data-lucide="layers"></i> @Shared["Label_Level"]</span><span class="wiz-sum-pill" id="sumLevel">—</span></div>
                <div class="wiz-sum-row"><span class="wiz-sum-label"><i data-lucide="corner-up-left"></i> @Shared["Label_ParentUnit"]</span><span class="wiz-sum-pill" id="sumParent">—</span></div>
                <div class="wiz-sum-row"><span class="wiz-sum-label"><i data-lucide="circle"></i> @Shared["Label_IsActive"]</span><span class="wiz-sum-pill wiz-sum-pill-on" id="sumActive">@(isRtl ? "نعم" : "Yes")</span></div>
            </div>

            <div class="wiz-sum-card">
                <div class="wiz-sum-hdr"><i data-lucide="contact"></i><h3>@(isRtl ? "الاتصال" : "Contact")</h3></div>
                <div class="wiz-sum-row"><span class="wiz-sum-label"><i data-lucide="mail"></i> @Shared["Label_Email"]</span><span class="wiz-sum-pill" id="sumEmail">—</span></div>
                <div class="wiz-sum-row"><span class="wiz-sum-label"><i data-lucide="phone"></i> @Shared["Label_Phone"]</span><span class="wiz-sum-pill" id="sumPhone">—</span></div>
                <div class="wiz-sum-row"><span class="wiz-sum-label"><i data-lucide="user"></i> @Shared["Label_UnitHead"]</span><span class="wiz-sum-pill" id="sumHead">—</span></div>
            </div>

            <div class="wiz-sum-actions">
                <button type="submit" class="pc-btn pc-btn-primary pc-btn-block" id="submitBtn" disabled
                        title="@(isRtl ? "أكمل جميع الخطوات لتفعيل الزر" : "Complete all steps to enable")">
                    <i data-lucide="save" style="width:16px;height:16px;"></i>
                    @Shared["Button_Save"]
                </button>
                <a asp-action="Index" class="pc-btn pc-btn-ghost pc-btn-block">
                    <i data-lucide="x" style="width:16px;height:16px;"></i>
                    @Shared["Button_Cancel"]
                </a>
            </div>
        </aside>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.CspNonce()">
        if (window.lucide) lucide.createIcons();
        const isRtl = @Html.Raw(isRtl ? "true" : "false");
        const TOTAL_STEPS = 2;
        let currentStep = 1, highestVisited = 1;
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const submitBtn = document.getElementById('submitBtn');
        const stepCounterEl = document.getElementById('stepCounter');

        function validateStep(n) {
            if (n !== 1) return true;
            const errors = [];
            const mark = (id, label) => {
                const el = document.getElementById(id);
                if (!el) return;
                if (!(el.value || '').trim()) { el.classList.add('invalid'); errors.push(label); } else { el.classList.remove('invalid'); }
            };
            mark('CodeInp', isRtl ? "الكود مطلوب" : "Code is required");
            mark('NameEn',  isRtl ? "الاسم بالإنجليزية مطلوب" : "English name is required");
            mark('NameAr',  isRtl ? "الاسم بالعربية مطلوب"   : "Arabic name is required");
            if (errors.length) {
                Swal.fire({ icon:'warning', title: isRtl ? "حقول مطلوبة" : "Required Fields", html: errors.join('<br>'), confirmButtonColor:'#005B99' });
                return false;
            }
            return true;
        }

        function showStep(n) {
            currentStep = Math.max(1, Math.min(TOTAL_STEPS, n));
            highestVisited = Math.max(highestVisited, currentStep);
            document.querySelectorAll('.wiz-step').forEach(el => {
                const s = parseInt(el.dataset.step, 10);
                el.classList.toggle('active', s === currentStep);
                el.classList.toggle('completed', s < highestVisited && s !== currentStep);
            });
            document.querySelectorAll('.wiz-step-content').forEach(p => {
                p.classList.toggle('active', parseInt(p.dataset.step, 10) === currentStep);
            });
            prevBtn.disabled = (currentStep === 1);
            nextBtn.classList.toggle('d-none', currentStep === TOTAL_STEPS);
            if (submitBtn) submitBtn.disabled = (currentStep !== TOTAL_STEPS);
            if (stepCounterEl) stepCounterEl.textContent = currentStep;
            if (window.lucide) lucide.createIcons();
        }
        window.wizGoTo = function (n) {
            if (n <= currentStep) { showStep(n); return; }
            if (n === currentStep + 1) { if (validateStep(currentStep)) showStep(n); return; }
            if (validateStep(currentStep)) showStep(currentStep + 1);
        };
        prevBtn.addEventListener('click', () => showStep(currentStep - 1));
        nextBtn.addEventListener('click', () => { if (validateStep(currentStep)) showStep(currentStep + 1); });

        function refresh() {
            const set = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v || '—'; };
            const code = document.getElementById('CodeInp')?.value || '';
            document.getElementById('codePreview').textContent = code || '—';
            set('sumLevel',  document.getElementById('LevelInp')?.value);
            const parent = document.getElementById('ParentSel');
            set('sumParent', parent?.value ? parent.options[parent.selectedIndex]?.text?.trim() : '');
            set('sumEmail',  document.getElementById('EmailInp')?.value);
            set('sumPhone',  document.getElementById('PhoneInp')?.value);
            const head = document.getElementById('HeadSel');
            set('sumHead',   head?.value ? head.options[head.selectedIndex]?.text?.trim() : '');
            const a = !!document.getElementById('IsActiveInp')?.checked;
            const sa = document.getElementById('sumActive');
            sa.textContent = a ? (isRtl ? 'نعم' : 'Yes') : (isRtl ? 'لا' : 'No');
            sa.className = 'wiz-sum-pill ' + (a ? 'wiz-sum-pill-on' : 'wiz-sum-pill-off');
        }
        ['CodeInp','LevelInp','ParentSel','EmailInp','PhoneInp','HeadSel','IsActiveInp'].forEach(id => {
            document.getElementById(id)?.addEventListener('change', refresh);
            document.getElementById(id)?.addEventListener('input', refresh);
        });
        document.getElementById('wizardForm').addEventListener('submit', function (e) {
            if (!validateStep(1)) { e.preventDefault(); showStep(1); }
        });

        showStep(1);
        refresh();
    </script>
}
