@model ESEMS.Web.Models.Services.StrategicObjective
@{
    ViewData["Title"] = (System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? Model.NameAr : Model.NameEn) ?? Model.Code;
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    var externalMode = ViewBag.ExternalMode as bool? ?? false;

    string LevelName(int l) => l switch
    {
        1 => isRtl ? "استراتيجي" : "Strategic",
        2 => isRtl ? "تكتيكي" : "Tactical",
        3 => isRtl ? "تشغيلي" : "Operational",
        _ => isRtl ? "هدف" : "Objective"
    };
    string LevelStyle(int l) => l switch
    {
        1 => "background:#dbeafe;color:#1e40af;",
        2 => "background:#fef3c7;color:#92400e;",
        3 => "background:#dcfce7;color:#166534;",
        _ => "background:#f3f4f6;color:#374151;"
    };

    var pct = Model.GetProgressPercentage();
    var name = isRtl ? Model.NameAr : Model.NameEn;
    var nameAlt = isRtl ? Model.NameEn : Model.NameAr;
    var unitName = Model.OwningUnit is null ? null : (isRtl ? Model.OwningUnit.NameAr : Model.OwningUnit.NameEn);
    var linkedProcesses = (Model.ProcessStrategicObjectives ?? new List<ESEMS.Web.Models.ServiceManagement.ProcessStrategicObjective>())
        .Where(j => j.Process is not null && !j.Process.IsDeleted)
        .Select(j => j.Process!)
        .OrderBy(p => p.Code)
        .ToList();
    var linkedServices = (Model.ServiceStrategicObjectives ?? new List<ESEMS.Web.Models.ServiceManagement.ServiceStrategicObjective>())
        .Where(j => j.Service is not null && !j.Service.IsDeleted)
        .Select(j => j.Service!)
        .OrderBy(s => s.Code)
        .ToList();
    var activeChildren = (Model.Children ?? new List<ESEMS.Web.Models.Services.StrategicObjective>())
        .Where(c => !c.IsDeleted)
        .OrderBy(c => c.Code)
        .ToList();
}

<style>
    .so-shell { display: flex; flex-direction: column; gap: .6rem; }
    .so-header { display: flex; align-items: center; justify-content: space-between; padding: .25rem 0 .5rem; border-bottom: 1px solid #e5e7eb; gap: .5rem; flex-wrap: wrap; }
    .so-title { display: flex; align-items: center; gap: .55rem; flex-wrap: wrap; }
    .so-title h1 { margin: 0; font-size: var(--fs-base); font-weight: 600; color: #111827; }
    .so-title .so-code { font-family: monospace; font-weight: 700; color: #475569; background: #f1f5f9; padding: .15rem .5rem; border-radius: .25rem; font-size: var(--fs-xs); }
    .so-title .so-level { padding: .15rem .5rem; border-radius: .25rem; font-size: var(--fs-xs); font-weight: 700; }
    .so-title .so-alt { font-size: var(--fs-xs); color: #6b7280; }
    .so-meta { display: flex; gap: 1rem; flex-wrap: wrap; font-size: var(--fs-xs); color: #6b7280; }
    .so-meta strong { color: #111827; font-weight: 600; }
    .so-btn { border-radius: .375rem; padding: .42rem .85rem; font-size: var(--fs-xs); font-weight: 600; display: inline-flex; align-items: center; gap: .4rem; cursor: pointer; text-decoration: none; border: none; }
    .so-btn-outline { background: #fff; color: #005B99; border: 1px solid #cbd5e1; } .so-btn-outline:hover { background: #f1f5f9; }
    .so-btn-primary { background: #005B99; color: #fff; } .so-btn-primary:hover { background: #003d6b; color: #fff; }
    .so-grid { display: grid; grid-template-columns: 2fr 1fr; gap: .6rem; align-items: start; }
    @@media (max-width: 992px) { .so-grid { grid-template-columns: 1fr; } }
    .so-card { background: #fff; border: 1px solid #e5e7eb; border-radius: .5rem; overflow: hidden; }
    .so-card-h { padding: .55rem .75rem; border-bottom: 1px solid #f1f5f9; font-size: var(--fs-sm); font-weight: 600; color: #111827; display: flex; align-items: center; gap: .45rem; }
    .so-card-b { padding: .65rem .75rem; }
    .so-progress-num { font-size: 2rem; font-weight: 800; color: #005B99; line-height: 1; }
    .so-progress-sub { font-size: var(--fs-xs); color: #6b7280; margin-top: .35rem; }
    .so-progress-bar { height: 8px; background: #f1f5f9; border-radius: 999px; overflow: hidden; margin-top: .6rem; }
    .so-progress-fill { height: 100%; background: linear-gradient(90deg, #16a34a, #005B99); border-radius: 999px; transition: width .4s ease; }
    .so-progress-help { font-size: 11px; color: #9ca3af; margin-top: .5rem; line-height: 1.4; }
    .so-list-empty { color: #9ca3af; font-size: var(--fs-xs); text-align: center; padding: .85rem 0; }
    .so-list-row { padding: .5rem .75rem; border-bottom: 1px solid #f3f4f6; display: flex; align-items: center; gap: .5rem; font-size: var(--fs-xs); }
    .so-list-row:last-child { border-bottom: none; }
    .so-list-row a { color: #005B99; text-decoration: none; font-weight: 600; }
    .so-list-row a:hover { text-decoration: underline; }
    .so-list-row .so-code-chip { font-family: monospace; color: #475569; background: #f1f5f9; padding: .1rem .4rem; border-radius: .25rem; font-size: 11px; }
    .so-children { display: flex; flex-wrap: wrap; gap: .35rem; }
    .so-child-chip { display: inline-flex; align-items: center; gap: .35rem; padding: .25rem .55rem; background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: .35rem; font-size: var(--fs-xs); color: #1e293b; text-decoration: none; }
    .so-child-chip:hover { background: #e2e8f0; }
</style>

<div class="so-shell">
    <div class="so-header">
        <div class="so-title">
            <a asp-action="Index" class="so-btn so-btn-outline" title="@(isRtl ? "العودة" : "Back")" aria-label="@(isRtl ? "العودة" : "Back")">
                <i data-lucide="@(isRtl ? "arrow-right" : "arrow-left")" class="w-4 h-4" aria-hidden="true"></i>
            </a>
            <span class="so-code">@Model.Code</span>
            <span class="so-level" style="@LevelStyle(Model.Level)">@LevelName(Model.Level)</span>
            <h1>@name</h1>
            @if (!string.IsNullOrEmpty(nameAlt) && nameAlt != name)
            {
                <span class="so-alt">· @nameAlt</span>
            }
            @if (!Model.IsActive)
            {
                <span style="background:#f3f4f6;color:#6b7280;padding:.15rem .5rem;border-radius:.25rem;font-size:var(--fs-xs);font-weight:700;">@(isRtl ? "متقاعد" : "Retired")</span>
            }
        </div>
        <div style="display:flex;gap:.4rem;">
            @if (!externalMode)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="so-btn so-btn-primary">
                    <i data-lucide="edit" class="w-4 h-4" aria-hidden="true"></i>
                    @(isRtl ? "تعديل" : "Edit")
                </a>
            }
        </div>
    </div>

    @* Quick meta line — parent / unit / target year — keeps the page scannable. *@
    <div class="so-meta">
        @if (Model.Parent is not null)
        {
            <span><strong>@(isRtl ? "الأب:" : "Parent:")</strong> @Model.Parent.Code — @(isRtl ? Model.Parent.NameAr : Model.Parent.NameEn)</span>
        }
        @if (!string.IsNullOrWhiteSpace(unitName))
        {
            <span><strong>@(isRtl ? "الوحدة:" : "Owning unit:")</strong> @unitName</span>
        }
        @if (Model.TargetYear.HasValue)
        {
            <span><strong>@(isRtl ? "السنة المستهدفة:" : "Target year:")</strong> @Model.TargetYear.Value</span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Tags))
        {
            <span><strong>@(isRtl ? "الوسوم:" : "Tags:")</strong> @Model.Tags</span>
        }
    </div>

    <div class="so-grid">
        <div style="display:flex;flex-direction:column;gap:.6rem;">
            <div class="so-card">
                <div class="so-card-h">
                    <i data-lucide="git-branch" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>
                    @(isRtl ? "العمليات المرتبطة" : "Linked Processes")
                    <span style="font-weight:400;color:#6b7280;font-size:var(--fs-xs);margin-inline-start:auto;">@linkedProcesses.Count</span>
                </div>
                <div>
                    @if (!linkedProcesses.Any())
                    {
                        <div class="so-list-empty">@(isRtl ? "لا توجد عمليات مرتبطة" : "No processes linked")</div>
                    }
                    else
                    {
                        @foreach (var p in linkedProcesses)
                        {
                            <div class="so-list-row">
                                <span class="so-code-chip">@p.Code</span>
                                <a asp-controller="Processes" asp-action="Details" asp-route-id="@p.Id">
                                    @(isRtl ? p.NameAr : p.NameEn)
                                </a>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="so-card">
                <div class="so-card-h">
                    <i data-lucide="briefcase" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>
                    @(isRtl ? "الخدمات المرتبطة" : "Linked Services")
                    <span style="font-weight:400;color:#6b7280;font-size:var(--fs-xs);margin-inline-start:auto;">@linkedServices.Count</span>
                </div>
                <div>
                    @if (!linkedServices.Any())
                    {
                        <div class="so-list-empty">@(isRtl ? "لا توجد خدمات مرتبطة" : "No services linked")</div>
                    }
                    else
                    {
                        @foreach (var s in linkedServices)
                        {
                            <div class="so-list-row">
                                <span class="so-code-chip">@s.Code</span>
                                <a asp-controller="Services" asp-action="Details" asp-route-id="@s.Id">
                                    @(isRtl ? s.NameAr : s.NameEn)
                                </a>
                            </div>
                        }
                    }
                </div>
            </div>

            @if (activeChildren.Any())
            {
                <div class="so-card">
                    <div class="so-card-h">
                        <i data-lucide="layers" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>
                        @(isRtl ? "الأهداف الفرعية" : "Sub-objectives")
                        <span style="font-weight:400;color:#6b7280;font-size:var(--fs-xs);margin-inline-start:auto;">@activeChildren.Count</span>
                    </div>
                    <div class="so-card-b">
                        <div class="so-children">
                            @foreach (var c in activeChildren)
                            {
                                <a asp-action="Details" asp-route-id="@c.Id" class="so-child-chip">
                                    <span style="font-family:monospace;font-weight:700;color:#475569;">@c.Code</span>
                                    <span>@(isRtl ? c.NameAr : c.NameEn)</span>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="so-card">
            <div class="so-card-h">
                <i data-lucide="trending-up" class="w-4 h-4" style="color:#005B99;" aria-hidden="true"></i>
                @(isRtl ? "التقدم" : "Progress")
            </div>
            <div class="so-card-b">
                @if (pct.HasValue)
                {
                    <div class="so-progress-num">@pct.Value.ToString("0.#")%</div>
                    <div class="so-progress-sub">
                        @(Model.CurrentValue?.ToString("0.##") ?? "—")
                        /
                        @(Model.TargetValue?.ToString("0.##") ?? "—")
                        @if (!string.IsNullOrWhiteSpace(Model.UnitOfMeasure)) { <text>@Model.UnitOfMeasure</text> }
                    </div>
                    <div class="so-progress-bar" role="progressbar" aria-valuenow="@((int)pct.Value)" aria-valuemin="0" aria-valuemax="100">
                        <div class="so-progress-fill" style="width:@(pct.Value)%;"></div>
                    </div>
                }
                else
                {
                    <div class="so-progress-num" style="color:#9ca3af;">—</div>
                    <div class="so-progress-sub">@(isRtl ? "لم يتم إدخال قيم بعد" : "No values entered yet")</div>
                }
                <div class="so-progress-help">
                    @(isRtl
                        ? "التقدم = القيمة الحالية ÷ القيمة المستهدفة × ١٠٠. يتم إدخال القيم يدويًا في تعديل الهدف؛ لا يتم تجميعها تلقائيًا من المبادرات أو القياسات المرتبطة."
                        : "Progress = Current ÷ Target × 100. Values are entered manually on the objective; they are not auto-rolled from linked initiatives or measurements.")
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.CspNonce()">if (window.lucide) lucide.createIcons();</script>
}
