    "ProcessPerformance": {
      "Provider": "None",
      "BaseUrl": "",
      "DisplayName": "",
      "ApiKey": "",
      "TimeoutSeconds": 8,
      "CacheSeconds": 60,
      "DeepLinkBaseUrl": ""
    }
  },
  "OutboundApi": {
    "_comment": "Outbound read-only API (api/v1/*) for other systems on the MBRHE server. Authenticated by the X-Api-Key header. OFF by default: set Enabled=true and add at least one key to ApiKeys (or via OutboundApi__ApiKeys__0 / OUTBOUND_API_KEY env) to turn it on. Generate a key at /ApiKeys/Generate (admin).",
    "Enabled": false,
    "ApiKeys": []
  },
  "AppSettings": {
    "PathBase": "/App"
  },
  "Bootstrap": {
    "RunSeeder": true
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "StartupRetryCount": 6,
    "ContinueOnMigrationFailure": false
  },
