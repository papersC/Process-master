{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Auditing": {
    "LogReads": false,
    "AuditIdentityChanges": false
  },
  "AllowedHosts": "ejraa360.com;www.ejraa360.com;esems.mbrhe.gov.ae;esems-internal.mbrhe.gov.ae;localhost",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=MBRHE-ERM-Prod;Initial Catalog=ESEMS;User ID=sa;Password=CHANGE_ME;Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;Pooling=true;Max Pool Size=100;MultipleActiveResultSets=true;",
    "MbrheConnection": ""
  },
  "Authentication": {
    "AllowFormsAuthenticationFallback": true,
    "WindowsDomain": "MBRHE",
    "AutoCreateUsers": true,
    "DefaultUserRoleGroupCode": "viewer"
  },
  "Email": {
    "Enabled": false,
    "Host": "smtp.office365.com",
    "Port": 587,
    "EnableSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@mbrhe.gov.ae",
    "FromName": "ESEMS",
    "TimeoutSeconds": 15
  },
  "AWS": {
    "Region": "us-east-1",
    "Bedrock": {
      "MaxTokens": 8000,
      "Temperature": 0.3
    }
  },
  "AzureOpenAI": {
    "Endpoint": "",
    "ApiKey": "",
    "DeploymentId": "gpt-4o",
    "ApiVersion": "2025-01-01-preview",
    "MaxTokens": 16000,
    "Temperature": 0.7
  },
  "Organization": {
    "Name": "Mohammed Bin Rashid Housing Establishment",
    "NameArabic": "مؤسسة محمد بن راشد للإسكان",
    "Abbreviation": "MBRHE"
  },
  "StallDetection": {
    "PollIntervalHours": 12,
