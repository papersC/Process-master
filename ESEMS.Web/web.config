<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom web.config — shipped in the project root because IsTransformWebConfigDisabled
  is set in ESEMS.Web.csproj. This file is copied verbatim into the publish output
  so the WebDAV-removal block below survives every `dotnet publish`.

  Why we need this:
    1. IIS WebDAV (installed on the deploy host) hijacks DELETE / PUT / MOVE / COPY
       and returns 405 before the request reaches ASP.NET Core. Removing both the
       module and the handler restores those verbs to the aspNetCore handler.
    2. The default IIS upload limit (30,000,000 bytes ≈ 28.6 MB) is too small for
       BPMN / Excel imports — bumped to 100 MB below.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <modules>
        <remove name="WebDAVModule" />
      </modules>
      <handlers>
        <remove name="WebDAV" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath=".\ESEMS.Web.exe" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
      <security>
        <authentication>
          <!-- Required for "Sign in with Windows": IIS must negotiate Kerberos/NTLM
               before Account/WindowsLogin can map DOMAIN\user to [user]. -->
          <windowsAuthentication enabled="true">
            <providers>
              <clear />
              <add value="Negotiate" />
              <add value="NTLM" />
            </providers>
          </windowsAuthentication>
          <anonymousAuthentication enabled="true" />
        </authentication>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="104857600" />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>
</configuration>
